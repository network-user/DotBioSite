# =============================================================================
# .env.example — шаблон конфигурации DotCore
# =============================================================================
# Скопируй этот файл в `.env` и заполни своими значениями.
# `.env` НИКОГДА не коммитится — добавлен в .gitignore.
#
# Префикс PUBLIC_ → переменная попадает в HTML/JS-bundle и видна посетителям
#                   (Vite заменяет import.meta.env.PUBLIC_* на строки при билде).
# Без префикса   → только build-time / server-side, никогда в bundle.
# =============================================================================

# --- Публичные: попадают в HTML после билда ---------------------------------

# Канонический URL сайта (для og:url, canonical, sitemap)
PUBLIC_DOMAIN=https://dotcore.pages.dev

# GitHub: username + имя репозитория этого сайта.
# Используется для:
#   1) ссылки на исходники в футере (footer.sourceCode);
#   2) автоматической сборки URL'ов GitHub-репозиториев проектов
#      из `src/content/projects/*.json` (см. `repoUrl()` в src/lib/projects.ts).
# Если оставить пустыми — ссылки просто не отрендерятся.
PUBLIC_GITHUB_USER=
PUBLIC_GITHUB_REPO=

# --- Автор -----------------------------------------------------------------

PUBLIC_AUTHOR_NAME_RU=.ядро
PUBLIC_AUTHOR_NAME_EN=.core

# Путь к фото (относительный, в public/) либо абсолютный URL.
# Пусто = в About показывается монограмма из инициалов.
# Совет: положи файл в public/people/ (gitignored), либо укажи URL на приватный CDN.
PUBLIC_AUTHOR_PHOTO=

# Краткое био (одна строка). Можно оставить пустым.
PUBLIC_AUTHOR_BIO_RU=Разработчик, автор DotSound и других точечных проектов.
PUBLIC_AUTHOR_BIO_EN=Developer, author of DotSound and other dot-prefixed projects.

# --- Соцсети ---------------------------------------------------------------
# Любую можно оставить пустой → ссылка/иконка не отрендерится.

# Пример: PUBLIC_SOCIAL_GITHUB=https://github.com/your-username
PUBLIC_SOCIAL_GITHUB=
PUBLIC_SOCIAL_TELEGRAM=
PUBLIC_SOCIAL_LINKEDIN=
PUBLIC_SOCIAL_X=
PUBLIC_SOCIAL_VK=

# --- Полу-приватные: обфусцируются на клиенте ------------------------------
# Email вшивается как base64 в data-атрибут и декодируется JS-ом по клику.
# Боты не видят plain email в HTML.

AUTHOR_EMAIL=

# --- Server / build only (никогда в bundle) ---------------------------------
# Зарезервировано на будущее (например, токены для контактной формы через
# Cloudflare Pages Functions). Сейчас не используется.

# CONTACT_FORM_SECRET=

# --- Ссылки на репозитории проектов (один URL на репо) ----------------------
# Если переменная пуста — URL собирается из PUBLIC_GITHUB_USER + имя репо.
# Ключ: PUBLIC_REPO_<ИДЕНТ>, где ИДЕНТ = repo.repo ?? repo.name в верхнем
# регистре, не-буквенно-цифровые символы заменены на "_".
# Как заполнять: вписать полный URL репозитория, например —
#   PUBLIC_REPO_DOTSOUNDBACKEND=https://github.com/acme/DotSoundBackend

# dotsound
PUBLIC_REPO_DOTSOUNDBACKEND=
PUBLIC_REPO_DOTSOUNDBOT=
PUBLIC_REPO_DOTSOUNDCOMPUTEWORKER=

# dotlearn
PUBLIC_REPO_DOTLEARN=

# dotmath
PUBLIC_REPO_DOTMATH=

# dotagents
PUBLIC_REPO_DOTAGENTS=

# dotworkbot
PUBLIC_REPO_DOTWORKBOT=

# dottraceip
PUBLIC_REPO_DOTTRACEIP=

# dotcore-skills (infra)
PUBLIC_REPO_DOTCORE_SKILLS=


# Явная ссылка проекта (сайт/telegram) — ключ: PUBLIC_LINK_<DOMAIN|TELEGRAM>_<SLUG>.
# Не задано — компонент падает на links.domain/links.telegram из JSON проекта.
PUBLIC_LINK_DOMAIN_DOTSOUND=
PUBLIC_LINK_TELEGRAM_DOTMATH=
PUBLIC_LINK_DOMAIN_DOTLEARN=
