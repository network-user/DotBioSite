---
import { useTranslations, type Locale } from "../lib/i18n";
import { config, authorName, authorBio, authorMonogram, socials } from "../lib/config";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";
import DotHalo from "./illustration/DotHalo.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const name = authorName(locale);
const bio = authorBio(locale);
const photo = config.PUBLIC_AUTHOR_PHOTO;
const monogram = authorMonogram(locale);
---

<section class="section about" id="about" aria-labelledby="about-title">
  <div class="container about__inner">
    <SectionHeader
      id="about-title"
      kicker={t("about.kicker")}
      title={t("about.title")}
      lede={t("about.lede")}
    />

    <div class="about__grid">
      <div class="about__portrait" data-reveal>
        <DotHalo size={320} count={18} radius={148} class="about__halo" />
        <div class="about__portrait-inner glass glass--bordered">
          {photo ? (
            <img src={photo} alt={name} class="about__photo" loading="lazy" decoding="async" />
          ) : (
            <span class="about__monogram display" aria-label={name}>
              {monogram}
            </span>
          )}
        </div>
      </div>

      <div class="about__content" data-reveal data-reveal-delay="120">
        <p class="about__name display">{name}</p>
        {bio && <p class="about__bio body">{bio}</p>}

        {socials.length > 0 && (
          <ul class="about__socials" aria-label={t("contact.title")}>
            {socials.map((s) => (
              <li>
                <a
                  href={s.url}
                  class="about__social"
                  target="_blank"
                  rel="noopener noreferrer me"
                  aria-label={t(`contact.${s.id}`)}
                >
                  <Icon name={s.id} size={20} />
                  <span class="about__social-label">{t(`contact.${s.id}`)}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    gap: var(--sp-7);
    grid-template-columns: 1fr;
    align-items: start;
  }

  .about__portrait {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
  }

  .about__halo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .about__portrait-inner {
    position: relative;
    width: 78%;
    height: 78%;
    display: grid;
    place-items: center;
    border-radius: var(--r-xl);
    overflow: hidden;
    transform-origin: center;
    animation: portrait-pulse var(--dur-slower) var(--ease-soft) both;
  }

  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.05);
  }

  .about__monogram {
    font-size: clamp(64px, 12vw, 120px);
    color: var(--text-muted);
    letter-spacing: var(--ls-display);
    user-select: none;
  }

  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .about__name {
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
  }

  .about__bio {
    color: var(--text-secondary);
    max-width: 60ch;
    font-size: var(--fs-17);
    line-height: var(--lh-normal);
  }

  .about__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block-start: var(--sp-3);
  }

  .about__social {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    min-height: var(--tap-min);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }

  .about__social:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--surface-2);
    opacity: 1;
  }

  @keyframes portrait-pulse {
    0% {
      transform: scale(0.96);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about__portrait-inner {
      animation: none;
    }
  }

  @media (min-width: 768px) {
    .about__grid {
      grid-template-columns: 320px 1fr;
      gap: var(--sp-10);
    }
  }
</style>
