---
import { useTranslations, type Locale } from "../lib/i18n";
import { config, authorName, authorBio, authorMonogram, socials } from "../lib/config";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const name = authorName(locale);
const bio = authorBio(locale);
const photo = config.PUBLIC_AUTHOR_PHOTO;
const monogram = authorMonogram(locale);
---

<section class="section about" id="about" aria-labelledby="about-title">
  <div class="container about__inner">
    <SectionHeader
      id="about-title"
      kicker={t("about.kicker")}
      title={t("about.title")}
      lede={t("about.lede")}
    />

    <div class="about__grid">
      <div class="about__portrait" data-reveal data-about-portrait>
        <div class="about__frame glass glass--bordered">
          {
            photo ? (
              <img src={photo} alt={name} class="about__photo" loading="lazy" decoding="async" />
            ) : (
              <span class="about__monogram display" aria-label={name}>
                {monogram}
              </span>
            )
          }
          <span class="about__sheen" aria-hidden="true"></span>
        </div>
      </div>

      <div class="about__content" data-reveal data-reveal-delay="120">
        <p class="about__name display">{name}</p>
        {bio && <p class="about__bio body">{bio}</p>}

        {
          socials.length > 0 && (
            <ul class="about__socials" aria-label={t("contact.title")}>
              {socials.map((s, i) => (
                <li class="about__social-item" style={`--pill-i: ${i};`}>
                  <a
                    href={s.url}
                    class="about__social"
                    target="_blank"
                    rel="noopener noreferrer me"
                    aria-label={t(`contact.${s.id}`)}
                  >
                    <Icon name={s.id} size={20} />
                    <span class="about__social-label">{t(`contact.${s.id}`)}</span>
                    <span class="about__social-shimmer" aria-hidden="true" />
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    gap: var(--sp-5);
    grid-template-columns: 1fr;
    align-items: start;
  }

  .about__portrait {
    width: 100%;
    max-width: 220px;
    margin-inline: auto;
  }

  .about__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    /* Параллакс/наклон рамки за курсором снят: чтение --ptr в transform форсило
       page-wide style recalc на каждый mousemove. Рамка стоит ровно; «жизнь»
       даёт медленный sheen, который крутится только пока портрет во вьюпорте. */
  }

  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.05);
  }

  .about__monogram {
    font-size: 72px;
    color: var(--text-muted);
    letter-spacing: var(--ls-display);
    user-select: none;
  }

  /* Мягкий блик, медленно проходящий по рамке. Двигаем только transform/opacity
     диагональной полосы — без анимации фильтров/теней и без mix-blend-mode.
     Полоса слегка шире и мягче, чтобы свет «проявлялся», а не вспыхивал. */
  .about__sheen {
    position: absolute;
    inset: -40%;
    pointer-events: none;
    background: linear-gradient(
      115deg,
      transparent 38%,
      var(--glass-edge-bright) 50%,
      transparent 62%
    );
    opacity: 0;
    transform: translateX(-60%);
  }

  /* Анимация блика включается ТОЛЬКО пока портрет реально во вьюпорте: .is-inview
     ставит/снимает отдельный IntersectionObserver ниже (глобальный data-reveal
     одноразовый и не годится). За экраном цикл не крутится, will-change не висит.
     Период удлинён (9s → 14s), пик яркости снижен (0.5 → 0.32). */
  @media (prefers-reduced-motion: no-preference) {
    .about__portrait.is-inview .about__sheen {
      animation: about-sheen 14s var(--ease-drift) 600ms infinite;
    }
  }

  @keyframes about-sheen {
    0%,
    100% {
      opacity: 0;
      transform: translateX(-60%);
    }
    46% {
      opacity: 0.32;
    }
    72% {
      opacity: 0;
      transform: translateX(60%);
    }
  }

  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .about__name {
    font-size: var(--fs-32);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
  }

  .about__bio {
    color: var(--text-secondary);
    max-width: 60ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
  }

  .about__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block-start: var(--sp-3);
  }

  /* Пилюли — реальный контент (ссылки): видимы по умолчанию на первом кадре,
     не ждут JS/IntersectionObserver. Вход «по очереди» — бонус: вся анимация
     самодостаточна в keyframe about-pill-in (from opacity:0 → to opacity:1),
     поэтому при выключенном JS пилюли просто остаются на месте видимыми. */
  .about__social-item {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .about__content.is-visible .about__social-item {
      animation: about-pill-in var(--dur-slow) var(--ease-soft);
      animation-delay: calc(var(--pill-i, 0) * 70ms + 220ms);
    }
  }

  @keyframes about-pill-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .about__social {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    min-height: var(--tap-min);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }

  .about__social:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--surface-2);
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) and (hover: hover) {
    .about__social:hover {
      transform: translateY(-1px);
    }
  }

  /* Блик-шиммер по пилюле при наведении: одна диагональная полоса проходит
     слева направо. Только transform/opacity. */
  .about__social-shimmer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(
      115deg,
      transparent 35%,
      var(--glass-edge-bright) 50%,
      transparent 65%
    );
    opacity: 0;
    transform: translateX(-120%);
  }

  @media (prefers-reduced-motion: no-preference) and (hover: hover) {
    .about__social:hover .about__social-shimmer {
      opacity: 1;
      animation: about-pill-shimmer var(--dur-slower) var(--ease-standard);
    }
  }

  @keyframes about-pill-shimmer {
    from {
      transform: translateX(-120%);
    }
    to {
      transform: translateX(120%);
    }
  }

  @media (min-width: 768px) {
    .about__grid {
      grid-template-columns: 320px 1fr;
      gap: var(--sp-10);
    }

    .about__portrait {
      max-width: 320px;
      margin-inline: 0;
    }

    .about__monogram {
      font-size: 120px;
    }

    .about__name {
      font-size: var(--fs-48);
    }

    .about__bio {
      font-size: var(--fs-17);
    }
  }

  @media (min-width: 1200px) {
    .about__name {
      font-size: 56px;
    }
  }

  /* Никакого параллакса/блика/шиммера при reduced-motion и на coarse-указателе:
     рамка стоит ровно, эффекты выключены. */
  @media (prefers-reduced-motion: reduce), (pointer: coarse) {
    .about__frame {
      transform: none;
      transition: none;
      will-change: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about__sheen,
    .about__portrait.is-inview .about__sheen {
      animation: none;
      opacity: 0;
      will-change: auto;
    }
    .about__social-item {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Гейтим бесконечный блик по реальной видимости портрета: .is-inview есть
  // только пока он на экране. Глобальный data-reveal-обсервер одноразовый, поэтому
  // здесь свой, переключающийся в обе стороны. Только смена класса — без JS-анимации.
  (() => {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced || !("IntersectionObserver" in window)) return;

    const el = document.querySelector<HTMLElement>("[data-about-portrait]");
    if (!el) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) el.classList.toggle("is-inview", e.isIntersecting);
      },
      { threshold: 0 },
    );
    io.observe(el);

    window.addEventListener(
      "pagehide",
      () => {
        el.classList.remove("is-inview");
        io.disconnect();
      },
      { once: true },
    );
  })();
</script>
