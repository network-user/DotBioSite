---
import { useTranslations, type Locale } from "../lib/i18n";
import { config, authorName, authorBio, authorMonogram, socials } from "../lib/config";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const name = authorName(locale);
const bio = authorBio(locale);
const photo = config.PUBLIC_AUTHOR_PHOTO;
const monogram = authorMonogram(locale);

interface ApproachItem {
  title: string;
  description: string;
}
const approach = t<ReadonlyArray<ApproachItem>>("about.approach", []);
const approachTitle = t("about.approachTitle", "");
---

<section class="section about" id="about" aria-labelledby="about-title">
  <div class="container about__inner">
    <SectionHeader
      id="about-title"
      kicker={t("about.kicker")}
      title={t("about.title")}
      lede={t("about.lede")}
    />

    <div class="about__grid">
      <div class="about__portrait glass glass--bordered" data-reveal>
        {
          photo ? (
            <img src={photo} alt={name} class="about__photo" loading="lazy" decoding="async" />
          ) : (
            <span class="about__monogram display" aria-label={name}>
              {monogram}
            </span>
          )
        }
      </div>

      <div class="about__content" data-reveal data-reveal-delay="120">
        <p class="about__name display">{name}</p>
        {bio && <p class="about__bio body">{bio}</p>}

        {
          socials.length > 0 && (
            <ul class="about__socials" aria-label={t("contact.title")}>
              {socials.map((s) => (
                <li>
                  <a
                    href={s.url}
                    class="about__social"
                    target="_blank"
                    rel="noopener noreferrer me"
                    aria-label={t(`contact.${s.id}`)}
                  >
                    <Icon name={s.id} size={20} />
                    <span class="about__social-label">{t(`contact.${s.id}`)}</span>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    {
      approach.length > 0 && (
        <div class="about__approach" aria-label={approachTitle}>
          {approach.map((item, i) => (
            <article class="about__principle glass glass--hover" data-reveal data-reveal-delay={i * 90}>
              <span class="about__principle-index mono">{`0${i + 1}`}</span>
              <h3 class="about__principle-title">{item.title}</h3>
              <p class="about__principle-desc body-sm">{item.description}</p>
            </article>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    gap: var(--sp-5);
    grid-template-columns: 1fr;
    align-items: start;
  }

  .about__portrait {
    position: relative;
    width: 100%;
    max-width: 220px;
    margin-inline: auto;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-2);
  }

  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.05);
  }

  .about__monogram {
    font-size: 72px;
    color: var(--text-muted);
    letter-spacing: var(--ls-display);
    user-select: none;
  }

  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .about__name {
    font-size: var(--fs-32);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
  }

  .about__bio {
    color: var(--text-secondary);
    max-width: 60ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
  }

  .about__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block-start: var(--sp-3);
  }

  .about__social {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    min-height: var(--tap-min);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }

  .about__social:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--surface-2);
    opacity: 1;
  }

  /* ---------- Approach: три принципа работы ---------- */
  .about__approach {
    margin-block-start: var(--sp-8);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }

  .about__principle {
    position: relative;
    padding: var(--sp-6);
    border-radius: var(--r-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    overflow: hidden;
  }

  .about__principle-index {
    font-size: var(--fs-13);
    color: var(--text-muted);
    letter-spacing: var(--ls-wide);
  }

  .about__principle-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-20);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
  }

  .about__principle-desc {
    color: var(--text-secondary);
  }

  @media (min-width: 768px) {
    .about__approach {
      margin-block-start: var(--sp-10);
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-5);
    }

    .about__principle {
      padding: var(--sp-6) var(--sp-6) var(--sp-7);
    }
  }

  @media (min-width: 768px) {
    .about__grid {
      grid-template-columns: 320px 1fr;
      gap: var(--sp-10);
    }

    .about__portrait {
      max-width: 320px;
      margin-inline: 0;
    }

    .about__monogram {
      font-size: 120px;
    }

    .about__name {
      font-size: var(--fs-48);
    }

    .about__bio {
      font-size: var(--fs-17);
    }
  }

  @media (min-width: 1200px) {
    .about__name {
      font-size: 56px;
    }
  }
</style>
