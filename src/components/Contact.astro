---
import { useTranslations, type Locale } from "../lib/i18n";
import { socials } from "../lib/config";
import { emailB64, hasEmail, emailDecoderScript } from "../lib/contacts";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="container contact__inner">
    <SectionHeader
      id="contact-title"
      kicker={t("contact.kicker")}
      title={t("contact.title")}
      lede={t("contact.lede")}
      align="center"
    />

    <div class="contact__channels">
      {hasEmail ? (
        <button
          type="button"
          class="contact__channel contact__channel--email contact-email glass glass--hover"
          data-e={emailB64}
          aria-label={t("contact.email")}
          data-reveal
        >
          <Icon name="mail" size={22} />
          <span class="contact__channel-label">{t("contact.email")}</span>
          <Icon name="arrow-right" size={16} />
          <span class="contact__channel-ring" aria-hidden="true"></span>
        </button>
      ) : (
        <span class="contact__channel contact__channel--disabled glass" aria-disabled="true">
          <Icon name="mail" size={22} />
          <span class="contact__channel-label">{t("contact.emailUnavailable")}</span>
        </span>
      )}

      {socials.map((s, i) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer me"
          class="contact__channel glass glass--hover"
          aria-label={t(`contact.${s.id}`)}
          data-reveal
          data-reveal-delay={(i + 1) * 80}
        >
          <Icon name={s.id} size={22} />
          <span class="contact__channel-label">{t(`contact.${s.id}`)}</span>
          <Icon name="external" size={16} />
        </a>
      ))}
    </div>
  </div>
</section>

{hasEmail && <script is:inline set:html={emailDecoderScript} />}

<style>
  .contact__channels {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
    max-width: 720px;
    margin-inline: auto;
  }

  .contact__channel {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    min-height: 56px;
    border-radius: var(--r-lg);
    color: var(--text);
    font-size: var(--fs-15);
    font-weight: var(--fw-medium);
    width: 100%;
    text-align: left;
    cursor: pointer;
  }

  .contact__channel-label {
    flex: 1;
  }

  .contact__channel--email {
    /* The full-width email button breaks the symmetric 2-col grid below 720px,
       so it occupies a full row on its own. */
    grid-column: 1 / -1;
    overflow: hidden;
  }

  /**
   * Sweeping highlight: a bright line slides across the top edge of the button.
   * Reuses the same 1px gradient pattern as Stack cards so the motion feels
   * consistent across the site. Translates from left to right on hover.
   */
  .contact__channel-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-edge-bright) 30%,
      rgba(255, 255, 255, 0.6) 50%,
      var(--glass-edge-bright) 70%,
      transparent
    );
    transform: translateX(-100%);
    transition: transform 1.2s var(--ease-soft);
    z-index: 2;
  }

  @media (pointer: fine) {
    .contact__channel--email:hover .contact__channel-ring {
      transform: translateX(100%);
    }
  }

  .contact__channel--disabled {
    color: var(--text-muted);
    cursor: not-allowed;
  }

  .contact__channel--disabled:hover {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__channel-ring {
      animation: none;
    }
  }

  @media (min-width: 720px) {
    .contact__channels {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
