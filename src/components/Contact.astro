---
import { useTranslations, type Locale } from "../lib/i18n";
import { socials } from "../lib/config";
import { emailB64, hasEmail, emailDecoderScript } from "../lib/contacts";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const briefOptions = hasEmail
  ? [
      {
        id: "project",
        icon: "rocket" as const,
        label: t("contact.briefProject"),
        subject: t("contact.subjectProject"),
      },
      {
        id: "hire",
        icon: "user" as const,
        label: t("contact.briefHire"),
        subject: t("contact.subjectHire"),
      },
      {
        id: "question",
        icon: "spark" as const,
        label: t("contact.briefQuestion"),
        subject: t("contact.subjectQuestion"),
      },
    ]
  : [];
---

<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="container contact__inner">
    <SectionHeader
      id="contact-title"
      kicker={t("contact.kicker")}
      title={t("contact.title")}
      lede={t("contact.lede")}
      align="center"
    />

    {
      briefOptions.length > 0 && (
        <div class="contact__brief glass glass--bordered" data-reveal data-warp>
          <div class="contact__brief-copy">
            <p class="caption">{t("contact.briefTitle")}</p>
            <p class="contact__brief-lede body-sm">{t("contact.briefLede")}</p>
          </div>
          <div class="contact__brief-actions" aria-label={t("contact.briefTitle")}>
            {briefOptions.map((option, i) => (
              <button
                type="button"
                class={`contact__brief-action contact__brief-action--${option.id} contact-email`}
                data-e={emailB64}
                data-subject={option.subject}
                data-body={t("contact.emailBody")}
                data-reveal
                data-reveal-delay={i * 60}
              >
                <Icon name={option.icon} size={18} />
                <span>{option.label}</span>
                <Icon name="arrow-right" size={15} />
              </button>
            ))}
          </div>
        </div>
      )
    }

    <div class="contact__channels">
      {
        hasEmail ? (
          <>
            <button
              type="button"
              class="contact__channel contact__channel--email contact-email glass glass--hover"
              data-channel
              data-e={emailB64}
              data-subject={t("contact.subjectGeneral")}
              data-body={t("contact.emailBody")}
              aria-label={t("contact.email")}
              data-reveal
            >
              <span class="contact__channel-glow" aria-hidden="true" />
              <span class="contact__channel-pulse" aria-hidden="true" />
              <Icon name="mail" size={22} />
              <span class="contact__channel-label" data-contact-label>
                {t("contact.email")}
              </span>
              <Icon name="arrow-right" size={16} />
              <span class="contact__channel-ring" aria-hidden="true" />
            </button>
            <button
              type="button"
              class="contact__channel contact__channel--copy contact-email glass glass--hover"
              data-channel
              data-e={emailB64}
              data-mode="copy"
              data-copied-label={t("contact.copied")}
              aria-label={t("contact.copyEmail")}
              data-reveal
              data-reveal-delay="80"
            >
              <span class="contact__channel-glow" aria-hidden="true" />
              <Icon name="copy" size={22} />
              <span class="contact__channel-label" data-contact-label>
                {t("contact.copyEmail")}
              </span>
              <Icon name="check" size={16} class="contact__copy-check" />
            </button>
          </>
        ) : (
          <span class="contact__channel contact__channel--disabled glass" aria-disabled="true">
            <Icon name="mail" size={22} />
            <span class="contact__channel-label">{t("contact.emailUnavailable")}</span>
          </span>
        )
      }

      {
        socials.map((s, i) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer me"
            class="contact__channel glass glass--hover"
            data-channel
            aria-label={t(`contact.${s.id}`)}
            data-reveal
            data-reveal-delay={(i + 1) * 80}
          >
            <span class="contact__channel-glow" aria-hidden="true" />
            <Icon name={s.id} size={22} />
            <span class="contact__channel-label">{t(`contact.${s.id}`)}</span>
            <Icon name="external" size={16} />
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Scoped pointer-follow glow for the contact channel buttons.
  // Independent of the email decoder (which owns clicks + data-e/data-subject);
  // this only writes --mx/--my CSS vars from pointer position, batched in rAF,
  // and tears its listeners down on pagehide. Fine pointers + motion-on only.
  const fine = window.matchMedia("(pointer: fine)");
  const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (fine.matches && motionOk) {
    const channels = Array.from(document.querySelectorAll<HTMLElement>("[data-channel]"));
    const cleanups: Array<() => void> = [];

    channels.forEach((el) => {
      let rafId: number | null = null;
      let px = 0;
      let py = 0;

      const apply = () => {
        rafId = null;
        el.style.setProperty("--mx", `${px}px`);
        el.style.setProperty("--my", `${py}px`);
      };

      const onMove = (e: PointerEvent) => {
        const r = el.getBoundingClientRect();
        px = e.clientX - r.left;
        py = e.clientY - r.top;
        if (rafId === null) rafId = requestAnimationFrame(apply);
      };

      const onLeave = () => {
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      };

      el.addEventListener("pointermove", onMove, { passive: true });
      el.addEventListener("pointerleave", onLeave, { passive: true });

      cleanups.push(() => {
        if (rafId !== null) cancelAnimationFrame(rafId);
        el.removeEventListener("pointermove", onMove);
        el.removeEventListener("pointerleave", onLeave);
      });
    });

    window.addEventListener("pagehide", () => cleanups.forEach((fn) => fn()), { once: true });
  }
</script>

{hasEmail && <script is:inline set:html={emailDecoderScript} />}

<style>
  .contact__brief {
    max-width: 900px;
    margin-inline: auto;
    margin-block-end: var(--sp-5);
    padding: var(--sp-4);
    border-radius: var(--r-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }

  .contact__brief-copy {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .contact__brief-lede {
    color: var(--text-secondary);
    max-width: 56ch;
  }

  .contact__brief-actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2);
  }

  .contact__brief-action {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-3);
    min-height: var(--tap-min);
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--r-md);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    background: var(--surface);
    text-align: left;
    min-width: 0;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .contact__brief-action:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--surface-2);
    transform: translateY(-1px);
  }

  .contact__channels {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
    max-width: 720px;
    margin-inline: auto;
  }

  .contact__channel {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4);
    min-height: 56px;
    border-radius: var(--r-lg);
    color: var(--text);
    font-size: var(--fs-15);
    font-weight: var(--fw-medium);
    width: 100%;
    text-align: left;
    cursor: pointer;
  }

  .contact__channel-label {
    flex: 1;
    min-width: 0;
  }

  /* Pointer-follow glow shared by every channel button. Sits below the content
     (z-index 0, above the glass tint) and is moved purely via transform; its
     visibility is an opacity fade. --mx/--my are card-local px from a scoped,
     rAF-batched listener. */
  .contact__channel-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 260px;
    height: 260px;
    margin: -130px 0 0 -130px;
    z-index: 0;
    pointer-events: none;
    border-radius: 50%;
    opacity: 0;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--project-accent) 26%, transparent) 0%,
      transparent 66%
    );
    transform: translate3d(var(--mx, 130px), var(--my, 28px), 0);
    /* Softer, slower fade so the glow eases in under the cursor instead of
       popping. Dimmer peak (0.6 -> 0.45) keeps it ambient, not glaring. */
    transition: opacity var(--dur-slow) var(--ease-soft);
  }

  @media (pointer: fine) {
    .contact__channel:hover .contact__channel-glow {
      opacity: 0.45;
    }
  }

  .contact__channel--email {
    /* The full-width email button breaks the symmetric 2-col grid below 720px,
       so it occupies a full row on its own. */
    grid-column: 1 / -1;
    overflow: hidden;
  }

  /* Breathing pulse on the primary CTA: a soft accent wash that fades in and
     out on a long, lazy loop. Animates opacity + transform: scale only, so it
     stays on the compositor and never touches the glass backdrop-filter. */
  .contact__channel-pulse {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    border-radius: inherit;
    opacity: 0;
    background: radial-gradient(
      120% 160% at 18% 50%,
      color-mix(in srgb, var(--project-accent) 16%, transparent) 0%,
      transparent 60%
    );
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact__channel-pulse {
      transform-origin: 18% 50%;
      /* Long, lazy breath: 9s so the wash drifts in and out calmly.
         transform/opacity only; stays on the compositor. will-change снят —
         persistent-слой памяти не оправдан для столь медленной анимации. */
      animation: contact-breathe 9s var(--ease-drift) infinite;
    }
  }

  /* On hover the pointer glow takes over; calm the ambient pulse so the two
     light sources don't fight. */
  .contact__channel--email:hover .contact__channel-pulse {
    animation-play-state: paused;
    opacity: 0;
  }

  @keyframes contact-breathe {
    0%,
    100% {
      opacity: 0.14;
      transform: scale(0.98);
    }
    50% {
      /* Gentler peak (0.42 -> 0.34) and smaller scale swing so the breath is
         soft and slow rather than a visible throb. */
      opacity: 0.34;
      transform: scale(1.015);
    }
  }

  .contact__channel--copy.is-copied {
    color: var(--state-ok);
    border-color: color-mix(in srgb, var(--state-ok) 42%, var(--border-hover));
  }

  .contact__copy-check {
    color: var(--state-ok);
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-spring);
  }

  .contact__channel--copy.is-copied .contact__copy-check {
    opacity: 1;
    transform: scale(1);
  }

  /**
   * Sweeping highlight: a bright line slides across the top edge of the button.
   * Reuses the same 1px gradient pattern as Stack cards so the motion feels
   * consistent across the site. Translates from left to right on hover.
   */
  .contact__channel-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-edge-bright) 30%,
      rgba(255, 255, 255, 0.6) 50%,
      var(--glass-edge-bright) 70%,
      transparent
    );
    transform: translateX(-100%);
    /* Slower sweep (1.2s -> 1.8s) so the highlight glides across the edge and
       the eye can follow it. */
    transition: transform 1.8s var(--ease-soft);
    z-index: 2;
  }

  @media (pointer: fine) {
    .contact__channel--email:hover .contact__channel-ring {
      transform: translateX(100%);
    }
  }

  .contact__channel--disabled {
    color: var(--text-muted);
    cursor: not-allowed;
  }

  .contact__channel--disabled:hover {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__channel-ring,
    .contact__channel-pulse {
      animation: none;
      transition: none;
    }

    /* No ambient breath, no pointer glow when motion is reduced. */
    .contact__channel-pulse,
    .contact__channel-glow {
      display: none;
    }
  }

  /* Touch: the cursor-follow glow has no meaning; hide it. The breathing pulse
     on the primary CTA stays (it's ambient, not pointer-driven). */
  @media (pointer: coarse) {
    .contact__channel-glow {
      display: none;
    }
  }

  @media (min-width: 720px) {
    .contact__brief {
      grid-template-columns: minmax(0, 0.8fr) minmax(360px, 1fr);
      align-items: center;
      padding: var(--sp-5);
    }

    .contact__brief-actions {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .contact__brief-action {
      grid-template-columns: 1fr auto;
      align-content: space-between;
      min-height: 112px;
    }

    .contact__brief-action > svg:first-child {
      grid-column: 1 / -1;
    }

    .contact__channels {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
