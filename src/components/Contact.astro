---
import { useTranslations, type Locale } from "../lib/i18n";
import { allSocials } from "../lib/config";
import { emailB64, hasEmail } from "../lib/contacts";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Lede блока контактов зациклено ротирует короткие фразы вместо статичного
// предложения. Каждая фраза держится LEDE_STEP секунд с плавным кросс-фейдом;
// под prefers-reduced-motion CSS откатывает раскладку к обычному потоку -
// все фразы читаются подряд одной строкой без анимации (см. <style> ниже).
const ledePhrases = t<string[]>("contact.ledePhrases");
const LEDE_STEP = 2.4;

// В блоке контактов сознательно показываем только email, GitHub и Telegram -
// LinkedIn/X/VK остаются в config для About.astro и JSON-LD, но не в этом списке.
const contactChannels = allSocials.filter((s) => s.id === "github" || s.id === "telegram");

const briefOptions = hasEmail
  ? [
      {
        id: "project",
        icon: "rocket" as const,
        label: t("contact.briefProject"),
        subject: t("contact.subjectProject"),
      },
      {
        id: "hire",
        icon: "user" as const,
        label: t("contact.briefHire"),
        subject: t("contact.subjectHire"),
      },
      {
        id: "question",
        icon: "spark" as const,
        label: t("contact.briefQuestion"),
        subject: t("contact.subjectQuestion"),
      },
    ]
  : [];
---

<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="container contact__inner">
    <SectionHeader
      id="contact-title"
      kicker={t("contact.kicker")}
      title={t("contact.title")}
      align="center"
    >
      <p
        slot="lede"
        class="section-header__lede subtitle lede-rotator"
        data-reveal
        data-reveal-delay="120"
      >
        {
          ledePhrases.map((phrase, i) => (
            <span class="lede-rotator__phrase" style={`animation-delay: ${(i * LEDE_STEP).toFixed(2)}s`}>
              {phrase}
              {i < ledePhrases.length - 1 ? " " : ""}
            </span>
          ))
        }
      </p>
    </SectionHeader>

    {
      briefOptions.length > 0 && (
        <div class="contact__brief glass glass--bordered" data-reveal data-warp>
          <div class="contact__brief-copy">
            <p class="caption">{t("contact.briefTitle")}</p>
            <p class="contact__brief-lede body-sm">{t("contact.briefLede")}</p>
          </div>
          <div class="contact__brief-actions" aria-label={t("contact.briefTitle")}>
            {briefOptions.map((option, i) => (
              <button
                type="button"
                class={`contact__brief-action contact__brief-action--${option.id} contact-email`}
                data-e={emailB64}
                data-subject={option.subject}
                data-body={t("contact.emailBody")}
                data-reveal
                data-reveal-delay={i * 60}
              >
                <Icon name={option.icon} size={18} />
                <span>{option.label}</span>
                <Icon name="arrow-right" size={15} />
              </button>
            ))}
          </div>
        </div>
      )
    }

    <div class="contact__channels">
      {
        hasEmail ? (
          <>
            <button
              type="button"
              class="contact__channel contact__channel--email contact-email glass glass--hover"
              data-channel
              data-touch-live
              data-e={emailB64}
              data-subject={t("contact.subjectGeneral")}
              data-body={t("contact.emailBody")}
              aria-label={t("contact.email")}
              data-reveal
            >
              <span class="contact__channel-glow" aria-hidden="true" />
              <span class="contact__channel-pulse" aria-hidden="true" />
              <Icon name="mail" size={20} />
              <span class="contact__channel-label" data-contact-label>
                {t("contact.email")}
              </span>
              <Icon name="arrow-right" size={15} class="contact__channel-trailing" />
              <span class="contact__channel-ring" aria-hidden="true" />
            </button>
            <button
              type="button"
              class="contact__channel contact__channel--copy contact-email glass glass--hover"
              data-channel
              data-touch-live
              data-e={emailB64}
              data-mode="copy"
              data-copied-label={t("contact.copied")}
              aria-label={t("contact.copyEmail")}
              data-reveal
              data-reveal-delay="80"
            >
              <span class="contact__channel-glow" aria-hidden="true" />
              <Icon name="copy" size={20} />
              <span class="contact__channel-label" data-contact-label>
                {t("contact.copyEmail")}
              </span>
              <Icon name="check" size={15} class="contact__copy-check" />
            </button>
          </>
        ) : (
          <span class="contact__channel contact__channel--disabled glass" aria-disabled="true">
            <Icon name="mail" size={20} />
            <span class="contact__channel-label">{t("contact.emailUnavailable")}</span>
          </span>
        )
      }

      {
        contactChannels.map((s, i) =>
          s.url ? (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer me"
              class="contact__channel glass glass--hover"
              data-channel
              data-touch-live
              aria-label={t(`contact.${s.id}`)}
              data-reveal
              data-reveal-delay={(i + 1) * 80}
            >
              <span class="contact__channel-glow" aria-hidden="true" />
              <Icon name={s.id} size={20} />
              <span class="contact__channel-label">{t(`contact.${s.id}`)}</span>
              <Icon name="external" size={15} class="contact__channel-trailing" />
            </a>
          ) : (
            <span
              class="contact__channel contact__channel--disabled glass"
              aria-disabled="true"
              data-reveal
              data-reveal-delay={(i + 1) * 80}
            >
              <Icon name={s.id} size={20} />
              <span class="contact__channel-label">{t(`contact.${s.id}`)}</span>
            </span>
          ),
        )
      }
    </div>
  </div>
</section>

<script>
  // Scoped pointer-follow glow for the contact channel buttons.
  // Independent of the email decoder (which owns clicks + data-e/data-subject);
  // this only writes --mx/--my CSS vars from pointer position, batched in rAF,
  // and tears its listeners down on pagehide. Fine pointers + motion-on only.
  const fine = window.matchMedia("(pointer: fine)");
  const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (fine.matches && motionOk) {
    const channels = Array.from(document.querySelectorAll<HTMLElement>("[data-channel]"));
    const cleanups: Array<() => void> = [];

    channels.forEach((el) => {
      let rafId: number | null = null;
      let px = 0;
      let py = 0;

      const apply = () => {
        rafId = null;
        el.style.setProperty("--mx", `${px}px`);
        el.style.setProperty("--my", `${py}px`);
      };

      const onMove = (e: PointerEvent) => {
        const r = el.getBoundingClientRect();
        px = e.clientX - r.left;
        py = e.clientY - r.top;
        if (rafId === null) rafId = requestAnimationFrame(apply);
      };

      const onLeave = () => {
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      };

      el.addEventListener("pointermove", onMove, { passive: true });
      el.addEventListener("pointerleave", onLeave, { passive: true });

      cleanups.push(() => {
        if (rafId !== null) cancelAnimationFrame(rafId);
        el.removeEventListener("pointermove", onMove);
        el.removeEventListener("pointerleave", onLeave);
      });
    });

    window.addEventListener("pagehide", () => cleanups.forEach((fn) => fn()), { once: true });
  }
</script>

<script>
  /* Email decoder: распаковывает обфусцированный адрес (base64 от перевёрнутой
     строки) из data-e и по клику открывает mailto или копирует. Вынесен из
     is:inline в обычный <script>, поэтому Astro хостит его во внешний бандл —
     CSP может быть script-src 'self' без 'unsafe-inline'. No-op без кнопок. */
  const decodeEmail = (b64: string): string => {
    try {
      const bin = atob(b64);
      const bytes = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
      return new TextDecoder("utf-8").decode(bytes).split("").reverse().join("");
    } catch {
      return "";
    }
  };

  const buildMailto = (addr: string, btn: HTMLElement): string => {
    const params = new URLSearchParams();
    const subject = btn.getAttribute("data-subject") || "";
    const body = btn.getAttribute("data-body") || "";
    if (subject) params.set("subject", subject);
    if (body) params.set("body", body);
    const qs = params.toString();
    return "mailto:" + addr + (qs ? "?" + qs : "");
  };

  const setCopied = (btn: HTMLElement): void => {
    const label = btn.querySelector<HTMLElement>("[data-contact-label]");
    if (!label) return;
    if (!btn.dataset.defaultLabel) btn.dataset.defaultLabel = label.textContent || "";
    label.textContent = btn.getAttribute("data-copied-label") || btn.dataset.defaultLabel || "";
    btn.classList.add("is-copied");
    window.setTimeout(() => {
      label.textContent = btn.dataset.defaultLabel || label.textContent;
      btn.classList.remove("is-copied");
    }, 1800);
  };

  const copyText = (text: string, done: () => void): void => {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard
        .writeText(text)
        .then(done)
        .catch(() => {
          /* clipboard write rejected; silently ignore */
        });
      return;
    }
    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.opacity = "0";
    document.body.appendChild(textarea);
    textarea.select();
    try {
      document.execCommand("copy");
      done();
    } catch {
      /* execCommand fallback failed; ignore */
    }
    document.body.removeChild(textarea);
  };

  document.querySelectorAll<HTMLElement>(".contact-email[data-e]").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const addr = decodeEmail(btn.getAttribute("data-e") || "");
      if (!addr) return;
      if (btn.getAttribute("data-mode") === "copy") {
        copyText(addr, () => setCopied(btn));
      } else {
        window.location.href = buildMailto(addr, btn);
      }
    });
  });
</script>

<style>
  .contact__brief {
    max-width: 900px;
    margin-inline: auto;
    margin-block-end: var(--sp-5);
    padding: var(--sp-4);
    border-radius: var(--r-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }

  .contact__brief-copy {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .contact__brief-lede {
    color: var(--text-secondary);
    max-width: 56ch;
  }

  .contact__brief-actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2);
  }

  .contact__brief-action {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-3);
    min-height: var(--tap-min);
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--r-md);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    background: var(--surface);
    text-align: left;
    min-width: 0;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .contact__brief-action:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--surface-2);
    transform: translateY(-1px);
  }

  .contact__channels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-2);
    max-width: 720px;
    margin-inline: auto;
  }

  .contact__channel {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-2);
    min-height: 56px;
    border-radius: var(--r-lg);
    color: var(--text);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    width: 100%;
    min-width: 0;
    text-align: left;
    cursor: pointer;
  }

  .contact__channel-trailing {
    flex-shrink: 0;
  }

  .contact__channel-label {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Pointer-follow glow shared by every channel button. Sits below the content
     (z-index 0, above the glass tint) and is moved purely via transform; its
     visibility is an opacity fade. --mx/--my are card-local px from a scoped,
     rAF-batched listener. */
  .contact__channel-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 260px;
    height: 260px;
    margin: -130px 0 0 -130px;
    z-index: 0;
    pointer-events: none;
    border-radius: 50%;
    opacity: 0;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--project-accent) 26%, transparent) 0%,
      transparent 66%
    );
    transform: translate3d(var(--mx, 130px), var(--my, 28px), 0);
    /* Softer, slower fade so the glow eases in under the cursor instead of
       popping. Dimmer peak (0.6 -> 0.45) keeps it ambient, not glaring. */
    transition: opacity var(--dur-slow) var(--ease-soft);
  }

  @media (pointer: fine) {
    .contact__channel:hover .contact__channel-glow {
      opacity: 0.45;
    }
  }

  .contact__channel--email {
    overflow: hidden;
  }

  /* Breathing pulse on the primary CTA: a soft accent wash that fades in and
     out on a long, lazy loop. Animates opacity + transform: scale only, so it
     stays on the compositor and never touches the glass backdrop-filter. */
  .contact__channel-pulse {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    border-radius: inherit;
    opacity: 0;
    background: radial-gradient(
      120% 160% at 18% 50%,
      color-mix(in srgb, var(--project-accent) 16%, transparent) 0%,
      transparent 60%
    );
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact__channel-pulse {
      transform-origin: 18% 50%;
      /* Long, lazy breath: 9s so the wash drifts in and out calmly.
         transform/opacity only; stays on the compositor. will-change снят —
         persistent-слой памяти не оправдан для столь медленной анимации. */
      animation: contact-breathe 9s var(--ease-drift) infinite;
    }
  }

  /* On hover the pointer glow takes over; calm the ambient pulse so the two
     light sources don't fight. */
  .contact__channel--email:hover .contact__channel-pulse {
    animation-play-state: paused;
    opacity: 0;
  }

  @keyframes contact-breathe {
    0%,
    100% {
      opacity: 0.14;
      transform: scale(0.98);
    }
    50% {
      /* Gentler peak (0.42 -> 0.34) and smaller scale swing so the breath is
         soft and slow rather than a visible throb. */
      opacity: 0.34;
      transform: scale(1.015);
    }
  }

  .contact__channel--copy.is-copied {
    color: var(--state-ok);
    border-color: color-mix(in srgb, var(--state-ok) 42%, var(--border-hover));
  }

  .contact__copy-check {
    color: var(--state-ok);
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-spring);
  }

  .contact__channel--copy.is-copied .contact__copy-check {
    opacity: 1;
    transform: scale(1);
  }

  /**
   * Sweeping highlight: a bright line slides across the top edge of the button.
   * Reuses the same 1px gradient pattern as Stack cards so the motion feels
   * consistent across the site. Translates from left to right on hover.
   */
  .contact__channel-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-edge-bright) 30%,
      rgba(255, 255, 255, 0.6) 50%,
      var(--glass-edge-bright) 70%,
      transparent
    );
    transform: translateX(-100%);
    /* Slower sweep (1.2s -> 1.8s) so the highlight glides across the edge and
       the eye can follow it. */
    transition: transform 1.8s var(--ease-soft);
    z-index: 2;
  }

  @media (pointer: fine) {
    .contact__channel--email:hover .contact__channel-ring {
      transform: translateX(100%);
    }
  }

  .contact__channel--disabled {
    color: var(--text-muted);
    cursor: not-allowed;
  }

  .contact__channel--disabled:hover {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__channel-ring,
    .contact__channel-pulse {
      animation: none;
      transition: none;
    }

    /* No ambient breath, no pointer glow when motion is reduced. */
    .contact__channel-pulse,
    .contact__channel-glow {
      display: none;
    }
  }

  /* Touch: the cursor-follow glow has no meaning; hide it. The breathing pulse
     on the primary CTA stays (it's ambient, not pointer-driven). */
  @media (pointer: coarse) {
    .contact__channel-glow {
      display: none;
    }
  }

  /* Тач-эквивалент hover (ОТДЕЛЬНАЯ мобильная реализация). Обводку каналов даёт
     общий хук .glass--hover.is-touch-active/:active (glass.css); здесь — запуск
     sweep-полосы email-кнопки при попадании в центр вьюпорта и tap-отклик
     brief-кнопок (на desktop их ведёт :hover). desktop (hover: hover) не видит. */
  @media (hover: none) {
    .contact__channel--email.is-touch-active .contact__channel-ring {
      transform: translateX(100%);
    }

    .contact__brief-action:active,
    .contact__brief-action.is-tapped {
      color: var(--text);
      border-color: var(--border-hover);
      background: var(--surface-2);
    }
  }

  @media (min-width: 720px) {
    .contact__brief {
      grid-template-columns: minmax(0, 0.8fr) minmax(360px, 1fr);
      align-items: center;
      padding: var(--sp-5);
    }

    .contact__brief-actions {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .contact__brief-action {
      grid-template-columns: 1fr auto;
      align-content: space-between;
      min-height: 112px;
    }

    .contact__brief-action > svg:first-child {
      grid-column: 1 / -1;
    }

    .contact__channels {
      gap: var(--sp-3);
    }

    .contact__channel {
      gap: var(--sp-3);
      padding: var(--sp-4);
      font-size: var(--fs-15);
    }
  }

  /* Узкие экраны: декоративная trailing-иконка (стрелка/external) съедает
     место, которого и так мало в ряду из трёх колонок - убираем её, метка
     остаётся и получает всю ширину. Чек-марк копирования не трогаем - это
     единственный визуальный сигнал успешного копирования на тач-устройствах. */
  @media (max-width: 420px) {
    .contact__channel {
      font-size: var(--fs-12);
    }

    .contact__channel-trailing {
      display: none;
    }
  }

  /* Lede-ротация: по умолчанию фразы идут обычным текстовым потоком (та же
     верстка, что и у статичного lede в других секциях) - это и есть
     reduced-motion/no-JS фолбэк, а не отдельная ветка. Стек-анимация
     появляется только когда браузер разрешает движение. */
  @media (prefers-reduced-motion: no-preference) {
    .lede-rotator {
      display: grid;
      justify-items: center;
    }

    .lede-rotator__phrase {
      display: inline-block;
      grid-row: 1;
      grid-column: 1;
      white-space: nowrap;
      opacity: 0;
      transform: translateY(6px);
      animation: lede-phrase-cycle 7.2s var(--ease-soft) infinite;
    }

    @keyframes lede-phrase-cycle {
      0%,
      100% {
        opacity: 0;
        transform: translateY(6px);
      }
      6%,
      27% {
        opacity: 1;
        transform: translateY(0);
      }
      33% {
        opacity: 0;
        transform: translateY(-6px);
      }
    }
  }
</style>
