---
import { useTranslations, type Locale } from "../lib/i18n";
import { allSocials } from "../lib/config";
import { emailB64, hasEmail } from "../lib/contacts";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Заголовок блока контактов - не статичная фраза, а зацикленные короткие
// фразы (заменяют title в SectionHeader через slot="title"). Каждая фраза
// держится LEDE_STEP секунд; внутри неё буквы всплывают волной по одной
// (CHAR_STEP секунд между соседними) вместо жёсткого сдвига всего слова
// целиком. Под prefers-reduced-motion CSS откатывает раскладку к обычному
// потоку - все фразы читаются подряд одной строкой без анимации (см. <style>
// ниже).
const ledePhrases = t<string[]>("contact.ledePhrases");
const LEDE_STEP = 2.4;
const CHAR_STEP = 0.02;

// В блоке контактов сознательно показываем только email, GitHub и Telegram -
// LinkedIn/X/VK остаются в config для About.astro и JSON-LD, но не в этом списке.
const contactChannels = allSocials.filter((s) => s.id === "github" || s.id === "telegram");
---

<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="container contact__inner">
    <SectionHeader id="contact-title" kicker={t("contact.kicker")} align="center">
      <span slot="kicker" class="contact__kicker-text">{t("contact.kicker")}</span>
      <span slot="title" class="contact__headline-rotator" data-reveal data-reveal-delay="60">
        {
          ledePhrases.map((phrase, i) => (
            <span class="contact__headline-phrase">
              {phrase.split("").map((ch, ci) => (
                <span
                  class="contact__headline-char"
                  style={`animation-delay: ${(i * LEDE_STEP + ci * CHAR_STEP).toFixed(3)}s`}
                >
                  {ch}
                </span>
              ))}
              {i < ledePhrases.length - 1 ? " " : ""}
            </span>
          ))
        }
      </span>
    </SectionHeader>

    <div class="contact__channels">
      {
        hasEmail ? (
          <button
            type="button"
            class="contact__channel contact__channel--email contact-email glass glass--hover"
            data-channel
            data-touch-live
            data-e={emailB64}
            data-subject={t("contact.subjectGeneral")}
            data-body={t("contact.emailBody")}
            aria-label={t("contact.email")}
            data-reveal
          >
            <span class="contact__channel-glow" aria-hidden="true" />
            <Icon name="mail" size={20} />
            <span class="contact__channel-label" data-contact-label>
              {t("contact.email")}
            </span>
            <Icon name="arrow-right" size={15} class="contact__channel-trailing" />
            <span class="contact__channel-ring" aria-hidden="true" />
          </button>
        ) : (
          <span class="contact__channel contact__channel--disabled glass" aria-disabled="true">
            <Icon name="mail" size={20} />
            <span class="contact__channel-label">{t("contact.emailUnavailable")}</span>
          </span>
        )
      }

      {
        contactChannels.map((s, i) =>
          s.url ? (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer me"
              class="contact__channel glass glass--hover"
              data-channel
              data-touch-live
              aria-label={t(`contact.${s.id}`)}
              data-reveal
              data-reveal-delay={(i + 1) * 80}
            >
              <span class="contact__channel-glow" aria-hidden="true" />
              <Icon name={s.id} size={20} />
              <span class="contact__channel-label">{t(`contact.${s.id}`)}</span>
              <Icon name="external" size={15} class="contact__channel-trailing" />
            </a>
          ) : (
            <span
              class="contact__channel contact__channel--disabled glass"
              aria-disabled="true"
              data-reveal
              data-reveal-delay={(i + 1) * 80}
            >
              <Icon name={s.id} size={20} />
              <span class="contact__channel-label">{t(`contact.${s.id}`)}</span>
            </span>
          ),
        )
      }
    </div>
  </div>
</section>

<script>
  // Scoped pointer-follow glow for the contact channel buttons.
  // Independent of the email decoder (which owns clicks + data-e/data-subject);
  // this only writes --mx/--my CSS vars from pointer position, batched in rAF,
  // and tears its listeners down on pagehide. Fine pointers + motion-on only.
  const fine = window.matchMedia("(pointer: fine)");
  const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (fine.matches && motionOk) {
    const channels = Array.from(document.querySelectorAll<HTMLElement>("[data-channel]"));
    const cleanups: Array<() => void> = [];

    channels.forEach((el) => {
      let rafId: number | null = null;
      let px = 0;
      let py = 0;

      const apply = () => {
        rafId = null;
        el.style.setProperty("--mx", `${px}px`);
        el.style.setProperty("--my", `${py}px`);
      };

      const onMove = (e: PointerEvent) => {
        const r = el.getBoundingClientRect();
        px = e.clientX - r.left;
        py = e.clientY - r.top;
        if (rafId === null) rafId = requestAnimationFrame(apply);
      };

      const onLeave = () => {
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      };

      el.addEventListener("pointermove", onMove, { passive: true });
      el.addEventListener("pointerleave", onLeave, { passive: true });

      cleanups.push(() => {
        if (rafId !== null) cancelAnimationFrame(rafId);
        el.removeEventListener("pointermove", onMove);
        el.removeEventListener("pointerleave", onLeave);
      });
    });

    window.addEventListener("pagehide", () => cleanups.forEach((fn) => fn()), { once: true });
  }
</script>

<script>
  /* Email decoder: распаковывает обфусцированный адрес (base64 от перевёрнутой
     строки) из data-e и по клику открывает mailto. Вынесен из
     is:inline в обычный <script>, поэтому Astro хостит его во внешний бандл:
     CSP может быть script-src 'self' без 'unsafe-inline'. No-op без кнопок. */
  const decodeEmail = (b64: string): string => {
    try {
      const bin = atob(b64);
      const bytes = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
      return new TextDecoder("utf-8").decode(bytes).split("").reverse().join("");
    } catch {
      return "";
    }
  };

  const buildMailto = (addr: string, btn: HTMLElement): string => {
    const params = new URLSearchParams();
    const subject = btn.getAttribute("data-subject") || "";
    const body = btn.getAttribute("data-body") || "";
    if (subject) params.set("subject", subject);
    if (body) params.set("body", body);
    const qs = params.toString();
    return "mailto:" + addr + (qs ? "?" + qs : "");
  };

  document.querySelectorAll<HTMLElement>(".contact-email[data-e]").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const addr = decodeEmail(btn.getAttribute("data-e") || "");
      if (!addr) return;
      window.location.href = buildMailto(addr, btn);
    });
  });
</script>

<style>
  .contact__channels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-2);
    max-width: 720px;
    margin-inline: auto;
  }

  .contact__channel {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-2);
    min-height: 56px;
    border-radius: var(--r-lg);
    color: var(--text);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    width: 100%;
    min-width: 0;
    text-align: left;
    cursor: pointer;
  }

  .contact__channel-trailing {
    flex-shrink: 0;
  }

  .contact__channel-label {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Pointer-follow glow shared by every channel button. Sits below the content
     (z-index 0, above the glass tint) and is moved purely via transform; its
     visibility is an opacity fade. --mx/--my are card-local px from a scoped,
     rAF-batched listener. */
  .contact__channel-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 260px;
    height: 260px;
    margin: -130px 0 0 -130px;
    z-index: 0;
    pointer-events: none;
    border-radius: 50%;
    opacity: 0;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--project-accent) 26%, transparent) 0%,
      transparent 66%
    );
    transform: translate3d(var(--mx, 130px), var(--my, 28px), 0);
    /* Softer, slower fade so the glow eases in under the cursor instead of
       popping. Dimmer peak (0.6 -> 0.45) keeps it ambient, not glaring. */
    transition: opacity var(--dur-slow) var(--ease-soft);
  }

  @media (pointer: fine) {
    .contact__channel:hover .contact__channel-glow {
      opacity: 0.45;
    }
  }

  .contact__channel--email {
    overflow: hidden;
  }

  /**
   * Sweeping highlight: a bright line slides across the top edge of the button.
   * Reuses the same 1px gradient pattern as Stack cards so the motion feels
   * consistent across the site. Translates from left to right on hover.
   */
  .contact__channel-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-edge-bright) 30%,
      rgba(255, 255, 255, 0.6) 50%,
      var(--glass-edge-bright) 70%,
      transparent
    );
    transform: translateX(-100%);
    /* Slower sweep (1.2s -> 1.8s) so the highlight glides across the edge and
       the eye can follow it. */
    transition: transform 1.8s var(--ease-soft);
    z-index: 2;
  }

  @media (pointer: fine) {
    .contact__channel--email:hover .contact__channel-ring {
      transform: translateX(100%);
    }
  }

  .contact__channel--disabled {
    color: var(--text-muted);
    cursor: not-allowed;
  }

  .contact__channel--disabled:hover {
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__channel-ring {
      transition: none;
    }

    /* No pointer glow when motion is reduced. */
    .contact__channel-glow {
      display: none;
    }
  }

  /* Touch: the cursor-follow glow has no meaning; hide it. */
  @media (pointer: coarse) {
    .contact__channel-glow {
      display: none;
    }
  }

  /* Тач-эквивалент hover (ОТДЕЛЬНАЯ мобильная реализация). Обводку каналов даёт
     общий хук .glass--hover.is-touch-active/:active (glass.css); здесь запуск
     sweep-полосы email-кнопки при попадании в центр вьюпорта.
     desktop (hover: hover) не видит. */
  @media (hover: none) {
    .contact__channel--email.is-touch-active .contact__channel-ring {
      transform: translateX(100%);
    }
  }

  @media (min-width: 720px) {
    .contact__channels {
      gap: var(--sp-3);
    }

    .contact__channel {
      gap: var(--sp-3);
      padding: var(--sp-4);
      font-size: var(--fs-15);
    }
  }

  /* Узкие экраны: декоративная trailing-иконка (стрелка/external) съедает
     место, которого и так мало в ряду из трёх колонок - убираем её, метка
     остаётся и получает всю ширину. */
  @media (max-width: 420px) {
    .contact__channel {
      font-size: var(--fs-12);
    }

    .contact__channel-trailing {
      display: none;
    }
  }

  /* Кикер «контакты» покачивается медленно и плавно, будто на воде. Анимация
     на ОТДЕЛЬНОМ inline-элементе (slot="kicker"), а не на родительском <p> -
     у того уже есть data-reveal со своим transform на transition, и он бы
     конфликтовал с transform из бесконечной анимации (анимации всегда
     перебивают transition на том же свойстве - реального покачивания было бы
     не видно). */
  .contact__kicker-text {
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact__kicker-text {
      animation: contact-kicker-float 4.8s steps(24) infinite;
    }
  }

  @keyframes contact-kicker-float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-6px) rotate(-2deg);
    }
  }

  /* Заголовок-волна: фразы заменяют статичный h2 и всплывают по букве -
     каждая буква приподнимается и проявляется чуть позже соседней
     (CHAR_STEP), на входе с лёгким пружинным перелётом (--ease-spring), на
     выходе - мягко (--ease-soft). Сами фразы стоят друг на друге в одной
     grid-ячейке; видна только та, чьи буквы сейчас в фазе opacity:1. По
     умолчанию (reduced-motion/no-JS фолбэк) весь текст идёт обычным
     потоком одной строкой - отдельной ветки для этого не нужно. */
  .contact__headline-rotator {
    display: inline;
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact__headline-rotator {
      display: grid;
      justify-items: center;
    }

    .contact__headline-phrase {
      display: inline-flex;
      grid-row: 1;
      grid-column: 1;
      white-space: nowrap;
    }

    .contact__headline-char {
      display: inline-block;
      white-space: pre;
      /* Разбивка на буквы теряет кернинг соседних пар символов - без
         компенсации слово выглядит растянутым. Подтягиваем trekking сильнее,
         чем у обычного заголовка (--ls-display: -0.02em). */
      letter-spacing: -0.12em;
      opacity: 0;
      transform: translateY(10px);
      animation: contact-headline-char 7.2s steps(12) infinite;
    }

    @keyframes contact-headline-char {
      0% {
        opacity: 0;
        transform: translateY(10px);
        animation-timing-function: var(--ease-spring);
      }
      6% {
        opacity: 1;
        transform: translateY(0);
        animation-timing-function: var(--ease-soft);
      }
      27% {
        opacity: 1;
        transform: translateY(0);
      }
      33%,
      100% {
        opacity: 0;
        transform: translateY(-8px);
      }
    }
  }
</style>
