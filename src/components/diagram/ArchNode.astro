---
/**
 * ArchNode.astro: glass-капсула узла архитектурной диаграммы.
 *
 * Один <g> с rect 140×56, скруглением, лёгкой обводкой и подписью по центру.
 * Опциональная иконка (тонкий glyph из набора Icon.astro) рендерится слева
 * от подписи. Координата `x,y` = центр капсулы; компонент сам смещает рамку
 * на полразмера, чтобы при позиционировании от центра можно было считать
 * рёбра без дополнительных оффсетов.
 */

type IconKey = "code" | "stack" | "rocket" | "spark" | "telegram" | "globe" | "user" | "dot";

interface Props {
  x: number;
  y: number;
  label: string;
  icon?: IconKey;
  width?: number;
  height?: number;
  emphasis?: "default" | "strong";
  class?: string;
}

const {
  x,
  y,
  label,
  icon,
  width = 140,
  height = 56,
  emphasis = "default",
  class: className = "",
} = Astro.props;

const left = x - width / 2;
const top = y - height / 2;
const radius = height / 2;

const iconSize = 16;
const iconGap = 8;

// Центрируем блок [иконка + зазор + текст] как единое целое и выкладываем текст
// слева-направо от иконки (text-anchor="start"). Ширина текста оценивается по
// числу символов: этого достаточно, чтобы иконка и подпись не накладывались
// даже на длинных лейблах («Backend Hub», «Elasticsearch 8»).
const charW = 7.1;
const textW = label.length * charW;
const contentW = icon ? iconSize + iconGap + textW : textW;
const startX = Math.max(10, (width - contentW) / 2);
const iconX = startX;
const iconY = height / 2;
const textX = startX + (icon ? iconSize + iconGap : 0);
---

<g
  class:list={["arch-node", `arch-node--${emphasis}`, className]}
  transform={`translate(${left}, ${top})`}
>
  {
    emphasis === "strong" && (
      <rect
        class="arch-node__ring"
        x={-5}
        y={-5}
        width={width + 10}
        height={height + 10}
        rx={radius + 5}
        ry={radius + 5}
      />
    )
  }
  <rect class="arch-node__bg" width={width} height={height} rx={radius} ry={radius}></rect>
  <rect
    class="arch-node__shine"
    x="1"
    y="1"
    width={width - 2}
    height={height / 2}
    rx={radius - 1}
    ry={radius - 1}></rect>
  {
    icon && (
      <g class="arch-node__icon" transform={`translate(${iconX}, ${iconY - iconSize / 2})`}>
        {icon === "code" && (
          <>
            <polyline points="11 12 15 8 11 4" />
            <polyline points="5 4 1 8 5 12" />
          </>
        )}
        {icon === "stack" && (
          <>
            <polyline points="8 1 15 5 8 9 1 5 8 1" />
            <polyline points="1 9 8 13 15 9" />
          </>
        )}
        {icon === "rocket" && (
          <>
            <path d="M3 9a5 5 0 0 1 9-5 5 5 0 0 1-5 9" />
            <path d="M3 9c-1 0.5-1.5 3-1.5 3s2.5-0.5 3-1.5" />
            <circle cx="9.5" cy="6.5" r="1" />
          </>
        )}
        {icon === "spark" && (
          <>
            <path d="M8 1v4" />
            <path d="M8 11v4" />
            <path d="M1 8h4" />
            <path d="M11 8h4" />
          </>
        )}
        {icon === "telegram" && <path d="m15 2-6 12-2-5-5-2 13-5Z" />}
        {icon === "globe" && (
          <>
            <circle cx="8" cy="8" r="6.5" />
            <path d="M1.5 8h13" />
            <path d="M8 1.5a9 9 0 0 1 0 13 9 9 0 0 1 0-13z" />
          </>
        )}
        {icon === "user" && (
          <>
            <circle cx="8" cy="6" r="2.5" />
            <path d="M3 14a5 5 0 0 1 10 0" />
          </>
        )}
        {icon === "dot" && <circle cx="8" cy="8" r="2" fill="currentColor" stroke="none" />}
      </g>
    )
  }
  <text
    x={textX}
    y={height / 2 + 1}
    text-anchor="start"
    dominant-baseline="middle"
    class="arch-node__label"
  >
    {label}
  </text>
</g>

<style>
  .arch-node__bg {
    fill: var(--glass-tint-2);
    stroke: var(--glass-edge);
    stroke-width: 1;
  }

  /* Hub node: lit with the project accent, the one point colour leans in. */
  .arch-node--strong .arch-node__bg {
    fill: var(--glass-tint-3);
    stroke: color-mix(in srgb, var(--project-accent) 52%, var(--glass-edge-bright));
    stroke-width: 1.5;
  }

  .arch-node__ring {
    fill: none;
    stroke: color-mix(in srgb, var(--project-accent) 32%, transparent);
    stroke-width: 1;
  }

  .arch-node__shine {
    fill: rgba(255, 255, 255, 0.05);
    pointer-events: none;
  }

  .arch-node__icon {
    fill: none;
    stroke: var(--text-secondary);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .arch-node--strong .arch-node__icon {
    stroke: color-mix(in srgb, var(--project-accent) 72%, var(--text));
  }

  .arch-node__label {
    fill: var(--text);
    font-family: var(--font-stack-display);
    font-size: 13px;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-snug);
  }
</style>
