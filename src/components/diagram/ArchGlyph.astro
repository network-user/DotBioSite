---
/**
 * ArchGlyph.astro — тот же набор glyph'ов, что в ArchNode, но как самостоятельный
 * inline-SVG для HTML-разметки (мобильный вертикальный flow диаграммы). В ArchNode
 * иконки живут внутри SVG-капсулы <g> со своим transform; здесь — обычный 16×16
 * SVG, который можно положить в HTML-кнопку узла. Пути идентичны ArchNode.
 */

type IconKey = "code" | "stack" | "rocket" | "spark" | "telegram" | "globe" | "user" | "dot";

interface Props {
  icon?: IconKey;
  class?: string;
}

const { icon, class: className = "" } = Astro.props;
---

{
  icon && (
    <svg
      class:list={["arch-glyph", className]}
      viewBox="0 0 16 16"
      width="16"
      height="16"
      fill="none"
      aria-hidden="true"
    >
      {icon === "code" && (
        <>
          <polyline points="11 12 15 8 11 4" />
          <polyline points="5 4 1 8 5 12" />
        </>
      )}
      {icon === "stack" && (
        <>
          <polyline points="8 1 15 5 8 9 1 5 8 1" />
          <polyline points="1 9 8 13 15 9" />
        </>
      )}
      {icon === "rocket" && (
        <>
          <path d="M3 9a5 5 0 0 1 9-5 5 5 0 0 1-5 9" />
          <path d="M3 9c-1 0.5-1.5 3-1.5 3s2.5-0.5 3-1.5" />
          <circle cx="9.5" cy="6.5" r="1" />
        </>
      )}
      {icon === "spark" && (
        <>
          <path d="M8 1v4" />
          <path d="M8 11v4" />
          <path d="M1 8h4" />
          <path d="M11 8h4" />
        </>
      )}
      {icon === "telegram" && <path d="m15 2-6 12-2-5-5-2 13-5Z" />}
      {icon === "globe" && (
        <>
          <circle cx="8" cy="8" r="6.5" />
          <path d="M1.5 8h13" />
          <path d="M8 1.5a9 9 0 0 1 0 13 9 9 0 0 1 0-13z" />
        </>
      )}
      {icon === "user" && (
        <>
          <circle cx="8" cy="6" r="2.5" />
          <path d="M3 14a5 5 0 0 1 10 0" />
        </>
      )}
      {icon === "dot" && <circle cx="8" cy="8" r="2" fill="currentColor" stroke="none" />}
    </svg>
  )
}

<style>
  .arch-glyph {
    display: block;
    width: 16px;
    height: 16px;
    flex: none;
    fill: none;
    stroke: var(--text-secondary);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
