---
/**
 * Architecture.astro — оркестратор архитектурной диаграммы.
 *
 * Принимает массивы узлов, рёбер и кластеров (опционально) и рендерит единый
 * SVG в системе координат 960×540 с `preserveAspectRatio="xMidYMid meet"`.
 * Каждый узел получает `data-reveal` со staggered delay (i * 80ms), чтобы
 * диаграмма «собиралась» при появлении в viewport через общий IO в BaseLayout.
 *
 * Узел адресуется по `id`; рёбра ссылаются на пару `from`/`to` — компонент
 * сам находит координаты центров капсул и направляет линию от края до края.
 */

import ArchNode from "./ArchNode.astro";
import ArchEdge from "./ArchEdge.astro";
import ArchCluster from "./ArchCluster.astro";

type IconKey = "code" | "stack" | "rocket" | "spark" | "telegram" | "globe" | "user" | "dot";
type EdgeKind = "sync" | "async" | "data";

interface NodeInput {
  id: string;
  x: number;
  y: number;
  label: string;
  icon?: IconKey;
  width?: number;
  height?: number;
  emphasis?: "default" | "strong";
}

interface EdgeInput {
  from: string;
  to: string;
  kind?: EdgeKind;
  label?: string;
  bend?: number;
}

interface ClusterInput {
  x: number;
  y: number;
  width: number;
  height: number;
  label: string;
}

interface Props {
  nodes: ReadonlyArray<NodeInput>;
  edges?: ReadonlyArray<EdgeInput>;
  clusters?: ReadonlyArray<ClusterInput>;
  viewBox?: string;
  class?: string;
  ariaLabel?: string;
}

const {
  nodes,
  edges = [],
  clusters = [],
  viewBox = "0 0 960 540",
  class: className = "",
  ariaLabel = "Architecture diagram",
} = Astro.props;

const DEFAULT_W = 140;
const DEFAULT_H = 56;

interface Resolved {
  id: string;
  x: number;
  y: number;
  hw: number;
  hh: number;
}

const resolved = new Map<string, Resolved>();
nodes.forEach((n) => {
  resolved.set(n.id, {
    id: n.id,
    x: n.x,
    y: n.y,
    hw: (n.width ?? DEFAULT_W) / 2,
    hh: (n.height ?? DEFAULT_H) / 2,
  });
});

/**
 * Вычисляет точку выхода ребра из капсулы: пересечение луча `(cx,cy) → (tx,ty)`
 * с прямоугольной рамкой капсулы (с округлыми концами — упрощаем до rect).
 */
function edgeAnchor(a: Resolved, b: Resolved): { x: number; y: number } {
  const dx = b.x - a.x;
  const dy = b.y - a.y;
  if (dx === 0 && dy === 0) return { x: a.x, y: a.y };
  const absDx = Math.abs(dx);
  const absDy = Math.abs(dy);
  const scale = Math.min(a.hw / Math.max(absDx, 0.001), a.hh / Math.max(absDy, 0.001));
  return { x: a.x + dx * scale, y: a.y + dy * scale };
}

const edgeData = edges
  .map((e) => {
    const a = resolved.get(e.from);
    const b = resolved.get(e.to);
    if (!a || !b) return null;
    const from = edgeAnchor(a, b);
    const to = edgeAnchor(b, a);
    return { ...e, fromId: e.from, toId: e.to, from, to };
  })
  .filter(
    (
      e,
    ): e is EdgeInput & {
      fromId: string;
      toId: string;
      from: { x: number; y: number };
      to: { x: number; y: number };
    } => e !== null,
  );
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  preserveAspectRatio="xMidYMid meet"
  class:list={["architecture", className]}
  role="img"
  aria-label={ariaLabel}
>
  <defs>
    <pattern id="arch-dotgrid" width="34" height="34" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="1" class="architecture__griddot"></circle>
    </pattern>
  </defs>
  <rect class="architecture__grid" x="0" y="0" width="100%" height="100%" fill="url(#arch-dotgrid)"
  ></rect>
  {clusters.map((c) => <ArchCluster {...c} />)}
  {
    edgeData.map((e) => (
      <ArchEdge
        from={e.from}
        to={e.to}
        fromId={e.fromId}
        toId={e.toId}
        kind={e.kind}
        label={e.label}
        bend={e.bend}
      />
    ))
  }
  {
    nodes.map((n, i) => (
      <g
        class="architecture__node"
        style={`--node-i: ${i};`}
        data-arch-node={n.id}
        tabindex="0"
        role="button"
        aria-label={n.label}
      >
        <ArchNode
          x={n.x}
          y={n.y}
          label={n.label}
          icon={n.icon}
          width={n.width}
          height={n.height}
          emphasis={n.emphasis}
        />
      </g>
    ))
  }
</svg>

<style>
  .architecture {
    display: block;
    width: 100%;
    height: auto;
    color: var(--text);
  }

  /* Faint schematic dot-grid behind the nodes — reads as a blueprint surface,
     never competes with the lines (kept at very low alpha). */
  .architecture__griddot {
    fill: rgba(255, 255, 255, 0.05);
  }

  .architecture__grid {
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__grid {
      opacity: 0;
      animation: arch-grid-in var(--dur-slower) var(--ease-standard) forwards;
    }
  }

  @keyframes arch-grid-in {
    to {
      opacity: 1;
    }
  }

  /* Nodes default to visible (no dependency on IntersectionObserver firing for
     SVG <g>). With motion enabled they assemble in a gentle stagger on load;
     the section-level reveal still handles the scroll-in fade of the whole box. */
  .architecture__node {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__node {
      opacity: 0;
      animation: arch-node-in var(--dur-slow) var(--ease-soft) forwards;
      animation-delay: calc(var(--node-i, 0) * 70ms + 200ms);
    }
  }

  @keyframes arch-node-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ----------------------------------------------------------------------
   * Интерактив: подсветка связей при наведении / фокусе / тапе на узел.
   * Приглушаем ВНУТРЕННИЙ .arch-node — на обёртке .architecture__node живёт
   * сборочная анимация с fill:forwards, её opacity перебивать нельзя.
   * Только смена opacity/stroke по классам: без rAF, без перерасчёта layout.
   * -------------------------------------------------------------------- */
  .architecture__node {
    cursor: pointer;
    outline: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture :global(.arch-node),
    .architecture :global(.arch-edge),
    .architecture :global(.arch-cluster) {
      transition: opacity var(--dur-fast) var(--ease-standard);
    }
  }

  /* подсветка активна: всё непричастное тускнеет, путь остаётся ярким */
  .architecture.is-focusing :global(.arch-node) {
    opacity: 0.26;
  }
  .architecture.is-focusing .architecture__node.is-active :global(.arch-node),
  .architecture.is-focusing .architecture__node.is-adj :global(.arch-node) {
    opacity: 1;
  }
  .architecture.is-focusing :global(.arch-edge) {
    opacity: 0.14;
  }
  .architecture.is-focusing :global(.arch-edge.is-lit) {
    opacity: 1;
  }
  .architecture.is-focusing :global(.arch-cluster) {
    opacity: 0.4;
  }

  /* видимый фокус с клавиатуры — кольцо акцентом на капсуле узла */
  .architecture__node:focus-visible :global(.arch-node__bg) {
    stroke: var(--project-accent);
    stroke-width: 2;
  }
</style>

<script>
  /**
   * Интерактивная подсветка связей архитектурной диаграммы.
   * Наведение/фокус (мышь, клавиатура) или тап (тач) по узлу подсвечивает его
   * рёбра и соседние узлы, остальное приглушается. Чистые class-toggle: ни
   * requestAnimationFrame, ни чтения геометрии. Каждая диаграмма независима.
   */
  (() => {
    const diagrams = document.querySelectorAll<SVGSVGElement>(".architecture");
    diagrams.forEach((svg) => {
      const nodes = Array.from(svg.querySelectorAll<SVGGElement>("[data-arch-node]"));
      const edges = Array.from(svg.querySelectorAll<SVGGElement>(".arch-edge[data-from]"));
      if (nodes.length === 0) return;

      // карта смежности: id → множество соседних id
      const neighbors = new Map<string, Set<string>>();
      for (const ed of edges) {
        const f = ed.getAttribute("data-from");
        const t = ed.getAttribute("data-to");
        if (!f || !t) continue;
        let sf = neighbors.get(f);
        if (!sf) {
          sf = new Set();
          neighbors.set(f, sf);
        }
        sf.add(t);
        let st = neighbors.get(t);
        if (!st) {
          st = new Set();
          neighbors.set(t, st);
        }
        st.add(f);
      }

      let activeId: string | null = null;

      const clear = (): void => {
        if (activeId === null) return;
        activeId = null;
        svg.classList.remove("is-focusing");
        for (const n of nodes) n.classList.remove("is-active", "is-adj");
        for (const e of edges) e.classList.remove("is-lit");
      };

      const activate = (id: string): void => {
        if (activeId === id) return;
        activeId = id;
        svg.classList.add("is-focusing");
        const adj = neighbors.get(id) ?? new Set<string>();
        for (const n of nodes) {
          const nid = n.getAttribute("data-arch-node");
          n.classList.toggle("is-active", nid === id);
          n.classList.toggle("is-adj", nid !== id && nid !== null && adj.has(nid));
        }
        for (const e of edges) {
          const f = e.getAttribute("data-from");
          const t = e.getAttribute("data-to");
          e.classList.toggle("is-lit", f === id || t === id);
        }
      };

      const toggle = (id: string): void => {
        if (activeId === id) clear();
        else activate(id);
      };

      for (const n of nodes) {
        const id = n.getAttribute("data-arch-node");
        if (id === null) continue;

        n.addEventListener("pointerenter", (ev) => {
          if (ev.pointerType === "touch") return; // тач — по тапу (toggle ниже)
          activate(id);
        });
        n.addEventListener("focus", () => activate(id));
        n.addEventListener("click", () => toggle(id));
        n.addEventListener("keydown", (ev) => {
          if (ev.key === "Enter" || ev.key === " ") {
            ev.preventDefault();
            toggle(id);
          } else if (ev.key === "Escape") {
            clear();
            n.blur();
          }
        });
      }

      // увод мыши за пределы диаграммы или уход фокуса наружу — сброс
      svg.addEventListener("pointerleave", (ev) => {
        if (ev.pointerType === "touch") return;
        clear();
      });
      svg.addEventListener("focusout", (ev) => {
        const next = ev.relatedTarget as Node | null;
        if (next === null || !svg.contains(next)) clear();
      });
    });
  })();
</script>
