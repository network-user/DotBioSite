---
/**
 * Architecture.astro: оркестратор архитектурной диаграммы.
 *
 * Раскладка выбирается по топологии (система координат 960×540):
 *   • Радиальная (звёзды): узел задаёт `angle` (направление от хаба, 0 = вверх,
 *     по часовой) и `radius` (вынос в px); хаб (`radius: 0`) в центре. Модули
 *     встают вокруг хаба со всех сторон, рёбра-спицы не пересекают узлы.
 *   • Слоистая (потоки): узел задаёт `col` (колонка-стадия слева направо) и
 *     `row` (порядок в колонке), компонент сам считает ровные координаты:
 *     вход → хаб → хранилища.
 *   • Legacy: явные координаты центра `x/y` (если нет ни `angle`, ни `col`).
 *
 * Рёбра привязаны ОРТОГОНАЛЬНО (см. `ports`): выходят/входят через середину
 * ближайшей грани капсулы перпендикулярно ей, наконечник упирается в середину
 * стороны блока, а между портами идёт мягкой S-дугой (см. ArchEdge.astro).
 *
 * Кластер задаётся списком `members`: рамка считается как их общий bounding
 * box плюс отступ, поэтому всегда аккуратно обнимает свои узлы.
 *
 * Два слоя интерактива (оба перф-лёгкие, под prefers-reduced-motion):
 *   1. Бегущие импульсы по рёбрам (в ArchEdge): запрос → обработка → ответ.
 *   2. Клик / тап / фокус по капсуле раскрывает в подписи под диаграммой
 *      короткое пояснение роли узла (поле `desc`). Чистые class-toggle +
 *      textContent: ни requestAnimationFrame, ни чтения геометрии.
 */

import type { Locale } from "../../lib/i18n";
import ArchNode from "./ArchNode.astro";
import ArchEdge from "./ArchEdge.astro";
import ArchCluster from "./ArchCluster.astro";
import ArchGlyph from "./ArchGlyph.astro";

type IconKey = "code" | "stack" | "rocket" | "spark" | "telegram" | "globe" | "user" | "dot";
type EdgeKind = "sync" | "async" | "data";
/** Грань капсулы: top / bottom / left / right. */
type Side = "t" | "b" | "l" | "r";

interface NodeInput {
  id: string;
  label: string;
  icon?: IconKey;
  width?: number;
  height?: number;
  emphasis?: "default" | "strong";
  col?: number;
  row?: number;
  /** Радиальная раскладка: `angle` = направление от хаба в градусах (0 = вверх,
   *  по часовой), `radius` = вынос от центра в px. Хаб задаёт `radius: 0`. */
  angle?: number;
  radius?: number;
  x?: number;
  y?: number;
  desc?: { ru: string; en: string };
}

interface EdgeInput {
  from: string;
  to: string;
  kind?: EdgeKind;
  label?: string;
  bend?: number;
  /** Принудительная грань выхода/входа (иначе выбирается авто по осям). Нужно
   *  рёбрам-перескокам, которым авто-грань мешала бы обойти соседний блок. */
  fromSide?: Side;
  toSide?: Side;
  oneway?: boolean;
}

interface ClusterInput {
  label: string;
  members?: ReadonlyArray<string>;
  x?: number;
  y?: number;
  width?: number;
  height?: number;
}

interface Props {
  nodes: ReadonlyArray<NodeInput>;
  edges?: ReadonlyArray<EdgeInput>;
  clusters?: ReadonlyArray<ClusterInput>;
  viewBox?: string;
  class?: string;
  ariaLabel?: string;
  locale?: Locale;
  /** Подсказка-приглашение в подписи под диаграммой (до выбора узла). */
  hint?: string;
}

const {
  nodes,
  edges = [],
  clusters = [],
  viewBox = "0 0 960 540",
  class: className = "",
  ariaLabel = "Architecture diagram",
  locale = "ru",
  hint = "",
} = Astro.props;

const DEFAULT_W = 140;
const DEFAULT_H = 56;

// Размер холста из viewBox (для слоистой раскладки).
const vb = viewBox.split(/\s+/).map(Number);
const VBW = vb[2] && vb[2] > 0 ? vb[2] : 960;
const VBH = vb[3] && vb[3] > 0 ? vb[3] : 540;

// Отступы колонок/рядов от краёв холста.
const PAD_X = 112;
const PAD_Y = 76;

/**
 * Три способа раскладки, по убыванию приоритета:
 *   1. Радиальная, если у узлов есть `angle`/`radius`: хаб (`radius: 0`) в центре
 *      холста, модули по кругу вокруг него (спицы не пересекают узлы). Для звёзд.
 *   2. Слоистая, если есть `col`: x по колонке (равномерно между PAD_X и
 *      VBW-PAD_X), y по позиции в колонке (группа центрируется). Для потоков.
 *   3. Legacy: явные координаты центра `x/y`.
 */
const pos = new Map<string, { x: number; y: number }>();
const radial = nodes.some((n) => typeof n.angle === "number" || typeof n.radius === "number");
const layered = !radial && nodes.some((n) => typeof n.col === "number");
if (radial) {
  const cx = VBW / 2;
  const cy = VBH / 2;
  nodes.forEach((n) => {
    const r = n.radius ?? 0;
    const a = ((n.angle ?? 0) * Math.PI) / 180;
    pos.set(n.id, { x: cx + r * Math.sin(a), y: cy - r * Math.cos(a) });
  });
} else if (layered) {
  const byCol = new Map<number, NodeInput[]>();
  nodes.forEach((n) => {
    const c = n.col ?? 0;
    const arr = byCol.get(c);
    if (arr) arr.push(n);
    else byCol.set(c, [n]);
  });
  const cols = [...byCol.keys()].sort((a, b) => a - b);
  const maxCol = cols.length > 0 ? cols[cols.length - 1]! : 0;
  const band = VBH - 2 * PAD_Y;
  byCol.forEach((arr, c) => {
    const ordered = [...arr].sort((a, b) => (a.row ?? 0) - (b.row ?? 0));
    const n = ordered.length;
    const x = maxCol === 0 ? VBW / 2 : PAD_X + (c * (VBW - 2 * PAD_X)) / maxCol;
    ordered.forEach((node, i) => {
      pos.set(node.id, { x, y: PAD_Y + ((i + 0.5) * band) / n });
    });
  });
} else {
  nodes.forEach((n) => pos.set(n.id, { x: n.x ?? 0, y: n.y ?? 0 }));
}

interface Resolved {
  id: string;
  x: number;
  y: number;
  hw: number;
  hh: number;
}

const resolved = new Map<string, Resolved>();
nodes.forEach((n) => {
  const p = pos.get(n.id) ?? { x: 0, y: 0 };
  resolved.set(n.id, {
    id: n.id,
    x: p.x,
    y: p.y,
    hw: (n.width ?? DEFAULT_W) / 2,
    hh: (n.height ?? DEFAULT_H) / 2,
  });
});

interface Port {
  from: { x: number; y: number };
  to: { x: number; y: number };
  fromDir: { x: number; y: number };
  toDir: { x: number; y: number };
}

/** Точка-порт на середине грани `side` капсулы и внешняя нормаль этой грани. */
function facePort(
  n: Resolved,
  side: Side,
): { p: { x: number; y: number }; d: { x: number; y: number } } {
  switch (side) {
    case "r":
      return { p: { x: n.x + n.hw, y: n.y }, d: { x: 1, y: 0 } };
    case "l":
      return { p: { x: n.x - n.hw, y: n.y }, d: { x: -1, y: 0 } };
    case "b":
      return { p: { x: n.x, y: n.y + n.hh }, d: { x: 0, y: 1 } };
    case "t":
      return { p: { x: n.x, y: n.y - n.hh }, d: { x: 0, y: -1 } };
  }
}

/**
 * Порты ребра: ОРТОГОНАЛЬНАЯ привязка. Ребро выходит из середины одной грани
 * капсулы-источника и входит в середину грани-цели СТРОГО ПЕРПЕНДИКУЛЯРНО ей,
 * а не вдоль косого луча центр→центр. Грань выбирается по доминирующей оси
 * разноса центров: горизонтальный разнос больше → лево/право, иначе → верх/низ;
 * `fromSide`/`toSide` принудительно перекрывают этот выбор (для рёбер-перескоков).
 * `fromDir`/`toDir` = единичные касательные на концах: `fromDir` = внешняя нормаль
 * грани выхода, `toDir` = направление ВНУТРЬ цели. По ним ArchEdge строит кривую,
 * поэтому наконечник упирается ровно в СЕРЕДИНУ стороны блока, без «протыкания угла».
 */
function ports(a: Resolved, b: Resolved, fromSide?: Side, toSide?: Side): Port {
  const dx = b.x - a.x;
  const dy = b.y - a.y;
  let aSide: Side;
  let bSide: Side;
  if (Math.abs(dx) >= Math.abs(dy)) {
    aSide = dx >= 0 ? "r" : "l";
    bSide = dx >= 0 ? "l" : "r";
  } else {
    aSide = dy >= 0 ? "b" : "t";
    bSide = dy >= 0 ? "t" : "b";
  }
  const A = facePort(a, fromSide ?? aSide);
  const B = facePort(b, toSide ?? bSide);
  return { from: A.p, to: B.p, fromDir: A.d, toDir: { x: -B.d.x, y: -B.d.y } };
}

const edgeData = edges
  .map((e) => {
    const a = resolved.get(e.from);
    const b = resolved.get(e.to);
    if (!a || !b) return null;
    const { from, to, fromDir, toDir } = ports(a, b, e.fromSide, e.toSide);
    return { ...e, fromId: e.from, toId: e.to, from, to, fromDir, toDir };
  })
  .filter((e): e is NonNullable<typeof e> => e !== null);

// Кластер по members → общий bounding box узлов + отступ. Иначе legacy x/y/w/h.
const CLUSTER_PAD = 22;
const clusterBoxes = clusters
  .map((c) => {
    if (c.members && c.members.length > 0) {
      let minX = Infinity;
      let minY = Infinity;
      let maxX = -Infinity;
      let maxY = -Infinity;
      for (const id of c.members) {
        const r = resolved.get(id);
        if (!r) continue;
        minX = Math.min(minX, r.x - r.hw);
        minY = Math.min(minY, r.y - r.hh);
        maxX = Math.max(maxX, r.x + r.hw);
        maxY = Math.max(maxY, r.y + r.hh);
      }
      if (!Number.isFinite(minX)) return null;
      return {
        x: minX - CLUSTER_PAD,
        y: minY - CLUSTER_PAD,
        width: maxX - minX + 2 * CLUSTER_PAD,
        height: maxY - minY + 2 * CLUSTER_PAD,
        label: c.label,
      };
    }
    if (
      typeof c.x === "number" &&
      typeof c.y === "number" &&
      typeof c.width === "number" &&
      typeof c.height === "number"
    ) {
      return { x: c.x, y: c.y, width: c.width, height: c.height, label: c.label };
    }
    return null;
  })
  .filter(
    (c): c is { x: number; y: number; width: number; height: number; label: string } => c !== null,
  );

// Локализуем пояснения один раз на сервере (страница рендерится под локаль).
const nodeData = nodes.map((n) => ({
  node: n,
  p: pos.get(n.id) ?? { x: 0, y: 0 },
  desc: n.desc ? (n.desc[locale] ?? n.desc.ru) : "",
}));

const hasCaption = hint.length > 0 && nodeData.some((n) => n.desc.length > 0);

/* ---------------------------------------------------------------------------
 * Мобильная вертикальная раскладка: ОТДЕЛЬНАЯ реализация для узких экранов.
 *
 * SVG с фиксированным холстом 960×540 на телефоне приходится скроллить вбок;
 * вместо этого на мобильных рендерим тот же граф как вертикальный поток
 * (HTML, не SVG): узлы в порядке слоёв (col → row), сгруппированы в «стадии»
 * со стрелками вниз, связи каждого узла вынесены в подписи-чипы под капсулой,
 * пояснение раскрывается тапом прямо под узлом. Помещается в ширину телефона,
 * без бокового скролла. Десктопный SVG этим не затрагивается, обе версии
 * переключаются media-запросом и в DOM-дереве доступности активна лишь видимая.
 * ------------------------------------------------------------------------- */
const labelById = new Map(nodes.map((n) => [n.id, n.label] as const));

// Исходящие связи узла → чипы (куда, каким каналом, с какой подписью).
const edgesByFrom = new Map<string, { toLabel: string; kind: EdgeKind; label?: string }[]>();
for (const e of edges) {
  const toLabel = labelById.get(e.to);
  if (!toLabel) continue;
  const arr = edgesByFrom.get(e.from) ?? [];
  arr.push({ toLabel, kind: e.kind ?? "sync", label: e.label });
  edgesByFrom.set(e.from, arr);
}

// Узлы по порядку слоёв (col → row → исходный индекс), сгруппированы по колонке.
type FlowItem = { node: NodeInput; desc: string };
const flowSorted = nodes
  .map((node, i) => ({ node, i, desc: node.desc ? (node.desc[locale] ?? node.desc.ru) : "" }))
  .sort((a, b) => {
    const ca = a.node.col ?? 0;
    const cb = b.node.col ?? 0;
    if (ca !== cb) return ca - cb;
    const ra = a.node.row ?? 0;
    const rb = b.node.row ?? 0;
    if (ra !== rb) return ra - rb;
    return a.i - b.i;
  });

const flowStages: { col: number; items: FlowItem[] }[] = [];
for (const { node, desc } of flowSorted) {
  const col = node.col ?? 0;
  let stage = flowStages.find((s) => s.col === col);
  if (!stage) {
    stage = { col, items: [] };
    flowStages.push(stage);
  }
  stage.items.push({ node, desc });
}
---

<figure class:list={["architecture-fig", className]}>
  <div class="architecture__viewport">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox={viewBox}
      preserveAspectRatio="xMidYMid meet"
      class="architecture"
      role="group"
      aria-label={ariaLabel}
    >
      <defs>
        <pattern id="arch-dotgrid" width="34" height="34" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" class="architecture__griddot"></circle>
        </pattern>
      </defs>
      <rect
        class="architecture__grid"
        x="0"
        y="0"
        width="100%"
        height="100%"
        fill="url(#arch-dotgrid)"></rect>
      {clusterBoxes.map((c) => <ArchCluster {...c} />)}
      {
        edgeData.map((e, i) => (
          <ArchEdge
            from={e.from}
            to={e.to}
            fromDir={e.fromDir}
            toDir={e.toDir}
            fromId={e.fromId}
            toId={e.toId}
            kind={e.kind}
            label={e.label}
            bend={e.bend}
            oneway={e.oneway}
            seq={i}
          />
        ))
      }
      {
        nodeData.map(({ node: n, p, desc }, i) => (
          <g
            class="architecture__node"
            style={`--node-i: ${i};`}
            data-arch-node={n.id}
            data-arch-label={n.label}
            data-arch-desc={desc || undefined}
            tabindex={desc ? "0" : undefined}
            role={desc ? "button" : undefined}
            aria-label={desc ? `${n.label}: ${desc}` : undefined}
          >
            <ArchNode
              x={p.x}
              y={p.y}
              label={n.label}
              icon={n.icon}
              width={n.width}
              height={n.height}
              emphasis={n.emphasis}
            />
          </g>
        ))
      }
    </svg>
  </div>

  <div class="architecture__flow" data-arch-flow>
    {
      flowStages.map((stage, si) => (
        <div class="archflow__stage">
          {stage.items.map(({ node: n, desc }) => {
            const out = edgesByFrom.get(n.id) ?? [];
            return (
              <div class="archflow__item">
                {desc ? (
                  <button
                    type="button"
                    class:list={[
                      "archflow__node",
                      "glass",
                      "glass--hover",
                      n.emphasis === "strong" && "archflow__node--strong",
                    ]}
                    data-archflow-node
                    aria-expanded="false"
                    aria-label={`${n.label}: ${desc}`}
                  >
                    <span class="archflow__node-main">
                      <ArchGlyph icon={n.icon} class="archflow__icon" />
                      <span class="archflow__label">{n.label}</span>
                    </span>
                    <span class="archflow__caret" aria-hidden="true">
                      <svg viewBox="0 0 12 12" width="12" height="12" fill="none">
                        <path d="M3 5l3 3 3-3" />
                      </svg>
                    </span>
                  </button>
                ) : (
                  <div
                    class:list={[
                      "archflow__node",
                      "glass",
                      n.emphasis === "strong" && "archflow__node--strong",
                    ]}
                  >
                    <span class="archflow__node-main">
                      <ArchGlyph icon={n.icon} class="archflow__icon" />
                      <span class="archflow__label">{n.label}</span>
                    </span>
                  </div>
                )}
                {desc && (
                  <div class="archflow__desc">
                    <p class="archflow__desc-text">{desc}</p>
                  </div>
                )}
                {out.length > 0 && (
                  <ul class="archflow__edges">
                    {out.map((e) => (
                      <li class:list={["archflow__edge", `archflow__edge--${e.kind}`]}>
                        <span class="archflow__edge-arrow" aria-hidden="true">
                          →
                        </span>
                        <span class="archflow__edge-to">{e.toLabel}</span>
                        {e.label && <span class="archflow__edge-kind">{e.label}</span>}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            );
          })}
          {si < flowStages.length - 1 && (
            <div class="archflow__down" aria-hidden="true">
              <svg viewBox="0 0 12 26" width="12" height="26" fill="none">
                <path d="M6 1v19m0 0 4.5-4.5M6 20l-4.5-4.5" />
              </svg>
            </div>
          )}
        </div>
      ))
    }
  </div>

  {
    hasCaption && (
      <figcaption class="architecture__caption" data-arch-caption aria-live="polite">
        <span class="architecture__caption-hint" data-arch-hint>
          {hint}
        </span>
        <span class="architecture__caption-active" data-arch-active hidden>
          <span class="architecture__caption-label" data-arch-cap-label />
          <span class="architecture__caption-text" data-arch-cap-text />
        </span>
      </figcaption>
    )
  }
</figure>

<style>
  .architecture-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  /* Горизонтальный скролл живёт на вьюпорте, а не на карточке: подпись под
     диаграммой остаётся на всю ширину и переносится нормально, тогда как сам
     SVG на узких экранах держит min-width и прокручивается. */
  .architecture__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-inline: contain;
    -webkit-overflow-scrolling: touch;
  }

  .architecture {
    display: block;
    width: 100%;
    height: auto;
    color: var(--text);
  }

  /* --- Переключение: desktop SVG ↔ mobile вертикальный flow ---
     На узких экранах SVG (фикс. холст 960×540) прячем целиком и показываем
     HTML-поток; на десктопе наоборот. Подпись-caption нужна только SVG-версии
     (там клик уходит в неё); на мобильном пояснение раскрывается inline. */
  .architecture__flow {
    display: none;
  }

  @media (max-width: 719px) {
    .architecture__viewport {
      display: none;
    }
    .architecture__flow {
      display: flex;
    }
    .architecture__caption {
      display: none;
    }
  }

  /* Faint schematic dot-grid behind the nodes: reads as a blueprint surface,
     never competes with the lines (kept at very low alpha). */
  .architecture__griddot {
    fill: rgba(255, 255, 255, 0.05);
  }

  .architecture__grid {
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__grid {
      opacity: 0;
      animation: arch-grid-in var(--dur-slower) var(--ease-standard) forwards;
    }
  }

  @keyframes arch-grid-in {
    to {
      opacity: 1;
    }
  }

  /* Nodes default to visible (no dependency on IntersectionObserver firing for
     SVG <g>). With motion enabled they assemble in a gentle stagger on load;
     the section-level reveal still handles the scroll-in fade of the whole box. */
  .architecture__node {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__node {
      opacity: 0;
      animation: arch-node-in var(--dur-slow) var(--ease-soft) forwards;
      animation-delay: calc(var(--node-i, 0) * 70ms + 200ms);
    }
  }

  @keyframes arch-node-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ----------------------------------------------------------------------
   * Слой «клик → пояснение». Капсула-кнопка подсвечивается акцентом, её роль
   * уходит в подпись под диаграммой. Только смена stroke/fill по классам,
   * без перерасчёта layout. (Подсветку соседних связей сознательно не делаем.)
   * -------------------------------------------------------------------- */
  .architecture__node[role="button"] {
    cursor: pointer;
  }
  .architecture__node:focus {
    outline: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__node :global(.arch-node__bg) {
      transition:
        stroke var(--dur-fast) var(--ease-standard),
        stroke-width var(--dur-fast) var(--ease-standard);
    }
  }

  .architecture__node[role="button"]:focus-visible :global(.arch-node__bg),
  .architecture__node.is-selected :global(.arch-node__bg) {
    stroke: var(--project-accent);
    stroke-width: 2;
  }
  .architecture__node.is-selected :global(.arch-node__shine) {
    fill: color-mix(in srgb, var(--project-accent) 16%, rgba(255, 255, 255, 0.05));
  }

  .architecture__caption {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-1) var(--sp-2);
    padding-block-start: var(--sp-3);
    border-block-start: var(--bw-thin) solid var(--glass-edge);
    font-size: var(--fs-14);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    min-height: 1.6em;
  }

  .architecture__caption-hint {
    color: var(--text-muted);
  }

  .architecture__caption-active {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-1) var(--sp-2);
  }
  .architecture__caption-active[hidden] {
    display: none;
  }

  .architecture__caption-label {
    color: var(--project-accent);
    font-weight: var(--fw-semibold);
    font-family: var(--font-stack-display);
  }

  .architecture__caption-text {
    color: var(--text-secondary);
  }

  /* ======================================================================
   * Мобильный вертикальный flow (виден только на узких экранах, см. toggle).
   * ==================================================================== */
  .architecture__flow {
    flex-direction: column;
    gap: var(--sp-5);
  }

  .archflow__stage {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .archflow__item {
    display: flex;
    flex-direction: column;
  }

  /* Капсула узла: glass даёт фон/обводку, здесь раскладка и тап-таргет. */
  .archflow__node {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3) var(--sp-4);
    text-align: left;
    color: var(--text);
  }

  .archflow__node--strong {
    border-color: color-mix(in srgb, var(--project-accent) 52%, var(--glass-edge-bright));
    background-color: var(--glass-tint-3);
  }

  .archflow__node-main {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    min-width: 0;
  }

  .archflow__label {
    font-family: var(--font-stack-display);
    font-size: var(--fs-15);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-snug);
    line-height: var(--lh-snug);
  }

  .archflow__node--strong :global(.arch-glyph) {
    stroke: color-mix(in srgb, var(--project-accent) 72%, var(--text));
  }

  .archflow__caret {
    display: flex;
    flex: none;
    color: var(--text-muted);
    transition: transform var(--dur-fast) var(--ease-standard);
  }
  .archflow__caret svg {
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .archflow__node[aria-expanded="true"] .archflow__caret {
    transform: rotate(180deg);
  }

  /* Раскрытие пояснения тапом: grid-rows 0fr→1fr (как в Capabilities). */
  .archflow__desc {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dur-med) var(--ease-standard);
  }
  .archflow__node[aria-expanded="true"] + .archflow__desc {
    grid-template-rows: 1fr;
  }
  .archflow__desc > * {
    overflow: hidden;
    min-height: 0;
  }
  .archflow__desc-text {
    padding: var(--sp-2) var(--sp-2) 0;
    font-size: var(--fs-13);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* Исходящие связи узла: компактные чипы со стрелкой, цвет по типу канала. */
  .archflow__edges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-2);
    padding-inline: var(--sp-1);
  }
  .archflow__edge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: 3px var(--sp-2);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-pill);
    background: var(--glass-tint-1);
    font-size: var(--fs-11);
    color: var(--text-secondary);
  }
  .archflow__edge-arrow {
    color: var(--text-muted);
    font-weight: var(--fw-semibold);
  }
  .archflow__edge-to {
    font-weight: var(--fw-medium);
    color: var(--text);
  }
  .archflow__edge-kind {
    font-family: var(--font-stack-display);
    font-size: var(--fs-10);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .archflow__edge--sync .archflow__edge-arrow {
    color: color-mix(in srgb, var(--text-secondary) 55%, var(--project-accent));
  }
  .archflow__edge--async {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--project-accent) 30%, var(--glass-edge));
  }
  .archflow__edge--async .archflow__edge-arrow {
    color: color-mix(in srgb, var(--project-accent) 70%, var(--text-secondary));
  }
  .archflow__edge--data {
    border-style: dotted;
  }
  .archflow__edge--data .archflow__edge-arrow {
    color: var(--text-muted);
  }

  /* Стрелка-разделитель между стадиями (col → col). */
  .archflow__down {
    display: flex;
    justify-content: center;
    padding-block: var(--sp-1);
    color: var(--text-muted);
    opacity: 0.65;
  }
  .archflow__down svg {
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>

<script>
  /**
   * Клик / тап / клавиатурный фокус по капсуле узла раскрывает его пояснение
   * (data-arch-desc) в подписи под диаграммой и подсвечивает капсулу акцентом.
   * Повторный клик или Escape: сброс. Чистые class/textContent-операции:
   * ни requestAnimationFrame, ни чтения геометрии. Каждая диаграмма независима.
   *
   * Указатель и клавиатура не конфликтуют: флаг viaPointer гасит «показ по
   * фокусу» для мыши/тача (там работает toggle по клику), оставляя авто-показ
   * по фокусу только для Tab-навигации.
   */
  (() => {
    const figs = Array.from(document.querySelectorAll<HTMLElement>(".architecture-fig"));
    figs.forEach((fig) => {
      const nodes = Array.from(
        fig.querySelectorAll<SVGGElement>('[data-arch-node][role="button"]'),
      );
      const hintEl = fig.querySelector<HTMLElement>("[data-arch-hint]");
      const activeEl = fig.querySelector<HTMLElement>("[data-arch-active]");
      const labelEl = fig.querySelector<HTMLElement>("[data-arch-cap-label]");
      const textEl = fig.querySelector<HTMLElement>("[data-arch-cap-text]");
      if (nodes.length === 0 || !hintEl || !activeEl || !labelEl || !textEl) return;

      let current: SVGGElement | null = null;
      let viaPointer = false;

      const show = (n: SVGGElement): void => {
        current = n;
        for (const x of nodes) x.classList.toggle("is-selected", x === n);
        labelEl.textContent = n.getAttribute("data-arch-label") ?? "";
        textEl.textContent = n.getAttribute("data-arch-desc") ?? "";
        hintEl.hidden = true;
        activeEl.hidden = false;
      };

      const clear = (): void => {
        current = null;
        for (const x of nodes) x.classList.remove("is-selected");
        hintEl.hidden = false;
        activeEl.hidden = true;
      };

      for (const n of nodes) {
        n.addEventListener("pointerdown", () => {
          viaPointer = true;
        });
        n.addEventListener("click", () => {
          if (current === n) clear();
          else show(n);
          viaPointer = false;
        });
        n.addEventListener("focus", () => {
          if (viaPointer) {
            viaPointer = false;
            return;
          }
          show(n);
        });
        n.addEventListener("keydown", (ev: KeyboardEvent) => {
          if (ev.key === "Enter" || ev.key === " ") {
            ev.preventDefault();
            show(n);
          } else if (ev.key === "Escape") {
            clear();
            n.blur();
          }
        });
      }

      // Уход фокуса за пределы диаграммы: сброс выбора.
      fig.addEventListener("focusout", (ev) => {
        const next = (ev as FocusEvent).relatedTarget as Node | null;
        if (next === null || !fig.contains(next)) clear();
      });
    });
  })();
</script>

<script>
  /**
   * Мобильный flow: тап по капсуле раскрывает пояснение прямо под ней
   * (grid-rows-аккордеон по aria-expanded). Single-open: открытие одного узла
   * закрывает остальные в той же диаграмме. Отдельно от desktop-caption: на
   * мобильном видим только flow, на desktop только SVG. Чистый class/attr-toggle.
   */
  (() => {
    const flows = Array.from(document.querySelectorAll<HTMLElement>("[data-arch-flow]"));
    flows.forEach((flow) => {
      const nodes = Array.from(flow.querySelectorAll<HTMLButtonElement>("[data-archflow-node]"));
      if (nodes.length === 0) return;
      nodes.forEach((node) => {
        node.addEventListener("click", () => {
          const willOpen = node.getAttribute("aria-expanded") !== "true";
          for (const other of nodes) other.setAttribute("aria-expanded", "false");
          node.setAttribute("aria-expanded", willOpen ? "true" : "false");
        });
      });
    });
  })();
</script>
