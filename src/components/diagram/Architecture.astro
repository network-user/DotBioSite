---
/**
 * Architecture.astro — оркестратор архитектурной диаграммы.
 *
 * Раскладка выбирается по топологии (система координат 960×540):
 *   • Радиальная (звёзды) — узел задаёт `angle` (направление от хаба, 0 = вверх,
 *     по часовой) и `radius` (вынос в px); хаб — `radius: 0` — в центре. Модули
 *     встают вокруг хаба со всех сторон, рёбра-спицы не пересекают узлы.
 *   • Слоистая (потоки) — узел задаёт `col` (колонка-стадия слева направо) и
 *     `row` (порядок в колонке), компонент сам считает ровные координаты:
 *     вход → хаб → хранилища.
 *   • Legacy — явные координаты центра `x/y` (если нет ни `angle`, ни `col`).
 *
 * Рёбра идут прямой спицей от края капсулы к краю капсулы (контрольные точки
 * лежат на луче центр→центр), поэтому наконечник смотрит точно в центр цели —
 * см. ArchEdge.astro.
 *
 * Кластер задаётся списком `members` — рамка считается как их общий bounding
 * box плюс отступ, поэтому всегда аккуратно обнимает свои узлы.
 *
 * Два слоя интерактива (оба перф-лёгкие, под prefers-reduced-motion):
 *   1. Бегущие импульсы по рёбрам (в ArchEdge): запрос → обработка → ответ.
 *   2. Клик / тап / фокус по капсуле раскрывает в подписи под диаграммой
 *      короткое пояснение роли узла (поле `desc`). Чистые class-toggle +
 *      textContent: ни requestAnimationFrame, ни чтения геометрии.
 */

import type { Locale } from "../../lib/i18n";
import ArchNode from "./ArchNode.astro";
import ArchEdge from "./ArchEdge.astro";
import ArchCluster from "./ArchCluster.astro";

type IconKey = "code" | "stack" | "rocket" | "spark" | "telegram" | "globe" | "user" | "dot";
type EdgeKind = "sync" | "async" | "data";

interface NodeInput {
  id: string;
  label: string;
  icon?: IconKey;
  width?: number;
  height?: number;
  emphasis?: "default" | "strong";
  col?: number;
  row?: number;
  /** Радиальная раскладка: `angle` — направление от хаба в градусах (0 = вверх,
   *  по часовой), `radius` — вынос от центра в px. Хаб задаёт `radius: 0`. */
  angle?: number;
  radius?: number;
  x?: number;
  y?: number;
  desc?: { ru: string; en: string };
}

interface EdgeInput {
  from: string;
  to: string;
  kind?: EdgeKind;
  label?: string;
  bend?: number;
  oneway?: boolean;
}

interface ClusterInput {
  label: string;
  members?: ReadonlyArray<string>;
  x?: number;
  y?: number;
  width?: number;
  height?: number;
}

interface Props {
  nodes: ReadonlyArray<NodeInput>;
  edges?: ReadonlyArray<EdgeInput>;
  clusters?: ReadonlyArray<ClusterInput>;
  viewBox?: string;
  class?: string;
  ariaLabel?: string;
  locale?: Locale;
  /** Подсказка-приглашение в подписи под диаграммой (до выбора узла). */
  hint?: string;
}

const {
  nodes,
  edges = [],
  clusters = [],
  viewBox = "0 0 960 540",
  class: className = "",
  ariaLabel = "Architecture diagram",
  locale = "ru",
  hint = "",
} = Astro.props;

const DEFAULT_W = 140;
const DEFAULT_H = 56;

// Размер холста из viewBox (для слоистой раскладки).
const vb = viewBox.split(/\s+/).map(Number);
const VBW = vb[2] && vb[2] > 0 ? vb[2] : 960;
const VBH = vb[3] && vb[3] > 0 ? vb[3] : 540;

// Отступы колонок/рядов от краёв холста.
const PAD_X = 112;
const PAD_Y = 76;

/**
 * Три способа раскладки, по убыванию приоритета:
 *   1. Радиальная — если у узлов есть `angle`/`radius`: хаб (`radius: 0`) в центре
 *      холста, модули по кругу вокруг него (спицы не пересекают узлы). Для звёзд.
 *   2. Слоистая — если есть `col`: x по колонке (равномерно между PAD_X и
 *      VBW-PAD_X), y по позиции в колонке (группа центрируется). Для потоков.
 *   3. Legacy — явные координаты центра `x/y`.
 */
const pos = new Map<string, { x: number; y: number }>();
const radial = nodes.some((n) => typeof n.angle === "number" || typeof n.radius === "number");
const layered = !radial && nodes.some((n) => typeof n.col === "number");
if (radial) {
  const cx = VBW / 2;
  const cy = VBH / 2;
  nodes.forEach((n) => {
    const r = n.radius ?? 0;
    const a = ((n.angle ?? 0) * Math.PI) / 180;
    pos.set(n.id, { x: cx + r * Math.sin(a), y: cy - r * Math.cos(a) });
  });
} else if (layered) {
  const byCol = new Map<number, NodeInput[]>();
  nodes.forEach((n) => {
    const c = n.col ?? 0;
    const arr = byCol.get(c);
    if (arr) arr.push(n);
    else byCol.set(c, [n]);
  });
  const cols = [...byCol.keys()].sort((a, b) => a - b);
  const maxCol = cols.length > 0 ? cols[cols.length - 1]! : 0;
  const band = VBH - 2 * PAD_Y;
  byCol.forEach((arr, c) => {
    const ordered = [...arr].sort((a, b) => (a.row ?? 0) - (b.row ?? 0));
    const n = ordered.length;
    const x = maxCol === 0 ? VBW / 2 : PAD_X + (c * (VBW - 2 * PAD_X)) / maxCol;
    ordered.forEach((node, i) => {
      pos.set(node.id, { x, y: PAD_Y + ((i + 0.5) * band) / n });
    });
  });
} else {
  nodes.forEach((n) => pos.set(n.id, { x: n.x ?? 0, y: n.y ?? 0 }));
}

interface Resolved {
  id: string;
  x: number;
  y: number;
  hw: number;
  hh: number;
}

const resolved = new Map<string, Resolved>();
nodes.forEach((n) => {
  const p = pos.get(n.id) ?? { x: 0, y: 0 };
  resolved.set(n.id, {
    id: n.id,
    x: p.x,
    y: p.y,
    hw: (n.width ?? DEFAULT_W) / 2,
    hh: (n.height ?? DEFAULT_H) / 2,
  });
});

/**
 * Вычисляет точку выхода ребра из капсулы: пересечение луча `(cx,cy) → (tx,ty)`
 * с прямоугольной рамкой капсулы (с округлыми концами — упрощаем до rect).
 */
function edgeAnchor(a: Resolved, b: Resolved): { x: number; y: number } {
  const dx = b.x - a.x;
  const dy = b.y - a.y;
  if (dx === 0 && dy === 0) return { x: a.x, y: a.y };
  const absDx = Math.abs(dx);
  const absDy = Math.abs(dy);
  const scale = Math.min(a.hw / Math.max(absDx, 0.001), a.hh / Math.max(absDy, 0.001));
  return { x: a.x + dx * scale, y: a.y + dy * scale };
}

const edgeData = edges
  .map((e) => {
    const a = resolved.get(e.from);
    const b = resolved.get(e.to);
    if (!a || !b) return null;
    const from = edgeAnchor(a, b);
    const to = edgeAnchor(b, a);
    return { ...e, fromId: e.from, toId: e.to, from, to };
  })
  .filter(
    (
      e,
    ): e is EdgeInput & {
      fromId: string;
      toId: string;
      from: { x: number; y: number };
      to: { x: number; y: number };
    } => e !== null,
  );

// Кластер по members → общий bounding box узлов + отступ. Иначе legacy x/y/w/h.
const CLUSTER_PAD = 22;
const clusterBoxes = clusters
  .map((c) => {
    if (c.members && c.members.length > 0) {
      let minX = Infinity;
      let minY = Infinity;
      let maxX = -Infinity;
      let maxY = -Infinity;
      for (const id of c.members) {
        const r = resolved.get(id);
        if (!r) continue;
        minX = Math.min(minX, r.x - r.hw);
        minY = Math.min(minY, r.y - r.hh);
        maxX = Math.max(maxX, r.x + r.hw);
        maxY = Math.max(maxY, r.y + r.hh);
      }
      if (!Number.isFinite(minX)) return null;
      return {
        x: minX - CLUSTER_PAD,
        y: minY - CLUSTER_PAD,
        width: maxX - minX + 2 * CLUSTER_PAD,
        height: maxY - minY + 2 * CLUSTER_PAD,
        label: c.label,
      };
    }
    if (
      typeof c.x === "number" &&
      typeof c.y === "number" &&
      typeof c.width === "number" &&
      typeof c.height === "number"
    ) {
      return { x: c.x, y: c.y, width: c.width, height: c.height, label: c.label };
    }
    return null;
  })
  .filter(
    (c): c is { x: number; y: number; width: number; height: number; label: string } => c !== null,
  );

// Локализуем пояснения один раз на сервере (страница рендерится под локаль).
const nodeData = nodes.map((n) => ({
  node: n,
  p: pos.get(n.id) ?? { x: 0, y: 0 },
  desc: n.desc ? (n.desc[locale] ?? n.desc.ru) : "",
}));

const hasCaption = hint.length > 0 && nodeData.some((n) => n.desc.length > 0);
---

<figure class:list={["architecture-fig", className]}>
  <div class="architecture__viewport">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox={viewBox}
      preserveAspectRatio="xMidYMid meet"
      class="architecture"
      role="group"
      aria-label={ariaLabel}
    >
      <defs>
        <pattern id="arch-dotgrid" width="34" height="34" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" class="architecture__griddot"></circle>
        </pattern>
      </defs>
      <rect
        class="architecture__grid"
        x="0"
        y="0"
        width="100%"
        height="100%"
        fill="url(#arch-dotgrid)"></rect>
      {clusterBoxes.map((c) => <ArchCluster {...c} />)}
      {
        edgeData.map((e, i) => (
          <ArchEdge
            from={e.from}
            to={e.to}
            fromId={e.fromId}
            toId={e.toId}
            kind={e.kind}
            label={e.label}
            bend={e.bend}
            oneway={e.oneway}
            seq={i}
          />
        ))
      }
      {
        nodeData.map(({ node: n, p, desc }, i) => (
          <g
            class="architecture__node"
            style={`--node-i: ${i};`}
            data-arch-node={n.id}
            data-arch-label={n.label}
            data-arch-desc={desc || undefined}
            tabindex={desc ? "0" : undefined}
            role={desc ? "button" : undefined}
            aria-label={desc ? `${n.label}: ${desc}` : undefined}
          >
            <ArchNode
              x={p.x}
              y={p.y}
              label={n.label}
              icon={n.icon}
              width={n.width}
              height={n.height}
              emphasis={n.emphasis}
            />
          </g>
        ))
      }
    </svg>
  </div>

  {
    hasCaption && (
      <figcaption class="architecture__caption" data-arch-caption aria-live="polite">
        <span class="architecture__caption-hint" data-arch-hint>
          {hint}
        </span>
        <span class="architecture__caption-active" data-arch-active hidden>
          <span class="architecture__caption-label" data-arch-cap-label />
          <span class="architecture__caption-text" data-arch-cap-text />
        </span>
      </figcaption>
    )
  }
</figure>

<style>
  .architecture-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  /* Горизонтальный скролл живёт на вьюпорте, а не на карточке: подпись под
     диаграммой остаётся на всю ширину и переносится нормально, тогда как сам
     SVG на узких экранах держит min-width и прокручивается. */
  .architecture__viewport {
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-inline: contain;
    -webkit-overflow-scrolling: touch;
  }

  .architecture {
    display: block;
    width: 100%;
    height: auto;
    color: var(--text);
  }

  @media (max-width: 719px) {
    .architecture {
      min-width: 640px;
    }
  }

  /* Faint schematic dot-grid behind the nodes — reads as a blueprint surface,
     never competes with the lines (kept at very low alpha). */
  .architecture__griddot {
    fill: rgba(255, 255, 255, 0.05);
  }

  .architecture__grid {
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__grid {
      opacity: 0;
      animation: arch-grid-in var(--dur-slower) var(--ease-standard) forwards;
    }
  }

  @keyframes arch-grid-in {
    to {
      opacity: 1;
    }
  }

  /* Nodes default to visible (no dependency on IntersectionObserver firing for
     SVG <g>). With motion enabled they assemble in a gentle stagger on load;
     the section-level reveal still handles the scroll-in fade of the whole box. */
  .architecture__node {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__node {
      opacity: 0;
      animation: arch-node-in var(--dur-slow) var(--ease-soft) forwards;
      animation-delay: calc(var(--node-i, 0) * 70ms + 200ms);
    }
  }

  @keyframes arch-node-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ----------------------------------------------------------------------
   * Слой «клик → пояснение». Капсула-кнопка подсвечивается акцентом, её роль
   * уходит в подпись под диаграммой. Только смена stroke/fill по классам —
   * без перерасчёта layout. (Подсветку соседних связей сознательно не делаем.)
   * -------------------------------------------------------------------- */
  .architecture__node[role="button"] {
    cursor: pointer;
  }
  .architecture__node:focus {
    outline: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .architecture__node :global(.arch-node__bg) {
      transition:
        stroke var(--dur-fast) var(--ease-standard),
        stroke-width var(--dur-fast) var(--ease-standard);
    }
  }

  .architecture__node[role="button"]:focus-visible :global(.arch-node__bg),
  .architecture__node.is-selected :global(.arch-node__bg) {
    stroke: var(--project-accent);
    stroke-width: 2;
  }
  .architecture__node.is-selected :global(.arch-node__shine) {
    fill: color-mix(in srgb, var(--project-accent) 16%, rgba(255, 255, 255, 0.05));
  }

  .architecture__caption {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-1) var(--sp-2);
    padding-block-start: var(--sp-3);
    border-block-start: var(--bw-thin) solid var(--glass-edge);
    font-size: var(--fs-14);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    min-height: 1.6em;
  }

  .architecture__caption-hint {
    color: var(--text-muted);
  }

  .architecture__caption-active {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-1) var(--sp-2);
  }
  .architecture__caption-active[hidden] {
    display: none;
  }

  .architecture__caption-label {
    color: var(--project-accent);
    font-weight: var(--fw-semibold);
    font-family: var(--font-stack-display);
  }

  .architecture__caption-text {
    color: var(--text-secondary);
  }
</style>

<script>
  /**
   * Клик / тап / клавиатурный фокус по капсуле узла раскрывает его пояснение
   * (data-arch-desc) в подписи под диаграммой и подсвечивает капсулу акцентом.
   * Повторный клик или Escape — сброс. Чистые class/textContent-операции:
   * ни requestAnimationFrame, ни чтения геометрии. Каждая диаграмма независима.
   *
   * Указатель и клавиатура не конфликтуют: флаг viaPointer гасит «показ по
   * фокусу» для мыши/тача (там работает toggle по клику), оставляя авто-показ
   * по фокусу только для Tab-навигации.
   */
  (() => {
    const figs = Array.from(document.querySelectorAll<HTMLElement>(".architecture-fig"));
    figs.forEach((fig) => {
      const nodes = Array.from(
        fig.querySelectorAll<SVGGElement>('[data-arch-node][role="button"]'),
      );
      const hintEl = fig.querySelector<HTMLElement>("[data-arch-hint]");
      const activeEl = fig.querySelector<HTMLElement>("[data-arch-active]");
      const labelEl = fig.querySelector<HTMLElement>("[data-arch-cap-label]");
      const textEl = fig.querySelector<HTMLElement>("[data-arch-cap-text]");
      if (nodes.length === 0 || !hintEl || !activeEl || !labelEl || !textEl) return;

      let current: SVGGElement | null = null;
      let viaPointer = false;

      const show = (n: SVGGElement): void => {
        current = n;
        for (const x of nodes) x.classList.toggle("is-selected", x === n);
        labelEl.textContent = n.getAttribute("data-arch-label") ?? "";
        textEl.textContent = n.getAttribute("data-arch-desc") ?? "";
        hintEl.hidden = true;
        activeEl.hidden = false;
      };

      const clear = (): void => {
        current = null;
        for (const x of nodes) x.classList.remove("is-selected");
        hintEl.hidden = false;
        activeEl.hidden = true;
      };

      for (const n of nodes) {
        n.addEventListener("pointerdown", () => {
          viaPointer = true;
        });
        n.addEventListener("click", () => {
          if (current === n) clear();
          else show(n);
          viaPointer = false;
        });
        n.addEventListener("focus", () => {
          if (viaPointer) {
            viaPointer = false;
            return;
          }
          show(n);
        });
        n.addEventListener("keydown", (ev: KeyboardEvent) => {
          if (ev.key === "Enter" || ev.key === " ") {
            ev.preventDefault();
            show(n);
          } else if (ev.key === "Escape") {
            clear();
            n.blur();
          }
        });
      }

      // Уход фокуса за пределы диаграммы — сброс выбора.
      fig.addEventListener("focusout", (ev) => {
        const next = (ev as FocusEvent).relatedTarget as Node | null;
        if (next === null || !fig.contains(next)) clear();
      });
    });
  })();
</script>
