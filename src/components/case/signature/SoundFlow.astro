      <ul class="sf__statline" role="list" aria-hidden="true">
        <li class="sf__stat"><b>540</b> {t({ ru: "эндпоинтов API", en: "API endpoints" })}</li>
        <li class="sf__stat"><b>17</b> {t({ ru: "типов GPU-задач", en: "GPU job types" })}</li>
        <li class="sf__stat"><b>121</b> {t({ ru: "миграция БД", en: "DB migration" })}</li>
        <li class="sf__stat sf__stat--wide">
          <b>238</b>
          {t({ ru: "тест-файлов · 95% branch coverage", en: "test files · 95% branch coverage" })}
        </li>
      </ul>
    </div>
  </div>

  <div class="sf__layout">
    <div class="sf__nav" role="tablist" aria-label={t({ ru: "Домены", en: "Domains" })}>
      {
        pillars.map((s, i) => (
          <button
            class="sf__tab"
            type="button"
            role="tab"
            id={`sf-tab-${s.id}`}
            data-sf-tab={i}
            data-id={s.id}
            data-title={t(s.title)}
            data-pitch={t(s.pitch)}
            data-desc={t(s.desc)}
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls="sf-panel"
            tabindex={i === 0 ? "0" : "-1"}
          >
            <span class="sf__tab-no mono" aria-hidden="true">{`0${i + 1}`}</span>
            <span class="sf__tab-body">
              <span class="sf__tab-label">{t(s.label)}</span>
              <span class="sf__tab-tag mono">{t(s.tag)}</span>
            </span>
          </button>
        ))
      }
    </div>

    <!-- ===================== ДЕТАЛЬНАЯ ПАНЕЛЬ ===================== -->
    <div class="sf__panel" id="sf-panel" role="tabpanel" aria-live="polite">
      <header class="sf__head">
        <h3 class="sf__title" id="sf-title" data-sf-title>{t(pillars[0]!.title)}</h3>
        <p class="sf__pitch" data-sf-pitch>{t(pillars[0]!.pitch)}</p>
        <button
          class="sf__more"
          type="button"
          data-sf-more
          aria-expanded="true"
          aria-controls="sf-detail"
        >
          <span class="sf__more-label">{t({ ru: "подробнее", en: "more" })}</span>
          <span class="sf__chevron" aria-hidden="true"></span>
        </button>
        <div class="sf__detail" id="sf-detail" role="region" aria-labelledby="sf-title">
          <p class="sf__desc body-sm sf__detail-inner" data-sf-desc>{t(pillars[0]!.desc)}</p>
        </div>
      </header>

      <div class="sf__stage" data-sf-stage>
        <!-- ----------------- (1) ХРАНЕНИЕ ----------------- -->
        <div class="sf__viz sf__viz--storage is-active" data-sf-viz="storage">
          <div class="sf__up-flow">
            <div class="sf__card" data-st-card>
              <span class="sf__card-ico" aria-hidden="true">♪</span>
              <span class="sf__card-name mono">{t(storage.file)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__dd-col">
              <span class="sf__cap caption">{t(storage.scan)}</span>
              <span class="sf__cap caption">{t(storage.hashCap)}</span>
              <code class="sf__hash mono"
                ><span class="sf__hash-pre">sha256:</span><span data-st-hash>a1f9…7e3c</span></code
              >
              <code class="sf__path mono" data-st-path>blobs/a1/a1f9…7e3c</code>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__blob" data-st-blob>
              <span class="sf__blob-cap caption">{t(storage.blobCap)}</span>
              <span class="sf__blob-glyph mono" aria-hidden="true">▢</span>
              <span class="sf__refcount mono">ref_count: <b data-st-ref>1</b></span>
            </div>
          </div>
          <p class="sf__up-steps mono" data-st-steps>{t(storage.steps)}</p>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-st-go>{t(storage.send)}</button>
            <button class="sf__act sf__act--ghost" type="button" data-st-again disabled
              >{t(storage.again)}</button
            >
            <span class="sf__viz-note mono" data-st-note></span>
          </div>
        </div>

        <!-- ----------------- (2) ТРАНСКОД ----------------- -->
        <div class="sf__viz sf__viz--pipeline" data-sf-viz="pipeline" hidden>
          <div class="sf__pl-flow">
            <div class="sf__pl-node" data-pl-node="raw">
              <span class="sf__pl-ico mono" aria-hidden="true">♪</span>
              <span class="sf__pl-label">{t(pipeline.raw)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__pl-node sf__pl-node--core" data-pl-node="ffmpeg">
              <span class="sf__pl-ico mono" aria-hidden="true">⚙</span>
              <span class="sf__pl-label">{t(pipeline.ffmpeg)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__pl-out">
              {
                (
                  [
                    ["mp3", pipeline.mp3],
                    ["hls", pipeline.hls],
                    ["wave", pipeline.wave],
                    ["snippet", pipeline.snippet],
                    ["cover", pipeline.cover],
                  ] as const
                ).map(([id, label]) => (
                  <div class="sf__pl-chip" data-pl-out={id}>
                    <span class="mono">{t(label)}</span>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-pl-go>{t(pipeline.go)}</button>
            <span class="sf__viz-note mono" data-pl-note></span>
          </div>
        </div>

        <!-- ----------------- (3) СТРИМИНГ ----------------- -->
        <div class="sf__viz sf__viz--listen" data-sf-viz="listen" hidden>
          <div class="sf__ls-card">
            <span class="sf__ls-cover" aria-hidden="true">♪</span>
            <div class="sf__ls-meta">
              <span class="sf__ls-title">{listen.title}</span>
              <span class="sf__ls-artist">{listen.artist}</span>
            </div>
            <span class="sf__ls-eq" data-ls-eq aria-hidden="true">
              <span></span><span></span><span></span><span></span><span></span>
            </span>
          </div>
          <div class="sf__ls-wave" data-ls-wave style="--p: 0">
            <div class="sf__wave-row sf__wave-row--base" aria-hidden="true">
              {WAVE.map((h) => <span class="sf__wave-bar" style={`--h: ${h}`} />)}
            </div>
            <div class="sf__wave-row sf__wave-row--played" aria-hidden="true">
              {WAVE.map((h) => <span class="sf__wave-bar" style={`--h: ${h}`} />)}
            </div>
            <input
              class="sf__wave-seek"
              type="range"
              min="0"
              max="1000"
              value="0"
              step="1"
              data-ls-seek
              aria-label={t(listen.seek)}
            />
          </div>
          <div class="sf__ls-time">
            <span class="mono" data-ls-cur>0:00</span>
            <span class="sf__ls-hls mono" aria-hidden="true">{t(listen.hls)}</span>
            <span class="mono">{listen.dur}</span>
          </div>
          <div class="sf__ls-lyr">
            <span class="sf__cap caption">{t(listen.lyrCap)}</span>
            <ol class="sf__ly-lines" data-ls-lines>
              {
                lyrics.map((l, i) => (
                  <li class="sf__ly-line" data-ls-line={i} data-at={l.at}>
                    <span class="sf__ly-tc mono" aria-hidden="true">
                      {l.tc}
                    </span>
                    <span class="sf__ly-text">{l.text}</span>
                  </li>
                ))
              }
            </ol>
          </div>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-ls-play aria-pressed="false"
              >{t(listen.play)}</button
            >
          </div>
        </div>

        <!-- ----------------- (4) ИМПОРТ ----------------- -->
        <div class="sf__viz sf__viz--import" data-sf-viz="import" hidden>
          <div class="sf__im-sources" role="group" aria-label={t({ ru: "Источник", en: "Source" })}>
            {
              sources.map((s, i) => (
                <button
                  class={`sf__chip${i === 0 ? " is-on" : ""}`}
                  type="button"
                  data-im-src={s.id}
                  aria-pressed={i === 0 ? "true" : "false"}
                >
                  {t(s.name)}
                </button>
              ))
            }
          </div>
          <div class="sf__im-field">
            <span class="sf__cap caption">{t(importT.linkCap)}</span>
            <div class="sf__si-field">
              <input
                class="sf__si-input mono"
                type="text"
                value="soundcloud.com/kaiangel"
                data-im-input
                aria-label={t(importT.linkCap)}
                autocomplete="off"
              />
              <button class="sf__act" type="button" data-im-go>{t(importT.go)}</button>
            </div>
          </div>
          <ul class="sf__im-list" data-im-list>
            {
              importTracks.map((tr, i) => (
                <li class="sf__im-row" data-im-row={i}>
                  <span class="sf__im-dot" aria-hidden="true" />
                  <span class="sf__im-name">{t(tr)}</span>
                  <span class="sf__im-ok mono" aria-hidden="true">
                    ok
                  </span>
                </li>
              ))
            }
          </ul>
          <p class="sf__viz-note mono" data-im-note>{t(importT.done)}</p>
        </div>

        <!-- ----------------- (5) РЕКОМЕНДАЦИИ ----------------- -->
        <div class="sf__viz sf__viz--discover" data-sf-viz="discover" hidden>
          <div class="sf__dc-steps" aria-hidden="true">
            <span class="sf__dc-step is-on" data-dc-si="0">
              <span class="sf__dc-step-n mono">01</span>
              <span class="sf__dc-step-l">{t(discover.step1label)}</span>
            </span>
            <span class="sf__dc-sep" aria-hidden="true"></span>
            <span class="sf__dc-step" data-dc-si="1">
              <span class="sf__dc-step-n mono">02</span>
              <span class="sf__dc-step-l">{t(discover.step2label)}</span>
            </span>
            <span class="sf__dc-sep" aria-hidden="true"></span>
            <span class="sf__dc-step" data-dc-si="2">
              <span class="sf__dc-step-n mono">03</span>
              <span class="sf__dc-step-l">{t(discover.step3label)}</span>
            </span>
          </div>

          <div class="sf__dc-pane" data-dc-pane="0">
            <span class="sf__cap caption">{t(discover.step1cap)}</span>
            <div class="sf__ta-chips" data-dc-chips>
              {
                tasteChips.map((c, i) => (
                  <button class="sf__chip" type="button" data-dc-chip={i} aria-pressed="false">
                    {t(c)}
                  </button>
                ))
              }
            </div>
            <div class="sf__viz-controls">
              <button class="sf__act" type="button" data-dc-next1 disabled>{t(discover.next)}</button>
              <span class="sf__viz-note mono" data-dc-note1>{t(discover.need1)}</span>
            </div>
          </div>

          <div class="sf__dc-pane" data-dc-pane="1" hidden>
            <span class="sf__cap caption">{t(discover.step2cap)}</span>
            <div class="sf__dc-swipe" data-dc-swipe>
              {
                swipeTracks.map((tr, i) => (
                  <div class="sf__dc-track" data-dc-track={i}>
                    <div class="sf__dc-tr-info">
                      <span class="sf__dc-tr-ico" aria-hidden="true">♪</span>
                      <div class="sf__dc-tr-meta">
                        <span class="sf__dc-tr-title">{tr.title}</span>
                        <span class="sf__dc-tr-artist">
                          {tr.artist} · <span class="mono">{t(tr.genre)}</span>
                        </span>
                      </div>
                    </div>
                    <div class="sf__dc-tr-btns">
                      <button
                        class="sf__dc-tr-btn sf__dc-tr-btn--like"
                        type="button"
                        data-dc-like={i}
                        aria-label={t(discover.like)}
                        aria-pressed="false"
                      >{t(discover.like)}</button>
                      <button
                        class="sf__dc-tr-btn sf__dc-tr-btn--skip"
                        type="button"
                        data-dc-skip={i}
                        aria-label={t(discover.skip)}
                        aria-pressed="false"
                      >{t(discover.skip)}</button>
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="sf__viz-controls">
              <button class="sf__act" type="button" data-dc-next2 disabled>{t(discover.done)}</button>
              <span class="sf__viz-note mono" data-dc-note2>{t(discover.need2)}</span>
            </div>
          </div>

          <div class="sf__dc-pane" data-dc-pane="2" hidden>
            <div class="sf__dc-maturity" data-dc-mat>
              <span class="sf__dc-mat-badge mono">{t(discover.maturity)}</span>
              <span class="sf__cap caption">{t(discover.matNote)}</span>
            </div>
            <span class="sf__cap caption">{t(discover.feedCap)}</span>
            <div class="sf__dc-feed" data-dc-feed>
              {
                feedSections.map((sec, i) => (
                  <div class="sf__dc-card" data-dc-sec={i} hidden>
                    <span class="sf__dc-label">{t(sec.label)}</span>
                    <span class="sf__dc-note mono">{t(sec.note)}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- ----------------- (6) ПОИСК ----------------- -->
        <div class="sf__viz sf__viz--search" data-sf-viz="search" hidden>
          <span class="sf__cap caption">{t(searchT.cap)}</span>
          <div class="sf__sr-field">
            <input
              class="sf__si-input mono"
              type="search"
              value={locale === "en" ? "onda" : "онда"}
              data-sr-input
              aria-label={t(searchT.cap)}
              autocomplete="off"
            />
            <button class="sf__chip is-on" type="button" data-sr-translit aria-pressed="true"
              >{t(searchT.translit)}</button
            >
          </div>
          <span class="sf__sr-fuzzy mono">{t(searchT.fuzzy)}</span>
          <ul class="sf__sr-hits" data-sr-hits>
            {
              searchHits.map((h, i) => (
                <li class="sf__sr-row" data-sr-row={i} hidden>
                  <span class="sf__sr-title">{t(h.title)}</span>
                  <span class="sf__sr-sub">{t(h.sub)}</span>
                  <span class="sf__sr-via mono">{t(h.via)}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- ----------------- (7) ВОРКЕР ----------------- -->
        <div class="sf__viz sf__viz--worker" data-sf-viz="worker" hidden>
          <div class="sf__wk-head">
            <span class="sf__cap caption">{t(worker.cap)}</span>
            <span class="sf__wk-asr mono">{t(worker.asr)}</span>
          </div>
          <div class="sf__jobs" data-wk-jobs>
            {
              jobs.map((j, i) => (
                <button
                  class={`sf__job${i >= VISIBLE_JOBS ? " is-extra" : ""}`}
                  type="button"
                  data-wk-job={i}
                  data-desc={t(j.desc)}
                  aria-pressed="false"
                  hidden={i >= VISIBLE_JOBS}
                >
                  <span class="sf__job-key mono">{j.key}</span>
                </button>
              ))
            }
            <button class="sf__job sf__job--more" type="button" data-wk-more aria-expanded="false">
              <span data-wk-more-t>{t(worker.more)}</span>
              <span class="mono" data-wk-more-c>(+{jobs.length - VISIBLE_JOBS})</span>
            </button>
          </div>
          <p class="sf__wk-desc body-sm" data-wk-desc>{t(worker.pick)}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="sf__pager">
    <button class="sf__pg-btn sf__pg-btn--prev" type="button" data-sf-prev>
      <span aria-hidden="true">←</span>
      <span>{t(nav.prev)}</span>
    </button>
    <ol class="sf__dots" aria-hidden="true">
      {pillars.map((_, i) => <li class="sf__dot" data-sf-dot={i} />)}
    </ol>
    <button class="sf__pg-btn sf__pg-btn--next" type="button" data-sf-next>
      <span>{t(nav.next)}</span>
      <span aria-hidden="true">→</span>
    </button>
  </div>
</section>

<style>
  .sf {
    --sf-line: color-mix(in srgb, var(--text) 26%, transparent);
    --sf-soft: color-mix(in srgb, var(--text) 6%, transparent);
    --sf-hot: color-mix(in srgb, var(--project-accent) 60%, var(--text));
    --sf-hot-line: color-mix(in srgb, var(--project-accent) 46%, transparent);
    --sf-hot-soft: color-mix(in srgb, var(--project-accent) 14%, transparent);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .sf__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 68ch;
  }

  .sf__statline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-4);
  }
  .sf__stat {
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .sf__stat b {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .sf__stat--wide {
    flex: 1 1 220px;
  }

  .sf__layout {
    display: grid;
    grid-template-columns: minmax(170px, 0.7fr) minmax(0, 2fr);
    gap: var(--sp-4);
    align-items: start;
  }

  /* селектор */
  .sf__nav {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  .sf__tab {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    color: var(--text-secondary);
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .sf__tab:hover {
    border-color: var(--border-hover);
  }
  .sf__tab:active {
    transform: scale(0.99);
  }
  .sf__tab:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__tab[aria-selected="true"] {
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__tab-no {
    flex: none;
    font-size: var(--fs-12);
    color: var(--text-faint);
  }
  .sf__tab[aria-selected="true"] .sf__tab-no {
    color: var(--sf-hot);
  }
  .sf__tab-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .sf__tab-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-14);
    color: var(--text);
    letter-spacing: var(--ls-snug);
  }
  .sf__tab-tag {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    overflow-wrap: anywhere;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
  }
  .sf__tab[aria-selected="true"] .sf__tab-tag,
  .sf__tab:hover .sf__tab-tag,
  .sf__tab:focus-visible .sf__tab-tag {
    max-height: 3em;
    opacity: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf__tab-tag {
      transition:
        max-height var(--dur-med) var(--ease-standard),
        opacity var(--dur-fast) var(--ease-standard);
    }
  }

  /* панель */
  .sf__panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-width: 0;
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 120% at 0% 0%, var(--sf-hot-soft), transparent 52%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }
  .sf__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-22);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--text);
  }
  .sf__desc {
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 72ch;
  }

  .sf__stage {
    position: relative;
    min-width: 0;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
  }
  .sf__viz {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-width: 0;
  }
  .sf__viz[hidden] {
    display: none;
  }
  .sf.is-inview .sf__viz.is-active {
    animation: sf-fade var(--dur-med) var(--ease-soft) both;
  }
  @keyframes sf-fade {
    from {
      opacity: 0;
      transform: translate3d(0, 6px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .sf__cap {
    color: var(--text-muted);
  }
  .sf__viz-controls {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }
  .sf__act {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    flex: none;
    border: var(--bw-thin) solid var(--sf-line);
    border-radius: var(--r-pill);
    background: var(--sf-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sf__act:hover:not(:disabled) {
    border-color: var(--text);
  }
  .sf__act:active:not(:disabled) {
    transform: scale(0.96);
  }
  .sf__act:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__act:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .sf__act--ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text-secondary);
  }
  .sf__viz-note {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    overflow-wrap: anywhere;
  }
  .sf__arrow {
    flex: none;
    width: 22px;
    height: 0;
    border-top: var(--bw-thin) solid var(--sf-line);
    position: relative;
    align-self: center;
  }
  .sf__arrow::after {
    content: "";
    position: absolute;
    right: -1px;
    top: -3px;
    width: 6px;
    height: 6px;
    border-top: var(--bw-thin) solid var(--sf-line);
    border-right: var(--bw-thin) solid var(--sf-line);
    transform: rotate(45deg);
  }

  /* чипы (вкус / источники) */
  .sf__chip {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__chip:hover {
    border-color: var(--border-hover);
  }
  .sf__chip.is-on {
    color: var(--text);
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }

  /* (1) Вход */
  .sf__si-methods {
    display: inline-flex;
    gap: var(--sp-1);
    padding: 3px;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    width: max-content;
  }
  .sf__seg {
    min-height: calc(var(--tap-min) - 8px);
    padding: var(--sp-1) var(--sp-4);
    border: 0;
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__seg.is-on {
    color: var(--text);
    background: var(--sf-soft);
  }
  .sf__si-pane[hidden] {
    display: none;
  }
  .sf__si-tg {
    background: var(--sf-hot-soft);
    border-color: var(--sf-hot-line);
  }
  .sf__si-tg-ico {
    color: var(--sf-hot);
    font-size: var(--fs-16);
  }
  .sf__si-field {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .sf__si-input {
    flex: 1 1 180px;
    min-width: 0;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text);
    font-size: var(--fs-13);
  }
  .sf__si-input:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 1px;
    border-color: var(--sf-hot-line);
  }
  .sf__si-link {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-3);
  }
  .sf__si-link[hidden] {
    display: none;
  }
  .sf__si-token {
    font-size: var(--fs-12);
    color: var(--sf-hot);
    padding: var(--sp-1) var(--sp-2);
    border: var(--bw-thin) dashed var(--sf-hot-line);
    border-radius: var(--r-sm);
    overflow-wrap: anywhere;
  }

  /* (2) Вкус */
  .sf__ta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__ta-tower {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .sf__ta-meter {
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .sf__ta-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--sf-hot);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-slow) var(--ease-soft);
  }
  .sf__ta-count {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }

  /* (3) Импорт */
  .sf__im-sources {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__im-field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__im-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 4em;
  }
  .sf__im-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
    opacity: 0;
    transform: translate3d(-8px, 0, 0);
  }
  .sf__im-row.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__im-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sf-hot);
  }
  .sf__im-name {
    font-size: var(--fs-13);
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sf__im-ok {
    font-size: var(--fs-11);
    color: var(--state-ok);
  }

  /* (4) Слушать */
  .sf__ls-card {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface-2);
  }
  .sf__ls-cover {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-xs);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    color: var(--text);
    font-size: var(--fs-18);
  }
  .sf__ls-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .sf__ls-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    color: var(--text);
  }
  .sf__ls-artist {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .sf__ls-hls {
    margin-left: auto;
    flex: none;
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .sf__ls-bar {
    height: 5px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .sf__ls-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--sf-hot);
    transform: scaleX(0);
    transform-origin: left center;
  }
  .sf__viz--listen.is-playing .sf__ls-fill {
    animation: sf-fill 12s linear forwards;
  }
  @keyframes sf-fill {
    to {
      transform: scaleX(1);
    }
  }
  .sf__ls-lyr {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__ly-lines {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 5.6em;
  }
  .sf__ly-line {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    opacity: 0;
    transform: translate3d(-6px, 0, 0);
  }
  .sf__ly-line.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__ly-tc {
    flex: none;
    font-size: var(--fs-11);
    color: var(--sf-hot);
    font-variant-numeric: tabular-nums;
  }
  .sf__ly-text {
    font-size: var(--fs-14);
    color: var(--text);
    line-height: var(--lh-snug);
  }

  /* (5) Загрузка */
  .sf__up-flow {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .sf__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    flex: none;
    width: 96px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface-2);
  }
  .sf.is-inview .sf__viz--storage.is-active .sf__card[data-st-card] {
    animation: sf-drop var(--dur-slow) var(--ease-soft) both;
  }
  @keyframes sf-drop {
    from {
      opacity: 0;
      transform: translate3d(0, -14px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .sf__card-ico {
    font-size: var(--fs-24);
    color: var(--text);
    line-height: 1;
  }
  .sf__card-name {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }
  .sf__dd-col {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1 1 200px;
  }
  .sf__hash,
  .sf__path {
    font-size: var(--fs-12);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .sf__hash-pre {
    color: var(--text-faint);
  }
  .sf__path {
    color: var(--text-secondary);
  }
  .sf__blob {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-1);
    flex: none;
    width: 116px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--sf-hot-line);
    border-radius: var(--r-sm);
    background: var(--surface);
    transition: transform var(--dur-med) var(--ease-spring);
  }
  .sf__blob.is-bump {
    transform: scale(1.05);
  }
  .sf__blob-cap {
    color: var(--text-muted);
  }
  .sf__blob-glyph {
    font-size: var(--fs-28);
    color: var(--sf-hot);
    line-height: 1;
  }
  .sf__refcount {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }
  .sf__refcount b {
    color: var(--sf-hot);
    font-size: var(--fs-15);
    font-variant-numeric: tabular-nums;
  }
  .sf__up-steps {
    font-size: var(--fs-12);
    color: var(--text-muted);
    opacity: 0.4;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .sf__up-steps.is-on {
    opacity: 1;
    color: var(--text-secondary);
  }

  /* (6) Воркер */
  .sf__wk-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sf__wk-asr {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    overflow-wrap: anywhere;
  }
  .sf__jobs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__job {
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__job[hidden] {
    display: none;
  }
  .sf__job:hover {
    border-color: var(--border-hover);
  }
  .sf__job.is-on {
    color: var(--text);
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__job-key {
    font-size: var(--fs-12);
  }
  .sf__job--more {
    color: var(--text);
    border-style: dashed;
    border-color: var(--sf-line);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
  }
  .sf__wk-desc {
    color: var(--text-secondary);
    min-height: 2.6em;
    line-height: var(--lh-normal);
  }

  /* (2) Транскод */
  .sf__pl-flow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .sf__pl-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-1);
    flex: none;
    min-width: 72px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    opacity: 0.45;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__pl-node.is-on {
    opacity: 1;
    border-color: var(--sf-hot-line);
    transform: translate3d(0, -2px, 0);
  }
  .sf__pl-node--core.is-on {
    background: var(--sf-hot-soft);
  }
  .sf__pl-ico {
    font-size: var(--fs-20);
    color: var(--text);
    line-height: 1;
  }
  .sf__pl-label {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    text-align: center;
  }
  .sf__pl-out {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    flex: 1 1 200px;
  }
  .sf__pl-chip {
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface-2);
    font-size: var(--fs-12);
    color: var(--text-muted);
    opacity: 0.35;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      color var(--dur-med) var(--ease-standard);
  }
  .sf__pl-chip.is-on {
    opacity: 1;
    color: var(--text);
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }

  /* (5) Рекомендации — 3-step onboarding */
  .sf__dc-steps {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .sf__dc-step {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-13);
    color: var(--text-faint);
  }
  .sf__dc-step.is-on {
    color: var(--text);
  }
  .sf__dc-step.is-done {
    color: var(--sf-hot);
  }
  .sf__dc-step-n {
    font-size: var(--fs-11);
  }
  .sf__dc-step-l {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-medium);
  }
  .sf__dc-sep {
    flex: 1 1 12px;
    height: 0;
    border-top: var(--bw-thin) dashed var(--border);
    min-width: 12px;
    max-width: 32px;
  }
  .sf__dc-pane {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .sf__dc-pane[hidden] {
    display: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf__dc-pane.is-entering {
      animation: sf-fade var(--dur-med) var(--ease-soft) both;
    }
  }

  /* swipe tracks */
  .sf__dc-swipe {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__dc-track {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-med) var(--ease-standard);
  }
  .sf__dc-track.is-rated {
    opacity: 0.5;
  }
  .sf__dc-track.is-liked {
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
    opacity: 1;
  }
  .sf__dc-tr-info {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex: 1 1 0;
    min-width: 0;
  }
  .sf__dc-tr-ico {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--r-xs);
    background: var(--surface-2);
    border: var(--bw-thin) solid var(--border);
    font-size: var(--fs-16);
    color: var(--text);
  }
  .sf__dc-tr-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 1px;
  }
  .sf__dc-tr-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-13);
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sf__dc-tr-artist {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .sf__dc-tr-btns {
    display: flex;
    gap: var(--sp-2);
    flex: none;
  }
  .sf__dc-tr-btn {
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sf__dc-tr-btn:active {
    transform: scale(0.94);
  }
  .sf__dc-tr-btn--like {
    color: var(--sf-hot);
    border-color: var(--sf-hot-line);
  }
  .sf__dc-tr-btn--like:hover,
  .sf__dc-tr-btn--like[aria-pressed="true"] {
    background: var(--sf-hot-soft);
  }
  .sf__dc-tr-btn--skip {
    color: var(--text-muted);
  }
  .sf__dc-tr-btn--skip:hover,
  .sf__dc-tr-btn--skip[aria-pressed="true"] {
    border-color: var(--border-hover);
    color: var(--text);
  }

  /* maturity badge */
  .sf__dc-maturity {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sf__dc-mat-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--sf-hot-line);
    border-radius: var(--r-pill);
    background: var(--sf-hot-soft);
    font-size: var(--fs-12);
    color: var(--sf-hot);
  }

  .sf__dc-feed {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: var(--sp-2);
    min-height: 4.5em;
  }
  .sf__dc-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    opacity: 0;
    transform: translate3d(0, 6px, 0);
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__dc-card:not([hidden]) {
    opacity: 1;
    transform: none;
  }
  .sf__dc-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-13);
    color: var(--text);
  }
  .sf__dc-note {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }

  /* (6) Поиск */
  .sf__sr-field {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
  }
  .sf__sr-fuzzy {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .sf__sr-hits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 6em;
  }
  .sf__sr-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2px var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
    opacity: 0;
    transform: translate3d(-6px, 0, 0);
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__sr-row:not([hidden]) {
    opacity: 1;
    transform: none;
  }
  .sf__sr-title {
    font-size: var(--fs-14);
    color: var(--text);
    grid-column: 1;
  }
  .sf__sr-sub {
    font-size: var(--fs-12);
    color: var(--text-muted);
    grid-column: 1;
  }
  .sf__sr-via {
    font-size: var(--fs-11);
    color: var(--sf-hot);
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: center;
  }

  /* пейджер-презентация */
  .sf__pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sf__pg-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--sf-line);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sf__pg-btn:hover {
    border-color: var(--text);
  }
  .sf__pg-btn:active {
    transform: scale(0.97);
  }
  .sf__pg-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__pg-btn--next {
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__dots {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--sp-2);
    align-items: center;
  }
  .sf__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: var(--bw-thin) solid var(--border-hover);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .sf__dot.is-on {
    background: var(--sf-hot);
    border-color: var(--sf-hot);
    transform: scale(1.3);
  }
  .sf__dot.is-done {
    background: var(--text-faint);
    border-color: var(--text-faint);
  }

  /* ---------- прогрессивное раскрытие ---------- */
  .sf__statbar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    align-items: flex-start;
  }
  .sf__stats-toggle,
  .sf__more {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-12);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .sf__more {
    align-self: flex-start;
  }
  .sf__stats-toggle:hover,
  .sf__more:hover {
    color: var(--text);
  }
  .sf__stats-toggle:focus-visible,
  .sf__more:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
    border-radius: var(--r-xs);
  }
  /* плюс → минус */
  .sf__stats-chevron,
  .sf__chevron {
    position: relative;
    flex: none;
    width: 10px;
    height: 10px;
  }
  .sf__stats-chevron::before,
  .sf__stats-chevron::after,
  .sf__chevron::before,
  .sf__chevron::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 10px;
    height: 1.5px;
    border-radius: 1px;
    background: currentColor;
    transform: translateY(-50%);
  }
  .sf__stats-chevron::after,
  .sf__chevron::after {
    transform: translateY(-50%) rotate(90deg);
  }
  .sf__stats-toggle[aria-expanded="true"] .sf__stats-chevron::after,
  .sf__more[aria-expanded="true"] .sf__chevron::after {
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf__stats-chevron::after,
    .sf__chevron::after {
      transition: opacity var(--dur-fast) var(--ease-standard);
    }
  }
  .sf__statline-box {
    display: grid;
    grid-template-rows: 1fr;
    width: 100%;
  }
  .sf__statline-box > .sf__statline {
    min-height: 0;
    overflow: hidden;
  }
  .sf.is-enhanced .sf__statline-box {
    grid-template-rows: 0fr;
  }
  .sf.is-enhanced.is-stats-open .sf__statline-box {
    grid-template-rows: 1fr;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf__statline-box {
      transition: grid-template-rows var(--dur-med) var(--ease-standard);
    }
  }

  .sf__pitch {
    font-size: var(--fs-16);
    line-height: var(--lh-snug);
    color: var(--text);
    max-width: 64ch;
  }
  .sf__detail {
    display: grid;
    grid-template-rows: 1fr;
  }
  .sf__detail-inner {
    min-height: 0;
    overflow: hidden;
  }
  .sf.is-enhanced .sf__detail {
    grid-template-rows: 0fr;
  }
  .sf.is-enhanced .sf__panel.is-detail-open .sf__detail {
    grid-template-rows: 1fr;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf.is-enhanced .sf__detail {
      transition: grid-template-rows var(--dur-med) var(--ease-standard);
    }
  }

  /* ---------- эквалайзер ---------- */
  .sf__ls-eq {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    margin-left: auto;
    height: 20px;
    flex: none;
  }
  .sf__ls-eq span {
    width: 3px;
    height: 100%;
    border-radius: 1px;
    background: var(--sf-hot);
    transform: scaleY(0.25);
    transform-origin: bottom center;
  }
  .sf__viz--listen.is-playing .sf__ls-eq span {
    animation: sf-eq 0.9s var(--ease-drift) infinite alternate;
  }
  .sf__ls-eq span:nth-child(1) {
    animation-delay: -0.2s;
  }
  .sf__ls-eq span:nth-child(2) {
    animation-delay: -0.5s;
  }
  .sf__ls-eq span:nth-child(3) {
    animation-delay: -0.1s;
  }
  .sf__ls-eq span:nth-child(4) {
    animation-delay: -0.7s;
  }
  .sf__ls-eq span:nth-child(5) {
    animation-delay: -0.35s;
  }
  @keyframes sf-eq {
    from {
      transform: scaleY(0.2);
    }
    to {
      transform: scaleY(1);
    }
  }

  /* ---------- waveform-скраббер ---------- */
  .sf__ls-wave {
    position: relative;
    height: 52px;
    border-radius: var(--r-xs);
  }
  .sf__wave-row {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 2px;
    pointer-events: none;
  }
  .sf__wave-bar {
    flex: 1 1 0;
    height: calc(var(--h, 0.5) * 100%);
    min-height: 2px;
    border-radius: 1px;
    background: var(--sf-line);
  }
  .sf__wave-row--played {
    clip-path: inset(0 calc((1 - var(--p, 0)) * 100%) 0 0);
  }
  .sf__wave-row--played .sf__wave-bar {
    background: var(--sf-hot);
  }
  .sf__ls-wave::after {
    content: "";
    position: absolute;
    inset-block: 0;
    left: calc(var(--p, 0) * 100%);
    width: 1.5px;
    border-radius: 1px;
    background: var(--sf-hot);
    opacity: 0.85;
    transform: translateX(-0.75px);
    pointer-events: none;
  }
  .sf__wave-seek {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    cursor: pointer;
    opacity: 0;
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
  }
  .sf__wave-seek::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 6px;
    height: 52px;
  }
  .sf__wave-seek::-moz-range-thumb {
    width: 6px;
    height: 52px;
    border: 0;
    background: transparent;
  }
  .sf__wave-seek:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
    border-radius: var(--r-xs);
  }
  .sf__ls-time {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .sf__ls-time .sf__ls-hls {
    margin-inline: auto;
  }

  /* активная строка лирики */
  .sf__ly-line.is-active .sf__ly-text {
    color: var(--sf-hot);
  }
  .sf__ly-line.is-in:not(.is-active) .sf__ly-text {
    color: var(--text-muted);
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf__ly-text {
      transition: color var(--dur-med) var(--ease-standard);
    }
  }

  /* список задач воркера: скролл в раскрытом виде */
  .sf__jobs.is-expanded {
    max-height: 220px;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding-right: var(--sp-1);
  }

  /* адаптив */
  @media (max-width: 760px) {
    .sf__layout {
      grid-template-columns: minmax(0, 1fr);
    }
    .sf__nav {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sf__tab {
      flex: 1 1 140px;
    }
    .sf__panel {
      padding: var(--sp-4);
    }
  }
  @media (max-width: 460px) {
    .sf__up-flow {
      flex-direction: column;
      align-items: stretch;
    }
    .sf__arrow {
      transform: rotate(90deg);
      align-self: center;
    }
    .sf__card,
    .sf__blob {
      width: 100%;
    }
  }

  /* reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .sf__viz.is-active,
    .sf__card[data-st-card],
    .sf__viz--listen.is-playing .sf__ls-fill,
    .sf__viz--listen.is-playing .sf__ls-eq span {
      animation: none !important;
    }
    .sf__ls-fill {
      transform: scaleX(1);
    }
    .sf__ls-eq span {
      transform: scaleY(0.5);
    }
    .sf__ta-fill {
      transition: none;
    }
    .sf__ly-line,
    .sf__im-row,
    .sf__dc-card,
    .sf__dc-track,
    .sf__sr-row {
      transition: none;
    }
  }
</style>

<script>
  /**
   * Интерактивный обзор возможностей .звук (не user flow). Селектор доменов +
   * живая схема на каждый. setTimeout через later(), IntersectionObserver,
   * prefers-reduced-motion → статичный кадр.
   */
  (() => {
    const root = document.querySelector<HTMLElement>("[data-sf]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.dataset.locale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-sf-tab]"));
    const titleEl = root.querySelector<HTMLElement>("[data-sf-title]");
    const pitchEl = root.querySelector<HTMLElement>("[data-sf-pitch]");
    const descEl = root.querySelector<HTMLElement>("[data-sf-desc]");
    const vizEls = Array.from(root.querySelectorAll<HTMLElement>("[data-sf-viz]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-sf-dot]"));
    dots.forEach((d, k) => d.classList.toggle("is-on", k === 0));

    // Прогрессивное раскрытие: контент размечен открытым (доступен без JS),
    // скрипт включает сворачивание цифр и описания + переключатели.
    root.classList.add("is-enhanced");

    const statsToggle = root.querySelector<HTMLButtonElement>("[data-sf-stats-toggle]");
    let statsOpen = false;
    const syncStats = (): void => {
      root.classList.toggle("is-stats-open", statsOpen);
      statsToggle?.setAttribute("aria-expanded", statsOpen ? "true" : "false");
    };
    statsToggle?.addEventListener("click", () => {
      statsOpen = !statsOpen;
      syncStats();
    });
    syncStats();

    const panelEl = root.querySelector<HTMLElement>(".sf__panel");
    const moreBtn = root.querySelector<HTMLButtonElement>("[data-sf-more]");
    let detailOpen = false;
    const syncDetail = (): void => {
      panelEl?.classList.toggle("is-detail-open", detailOpen);
      moreBtn?.setAttribute("aria-expanded", detailOpen ? "true" : "false");
    };
    moreBtn?.addEventListener("click", () => {
      detailOpen = !detailOpen;
      syncDetail();
    });
    syncDetail();

    // ---- инфраструктура таймеров ----
    let inview = false;
    const timers: number[] = [];
    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };
    const D = (ms: number): number => (reduced ? 0 : ms);

    // ============ (1) ХРАНЕНИЕ ============
    const stRef = root.querySelector<HTMLElement>("[data-st-ref]");
    const stBlob = root.querySelector<HTMLElement>("[data-st-blob]");
    const stSteps = root.querySelector<HTMLElement>("[data-st-steps]");
    const stGo = root.querySelector<HTMLButtonElement>("[data-st-go]");
    const stAgain = root.querySelector<HTMLButtonElement>("[data-st-again]");
    const stNote = root.querySelector<HTMLElement>("[data-st-note]");
    let stRc = 1;

    const stRun = (): void => {
      clearTimers();
      if (stGo) { stGo.disabled = true; stGo.textContent = tr("загружаем…", "uploading…"); }
      if (stSteps) stSteps.classList.remove("is-on");
      if (stNote) stNote.textContent = "";
      later(() => {
        if (stSteps) stSteps.classList.add("is-on");
        if (stAgain) stAgain.disabled = false;
        if (stGo) { stGo.disabled = false; stGo.textContent = tr("Залить трек", "Upload track"); }
        if (stNote) stNote.textContent = tr("сохранено", "saved");
      }, D(700));
    };
    const stBump = (): void => {
      stRc += 1;
      if (stRef) stRef.textContent = String(stRc);
      if (stBlob) {
        stBlob.classList.add("is-bump");
        later(() => stBlob.classList.remove("is-bump"), D(220));
      }
      if (stNote) {
        stNote.textContent = tr(
          "файл уже есть - новый не создаётся, счётчик +1",
          "file already exists — no new copy, counter +1",
        );
      }
    };
    stGo?.addEventListener("click", stRun);
    stAgain?.addEventListener("click", stBump);

    // ============ (2) ТРАНСКОД ============
    const plNodes = Array.from(root.querySelectorAll<HTMLElement>("[data-pl-node]"));
    const plOuts = Array.from(root.querySelectorAll<HTMLElement>("[data-pl-out]"));
    const plGo = root.querySelector<HTMLButtonElement>("[data-pl-go]");
    const plNote = root.querySelector<HTMLElement>("[data-pl-note]");

    const runPipeline = (): void => {
      clearTimers();
      plNodes.forEach((n) => n.classList.remove("is-on"));
      plOuts.forEach((o) => o.classList.remove("is-on"));
      if (plGo) { plGo.disabled = true; plGo.textContent = tr("обрабатываем…", "processing…"); }
      if (plNote) plNote.textContent = "";
      const seq = [...plNodes, ...plOuts];
      seq.forEach((el, i) => {
        later(() => el.classList.add("is-on"), D(280) * (i + 1));
      });
      later(
        () => {
          if (plNote) plNote.textContent = tr("все форматы готовы", "all formats ready");
          if (plGo) { plGo.disabled = false; plGo.textContent = tr("Обработать файл", "Process file"); }
        },
        D(280) * (seq.length + 1),
      );
    };
    plGo?.addEventListener("click", runPipeline);

    // ============ (3) ИМПОРТ ============
    const imSrcBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-im-src]"));
    const imRows = Array.from(root.querySelectorAll<HTMLElement>("[data-im-row]"));
    const imGo = root.querySelector<HTMLButtonElement>("[data-im-go]");
    const imNote = root.querySelector<HTMLElement>("[data-im-note]");

    imSrcBtns.forEach((b) => {
      b.addEventListener("click", () => {
        imSrcBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", on ? "true" : "false");
        });
      });
    });
    const runImport = (): void => {
      clearTimers();
      imRows.forEach((r) => r.classList.remove("is-in"));
      if (imGo) { imGo.disabled = true; imGo.textContent = tr("загружаем…", "fetching…"); }
      if (imNote) imNote.textContent = "";
      imRows.forEach((r, i) => {
        later(() => r.classList.add("is-in"), D(260) * (i + 1));
      });
      later(
        () => {
          if (imNote) imNote.textContent = tr("добавлено в каталог", "added to the catalog");
          if (imGo) { imGo.disabled = false; imGo.textContent = tr("Импортировать", "Import"); }
        },
        D(260) * (imRows.length + 1),
      );
    };
    imGo?.addEventListener("click", runImport);

    // ============ (4) СЛУШАТЬ ============
    // Мини-плеер: waveform-скраббер (seek), эквалайзер и караоке-подсветка строк.
    // Один rAF только во время воспроизведения; останавливается на паузе/конце/
    // offscreen. Под reduced-motion — статичный кадр без rAF.
    const lsViz = root.querySelector<HTMLElement>("[data-sf-viz='listen']");
    const lsWave = root.querySelector<HTMLElement>("[data-ls-wave]");
    const lsSeek = root.querySelector<HTMLInputElement>("[data-ls-seek]");
    const lsCur = root.querySelector<HTMLElement>("[data-ls-cur]");
    const lsLines = Array.from(root.querySelectorAll<HTMLElement>("[data-ls-line]"));
    const lsPlay = root.querySelector<HTMLButtonElement>("[data-ls-play]");
    const TRACK_LEN = 168; // 2:48 — для подписи текущего времени
    const PLAY_DUR = 20; // секунд на полный проход в демо
    let lsRaf = 0;
    let lsTs = 0;
    let lsP0 = 0;
    let lsP = 0;
    let lsPlaying = false;

    const fmt = (s: number): string => {
      const m = Math.floor(s / 60);
      const sec = Math.max(0, Math.floor(s % 60));
      return `${m}:${sec < 10 ? "0" : ""}${sec}`;
    };
    const lsCancel = (): void => {
      if (lsRaf) {
        cancelAnimationFrame(lsRaf);
        lsRaf = 0;
      }
    };
    const lsApply = (p: number): void => {
      lsP = p;
      lsWave?.style.setProperty("--p", p.toFixed(4));
      if (lsSeek) lsSeek.value = String(Math.round(p * 1000));
      if (lsCur) lsCur.textContent = fmt(p * TRACK_LEN);
      let active = -1;
      lsLines.forEach((l, i) => {
        const at = Number(l.dataset.at) || 0;
        const on = p >= at - 0.001;
        l.classList.toggle("is-in", on);
        if (on) active = i;
      });
      lsLines.forEach((l, i) => l.classList.toggle("is-active", i === active));
    };
    const lsLabel = (text: string, pressed: boolean): void => {
      if (!lsPlay) return;
      lsPlay.textContent = text;
      lsPlay.setAttribute("aria-pressed", pressed ? "true" : "false");
    };
    const lsStop = (): void => {
      lsCancel();
      lsPlaying = false;
      lsViz?.classList.remove("is-playing");
      lsLabel(tr("Играть", "Play"), false);
    };
    const lsFrame = (ts: number): void => {
      if (!lsTs) lsTs = ts;
      const p = Math.min(1, lsP0 + (ts - lsTs) / 1000 / PLAY_DUR);
      lsApply(p);
      if (p >= 1) {
        lsCancel();
        lsPlaying = false;
        lsViz?.classList.remove("is-playing");
        lsLabel(tr("Заново", "Replay"), false);
        return;
      }
      lsRaf = requestAnimationFrame(lsFrame);
    };
    const lsStart = (): void => {
      lsCancel();
      if (reduced) {
        lsApply(1);
        lsLabel(tr("Заново", "Replay"), false);
        return;
      }
      if (lsP >= 1) lsP = 0;
      lsP0 = lsP;
      lsTs = 0;
      lsPlaying = true;
      lsViz?.classList.add("is-playing");
      lsLabel(tr("Пауза", "Pause"), true);
      lsRaf = requestAnimationFrame(lsFrame);
    };
    lsPlay?.addEventListener("click", () => {
      if (lsPlaying) lsStop();
      else lsStart();
    });
    lsSeek?.addEventListener("input", () => {
      const p = (Number(lsSeek.value) || 0) / 1000;
      if (lsPlaying) {
        lsP0 = p;
        lsTs = 0;
      }
      lsApply(p);
    });

    // ============ (5) РЕКОМЕНДАЦИИ — 3-step onboarding ============
    const dcChips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dc-chip]"));
    const dcNext1 = root.querySelector<HTMLButtonElement>("[data-dc-next1]");
    const dcNote1 = root.querySelector<HTMLElement>("[data-dc-note1]");
    const dcNext2 = root.querySelector<HTMLButtonElement>("[data-dc-next2]");
    const dcNote2 = root.querySelector<HTMLElement>("[data-dc-note2]");
    const dcCards = Array.from(root.querySelectorAll<HTMLElement>("[data-dc-sec]"));
    const dcLikeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dc-like]"));
    const dcSkipBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dc-skip]"));
    const dcStepIndicators = Array.from(root.querySelectorAll<HTMLElement>("[data-dc-si]"));
    const dcPanes = Array.from(root.querySelectorAll<HTMLElement>("[data-dc-pane]"));

    let dcGenreSel = 0;
    let dcRated = 0;
    let dcCurrentStep = 0;

    const dcGoToStep = (step: number): void => {
      dcCurrentStep = step;
      dcPanes.forEach((p, i) => {
        const on = i === step;
        p.hidden = !on;
        if (on) p.classList.add("is-entering");
      });
      dcStepIndicators.forEach((s, i) => {
        s.classList.toggle("is-on", i === step);
        s.classList.toggle("is-done", i < step);
      });
      if (step === 2) {
        dcCards.forEach((card, i) => {
          later(() => { card.hidden = false; }, D(150) * (i + 1));
        });
      }
    };

    const dcResetDiscover = (): void => {
      dcGenreSel = 0;
      dcRated = 0;
      dcCurrentStep = 0;
      dcChips.forEach((c) => {
        c.setAttribute("aria-pressed", "false");
        c.classList.remove("is-on");
      });
      dcLikeBtns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      dcSkipBtns.forEach((b) => b.setAttribute("aria-pressed", "false"));
      Array.from(root.querySelectorAll<HTMLElement>("[data-dc-track]")).forEach((t) => {
        t.classList.remove("is-rated", "is-liked");
      });
      dcCards.forEach((c) => { c.hidden = true; });
      if (dcNext1) dcNext1.disabled = true;
      if (dcNext2) dcNext2.disabled = true;
      if (dcNote1) dcNote1.textContent = tr("выберите хотя бы 2 жанра", "pick at least 2 genres");
      if (dcNote2) dcNote2.textContent = tr("оцените хотя бы 2 трека", "rate at least 2 tracks");
      dcGoToStep(0);
    };

    dcChips.forEach((c) => {
      c.addEventListener("click", () => {
        const on = c.getAttribute("aria-pressed") === "true";
        c.setAttribute("aria-pressed", on ? "false" : "true");
        c.classList.toggle("is-on", !on);
        dcGenreSel += on ? -1 : 1;
        if (dcGenreSel < 0) dcGenreSel = 0;
        if (dcNext1) dcNext1.disabled = dcGenreSel < 2;
        if (dcNote1) {
          dcNote1.textContent = dcGenreSel >= 2
            ? tr(`${dcGenreSel} жанра — можно идти дальше`, `${dcGenreSel} genres — ready to continue`)
            : tr("выберите хотя бы 2 жанра", "pick at least 2 genres");
        }
      });
    });

    dcNext1?.addEventListener("click", () => dcGoToStep(1));

    const dcRateTrack = (idx: number, liked: boolean): void => {
      const track = root.querySelector<HTMLElement>(`[data-dc-track="${idx}"]`);
      const likeBtn = root.querySelector<HTMLButtonElement>(`[data-dc-like="${idx}"]`);
      const skipBtn = root.querySelector<HTMLButtonElement>(`[data-dc-skip="${idx}"]`);
      if (!track || likeBtn?.getAttribute("aria-pressed") === "true" || skipBtn?.getAttribute("aria-pressed") === "true") return;
      track.classList.add("is-rated");
      if (liked) track.classList.add("is-liked");
      likeBtn?.setAttribute("aria-pressed", liked ? "true" : "false");
      skipBtn?.setAttribute("aria-pressed", liked ? "false" : "true");
      dcRated += 1;
      if (dcNext2) dcNext2.disabled = dcRated < 2;
      if (dcNote2) {
        dcNote2.textContent = dcRated >= 2
          ? tr("вкус собран — смотрите что получилось", "taste collected — see the result")
          : tr("оцените хотя бы 2 трека", "rate at least 2 tracks");
      }
    };

    dcLikeBtns.forEach((b) => {
      b.addEventListener("click", () => dcRateTrack(Number(b.dataset.dcLike), true));
    });
    dcSkipBtns.forEach((b) => {
      b.addEventListener("click", () => dcRateTrack(Number(b.dataset.dcSkip), false));
    });

    dcNext2?.addEventListener("click", () => dcGoToStep(2));

    // ============ (6) ПОИСК ============
    const srInput = root.querySelector<HTMLInputElement>("[data-sr-input]");
    const srRows = Array.from(root.querySelectorAll<HTMLElement>("[data-sr-row]"));
    const srTranslit = root.querySelector<HTMLButtonElement>("[data-sr-translit]");

    const runSearch = (): void => {
      clearTimers();
      srRows.forEach((r) => {
        r.hidden = true;
      });
      srRows.forEach((r, i) => {
        later(
          () => {
            r.hidden = false;
          },
          D(180) * (i + 1),
        );
      });
    };
    srInput?.addEventListener("input", runSearch);
    srInput?.addEventListener("focus", runSearch);
    srTranslit?.addEventListener("click", () => {
      const on = srTranslit.getAttribute("aria-pressed") === "true";
      srTranslit.setAttribute("aria-pressed", on ? "false" : "true");
      srTranslit.classList.toggle("is-on", !on);
      runSearch();
    });

    // ============ (7) ВОРКЕР ============
    const wkJobs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-wk-job]"));
    const wkJobsBox = root.querySelector<HTMLElement>("[data-wk-jobs]");
    const wkMore = root.querySelector<HTMLButtonElement>("[data-wk-more]");
    const wkDesc = root.querySelector<HTMLElement>("[data-wk-desc]");
    const wkMoreT = root.querySelector<HTMLElement>("[data-wk-more-t]");
    const wkMoreC = root.querySelector<HTMLElement>("[data-wk-more-c]");
    const wkExtra = wkJobs.filter((j) => j.hidden);
    let wkExpanded = false;

    wkMore?.addEventListener("click", () => {
      wkExpanded = !wkExpanded;
      wkExtra.forEach((j) => {
        j.hidden = !wkExpanded;
      });
      wkMore.setAttribute("aria-expanded", wkExpanded ? "true" : "false");
      wkJobsBox?.classList.toggle("is-expanded", wkExpanded);
      if (wkMoreT)
        wkMoreT.textContent = wkExpanded
          ? tr("Свернуть", "Collapse")
          : tr("Показать все", "Show all");
      if (wkMoreC) wkMoreC.hidden = wkExpanded;
    });
    wkJobs.forEach((j) => {
      j.addEventListener("click", () => {
        wkJobs.forEach((x) => {
          x.classList.remove("is-on");
          x.setAttribute("aria-pressed", "false");
        });
        j.classList.add("is-on");
        j.setAttribute("aria-pressed", "true");
        if (wkDesc) wkDesc.textContent = j.dataset.desc ?? "";
      });
    });

    // ============ Автоплей при показе шага ============
    const autoplay = (id: string): void => {
      if (id === "storage") {
        if (reduced && stSteps) stSteps.classList.add("is-on");
        else if (!reduced) later(() => stGo?.click(), D(250));
      } else if (id === "pipeline") {
        if (reduced) {
          plNodes.forEach((n) => n.classList.add("is-on"));
          plOuts.forEach((o) => o.classList.add("is-on"));
        } else runPipeline();
      } else if (id === "import") {
        if (reduced) imRows.forEach((r) => r.classList.add("is-in"));
        else runImport();
      } else if (id === "listen") {
        if (reduced) lsApply(1);
        else lsStart();
      } else if (id === "search") {
        if (reduced)
          srRows.forEach((r) => {
            r.hidden = false;
          });
        else runSearch();
      } else if (id === "discover") {
        dcResetDiscover();
      }
    };

    // ============ Переключение табов ============
    let current = 0;
    const select = (i: number, focus: boolean): void => {
      const idx = Math.max(0, Math.min(tabs.length - 1, i));
      current = idx;
      clearTimers();
      lsStop();
      tabs.forEach((tab, k) => {
        const on = k === idx;
        tab.setAttribute("aria-selected", on ? "true" : "false");
        tab.tabIndex = on ? 0 : -1;
        if (on && focus) tab.focus();
      });
      const id = tabs[idx]?.dataset.id ?? "storage";
      vizEls.forEach((v) => {
        const on = v.dataset.sfViz === id;
        v.hidden = !on;
        v.classList.toggle("is-active", on);
      });
      const tab = tabs[idx];
      if (tab) {
        if (titleEl) titleEl.textContent = tab.dataset.title ?? "";
        if (pitchEl) pitchEl.textContent = tab.dataset.pitch ?? "";
        if (descEl) descEl.textContent = tab.dataset.desc ?? "";
      }
      detailOpen = false;
      syncDetail();
      dots.forEach((d, k) => {
        d.classList.toggle("is-on", k === idx);
        d.classList.toggle("is-done", k < idx);
      });
      if (inview) autoplay(id);
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(i, false));
      tab.addEventListener("keydown", (e: KeyboardEvent) => {
        let next = -1;
        if (e.key === "ArrowDown" || e.key === "ArrowRight") next = (current + 1) % tabs.length;
        else if (e.key === "ArrowUp" || e.key === "ArrowLeft")
          next = (current - 1 + tabs.length) % tabs.length;
        else if (e.key === "Home") next = 0;
        else if (e.key === "End") next = tabs.length - 1;
        if (next >= 0) {
          e.preventDefault();
          select(next, true);
        }
      });
    });

    const prevBtn = root.querySelector<HTMLButtonElement>("[data-sf-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-sf-next]");
    prevBtn?.addEventListener("click", () =>
      select((current - 1 + tabs.length) % tabs.length, false),
    );
    nextBtn?.addEventListener("click", () => select((current + 1) % tabs.length, false));

    // ============ IntersectionObserver-гейтинг ============
    const stopAll = (): void => {
      inview = false;
      clearTimers();
      lsStop();
      root.classList.remove("is-inview");
    };

    if (typeof IntersectionObserver === "undefined") {
      inview = true;
      root.classList.add("is-inview");
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            inview = e.isIntersecting;
            root.classList.toggle("is-inview", inview);
            if (!inview) {
              clearTimers();
              lsStop();
            } else {
              autoplay(tabs[current]?.dataset.id ?? "storage");
            }
          }
        },
        { threshold: 0.2 },
      );
      io.observe(root);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
