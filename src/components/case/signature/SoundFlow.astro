// Форма волны: детерминированные высоты (build-time, без рандома).
const WAVE: number[] = Array.from({ length: 56 }, (_, i) => {
  const a = Math.sin(i * 0.55) * 0.5 + 0.5;
  const b = Math.sin(i * 0.17 + 1.3) * 0.5 + 0.5;
  return Math.round((0.22 + 0.78 * a * (0.55 + 0.45 * b)) * 100) / 100;
});

