/**
 * SoundFlow.astro — сигнатурная визуализация .звук (DotSound), флагман.
 *
 * Формат: интерактивный обзор ВОЗМОЖНОСТЕЙ ПЛАТФОРМЫ (не пользовательский flow).
 * Слева селектор из 7 доменов «что внутри» (по README DotSoundBackend), справа —
 * заголовок, описание и живая мини-схема. Монохром, акцент — единичная подсветка.
 *
 * Домены: Хранение (chunked + ClamAV + SHA-256 dedup) → Транскод (FFmpeg → HLS,
 * waveform, snippet) → Воспроизведение (адаптивный HLS + синхро-лирика) → Импорт
 * (yt-dlp, очередь) → Рекомендации (128d, миксы, радио) → Поиск (Elasticsearch
 * SAYT, транслит RU↔LAT) → Воркер (HMAC pull, 17 типов задач + ASR).
 *
 * Движение: только transform/opacity, конечные CSS-анимации (нет вечного rAF).
 * setTimeout через later(), очистка при смене вкладки / offscreen / pagehide.
 * IntersectionObserver (.sf.is-inview). prefers-reduced-motion → статичный кадр.
 */
import type { Locale } from "../../../lib/i18n";

