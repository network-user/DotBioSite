---
/**
 * SoundFlow.astro - сигнатурная визуализация .звук (DotSound), флагман.
 *
 * Формат: конкретный иллюстрированный объяснитель ПОЛЬЗОВАТЕЛЬСКОГО FLOW.
 * Слева селектор из 6 шагов, справа панель, где заголовок + описание стоят
 * рядом со своей живой интерактивной мини-схемой. Монохром, белый приоритет;
 * акцент проекта - только единичная подсветка.
 *
 * Шаги: Вход (Telegram / email magic link) -> Вкус (настройка рекомендаций,
 * 128d) -> Импорт (SoundCloud/YouTube/Bandcamp) -> Слушать (HLS + лирика в
 * такт) -> Загрузка (дедуп SHA-256, один blob) -> Воркер (все 17 типов задач:
 * часть скрыта, кнопка раскрывает остальные, тап по задаче даёт описание).
 *
 * Движение: только transform/opacity, конечные CSS-анимации (нет вечного rAF).
 * Все setTimeout идут через трекер later() и гасятся clearTimers() при смене
 * шага / уходе из вьюпорта / visibilitychange(hidden) / pagehide. Всё гейтится
 * IntersectionObserver (.sf.is-inview). При prefers-reduced-motion - финальное
 * статичное читаемое состояние, интеракции работают.
 *
 * Факты сверены по репозиториям DotSound*: Telegram Mini App поверх сессии;
 * рекомендации - башня слушателя 128d; импорт через yt-dlp (soundcloud_rpc);
 * адаптивный HLS, лирика Demucs(--two-stems=vocals)+faster-whisper; дедуп по
 * SHA-256 (один blob, ref_count++); 17 типов задач воркера (worker/handlers).
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Путь слушателя в .звук - шаг за шагом. Выберите шаг слева: справа появится его живая схема и описание. Тыкайте кнопки внутри схем - они показывают, как это работает на самом деле.",
  en: "A listener's path through .звук - step by step. Pick a step on the left: its live diagram and description appear on the right. Press the buttons inside each diagram - they show how it actually works.",
};

type Step = { id: string; label: Bi; tag: Bi; title: Bi; desc: Bi };
const steps: Step[] = [
  {
    id: "signin",
    label: { ru: "Вход", en: "Sign in" },
    tag: { ru: "Telegram · magic link", en: "Telegram · magic link" },
    title: { ru: "Вход без пароля", en: "Passwordless sign-in" },
    desc: {
      ru: "Два способа войти без пароля. Telegram - в один тап: Mini App открывается поверх уже существующей сессии Telegram. Или по почте: приходит magic link - одноразовая ссылка с коротким сроком жизни, по которой вы сразу внутри.",
      en: "Two passwordless ways in. Telegram - one tap: the Mini App opens over your existing Telegram session. Or by email: a magic link arrives - a one-time, short-lived link that signs you straight in.",
    },
  },
  {
    id: "taste",
    label: { ru: "Вкус", en: "Taste" },
    tag: { ru: "рекомендации · 128d", en: "recommendations · 128d" },
    title: { ru: "Настройка рекомендаций", en: "Set up recommendations" },
    desc: {
      ru: "Отметьте, что любите - жанры и настроения. Из выбора собирается ваша «башня» из 128 чисел (128d): вектор вкуса, по близости которого к векторам треков и подбирается лента «для вас». Чем больше отмечено, тем точнее старт.",
      en: "Mark what you like - genres and moods. Your choices build your 128-number 'tower' (128d): a taste vector whose closeness to track vectors drives your 'for you' feed. The more you mark, the sharper the start.",
    },
  },
  {
    id: "import",
    label: { ru: "Импорт", en: "Import" },
    tag: { ru: "SoundCloud · YouTube · Bandcamp", en: "SoundCloud · YouTube · Bandcamp" },
    title: { ru: "Импорт треков из источников", en: "Import tracks from sources" },
    desc: {
      ru: "Подтяните музыку из SoundCloud, YouTube или Bandcamp - ссылкой или целым каталогом артиста. Под капотом задача soundcloud_rpc тянет треки через yt-dlp и синхронизирует их в ваш каталог, без ручной заливки по одному.",
      en: "Pull music from SoundCloud, YouTube or Bandcamp - by link or a whole artist catalog. Under the hood a soundcloud_rpc job fetches tracks via yt-dlp and syncs them into your library, with no manual one-by-one upload.",
    },
  },
  {
    id: "listen",
    label: { ru: "Слушать", en: "Listen" },
    tag: { ru: "HLS · лирика", en: "HLS · lyrics" },
    title: { ru: "Прослушивание с лирикой", en: "Listening with lyrics" },
    desc: {
      ru: "Трек играет адаптивным HLS - качество подстраивается под сеть. Лирика всплывает сама, строчка за строчкой в такт: Demucs (--two-stems=vocals) снимает вокал, faster-whisper его расшифровывает, а выравнивание ставит тайм-код каждой строке.",
      en: "A track plays as adaptive HLS - quality adapts to the network. Lyrics surface on their own, line by line in time: Demucs (--two-stems=vocals) lifts the vocals, faster-whisper transcribes them, and alignment timestamps each line.",
    },
  },
  {
    id: "upload",
    label: { ru: "Загрузка", en: "Upload" },
    tag: { ru: "дедуп · авто-лирика", en: "dedup · auto-lyrics" },
    title: { ru: "Загрузка своего трека", en: "Upload your own track" },
    desc: {
      ru: "Кидаете файл прямо в чат с ботом. Сервер берёт SHA-256 от содержимого - это и ключ дедупа, и часть пути в хранилище: одинаковый трек хранится один раз, повторная заливка лишь увеличивает ref_count. Дальше воркер сам делает лирику, и трек в каталоге.",
      en: "You drop a file right into the bot chat. The server hashes the content with SHA-256 - both the dedup key and part of the storage path: an identical track is stored once, a re-upload only bumps ref_count. Then the worker makes lyrics itself, and the track lands in the catalog.",
    },
  },
  {
    id: "worker",
    label: { ru: "Воркер", en: "Worker" },
    tag: { ru: "17 типов задач", en: "17 job types" },
    title: { ru: "Что воркер делает с треком", en: "What the worker does with a track" },
    desc: {
      ru: "Тяжёлое считает отдельный GPU-воркер без открытых портов. Из одной очереди он тянет 17 типов задач - от эмбеддингов и похожих треков до транскода в HLS, волны, превью и импорта. Плюс отдельный ASR-конвейер (Demucs + faster-whisper) для лирики. Тапните задачу - покажу, что она делает.",
      en: "Heavy work runs on a separate GPU worker with no open ports. From one queue it pulls 17 job types - from embeddings and similar tracks to HLS transcoding, waveform, snippet and import. Plus a dedicated ASR pipeline (Demucs + faster-whisper) for lyrics. Tap a job to see what it does.",
    },
  },
];

// ---------- ДАННЫЕ ИЛЛЮСТРАЦИЙ ----------

// (1) Вход
const signin = {
  tg: { ru: "Telegram", en: "Telegram" },
  email: { ru: "Почта", en: "Email" },
  tgBtn: { ru: "Открыть в Telegram", en: "Open in Telegram" },
  tgDone: { ru: "вошли через сессию Telegram - один тап, без пароля", en: "signed in via the Telegram session - one tap, no password" },
  emailPh: { ru: "you@example.com", en: "you@example.com" },
  send: { ru: "Отправить magic link", en: "Send magic link" },
  link: { ru: "magic link: одноразовый · ~15 мин · без пароля", en: "magic link: one-time · ~15 min · no password" },
  open: { ru: "Перейти по ссылке", en: "Open the link" },
  emailDone: { ru: "вошли по magic link - ссылка погашена", en: "signed in by magic link - link burned" },
  idle: { ru: "выберите способ входа", en: "choose how to sign in" },
};

// (2) Вкус
const tasteChips: Bi[] = [
  { ru: "электроника", en: "electronic" },
  { ru: "эмбиент", en: "ambient" },
  { ru: "инди", en: "indie" },
  { ru: "хип-хоп", en: "hip-hop" },
  { ru: "джаз", en: "jazz" },
  { ru: "рок", en: "rock" },
  { ru: "lo-fi", en: "lo-fi" },
  { ru: "классика", en: "classical" },
  { ru: "поп", en: "pop" },
];
const taste = {
  cap: { ru: "отметьте, что любите", en: "mark what you like" },
  towerCap: { ru: "ваша башня · 128d", en: "your tower · 128d" },
  pick: { ru: "выбрано", en: "selected" },
  ready: { ru: "подбор настроен - лента «для вас» готова", en: "tuned - your 'for you' feed is ready" },
  need: { ru: "отметьте хотя бы 3", en: "mark at least 3" },
};

// (3) Импорт
const sources: { id: string; name: Bi }[] = [
  { id: "sc", name: { ru: "SoundCloud", en: "SoundCloud" } },
  { id: "yt", name: { ru: "YouTube", en: "YouTube" } },
  { id: "bc", name: { ru: "Bandcamp", en: "Bandcamp" } },
];
const importT = {
  linkCap: { ru: "ссылка на трек или каталог артиста", en: "a track or artist-catalog link" },
  go: { ru: "Импортировать", en: "Import" },
  pulling: { ru: "тянем через yt-dlp…", en: "fetching via yt-dlp…" },
  done: { ru: "синхронизировано в каталог", en: "synced into the catalog" },
};
const importTracks: Bi[] = [
  { ru: "Ночной эфир", en: "Night Air" },
  { ru: "Длинная дорога", en: "Long Way Home" },
  { ru: "Тихий код", en: "Quiet Code" },
  { ru: "Серый асфальт", en: "Grey Asphalt" },
];

// (4) Слушать
const listen = {
  title: { ru: "Держит зал", en: "Holds the Room" },
  artist: { ru: "Невод", en: "Seine" },
  play: { ru: "Играть", en: "Play" },
  pause: { ru: "Пауза", en: "Pause" },
  hls: { ru: "HLS · авто-качество", en: "HLS · adaptive" },
  lyrCap: { ru: "лирика всплывает в такт", en: "lyrics surface on the beat" },
};
const lyricLines: { tc: string; ru: string; en: string }[] = [
  { tc: "0:00", ru: "свет гаснет, зал затих", en: "lights go down, the room is still" },
  { tc: "0:06", ru: "первый удар держит зал", en: "the first beat holds the room" },
  { tc: "0:12", ru: "голос ведёт сквозь шум", en: "a voice cuts through the noise" },
  { tc: "0:18", ru: "и мы снова на ногах", en: "and we're on our feet again" },
];

// (5) Загрузка
const upload = {
  file: { ru: "my-track.mp3", en: "my-track.mp3" },
  chat: { ru: "чат с ботом", en: "bot chat" },
  send: { ru: "Залить в бота", en: "Upload to the bot" },
  again: { ru: "Залить тот же файл снова", en: "Upload the same file again" },
  hashCap: { ru: "SHA-256 содержимого", en: "content SHA-256" },
  blobCap: { ru: "один blob", en: "single blob" },
  steps: { ru: "дедуп → авто-лирика → в каталоге", en: "dedup → auto-lyrics → in the catalog" },
  sameNote: { ru: "тот же хэш → ref_count++, новый blob НЕ создаётся", en: "same hash → ref_count++, no new blob created" },
};

// (6) Воркер - 17 типов задач (worker/handlers) + краткие описания
type Job = { key: string; desc: Bi };
const jobs: Job[] = [
  { key: "audio_embedding", desc: { ru: "эмбеддинг трека: вектор из 128 чисел для похожести и рекомендаций.", en: "track embedding: a 128-number vector for similarity and recommendations." } },
  { key: "track_audio_features", desc: { ru: "аудио-фичи трека: темп, тональность, энергия.", en: "track audio features: tempo, key, energy." } },
  { key: "track_similarity", desc: { ru: "ближайшие треки по вектору эмбеддинга.", en: "nearest tracks by the embedding vector." } },
  { key: "artist_similarity", desc: { ru: "похожие артисты по агрегированным фичам.", en: "similar artists by aggregated features." } },
  { key: "track_transcoding", desc: { ru: "транскод трека в адаптивные HLS-сегменты.", en: "transcode the track into adaptive HLS segments." } },
  { key: "track_waveform", desc: { ru: "строит форму волны для плеера.", en: "builds the waveform for the player." } },
  { key: "track_snippet", desc: { ru: "короткий превью-сэмпл трека.", en: "a short preview snippet of the track." } },
  { key: "track_cover_processing", desc: { ru: "обложка: ресайз и извлечение палитры.", en: "cover art: resize and palette extraction." } },
  { key: "catalog_normalize", desc: { ru: "нормализует и чистит метаданные каталога.", en: "normalizes and cleans catalog metadata." } },
  { key: "artist_features_update", desc: { ru: "пересчитывает агрегированные фичи артиста.", en: "recomputes an artist's aggregated features." } },
  { key: "artist_enrichment", desc: { ru: "обогащает профиль артиста доп. данными.", en: "enriches an artist's profile with extra data." } },
  { key: "track_info_fetch", desc: { ru: "дотягивает метаданные трека из источника.", en: "fetches a track's metadata from the source." } },
  { key: "soundcloud_rpc", desc: { ru: "импорт и синхронизация с SoundCloud через yt-dlp.", en: "import and sync with SoundCloud via yt-dlp." } },
  { key: "sc_artist_catalog_sync", desc: { ru: "синхронизирует каталог артиста из SoundCloud.", en: "syncs an artist's catalog from SoundCloud." } },
  { key: "sc_artist_release_sync", desc: { ru: "синхронизирует релизы артиста из SoundCloud.", en: "syncs an artist's releases from SoundCloud." } },
  { key: "sc_artist_similar_station_sync", desc: { ru: "синхронизирует станцию «похожее» артиста из SoundCloud.", en: "syncs an artist's 'similar' station from SoundCloud." } },
  { key: "external_import_scan", desc: { ru: "сканирует внешние источники на новые треки для импорта.", en: "scans external sources for new tracks to import." } },
];
const VISIBLE_JOBS = 8;
const worker = {
  cap: { ru: "из одной очереди · 17 типов", en: "from one queue · 17 types" },
  more: { ru: "Показать все", en: "Show all" },
  hide: { ru: "Свернуть", en: "Collapse" },
  pick: { ru: "тапните задачу - покажу, что она делает", en: "tap a job - I'll show what it does" },
  asr: { ru: "+ ASR-конвейер: Demucs --two-stems=vocals → faster-whisper", en: "+ ASR pipeline: Demucs --two-stems=vocals → faster-whisper" },
};

const nav = {
  prev: { ru: "Назад", en: "Back" },
  next: { ru: "Далее", en: "Next" },
};
---

<section class="sf" data-sf aria-label={t({ ru: "Путь слушателя в .звук", en: "A listener's path through DotSound" })}>
  <p class="sf__intro">{t(intro)}</p>

  <div class="sf__layout">
    <!-- ===================== СЕЛЕКТОР ШАГОВ ===================== -->
    <div class="sf__nav" role="tablist" aria-label={t({ ru: "Шаги", en: "Steps" })}>
      {
        steps.map((s, i) => (
          <button
            class="sf__tab"
            type="button"
            role="tab"
            id={`sf-tab-${s.id}`}
            data-sf-tab={i}
            data-id={s.id}
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls="sf-panel"
            tabindex={i === 0 ? "0" : "-1"}
          >
            <span class="sf__tab-no mono" aria-hidden="true">{`0${i + 1}`}</span>
            <span class="sf__tab-body">
              <span class="sf__tab-label">{t(s.label)}</span>
              <span class="sf__tab-tag mono">{t(s.tag)}</span>
            </span>
          </button>
        ))
      }
    </div>

    <!-- ===================== ДЕТАЛЬНАЯ ПАНЕЛЬ ===================== -->
    <div class="sf__panel" id="sf-panel" role="tabpanel" aria-live="polite">
      <header class="sf__head">
        <h3 class="sf__title" data-sf-title>{t(steps[0]!.title)}</h3>
        <p class="sf__desc body-sm" data-sf-desc>{t(steps[0]!.desc)}</p>
      </header>

      <div class="sf__stage" data-sf-stage>
        <!-- ----------------- (1) ВХОД ----------------- -->
        <div class="sf__viz sf__viz--signin is-active" data-sf-viz="signin">
          <div class="sf__si-methods" role="group" aria-label={t({ ru: "Способ входа", en: "Sign-in method" })}>
            <button class="sf__seg is-on" type="button" data-si-method="tg" aria-pressed="true">{t(signin.tg)}</button>
            <button class="sf__seg" type="button" data-si-method="email" aria-pressed="false">{t(signin.email)}</button>
          </div>

          <div class="sf__si-pane" data-si-pane="tg">
            <button class="sf__act sf__si-tg" type="button" data-si-tg>
              <span class="sf__si-tg-ico" aria-hidden="true">✈</span>
              <span>{t(signin.tgBtn)}</span>
            </button>
          </div>

          <div class="sf__si-pane" data-si-pane="email" hidden>
            <div class="sf__si-field">
              <input class="sf__si-input mono" type="email" value="you@dotsound.app" data-si-input aria-label={t(signin.email)} placeholder={t(signin.emailPh)} autocomplete="off" />
              <button class="sf__act" type="button" data-si-send>{t(signin.send)}</button>
            </div>
            <div class="sf__si-link" data-si-link hidden>
              <code class="sf__si-token mono">{t(signin.link)}</code>
              <button class="sf__act sf__act--ghost" type="button" data-si-open>{t(signin.open)}</button>
            </div>
          </div>

          <p class="sf__viz-note mono" data-si-note>{t(signin.idle)}</p>
        </div>

        <!-- ----------------- (2) ВКУС ----------------- -->
        <div class="sf__viz sf__viz--taste" data-sf-viz="taste" hidden>
          <span class="sf__cap caption">{t(taste.cap)}</span>
          <div class="sf__ta-chips" data-ta-chips>
            {
              tasteChips.map((c, i) => (
                <button class="sf__chip" type="button" data-ta-chip={i} aria-pressed="false">
                  {t(c)}
                </button>
              ))
            }
          </div>
          <div class="sf__ta-tower">
            <span class="sf__cap caption">{t(taste.towerCap)}</span>
            <div class="sf__ta-meter" aria-hidden="true"><span class="sf__ta-fill" data-ta-fill></span></div>
            <span class="sf__ta-count mono" data-ta-count>0 {t(taste.pick)}</span>
          </div>
          <p class="sf__viz-note mono" data-ta-note>{t(taste.need)}</p>
        </div>

        <!-- ----------------- (3) ИМПОРТ ----------------- -->
        <div class="sf__viz sf__viz--import" data-sf-viz="import" hidden>
          <div class="sf__im-sources" role="group" aria-label={t({ ru: "Источник", en: "Source" })}>
            {
              sources.map((s, i) => (
                <button class={`sf__chip${i === 0 ? " is-on" : ""}`} type="button" data-im-src={s.id} aria-pressed={i === 0 ? "true" : "false"}>
                  {t(s.name)}
                </button>
              ))
            }
          </div>
          <div class="sf__im-field">
            <span class="sf__cap caption">{t(importT.linkCap)}</span>
            <div class="sf__si-field">
              <input class="sf__si-input mono" type="text" value="soundcloud.com/seine/sets" data-im-input aria-label={t(importT.linkCap)} autocomplete="off" />
              <button class="sf__act" type="button" data-im-go>{t(importT.go)}</button>
            </div>
          </div>
          <ul class="sf__im-list" data-im-list>
            {
              importTracks.map((tr, i) => (
                <li class="sf__im-row" data-im-row={i}>
                  <span class="sf__im-dot" aria-hidden="true"></span>
                  <span class="sf__im-name">{t(tr)}</span>
                  <span class="sf__im-ok mono" aria-hidden="true">ok</span>
                </li>
              ))
            }
          </ul>
          <p class="sf__viz-note mono" data-im-note>{t(importT.done)}</p>
        </div>

        <!-- ----------------- (4) СЛУШАТЬ ----------------- -->
        <div class="sf__viz sf__viz--listen" data-sf-viz="listen" hidden>
          <div class="sf__ls-card">
            <span class="sf__ls-cover" aria-hidden="true">♪</span>
            <div class="sf__ls-meta">
              <span class="sf__ls-title">{t(listen.title)}</span>
              <span class="sf__ls-artist">{t(listen.artist)}</span>
            </div>
            <span class="sf__ls-hls mono" aria-hidden="true">{t(listen.hls)}</span>
          </div>
          <div class="sf__ls-bar" data-ls-bar aria-hidden="true"><span class="sf__ls-fill" data-ls-fill></span></div>
          <div class="sf__ls-lyr" data-ls-stage data-ls-state="idle">
            <span class="sf__cap caption">{t(listen.lyrCap)}</span>
            <ol class="sf__ly-lines" data-ls-lines>
              {
                lyricLines.map((l, i) => (
                  <li class="sf__ly-line" data-ls-line={i}>
                    <span class="sf__ly-tc mono" aria-hidden="true">{l.tc}</span>
                    <span class="sf__ly-text">{locale === "en" ? l.en : l.ru}</span>
                  </li>
                ))
              }
            </ol>
          </div>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-ls-play aria-pressed="false">{t(listen.play)}</button>
          </div>
        </div>

        <!-- ----------------- (5) ЗАГРУЗКА ----------------- -->
        <div class="sf__viz sf__viz--upload" data-sf-viz="upload" hidden>
          <div class="sf__up-flow">
            <div class="sf__card" data-up-card>
              <span class="sf__card-ico" aria-hidden="true">♪</span>
              <span class="sf__card-name mono">{t(upload.file)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__dd-col">
              <span class="sf__cap caption">{t(upload.hashCap)}</span>
              <code class="sf__hash mono"><span class="sf__hash-pre">sha256:</span><span data-up-hash>a1f9…7e3c</span></code>
              <code class="sf__path mono" data-up-path>blobs/a1/a1f9…7e3c.ts</code>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__blob" data-up-blob>
              <span class="sf__blob-cap caption">{t(upload.blobCap)}</span>
              <span class="sf__blob-glyph mono" aria-hidden="true">▢</span>
              <span class="sf__refcount mono">ref_count: <b data-up-ref>1</b></span>
            </div>
          </div>
          <p class="sf__up-steps mono" data-up-steps>{t(upload.steps)}</p>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-up-go>{t(upload.send)}</button>
            <button class="sf__act sf__act--ghost" type="button" data-up-again disabled>{t(upload.again)}</button>
            <span class="sf__viz-note mono" data-up-note></span>
          </div>
        </div>

        <!-- ----------------- (6) ВОРКЕР ----------------- -->
        <div class="sf__viz sf__viz--worker" data-sf-viz="worker" hidden>
          <div class="sf__wk-head">
            <span class="sf__cap caption">{t(worker.cap)}</span>
            <span class="sf__wk-asr mono">{t(worker.asr)}</span>
          </div>
          <div class="sf__jobs" data-wk-jobs>
            {
              jobs.map((j, i) => (
                <button
                  class={`sf__job${i >= VISIBLE_JOBS ? " is-extra" : ""}`}
                  type="button"
                  data-wk-job={i}
                  data-desc={t(j.desc)}
                  aria-pressed="false"
                  hidden={i >= VISIBLE_JOBS}
                >
                  <span class="sf__job-key mono">{j.key}</span>
                </button>
              ))
            }
            <button class="sf__job sf__job--more" type="button" data-wk-more aria-expanded="false">
              <span data-wk-more-t>{t(worker.more)}</span>
              <span class="mono" data-wk-more-c>(+{jobs.length - VISIBLE_JOBS})</span>
            </button>
          </div>
          <p class="sf__wk-desc body-sm" data-wk-desc>{t(worker.pick)}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="sf__pager">
    <button class="sf__pg-btn sf__pg-btn--prev" type="button" data-sf-prev>
      <span aria-hidden="true">←</span> <span>{t(nav.prev)}</span>
    </button>
    <ol class="sf__dots" aria-hidden="true">
      {steps.map((_, i) => <li class="sf__dot" data-sf-dot={i}></li>)}
    </ol>
    <button class="sf__pg-btn sf__pg-btn--next" type="button" data-sf-next>
      <span>{t(nav.next)}</span> <span aria-hidden="true">→</span>
    </button>
  </div>
</section>

<style>
  .sf {
    --sf-line: color-mix(in srgb, var(--text) 26%, transparent);
    --sf-soft: color-mix(in srgb, var(--text) 6%, transparent);
    --sf-hot: color-mix(in srgb, var(--project-accent) 60%, var(--text));
    --sf-hot-line: color-mix(in srgb, var(--project-accent) 46%, transparent);
    --sf-hot-soft: color-mix(in srgb, var(--project-accent) 14%, transparent);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .sf__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 68ch;
  }

  .sf__layout {
    display: grid;
    grid-template-columns: minmax(170px, 0.7fr) minmax(0, 2fr);
    gap: var(--sp-4);
    align-items: start;
  }

  /* селектор */
  .sf__nav {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  .sf__tab {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    color: var(--text-secondary);
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .sf__tab:hover {
    border-color: var(--border-hover);
  }
  .sf__tab:active {
    transform: scale(0.99);
  }
  .sf__tab:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__tab[aria-selected="true"] {
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__tab-no {
    flex: none;
    font-size: var(--fs-12);
    color: var(--text-faint);
  }
  .sf__tab[aria-selected="true"] .sf__tab-no {
    color: var(--sf-hot);
  }
  .sf__tab-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .sf__tab-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-14);
    color: var(--text);
    letter-spacing: var(--ls-snug);
  }
  .sf__tab-tag {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    overflow-wrap: anywhere;
  }

  /* панель */
  .sf__panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-width: 0;
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 120% at 0% 0%, var(--sf-hot-soft), transparent 52%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }
  .sf__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-22);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--text);
  }
  .sf__desc {
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 72ch;
  }

  .sf__stage {
    position: relative;
    min-width: 0;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
  }
  .sf__viz {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-width: 0;
  }
  .sf__viz[hidden] {
    display: none;
  }
  .sf.is-inview .sf__viz.is-active {
    animation: sf-fade var(--dur-med) var(--ease-soft) both;
  }
  @keyframes sf-fade {
    from {
      opacity: 0;
      transform: translate3d(0, 6px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .sf__cap {
    color: var(--text-muted);
  }
  .sf__viz-controls {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }
  .sf__act {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    flex: none;
    border: var(--bw-thin) solid var(--sf-line);
    border-radius: var(--r-pill);
    background: var(--sf-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sf__act:hover:not(:disabled) {
    border-color: var(--text);
  }
  .sf__act:active:not(:disabled) {
    transform: scale(0.96);
  }
  .sf__act:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__act:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .sf__act--ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text-secondary);
  }
  .sf__viz-note {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    overflow-wrap: anywhere;
  }
  .sf__arrow {
    flex: none;
    width: 22px;
    height: 0;
    border-top: var(--bw-thin) solid var(--sf-line);
    position: relative;
    align-self: center;
  }
  .sf__arrow::after {
    content: "";
    position: absolute;
    right: -1px;
    top: -3px;
    width: 6px;
    height: 6px;
    border-top: var(--bw-thin) solid var(--sf-line);
    border-right: var(--bw-thin) solid var(--sf-line);
    transform: rotate(45deg);
  }

  /* чипы (вкус / источники) */
  .sf__chip {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__chip:hover {
    border-color: var(--border-hover);
  }
  .sf__chip.is-on {
    color: var(--text);
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }

  /* (1) Вход */
  .sf__si-methods {
    display: inline-flex;
    gap: var(--sp-1);
    padding: 3px;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    width: max-content;
  }
  .sf__seg {
    min-height: calc(var(--tap-min) - 8px);
    padding: var(--sp-1) var(--sp-4);
    border: 0;
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease-standard), background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__seg.is-on {
    color: var(--text);
    background: var(--sf-soft);
  }
  .sf__si-pane[hidden] {
    display: none;
  }
  .sf__si-tg {
    background: var(--sf-hot-soft);
    border-color: var(--sf-hot-line);
  }
  .sf__si-tg-ico {
    color: var(--sf-hot);
    font-size: var(--fs-16);
  }
  .sf__si-field {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .sf__si-input {
    flex: 1 1 180px;
    min-width: 0;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text);
    font-size: var(--fs-13);
  }
  .sf__si-input:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 1px;
    border-color: var(--sf-hot-line);
  }
  .sf__si-link {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-3);
  }
  .sf__si-link[hidden] {
    display: none;
  }
  .sf__si-token {
    font-size: var(--fs-12);
    color: var(--sf-hot);
    padding: var(--sp-1) var(--sp-2);
    border: var(--bw-thin) dashed var(--sf-hot-line);
    border-radius: var(--r-sm);
    overflow-wrap: anywhere;
  }

  /* (2) Вкус */
  .sf__ta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__ta-tower {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .sf__ta-meter {
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .sf__ta-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--sf-hot);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-slow) var(--ease-soft);
  }
  .sf__ta-count {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }

  /* (3) Импорт */
  .sf__im-sources {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__im-field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__im-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 4em;
  }
  .sf__im-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
    opacity: 0;
    transform: translate3d(-8px, 0, 0);
  }
  .sf__im-row.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__im-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sf-hot);
  }
  .sf__im-name {
    font-size: var(--fs-13);
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sf__im-ok {
    font-size: var(--fs-11);
    color: var(--state-ok);
  }

  /* (4) Слушать */
  .sf__ls-card {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface-2);
  }
  .sf__ls-cover {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-xs);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    color: var(--text);
    font-size: var(--fs-18);
  }
  .sf__ls-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .sf__ls-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    color: var(--text);
  }
  .sf__ls-artist {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .sf__ls-hls {
    margin-left: auto;
    flex: none;
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .sf__ls-bar {
    height: 5px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .sf__ls-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--sf-hot);
    transform: scaleX(0);
    transform-origin: left center;
  }
  .sf__viz--listen.is-playing .sf__ls-fill {
    animation: sf-fill 12s linear forwards;
  }
  @keyframes sf-fill {
    to {
      transform: scaleX(1);
    }
  }
  .sf__ls-lyr {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__ly-lines {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 5.6em;
  }
  .sf__ly-line {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    opacity: 0;
    transform: translate3d(-6px, 0, 0);
  }
  .sf__ly-line.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__ly-tc {
    flex: none;
    font-size: var(--fs-11);
    color: var(--sf-hot);
    font-variant-numeric: tabular-nums;
  }
  .sf__ly-text {
    font-size: var(--fs-14);
    color: var(--text);
    line-height: var(--lh-snug);
  }

  /* (5) Загрузка */
  .sf__up-flow {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .sf__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    flex: none;
    width: 96px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface-2);
  }
  .sf.is-inview .sf__viz--upload.is-active .sf__card[data-up-card] {
    animation: sf-drop var(--dur-slow) var(--ease-soft) both;
  }
  @keyframes sf-drop {
    from {
      opacity: 0;
      transform: translate3d(0, -14px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .sf__card-ico {
    font-size: var(--fs-24);
    color: var(--text);
    line-height: 1;
  }
  .sf__card-name {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }
  .sf__dd-col {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1 1 200px;
  }
  .sf__hash,
  .sf__path {
    font-size: var(--fs-12);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .sf__hash-pre {
    color: var(--text-faint);
  }
  .sf__path {
    color: var(--text-secondary);
  }
  .sf__blob {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-1);
    flex: none;
    width: 116px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--sf-hot-line);
    border-radius: var(--r-sm);
    background: var(--surface);
    transition: transform var(--dur-med) var(--ease-spring);
  }
  .sf__blob.is-bump {
    transform: scale(1.05);
  }
  .sf__blob-cap {
    color: var(--text-muted);
  }
  .sf__blob-glyph {
    font-size: var(--fs-28);
    color: var(--sf-hot);
    line-height: 1;
  }
  .sf__refcount {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }
  .sf__refcount b {
    color: var(--sf-hot);
    font-size: var(--fs-15);
    font-variant-numeric: tabular-nums;
  }
  .sf__up-steps {
    font-size: var(--fs-12);
    color: var(--text-muted);
    opacity: 0.4;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .sf__up-steps.is-on {
    opacity: 1;
    color: var(--text-secondary);
  }

  /* (6) Воркер */
  .sf__wk-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sf__wk-asr {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    overflow-wrap: anywhere;
  }
  .sf__jobs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__job {
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__job[hidden] {
    display: none;
  }
  .sf__job:hover {
    border-color: var(--border-hover);
  }
  .sf__job.is-on {
    color: var(--text);
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__job-key {
    font-size: var(--fs-12);
  }
  .sf__job--more {
    color: var(--text);
    border-style: dashed;
    border-color: var(--sf-line);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
  }
  .sf__wk-desc {
    color: var(--text-secondary);
    min-height: 2.6em;
    line-height: var(--lh-normal);
  }

  /* пейджер-презентация */
  .sf__pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sf__pg-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--sf-line);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sf__pg-btn:hover {
    border-color: var(--text);
  }
  .sf__pg-btn:active {
    transform: scale(0.97);
  }
  .sf__pg-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__pg-btn--next {
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__dots {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--sp-2);
    align-items: center;
  }
  .sf__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: var(--bw-thin) solid var(--border-hover);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .sf__dot.is-on {
    background: var(--sf-hot);
    border-color: var(--sf-hot);
    transform: scale(1.3);
  }
  .sf__dot.is-done {
    background: var(--text-faint);
    border-color: var(--text-faint);
  }

  /* адаптив */
  @media (max-width: 760px) {
    .sf__layout {
      grid-template-columns: minmax(0, 1fr);
    }
    .sf__nav {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sf__tab {
      flex: 1 1 140px;
    }
    .sf__panel {
      padding: var(--sp-4);
    }
  }
  @media (max-width: 460px) {
    .sf__up-flow {
      flex-direction: column;
      align-items: stretch;
    }
    .sf__arrow {
      transform: rotate(90deg);
      align-self: center;
    }
    .sf__card,
    .sf__blob {
      width: 100%;
    }
  }

  /* reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .sf__viz.is-active,
    .sf__card[data-up-card],
    .sf__viz--listen.is-playing .sf__ls-fill {
      animation: none !important;
    }
    .sf__ls-fill {
      transform: scaleX(1);
    }
    .sf__ta-fill {
      transition: none;
    }
    .sf__ly-line,
    .sf__im-row {
      transition: none;
    }
  }
</style>

<script>
  /**
   * Объяснитель пользовательского flow .звук. Селектор табов + одна сцена с
   * шестью иллюстрациями (видна активная). Нет вечного rAF: автоплей ведут
   * CSS-анимации + setTimeout через трекер later(), который ОЧИЩАЕТСЯ за кадром
   * / на скрытой вкладке / при pagehide. Всё гейтится IntersectionObserver. При
   * prefers-reduced-motion - финальное статичное состояние, интеракции работают.
   */
  (() => {
    const root = document.querySelector<HTMLElement>("[data-sf]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.dataset.locale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-sf-tab]"));
    const titleEl = root.querySelector<HTMLElement>("[data-sf-title]");
    const descEl = root.querySelector<HTMLElement>("[data-sf-desc]");
    const vizEls = Array.from(root.querySelectorAll<HTMLElement>("[data-sf-viz]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-sf-dot]"));
    dots.forEach((d, k) => d.classList.toggle("is-on", k === 0));

    type Copy = { id: string; title: string; desc: string };
    const copy: Copy[] = [
      {
        id: "signin",
        title: tr("Вход без пароля", "Passwordless sign-in"),
        desc: tr(
          "Два способа войти без пароля. Telegram - в один тап: Mini App открывается поверх уже существующей сессии Telegram. Или по почте: приходит magic link - одноразовая ссылка с коротким сроком жизни, по которой вы сразу внутри.",
          "Two passwordless ways in. Telegram - one tap: the Mini App opens over your existing Telegram session. Or by email: a magic link arrives - a one-time, short-lived link that signs you straight in.",
        ),
      },
      {
        id: "taste",
        title: tr("Настройка рекомендаций", "Set up recommendations"),
        desc: tr(
          "Отметьте, что любите - жанры и настроения. Из выбора собирается ваша «башня» из 128 чисел (128d): вектор вкуса, по близости которого к векторам треков и подбирается лента «для вас». Чем больше отмечено, тем точнее старт.",
          "Mark what you like - genres and moods. Your choices build your 128-number 'tower' (128d): a taste vector whose closeness to track vectors drives your 'for you' feed. The more you mark, the sharper the start.",
        ),
      },
      {
        id: "import",
        title: tr("Импорт треков из источников", "Import tracks from sources"),
        desc: tr(
          "Подтяните музыку из SoundCloud, YouTube или Bandcamp - ссылкой или целым каталогом артиста. Под капотом задача soundcloud_rpc тянет треки через yt-dlp и синхронизирует их в ваш каталог, без ручной заливки по одному.",
          "Pull music from SoundCloud, YouTube or Bandcamp - by link or a whole artist catalog. Under the hood a soundcloud_rpc job fetches tracks via yt-dlp and syncs them into your library, with no manual one-by-one upload.",
        ),
      },
      {
        id: "listen",
        title: tr("Прослушивание с лирикой", "Listening with lyrics"),
        desc: tr(
          "Трек играет адаптивным HLS - качество подстраивается под сеть. Лирика всплывает сама, строчка за строчкой в такт: Demucs (--two-stems=vocals) снимает вокал, faster-whisper его расшифровывает, а выравнивание ставит тайм-код каждой строке.",
          "A track plays as adaptive HLS - quality adapts to the network. Lyrics surface on their own, line by line in time: Demucs (--two-stems=vocals) lifts the vocals, faster-whisper transcribes them, and alignment timestamps each line.",
        ),
      },
      {
        id: "upload",
        title: tr("Загрузка своего трека", "Upload your own track"),
        desc: tr(
          "Кидаете файл прямо в чат с ботом. Сервер берёт SHA-256 от содержимого - это и ключ дедупа, и часть пути в хранилище: одинаковый трек хранится один раз, повторная заливка лишь увеличивает ref_count. Дальше воркер сам делает лирику, и трек в каталоге.",
          "You drop a file right into the bot chat. The server hashes the content with SHA-256 - both the dedup key and part of the storage path: an identical track is stored once, a re-upload only bumps ref_count. Then the worker makes lyrics itself, and the track lands in the catalog.",
        ),
      },
      {
        id: "worker",
        title: tr("Что воркер делает с треком", "What the worker does with a track"),
        desc: tr(
          "Тяжёлое считает отдельный GPU-воркер без открытых портов. Из одной очереди он тянет 17 типов задач - от эмбеддингов и похожих треков до транскода в HLS, волны, превью и импорта. Плюс отдельный ASR-конвейер (Demucs + faster-whisper) для лирики. Тапните задачу - покажу, что она делает.",
          "Heavy work runs on a separate GPU worker with no open ports. From one queue it pulls 17 job types - from embeddings and similar tracks to HLS transcoding, waveform, snippet and import. Plus a dedicated ASR pipeline (Demucs + faster-whisper) for lyrics. Tap a job to see what it does.",
        ),
      },
    ];

    // ---- инфраструктура таймеров ----
    let inview = false;
    const timers: number[] = [];
    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };
    const D = (ms: number): number => (reduced ? 0 : ms);

    // ---- акцентный цвет (для конфети) ----
    const probe = document.createElement("span");
    probe.style.cssText = "color:var(--project-accent);position:absolute;opacity:0";
    root.appendChild(probe);
    const accent = getComputedStyle(probe).color || "rgb(150,150,170)";
    probe.remove();

    // ---- фуллскрин-конфети: одноразовый, чистится сам ----
    const confetti = (): void => {
      if (reduced) return;
      const cv = document.createElement("canvas");
      cv.setAttribute("aria-hidden", "true");
      cv.style.cssText = "position:fixed;inset:0;pointer-events:none;z-index:80";
      const cc = cv.getContext("2d");
      if (!cc) return;
      document.body.appendChild(cv);
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      cv.width = Math.round(vw * dpr);
      cv.height = Math.round(vh * dpr);
      cc.scale(dpr, dpr);
      const palette = [accent, "#ffffff", "#d8dbe6", "#aab0bd"];
      type Cf = { x: number; y: number; vx: number; vy: number; rot: number; vr: number; s: number; c: string };
      const cfs: Cf[] = Array.from({ length: 150 }, (_, i) => ({
        x: vw / 2 + (Math.random() - 0.5) * vw * 0.55,
        y: vh * 0.28 + (Math.random() - 0.5) * 70,
        vx: (Math.random() - 0.5) * 9,
        vy: Math.random() * -11 - 4,
        rot: Math.random() * Math.PI,
        vr: (Math.random() - 0.5) * 0.4,
        s: 5 + Math.random() * 6,
        c: palette[i % palette.length] ?? "#ffffff",
      }));
      let frame = 0;
      const tick = (): void => {
        frame += 1;
        cc.clearRect(0, 0, vw, vh);
        for (const p of cfs) {
          p.vy += 0.34;
          p.vx *= 0.99;
          p.x += p.vx;
          p.y += p.vy;
          p.rot += p.vr;
          cc.save();
          cc.translate(p.x, p.y);
          cc.rotate(p.rot);
          cc.globalAlpha = Math.max(0, 1 - frame / 150);
          cc.fillStyle = p.c;
          cc.fillRect(-p.s / 2, -p.s / 2, p.s, p.s * 0.6);
          cc.restore();
        }
        if (frame < 150) requestAnimationFrame(tick);
        else cv.remove();
      };
      requestAnimationFrame(tick);
    };

    // ============ (1) ВХОД ============
    const siNote = root.querySelector<HTMLElement>("[data-si-note]");
    const siPanes = Array.from(root.querySelectorAll<HTMLElement>("[data-si-pane]"));
    const siMethodBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-si-method]"));
    const siTg = root.querySelector<HTMLButtonElement>("[data-si-tg]");
    const siSend = root.querySelector<HTMLButtonElement>("[data-si-send]");
    const siLink = root.querySelector<HTMLElement>("[data-si-link]");
    const siOpen = root.querySelector<HTMLButtonElement>("[data-si-open]");

    const setNote = (el: HTMLElement | null, txt: string): void => {
      if (el) el.textContent = txt;
    };

    siMethodBtns.forEach((b) => {
      b.addEventListener("click", () => {
        const m = b.dataset.siMethod ?? "tg";
        siMethodBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", on ? "true" : "false");
        });
        siPanes.forEach((p) => {
          p.hidden = p.dataset.siPane !== m;
        });
        setNote(siNote, tr("выберите способ входа", "choose how to sign in"));
      });
    });
    siTg?.addEventListener("click", () => {
      setNote(siNote, tr("вошли через сессию Telegram - один тап, без пароля", "signed in via the Telegram session - one tap, no password"));
      confetti();
    });
    siSend?.addEventListener("click", () => {
      if (siLink) siLink.hidden = false;
      setNote(siNote, tr("magic link отправлен на почту", "magic link sent to your email"));
    });
    siOpen?.addEventListener("click", () => {
      setNote(siNote, tr("вошли по magic link - ссылка погашена", "signed in by magic link - link burned"));
      confetti();
    });

    // ============ (2) ВКУС ============
    const taChips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ta-chip]"));
    const taFill = root.querySelector<HTMLElement>("[data-ta-fill]");
    const taCount = root.querySelector<HTMLElement>("[data-ta-count]");
    const taNote = root.querySelector<HTMLElement>("[data-ta-note]");
    let taSel = 0;

    const taSync = (): void => {
      if (taFill) taFill.style.transform = `scaleX(${Math.min(1, taSel / 6).toFixed(3)})`;
      if (taCount) taCount.textContent = `${taSel} ${tr("выбрано", "selected")}`;
      if (taNote) {
        taNote.textContent =
          taSel >= 3
            ? tr("подбор настроен - лента «для вас» готова", "tuned - your 'for you' feed is ready")
            : tr("отметьте хотя бы 3", "mark at least 3");
      }
    };
    taChips.forEach((c) => {
      c.addEventListener("click", () => {
        const on = c.getAttribute("aria-pressed") === "true";
        c.setAttribute("aria-pressed", on ? "false" : "true");
        c.classList.toggle("is-on", !on);
        taSel += on ? -1 : 1;
        if (taSel < 0) taSel = 0;
        taSync();
      });
    });

    // ============ (3) ИМПОРТ ============
    const imSrcBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-im-src]"));
    const imRows = Array.from(root.querySelectorAll<HTMLElement>("[data-im-row]"));
    const imGo = root.querySelector<HTMLButtonElement>("[data-im-go]");
    const imNote = root.querySelector<HTMLElement>("[data-im-note]");

    imSrcBtns.forEach((b) => {
      b.addEventListener("click", () => {
        imSrcBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", on ? "true" : "false");
        });
      });
    });
    const runImport = (): void => {
      clearTimers();
      imRows.forEach((r) => r.classList.remove("is-in"));
      if (imGo) imGo.disabled = true;
      if (imNote) imNote.textContent = tr("тянем через yt-dlp…", "fetching via yt-dlp…");
      imRows.forEach((r, i) => {
        later(() => r.classList.add("is-in"), D(260) * (i + 1));
      });
      later(() => {
        if (imNote) imNote.textContent = tr("синхронизировано в каталог", "synced into the catalog");
        if (imGo) imGo.disabled = false;
      }, D(260) * (imRows.length + 1));
    };
    imGo?.addEventListener("click", runImport);

    // ============ (4) СЛУШАТЬ ============
    const lsViz = root.querySelector<HTMLElement>("[data-sf-viz='listen']");
    const lsLines = Array.from(root.querySelectorAll<HTMLElement>("[data-ls-line]"));
    const lsPlay = root.querySelector<HTMLButtonElement>("[data-ls-play]");
    let lsPlaying = false;

    const lsStop = (): void => {
      lsPlaying = false;
      lsViz?.classList.remove("is-playing");
      lsLines.forEach((l) => l.classList.remove("is-in"));
      if (lsPlay) {
        lsPlay.setAttribute("aria-pressed", "false");
        lsPlay.textContent = tr("Играть", "Play");
      }
    };
    const lsStart = (): void => {
      clearTimers();
      lsLines.forEach((l) => l.classList.remove("is-in"));
      lsViz?.classList.remove("is-playing");
      // рестарт CSS-анимации полосы прогресса
      void lsViz?.offsetWidth;
      lsViz?.classList.add("is-playing");
      lsPlaying = true;
      if (lsPlay) {
        lsPlay.setAttribute("aria-pressed", "true");
        lsPlay.textContent = tr("Пауза", "Pause");
      }
      lsLines.forEach((l, i) => {
        later(() => l.classList.add("is-in"), D(400) + D(1500) * i);
      });
    };
    lsPlay?.addEventListener("click", () => {
      if (lsPlaying) lsStop();
      else lsStart();
    });

    // ============ (5) ЗАГРУЗКА ============
    const upRef = root.querySelector<HTMLElement>("[data-up-ref]");
    const upBlob = root.querySelector<HTMLElement>("[data-up-blob]");
    const upSteps = root.querySelector<HTMLElement>("[data-up-steps]");
    const upGo = root.querySelector<HTMLButtonElement>("[data-up-go]");
    const upAgain = root.querySelector<HTMLButtonElement>("[data-up-again]");
    const upNote = root.querySelector<HTMLElement>("[data-up-note]");
    let upRc = 1;

    const upRun = (): void => {
      clearTimers();
      if (upGo) upGo.disabled = true;
      if (upSteps) upSteps.classList.remove("is-on");
      if (upNote) upNote.textContent = "";
      later(() => {
        if (upSteps) upSteps.classList.add("is-on");
        if (upAgain) upAgain.disabled = false;
        if (upGo) upGo.disabled = false;
      }, D(700));
    };
    const upBump = (): void => {
      upRc += 1;
      if (upRef) upRef.textContent = String(upRc);
      if (upBlob) {
        upBlob.classList.add("is-bump");
        later(() => upBlob.classList.remove("is-bump"), D(220));
      }
      if (upNote) upNote.textContent = tr("тот же хэш → ref_count++, новый blob НЕ создаётся", "same hash → ref_count++, no new blob created");
    };
    upGo?.addEventListener("click", upRun);
    upAgain?.addEventListener("click", upBump);

    // ============ (6) ВОРКЕР ============
    const wkJobs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-wk-job]"));
    const wkMore = root.querySelector<HTMLButtonElement>("[data-wk-more]");
    const wkDesc = root.querySelector<HTMLElement>("[data-wk-desc]");
    const wkMoreT = root.querySelector<HTMLElement>("[data-wk-more-t]");
    const wkMoreC = root.querySelector<HTMLElement>("[data-wk-more-c]");
    const wkExtra = wkJobs.filter((j) => j.hidden);
    let wkExpanded = false;

    wkMore?.addEventListener("click", () => {
      wkExpanded = !wkExpanded;
      wkExtra.forEach((j) => {
        j.hidden = !wkExpanded;
      });
      wkMore.setAttribute("aria-expanded", wkExpanded ? "true" : "false");
      if (wkMoreT) wkMoreT.textContent = wkExpanded ? tr("Свернуть", "Collapse") : tr("Показать все", "Show all");
      if (wkMoreC) wkMoreC.hidden = wkExpanded;
    });
    wkJobs.forEach((j) => {
      j.addEventListener("click", () => {
        wkJobs.forEach((x) => {
          x.classList.remove("is-on");
          x.setAttribute("aria-pressed", "false");
        });
        j.classList.add("is-on");
        j.setAttribute("aria-pressed", "true");
        if (wkDesc) wkDesc.textContent = j.dataset.desc ?? "";
      });
    });

    // ============ Автоплей при показе шага ============
    const autoplay = (id: string): void => {
      if (id === "import") {
        if (reduced) imRows.forEach((r) => r.classList.add("is-in"));
        else runImport();
      } else if (id === "listen") {
        if (reduced) lsLines.forEach((l) => l.classList.add("is-in"));
        else lsStart();
      } else if (id === "upload") {
        if (reduced && upSteps) upSteps.classList.add("is-on");
        else if (!reduced) later(() => upGo?.click(), D(250));
      }
    };

    // ============ Переключение табов ============
    let current = 0;
    const select = (i: number, focus: boolean): void => {
      const idx = Math.max(0, Math.min(tabs.length - 1, i));
      current = idx;
      clearTimers();
      lsStop();
      tabs.forEach((tab, k) => {
        const on = k === idx;
        tab.setAttribute("aria-selected", on ? "true" : "false");
        tab.tabIndex = on ? 0 : -1;
        if (on && focus) tab.focus();
      });
      const id = tabs[idx]?.dataset.id ?? "signin";
      vizEls.forEach((v) => {
        const on = v.dataset.sfViz === id;
        v.hidden = !on;
        v.classList.toggle("is-active", on);
      });
      const c = copy[idx];
      if (c) {
        if (titleEl) titleEl.textContent = c.title;
        if (descEl) descEl.textContent = c.desc;
      }
      dots.forEach((d, k) => {
        d.classList.toggle("is-on", k === idx);
        d.classList.toggle("is-done", k < idx);
      });
      if (inview) autoplay(id);
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(i, false));
      tab.addEventListener("keydown", (e: KeyboardEvent) => {
        let next = -1;
        if (e.key === "ArrowDown" || e.key === "ArrowRight") next = (current + 1) % tabs.length;
        else if (e.key === "ArrowUp" || e.key === "ArrowLeft") next = (current - 1 + tabs.length) % tabs.length;
        else if (e.key === "Home") next = 0;
        else if (e.key === "End") next = tabs.length - 1;
        if (next >= 0) {
          e.preventDefault();
          select(next, true);
        }
      });
    });

    const prevBtn = root.querySelector<HTMLButtonElement>("[data-sf-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-sf-next]");
    prevBtn?.addEventListener("click", () => select((current - 1 + tabs.length) % tabs.length, false));
    nextBtn?.addEventListener("click", () => select((current + 1) % tabs.length, false));

    // ============ IntersectionObserver-гейтинг ============
    const stopAll = (): void => {
      inview = false;
      clearTimers();
      lsStop();
      root.classList.remove("is-inview");
    };

    if (typeof IntersectionObserver === "undefined") {
      inview = true;
      root.classList.add("is-inview");
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            inview = e.isIntersecting;
            root.classList.toggle("is-inview", inview);
            if (!inview) {
              clearTimers();
              lsStop();
            } else {
              autoplay(tabs[current]?.dataset.id ?? "signin");
            }
          }
        },
        { threshold: 0.2 },
      );
      io.observe(root);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
