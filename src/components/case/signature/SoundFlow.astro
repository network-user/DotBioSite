---
/**
 * SoundFlow.astro — сигнатурная визуализация .звук (DotSound), флагман.
 *
 * Формат: интерактивный обзор ВОЗМОЖНОСТЕЙ ПЛАТФОРМЫ (не пользовательский flow).
 * Слева селектор из 7 доменов «что внутри» (по README DotSoundBackend), справа —
 * заголовок, описание и живая мини-схема. Монохром, акцент — единичная подсветка.
 *
 * Домены: Хранение (chunked + ClamAV + SHA-256 dedup) → Транскод (FFmpeg → HLS,
 * waveform, snippet) → Воспроизведение (адаптивный HLS + синхро-лирика) → Импорт
 * (yt-dlp, очередь) → Рекомендации (128d, миксы, радио) → Поиск (Elasticsearch
 * SAYT, транслит RU↔LAT) → Воркер (HMAC pull, 17 типов задач + ASR).
 *
 * Движение: только transform/opacity, конечные CSS-анимации (нет вечного rAF).
 * setTimeout через later(), очистка при смене вкладки / offscreen / pagehide.
 * IntersectionObserver (.sf.is-inview). prefers-reduced-motion → статичный кадр.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Не путь пользователя, а карта возможностей .звук — по блоку «что внутри» бэкенда. Выберите домен слева: справа живая схема и краткое описание сильной стороны. Тыкайте кнопки внутри — они показывают механику под капотом.",
  en: "Not a user journey but a map of what .звук can do — drawn from the backend's “what's inside” section. Pick a domain on the left: a live diagram and a short pitch appear on the right. Press the buttons inside to see the mechanics underneath.",
};

type Pillar = { id: string; label: Bi; tag: Bi; title: Bi; desc: Bi };
const pillars: Pillar[] = [
  {
    id: "storage",
    label: { ru: "Хранение", en: "Storage" },
    tag: { ru: "SHA-256 · MinIO", en: "SHA-256 · MinIO" },
