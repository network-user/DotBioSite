---

<section class="sf" data-sf aria-label={t({ ru: "Возможности платформы .звук", en: "DotSound platform capabilities" })}>
  <p class="sf__intro">{t(intro)}</p>

  <ul class="sf__statline" role="list" aria-hidden="true">
    <li class="sf__stat"><b>~30</b> {t({ ru: "доменов API", en: "API domains" })}</li>
    <li class="sf__stat"><b>~25</b> {t({ ru: "Taskiq-воркеров", en: "Taskiq workers" })}</li>
    <li class="sf__stat"><b>121</b> {t({ ru: "миграция", en: "migration" })}</li>
    <li class="sf__stat sf__stat--wide"><b>250</b> {t({ ru: "тест-файлов · 95% branch coverage", en: "test files · 95% branch coverage" })}</li>
  </ul>

  <div class="sf__layout">
    <div class="sf__nav" role="tablist" aria-label={t({ ru: "Домены", en: "Domains" })}>
      {
        pillars.map((s, i) => (
          <button
            class="sf__tab"
            type="button"
            role="tab"
            id={`sf-tab-${s.id}`}
            data-sf-tab={i}
            data-id={s.id}
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls="sf-panel"
            tabindex={i === 0 ? "0" : "-1"}
          >
            <span class="sf__tab-no mono" aria-hidden="true">{`0${i + 1}`}</span>
            <span class="sf__tab-body">
              <span class="sf__tab-label">{t(s.label)}</span>
              <span class="sf__tab-tag mono">{t(s.tag)}</span>
            </span>
          </button>
        ))
      }
    </div>

    <!-- ===================== ДЕТАЛЬНАЯ ПАНЕЛЬ ===================== -->
    <div class="sf__panel" id="sf-panel" role="tabpanel" aria-live="polite">
      <header class="sf__head">
        <h3 class="sf__title" data-sf-title>{t(pillars[0]!.title)}</h3>
        <p class="sf__desc body-sm" data-sf-desc>{t(pillars[0]!.desc)}</p>
      </header>

      <div class="sf__stage" data-sf-stage>
        <!-- ----------------- (1) ХРАНЕНИЕ ----------------- -->
        <div class="sf__viz sf__viz--storage is-active" data-sf-viz="storage">
          <div class="sf__up-flow">
            <div class="sf__card" data-st-card>
              <span class="sf__card-ico" aria-hidden="true">♪</span>
              <span class="sf__card-name mono">{t(storage.file)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__dd-col">
              <span class="sf__cap caption">{t(storage.scan)}</span>
              <span class="sf__cap caption">{t(storage.hashCap)}</span>
              <code class="sf__hash mono"><span class="sf__hash-pre">sha256:</span><span data-st-hash>a1f9…7e3c</span></code>
              <code class="sf__path mono" data-st-path>blobs/a1/a1f9…7e3c</code>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__blob" data-st-blob>
              <span class="sf__blob-cap caption">{t(storage.blobCap)}</span>
              <span class="sf__blob-glyph mono" aria-hidden="true">▢</span>
              <span class="sf__refcount mono">ref_count: <b data-st-ref>1</b></span>
            </div>
          </div>
          <p class="sf__up-steps mono" data-st-steps>{t(storage.steps)}</p>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-st-go>{t(storage.send)}</button>
            <button class="sf__act sf__act--ghost" type="button" data-st-again disabled>{t(storage.again)}</button>
            <span class="sf__viz-note mono" data-st-note></span>
          </div>
        </div>

        <!-- ----------------- (2) ТРАНСКОД ----------------- -->
        <div class="sf__viz sf__viz--pipeline" data-sf-viz="pipeline" hidden>
          <div class="sf__pl-flow">
            <div class="sf__pl-node" data-pl-node="raw">
              <span class="sf__pl-ico mono" aria-hidden="true">♪</span>
              <span class="sf__pl-label">{t(pipeline.raw)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__pl-node sf__pl-node--core" data-pl-node="ffmpeg">
              <span class="sf__pl-ico mono" aria-hidden="true">⚙</span>
              <span class="sf__pl-label">{t(pipeline.ffmpeg)}</span>
            </div>
            <span class="sf__arrow" aria-hidden="true"></span>
            <div class="sf__pl-out">
              {
                (
                  [
                    ["mp3", pipeline.mp3],
                    ["hls", pipeline.hls],
                    ["wave", pipeline.wave],
                    ["snippet", pipeline.snippet],
                    ["cover", pipeline.cover],
                  ] as const
                ).map(([id, label]) => (
                  <div class="sf__pl-chip" data-pl-out={id}>
                    <span class="mono">{t(label)}</span>
                  </div>
                ))
              }
            </div>
          </div>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-pl-go>{t(pipeline.go)}</button>
            <span class="sf__viz-note mono" data-pl-note></span>
          </div>
        </div>

        <!-- ----------------- (3) СТРИМИНГ ----------------- -->
        <div class="sf__viz sf__viz--listen" data-sf-viz="listen" hidden>
          <div class="sf__ls-card">
            <span class="sf__ls-cover" aria-hidden="true">♪</span>
            <div class="sf__ls-meta">
              <span class="sf__ls-title">{t(listen.title)}</span>
              <span class="sf__ls-artist">{t(listen.artist)}</span>
            </div>
            <span class="sf__ls-hls mono" aria-hidden="true">{t(listen.hls)}</span>
          </div>
          <div class="sf__ls-bar" data-ls-bar aria-hidden="true"><span class="sf__ls-fill" data-ls-fill></span></div>
          <div class="sf__ls-lyr" data-ls-stage data-ls-state="idle">
            <span class="sf__cap caption">{t(listen.lyrCap)}</span>
            <ol class="sf__ly-lines" data-ls-lines>
              {
                lyricLines.map((l, i) => (
                  <li class="sf__ly-line" data-ls-line={i}>
                    <span class="sf__ly-tc mono" aria-hidden="true">{l.tc}</span>
                    <span class="sf__ly-text">{locale === "en" ? l.en : l.ru}</span>
                  </li>
                ))
              }
            </ol>
          </div>
          <div class="sf__viz-controls">
            <button class="sf__act" type="button" data-ls-play aria-pressed="false">{t(listen.play)}</button>
          </div>
        </div>

        <!-- ----------------- (4) ИМПОРТ ----------------- -->
        <div class="sf__viz sf__viz--import" data-sf-viz="import" hidden>
          <div class="sf__im-sources" role="group" aria-label={t({ ru: "Источник", en: "Source" })}>
            {
              sources.map((s, i) => (
                <button class={`sf__chip${i === 0 ? " is-on" : ""}`} type="button" data-im-src={s.id} aria-pressed={i === 0 ? "true" : "false"}>
                  {t(s.name)}
                </button>
              ))
            }
          </div>
          <div class="sf__im-field">
            <span class="sf__cap caption">{t(importT.linkCap)}</span>
            <div class="sf__si-field">
              <input class="sf__si-input mono" type="text" value="soundcloud.com/seine/sets" data-im-input aria-label={t(importT.linkCap)} autocomplete="off" />
              <button class="sf__act" type="button" data-im-go>{t(importT.go)}</button>
            </div>
          </div>
          <ul class="sf__im-list" data-im-list>
            {
              importTracks.map((tr, i) => (
                <li class="sf__im-row" data-im-row={i}>
                  <span class="sf__im-dot" aria-hidden="true"></span>
                  <span class="sf__im-name">{t(tr)}</span>
                  <span class="sf__im-ok mono" aria-hidden="true">ok</span>
                </li>
              ))
            }
          </ul>
          <p class="sf__viz-note mono" data-im-note>{t(importT.done)}</p>
        </div>

        <!-- ----------------- (5) РЕКОМЕНДАЦИИ ----------------- -->
        <div class="sf__viz sf__viz--discover" data-sf-viz="discover" hidden>
          <span class="sf__cap caption">{t(discover.cap)}</span>
          <div class="sf__ta-chips" data-dc-chips>
            {
              tasteChips.map((c, i) => (
                <button class="sf__chip" type="button" data-dc-chip={i} aria-pressed="false">
                  {t(c)}
                </button>
              ))
            }
          </div>
          <div class="sf__ta-tower">
            <span class="sf__cap caption">{t(discover.towerCap)}</span>
            <div class="sf__ta-meter" aria-hidden="true"><span class="sf__ta-fill" data-dc-fill></span></div>
            <span class="sf__ta-count mono" data-dc-count>0 {t(discover.pick)}</span>
          </div>
          <span class="sf__cap caption">{t(discover.feedCap)}</span>
          <div class="sf__dc-feed" data-dc-feed>
            {
              feedSections.map((sec, i) => (
                <button class="sf__dc-card" type="button" data-dc-sec={i} data-note={t(sec.note)} aria-pressed="false" hidden>
                  <span class="sf__dc-label">{t(sec.label)}</span>
                  <span class="sf__dc-note mono">{t(sec.note)}</span>
                </button>
              ))
            }
          </div>
          <p class="sf__viz-note mono" data-dc-note>{t(discover.need)}</p>
        </div>

        <!-- ----------------- (6) ПОИСК ----------------- -->
        <div class="sf__viz sf__viz--search" data-sf-viz="search" hidden>
          <span class="sf__cap caption">{t(searchT.cap)}</span>
          <div class="sf__sr-field">
            <input class="sf__si-input mono" type="search" value={locale === "en" ? "kino" : "кин"} data-sr-input aria-label={t(searchT.cap)} autocomplete="off" />
            <button class="sf__chip is-on" type="button" data-sr-translit aria-pressed="true">{t(searchT.translit)}</button>
          </div>
          <span class="sf__sr-fuzzy mono">{t(searchT.fuzzy)}</span>
          <ul class="sf__sr-hits" data-sr-hits>
            {
              searchHits.map((h, i) => (
                <li class="sf__sr-row" data-sr-row={i} hidden>
                  <span class="sf__sr-title">{t(h.title)}</span>
                  <span class="sf__sr-sub">{t(h.sub)}</span>
                  <span class="sf__sr-via mono">{t(h.via)}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- ----------------- (7) ВОРКЕР ----------------- -->
        <div class="sf__viz sf__viz--worker" data-sf-viz="worker" hidden>
          <div class="sf__wk-head">
            <span class="sf__cap caption">{t(worker.cap)}</span>
            <span class="sf__wk-asr mono">{t(worker.asr)}</span>
          </div>
          <div class="sf__jobs" data-wk-jobs>
            {
              jobs.map((j, i) => (
                <button
                  class={`sf__job${i >= VISIBLE_JOBS ? " is-extra" : ""}`}
                  type="button"
                  data-wk-job={i}
                  data-desc={t(j.desc)}
                  aria-pressed="false"
                  hidden={i >= VISIBLE_JOBS}
                >
                  <span class="sf__job-key mono">{j.key}</span>
                </button>
              ))
            }
            <button class="sf__job sf__job--more" type="button" data-wk-more aria-expanded="false">
              <span data-wk-more-t>{t(worker.more)}</span>
              <span class="mono" data-wk-more-c>(+{jobs.length - VISIBLE_JOBS})</span>
            </button>
          </div>
          <p class="sf__wk-desc body-sm" data-wk-desc>{t(worker.pick)}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="sf__pager">
    <button class="sf__pg-btn sf__pg-btn--prev" type="button" data-sf-prev>
      <span aria-hidden="true">←</span> <span>{t(nav.prev)}</span>
    </button>
    <ol class="sf__dots" aria-hidden="true">
      {pillars.map((_, i) => <li class="sf__dot" data-sf-dot={i}></li>)}
    </ol>
    <button class="sf__pg-btn sf__pg-btn--next" type="button" data-sf-next>
      <span>{t(nav.next)}</span> <span aria-hidden="true">→</span>
    </button>
  </div>
</section>

<style>
  .sf {
    --sf-line: color-mix(in srgb, var(--text) 26%, transparent);
    --sf-soft: color-mix(in srgb, var(--text) 6%, transparent);
    --sf-hot: color-mix(in srgb, var(--project-accent) 60%, var(--text));
    --sf-hot-line: color-mix(in srgb, var(--project-accent) 46%, transparent);
    --sf-hot-soft: color-mix(in srgb, var(--project-accent) 14%, transparent);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .sf__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 68ch;
  }

  .sf__statline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-4);
  }
  .sf__stat {
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .sf__stat b {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .sf__stat--wide {
    flex: 1 1 220px;
  }

  .sf__layout {
    display: grid;
    grid-template-columns: minmax(170px, 0.7fr) minmax(0, 2fr);
    gap: var(--sp-4);
    align-items: start;
  }

  /* селектор */
  .sf__nav {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  .sf__tab {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    color: var(--text-secondary);
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .sf__tab:hover {
    border-color: var(--border-hover);
  }
  .sf__tab:active {
    transform: scale(0.99);
  }
  .sf__tab:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__tab[aria-selected="true"] {
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }
  .sf__tab-no {
    flex: none;
    font-size: var(--fs-12);
    color: var(--text-faint);
  }
  .sf__tab[aria-selected="true"] .sf__tab-no {
    color: var(--sf-hot);
  }
  .sf__tab-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .sf__tab-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-14);
    color: var(--text);
    letter-spacing: var(--ls-snug);
  }
  .sf__tab-tag {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    overflow-wrap: anywhere;
  }

  /* панель */
  .sf__panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-width: 0;
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 120% at 0% 0%, var(--sf-hot-soft), transparent 52%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }
  .sf__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-22);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--text);
  }
  .sf__desc {
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    max-width: 72ch;
  }

  .sf__stage {
    position: relative;
    min-width: 0;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
  }
  .sf__viz {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-width: 0;
  }
  .sf__viz[hidden] {
    display: none;
  }
  .sf.is-inview .sf__viz.is-active {
    animation: sf-fade var(--dur-med) var(--ease-soft) both;
  }
  @keyframes sf-fade {
    from {
      opacity: 0;
      transform: translate3d(0, 6px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .sf__cap {
    color: var(--text-muted);
  }
  .sf__viz-controls {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }
  .sf__act {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    flex: none;
    border: var(--bw-thin) solid var(--sf-line);
    border-radius: var(--r-pill);
    background: var(--sf-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sf__act:hover:not(:disabled) {
    border-color: var(--text);
  }
  .sf__act:active:not(:disabled) {
    transform: scale(0.96);
  }
  .sf__act:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sf__act:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .sf__act--ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text-secondary);
  }
  .sf__viz-note {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    line-height: var(--lh-normal);
    overflow-wrap: anywhere;
  }
  .sf__arrow {
    flex: none;
    width: 22px;
    height: 0;
    border-top: var(--bw-thin) solid var(--sf-line);
    position: relative;
    align-self: center;
  }
  .sf__arrow::after {
    content: "";
    position: absolute;
    right: -1px;
    top: -3px;
    width: 6px;
    height: 6px;
    border-top: var(--bw-thin) solid var(--sf-line);
    border-right: var(--bw-thin) solid var(--sf-line);
    transform: rotate(45deg);
  }

  /* чипы (вкус / источники) */
  .sf__chip {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__chip:hover {
    border-color: var(--border-hover);
  }
  .sf__chip.is-on {
    color: var(--text);
    border-color: var(--sf-hot-line);
    background: var(--sf-hot-soft);
  }

  /* (1) Вход */
  .sf__si-methods {
    display: inline-flex;
    gap: var(--sp-1);
    padding: 3px;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    width: max-content;
  }
  .sf__seg {
    min-height: calc(var(--tap-min) - 8px);
    padding: var(--sp-1) var(--sp-4);
    border: 0;
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease-standard), background-color var(--dur-fast) var(--ease-standard);
  }
  .sf__seg.is-on {
    color: var(--text);
    background: var(--sf-soft);
  }
  .sf__si-pane[hidden] {
    display: none;
  }
  .sf__si-tg {
    background: var(--sf-hot-soft);
    border-color: var(--sf-hot-line);
  }
  .sf__si-tg-ico {
    color: var(--sf-hot);
    font-size: var(--fs-16);
  }
  .sf__si-field {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .sf__si-input {
    flex: 1 1 180px;
    min-width: 0;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text);
    font-size: var(--fs-13);
  }
  .sf__si-input:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 1px;
    border-color: var(--sf-hot-line);
  }
  .sf__si-link {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-3);
  }
  .sf__si-link[hidden] {
    display: none;
  }
  .sf__si-token {
    font-size: var(--fs-12);
    color: var(--sf-hot);
    padding: var(--sp-1) var(--sp-2);
    border: var(--bw-thin) dashed var(--sf-hot-line);
    border-radius: var(--r-sm);
    overflow-wrap: anywhere;
  }

  /* (2) Вкус */
  .sf__ta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__ta-tower {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .sf__ta-meter {
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .sf__ta-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--sf-hot);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-slow) var(--ease-soft);
  }
  .sf__ta-count {
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }

  /* (3) Импорт */
  .sf__im-sources {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sf__im-field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__im-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 4em;
  }
  .sf__im-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
    opacity: 0;
    transform: translate3d(-8px, 0, 0);
  }
  .sf__im-row.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__im-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sf-hot);
  }
  .sf__im-name {
    font-size: var(--fs-13);
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sf__im-ok {
    font-size: var(--fs-11);
    color: var(--state-ok);
  }

  /* (4) Слушать */
  .sf__ls-card {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-sm);
    background: var(--surface-2);
  }
  .sf__ls-cover {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-xs);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    color: var(--text);
    font-size: var(--fs-18);
  }
  .sf__ls-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .sf__ls-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    color: var(--text);
  }
  .sf__ls-artist {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .sf__ls-hls {
    margin-left: auto;
    flex: none;
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .sf__ls-bar {
    height: 5px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .sf__ls-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--sf-hot);
    transform: scaleX(0);
    transform-origin: left center;
  }
  .sf__viz--listen.is-playing .sf__ls-fill {
    animation: sf-fill 12s linear forwards;
  }
  @keyframes sf-fill {
    to {
      transform: scaleX(1);
    }
  }
  .sf__ls-lyr {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sf__ly-lines {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-height: 5.6em;
  }
  .sf__ly-line {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    opacity: 0;
    transform: translate3d(-6px, 0, 0);
  }
  .sf__ly-line.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .sf__ly-tc {
    flex: none;
    font-size: var(--fs-11);
