  /* reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .sf__viz.is-active,
    .sf__card[data-st-card],
    .sf__viz--listen.is-playing .sf__ls-fill {
      animation: none !important;
    }
    .sf__ls-fill {
      transform: scaleX(1);
    }
    .sf__ta-fill {
      transition: none;
    }
    .sf__ly-line,
    .sf__im-row,
    .sf__dc-card,
    .sf__sr-row {
      transition: none;
    }
  }
</style>

<script>
  /**
   * Интерактивный обзор возможностей .звук (не user flow). Селектор доменов +
   * живая схема на каждый. setTimeout через later(), IntersectionObserver,
   * prefers-reduced-motion → статичный кадр.
   */
  (() => {
    const root = document.querySelector<HTMLElement>("[data-sf]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.dataset.locale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-sf-tab]"));
    const titleEl = root.querySelector<HTMLElement>("[data-sf-title]");
    const descEl = root.querySelector<HTMLElement>("[data-sf-desc]");
    const vizEls = Array.from(root.querySelectorAll<HTMLElement>("[data-sf-viz]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-sf-dot]"));
    dots.forEach((d, k) => d.classList.toggle("is-on", k === 0));

    type Copy = { id: string; title: string; desc: string };
    const copy: Copy[] = [
      {
        id: "storage",
        title: tr("Загрузка и content-addressed storage", "Upload and content-addressed storage"),
        desc: tr(
          "Chunked-загрузка (resumable, S3 multipart) с MIME-валидацией и ClamAV-сканом. Контент адресуется по SHA-256: одинаковый трек хранится один раз, повторная заливка лишь увеличивает ref_count. Пользовательские квоты, MinIO с дедупликацией.",
          "Chunked upload (resumable, S3 multipart) with MIME validation and a ClamAV scan. Content is addressed by SHA-256: an identical track is stored once, a re-upload only bumps ref_count. Per-user quotas, MinIO with deduplication.",
        ),
      },
      {
        id: "pipeline",
        title: tr("Транскодинг и деривативы", "Transcoding and derivatives"),
        desc: tr(
          "FFmpeg строит progressive MP3 и адаптивный HLS (две дорожки), нормализует громкость. На каждый трек — waveform (200 столбцов), сниппет-превью и процедурная обложка.",
          "FFmpeg builds progressive MP3 and adaptive HLS (two renditions) and normalizes loudness. Per track: a 200-bar waveform, a preview snippet, and a procedural cover.",
        ),
      },
      {
        id: "listen",
        title: tr("Воспроизведение и синхро-лирика", "Playback and synced lyrics"),
        desc: tr(
          "Presigned URL, range-стриминг, HLS с adaptive bitrate (hls.js). Лирика всплывает построчно в такт: Demucs (--two-stems=vocals) + faster-whisper. Prefetch следующих треков.",
          "Presigned URLs, range streaming, HLS with adaptive bitrate (hls.js). Lyrics surface line by line in sync: Demucs (--two-stems=vocals) + faster-whisper. Prefetch of next tracks.",
        ),
      },
      {
        id: "import",
        title: tr("Импорт из внешних источников", "Import from external sources"),
        desc: tr(
          "Импорт треков из SoundCloud, YouTube, Bandcamp — по ссылке или каталогом. Очередь с диспетчером и лимитами, backfill артистов, in-app уведомления RU/EN.",
          "Import tracks from SoundCloud, YouTube, Bandcamp — by link or catalog. A queued dispatcher with limits, artist backfill, in-app notifications in RU/EN.",
        ),
      },
      {
        id: "discover",
        title: tr("Персональная лента и миксы", "Personal feed and mixes"),
        desc: tr(
          "Главный экран (8–10 секций): Daily / Weekly Mix, жанровые миксы, радио (seed-first), похожие треки. Скоринг в приватном ядре; телеметрия impressions ↔ listen.",
          "Home screen (8–10 sections): Daily / Weekly Mix, genre mixes, radio (seed-first), similar tracks. Scoring in the private core; impressions ↔ listen telemetry.",
        ),
      },
      {
        id: "search",
        title: tr("Полнотекстовый поиск", "Full-text search"),
        desc: tr(
          "Elasticsearch 8: полнотекст, SAYT, транслитерация RU↔LAT, fuzzy. Индексируются метаданные и распознанная лирика — трек находится по строчке из песни.",
          "Elasticsearch 8: full-text, SAYT, RU↔LAT transliteration, fuzzy. Metadata and recognized lyrics are indexed — find a track by a line from the song.",
        ),
      },
      {
        id: "worker",
        title: tr("Compute-воркер без открытых портов", "Compute worker with no open ports"),
        desc: tr(
          "Pull-based протокол с HMAC и одноразовыми токенами. 17 типов задач в одной очереди + ASR-конвейер (Demucs + faster-whisper). Тапните задачу — покажу, что она делает.",
          "Pull-based protocol with HMAC and one-time tokens. 17 job types in one queue plus an ASR pipeline (Demucs + faster-whisper). Tap a job to see what it does.",
        ),
      },
    ];

    // ---- инфраструктура таймеров ----
    let inview = false;
    const timers: number[] = [];
    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };
    const D = (ms: number): number => (reduced ? 0 : ms);

    // ============ (1) ХРАНЕНИЕ ============
    const stRef = root.querySelector<HTMLElement>("[data-st-ref]");
    const stBlob = root.querySelector<HTMLElement>("[data-st-blob]");
    const stSteps = root.querySelector<HTMLElement>("[data-st-steps]");
    const stGo = root.querySelector<HTMLButtonElement>("[data-st-go]");
    const stAgain = root.querySelector<HTMLButtonElement>("[data-st-again]");
    const stNote = root.querySelector<HTMLElement>("[data-st-note]");
    let stRc = 1;

    const stRun = (): void => {
      clearTimers();
      if (stGo) stGo.disabled = true;
      if (stSteps) stSteps.classList.remove("is-on");
      if (stNote) stNote.textContent = "";
      later(() => {
        if (stSteps) stSteps.classList.add("is-on");
        if (stAgain) stAgain.disabled = false;
        if (stGo) stGo.disabled = false;
      }, D(700));
    };
    const stBump = (): void => {
      stRc += 1;
      if (stRef) stRef.textContent = String(stRc);
      if (stBlob) {
        stBlob.classList.add("is-bump");
        later(() => stBlob.classList.remove("is-bump"), D(220));
      }
      if (stNote) {
        stNote.textContent = tr(
          "тот же хэш → ref_count++, новый blob НЕ создаётся",
          "same hash → ref_count++, no new blob created",
        );
      }
    };
    stGo?.addEventListener("click", stRun);
    stAgain?.addEventListener("click", stBump);

    // ============ (2) ТРАНСКОД ============
    const plNodes = Array.from(root.querySelectorAll<HTMLElement>("[data-pl-node]"));
    const plOuts = Array.from(root.querySelectorAll<HTMLElement>("[data-pl-out]"));
    const plGo = root.querySelector<HTMLButtonElement>("[data-pl-go]");
    const plNote = root.querySelector<HTMLElement>("[data-pl-note]");

    const runPipeline = (): void => {
      clearTimers();
      plNodes.forEach((n) => n.classList.remove("is-on"));
      plOuts.forEach((o) => o.classList.remove("is-on"));
      if (plGo) plGo.disabled = true;
      if (plNote) plNote.textContent = "";
      const seq = [...plNodes, ...plOuts];
      seq.forEach((el, i) => {
        later(() => el.classList.add("is-on"), D(280) * (i + 1));
      });
      later(() => {
        if (plNote) {
          plNote.textContent = tr(
            "деривативы готовы — immutable сегменты",
            "derivatives ready — immutable segments",
          );
        }
        if (plGo) plGo.disabled = false;
      }, D(280) * (seq.length + 1));
    };
    plGo?.addEventListener("click", runPipeline);

    // ============ (3) ИМПОРТ ============
    const imSrcBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-im-src]"));
    const imRows = Array.from(root.querySelectorAll<HTMLElement>("[data-im-row]"));
    const imGo = root.querySelector<HTMLButtonElement>("[data-im-go]");
    const imNote = root.querySelector<HTMLElement>("[data-im-note]");

    imSrcBtns.forEach((b) => {
      b.addEventListener("click", () => {
        imSrcBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", on ? "true" : "false");
        });
      });
    });
    const runImport = (): void => {
      clearTimers();
      imRows.forEach((r) => r.classList.remove("is-in"));
      if (imGo) imGo.disabled = true;
      if (imNote) imNote.textContent = tr("тянем через yt-dlp…", "fetching via yt-dlp…");
      imRows.forEach((r, i) => {
        later(() => r.classList.add("is-in"), D(260) * (i + 1));
      });
      later(() => {
        if (imNote) imNote.textContent = tr("синхронизировано в каталог", "synced into the catalog");
        if (imGo) imGo.disabled = false;
      }, D(260) * (imRows.length + 1));
    };
    imGo?.addEventListener("click", runImport);

    // ============ (4) СЛУШАТЬ ============
    const lsViz = root.querySelector<HTMLElement>("[data-sf-viz='listen']");
    const lsLines = Array.from(root.querySelectorAll<HTMLElement>("[data-ls-line]"));
    const lsPlay = root.querySelector<HTMLButtonElement>("[data-ls-play]");
    let lsPlaying = false;

    const lsStop = (): void => {
      lsPlaying = false;
      lsViz?.classList.remove("is-playing");
      lsLines.forEach((l) => l.classList.remove("is-in"));
      if (lsPlay) {
        lsPlay.setAttribute("aria-pressed", "false");
        lsPlay.textContent = tr("Играть", "Play");
      }
    };
    const lsStart = (): void => {
      clearTimers();
      lsLines.forEach((l) => l.classList.remove("is-in"));
      lsViz?.classList.remove("is-playing");
      // рестарт CSS-анимации полосы прогресса
      void lsViz?.offsetWidth;
      lsViz?.classList.add("is-playing");
      lsPlaying = true;
      if (lsPlay) {
        lsPlay.setAttribute("aria-pressed", "true");
        lsPlay.textContent = tr("Пауза", "Pause");
      }
      lsLines.forEach((l, i) => {
        later(() => l.classList.add("is-in"), D(400) + D(1500) * i);
      });
    };
    lsPlay?.addEventListener("click", () => {
      if (lsPlaying) lsStop();
      else lsStart();
    });

    // ============ (5) РЕКОМЕНДАЦИИ ============
    const dcChips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dc-chip]"));
    const dcFill = root.querySelector<HTMLElement>("[data-dc-fill]");
    const dcCount = root.querySelector<HTMLElement>("[data-dc-count]");
    const dcNote = root.querySelector<HTMLElement>("[data-dc-note]");
    const dcCards = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dc-sec]"));
    let dcSel = 0;

    const dcSync = (): void => {
      if (dcFill) dcFill.style.transform = `scaleX(${Math.min(1, dcSel / 5).toFixed(3)})`;
      if (dcCount) dcCount.textContent = `${dcSel} ${tr("выбрано", "selected")}`;
      const showFeed = dcSel >= 2;
      dcCards.forEach((card, i) => {
        card.hidden = !showFeed;
        if (!showFeed) card.classList.remove("is-on");
        else later(() => {
          card.hidden = false;
        }, D(120) * i);
      });
      if (dcNote) {
        dcNote.textContent = showFeed
          ? tr("лента прогрета — impressions ↔ listen", "feed warmed — impressions ↔ listen")
          : tr("отметьте хотя бы 2 — появятся секции ленты", "mark at least 2 — feed sections appear");
      }
    };
    dcChips.forEach((c) => {
      c.addEventListener("click", () => {
        const on = c.getAttribute("aria-pressed") === "true";
        c.setAttribute("aria-pressed", on ? "false" : "true");
        c.classList.toggle("is-on", !on);
        dcSel += on ? -1 : 1;
        if (dcSel < 0) dcSel = 0;
        dcSync();
      });
    });
    dcCards.forEach((card) => {
      card.addEventListener("click", () => {
        dcCards.forEach((x) => {
          x.classList.remove("is-on");
          x.setAttribute("aria-pressed", "false");
        });
        card.classList.add("is-on");
        card.setAttribute("aria-pressed", "true");
      });
    });

    // ============ (6) ПОИСК ============
    const srInput = root.querySelector<HTMLInputElement>("[data-sr-input]");
    const srRows = Array.from(root.querySelectorAll<HTMLElement>("[data-sr-row]"));
    const srTranslit = root.querySelector<HTMLButtonElement>("[data-sr-translit]");

    const runSearch = (): void => {
      clearTimers();
      srRows.forEach((r) => {
        r.hidden = true;
      });
      srRows.forEach((r, i) => {
        later(() => {
          r.hidden = false;
        }, D(180) * (i + 1));
      });
    };
    srInput?.addEventListener("input", runSearch);
    srInput?.addEventListener("focus", runSearch);
    srTranslit?.addEventListener("click", () => {
      const on = srTranslit.getAttribute("aria-pressed") === "true";
      srTranslit.setAttribute("aria-pressed", on ? "false" : "true");
      srTranslit.classList.toggle("is-on", !on);
      runSearch();
    });

    // ============ (7) ВОРКЕР ============
    const wkJobs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-wk-job]"));
    const wkMore = root.querySelector<HTMLButtonElement>("[data-wk-more]");
    const wkDesc = root.querySelector<HTMLElement>("[data-wk-desc]");
    const wkMoreT = root.querySelector<HTMLElement>("[data-wk-more-t]");
    const wkMoreC = root.querySelector<HTMLElement>("[data-wk-more-c]");
    const wkExtra = wkJobs.filter((j) => j.hidden);
    let wkExpanded = false;

    wkMore?.addEventListener("click", () => {
      wkExpanded = !wkExpanded;
      wkExtra.forEach((j) => {
        j.hidden = !wkExpanded;
      });
      wkMore.setAttribute("aria-expanded", wkExpanded ? "true" : "false");
      if (wkMoreT) wkMoreT.textContent = wkExpanded ? tr("Свернуть", "Collapse") : tr("Показать все", "Show all");
      if (wkMoreC) wkMoreC.hidden = wkExpanded;
    });
    wkJobs.forEach((j) => {
      j.addEventListener("click", () => {
        wkJobs.forEach((x) => {
          x.classList.remove("is-on");
          x.setAttribute("aria-pressed", "false");
        });
        j.classList.add("is-on");
        j.setAttribute("aria-pressed", "true");
        if (wkDesc) wkDesc.textContent = j.dataset.desc ?? "";
      });
    });

    // ============ Автоплей при показе шага ============
    const autoplay = (id: string): void => {
      if (id === "storage") {
        if (reduced && stSteps) stSteps.classList.add("is-on");
        else if (!reduced) later(() => stGo?.click(), D(250));
      } else if (id === "pipeline") {
        if (reduced) {
          plNodes.forEach((n) => n.classList.add("is-on"));
          plOuts.forEach((o) => o.classList.add("is-on"));
        } else runPipeline();
      } else if (id === "import") {
        if (reduced) imRows.forEach((r) => r.classList.add("is-in"));
        else runImport();
      } else if (id === "listen") {
        if (reduced) lsLines.forEach((l) => l.classList.add("is-in"));
        else lsStart();
      } else if (id === "search") {
        if (reduced) srRows.forEach((r) => {
          r.hidden = false;
        });
        else runSearch();
      }
    };

    // ============ Переключение табов ============
    let current = 0;
    const select = (i: number, focus: boolean): void => {
      const idx = Math.max(0, Math.min(tabs.length - 1, i));
      current = idx;
      clearTimers();
      lsStop();
      tabs.forEach((tab, k) => {
        const on = k === idx;
        tab.setAttribute("aria-selected", on ? "true" : "false");
        tab.tabIndex = on ? 0 : -1;
        if (on && focus) tab.focus();
      });
      const id = tabs[idx]?.dataset.id ?? "storage";
      vizEls.forEach((v) => {
        const on = v.dataset.sfViz === id;
        v.hidden = !on;
        v.classList.toggle("is-active", on);
      });
      const c = copy[idx];
      if (c) {
        if (titleEl) titleEl.textContent = c.title;
        if (descEl) descEl.textContent = c.desc;
      }
      dots.forEach((d, k) => {
        d.classList.toggle("is-on", k === idx);
        d.classList.toggle("is-done", k < idx);
      });
      if (inview) autoplay(id);
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(i, false));
      tab.addEventListener("keydown", (e: KeyboardEvent) => {
        let next = -1;
        if (e.key === "ArrowDown" || e.key === "ArrowRight") next = (current + 1) % tabs.length;
        else if (e.key === "ArrowUp" || e.key === "ArrowLeft") next = (current - 1 + tabs.length) % tabs.length;
        else if (e.key === "Home") next = 0;
        else if (e.key === "End") next = tabs.length - 1;
        if (next >= 0) {
          e.preventDefault();
          select(next, true);
        }
      });
    });

    const prevBtn = root.querySelector<HTMLButtonElement>("[data-sf-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-sf-next]");
    prevBtn?.addEventListener("click", () => select((current - 1 + tabs.length) % tabs.length, false));
    nextBtn?.addEventListener("click", () => select((current + 1) % tabs.length, false));

    // ============ IntersectionObserver-гейтинг ============
    const stopAll = (): void => {
      inview = false;
      clearTimers();
      lsStop();
      root.classList.remove("is-inview");
    };

    if (typeof IntersectionObserver === "undefined") {
      inview = true;
      root.classList.add("is-inview");
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            inview = e.isIntersecting;
            root.classList.toggle("is-inview", inview);
            if (!inview) {
              clearTimers();
              lsStop();
            } else {
              autoplay(tabs[current]?.dataset.id ?? "storage");
            }
          }
        },
        { threshold: 0.2 },
      );
      io.observe(root);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
