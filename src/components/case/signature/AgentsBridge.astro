---
/**
 * AgentsBridge.astro - сигнатурная визуализация .агенты (DotAgents).
 *
 * Концепт: ТЕЛЕФОН КАК ПУЛЬТ. Одна понятная петля для обычного человека:
 * AI-агент на твоей машине тянется к рискованной команде → хук ставит его на
 * паузу → телефон спрашивает → ты жмёшь Allow / Deny (или молчишь) → результат
 * сразу виден на стороне агента. Никаких двух селекторов сразу: на главном
 * экране одно действие. Режимы демона (remote / readonly / standby) и
 * security-инварианты вынесены в сворачиваемый блок «Режимы и безопасность» -
 * кто хочет, докопается до механики, остальным не мешает.
 *
 * Fail-closed показан без авто-таймера, который «сам всё решает»: тишина
 * демонстрируется явной кнопкой «Ничего не делать», так пользователь остаётся
 * хозяином демо. Авто-allow/deny включаются только когда сам переключишь режим.
 *
 * Перф: только transform/opacity, конечные CSS-переходы (нет вечного rAF).
 * Тайминги - один setTimeout-конвейер later() с очисткой офскрин / на скрытой
 * вкладке / при pagehide. Всё под IntersectionObserver (.ab.is-inview).
 * prefers-reduced-motion → финальный статичный кадр, интеракции работают.
 *
 * Факты сверены по репозиторию DotAgents:
 *  - hook before_shell / before_mcp → long-poll до 270 c, ошибка/таймаут = deny.
 *  - режимы AFK: remote (спрашивать), readonly (авто-allow), standby (авто-deny).
 *  - argon2id passcode, HMAC-SHA256 + одноразовый nonce на callback, owner-only,
 *    audit-log, uvicorn только на 127.0.0.1, env чистится от секретов при спавне.
 *  - 3 агента: claude-code (stream-json), cursor-agent, antigravity (заглушка).
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "AI-агент работает прямо на твоей машине. Стоит ему потянуться к рискованной команде - хук DotAgents ставит его на паузу и спрашивает тебя в Telegram. Выбери, что агент пытается сделать, и реши за него. Промолчишь - откажет само.",
  en: "An AI agent runs right on your machine. The moment it reaches for a risky command, the DotAgents hook pauses it and asks you in Telegram. Pick what the agent is attempting and decide for it. Stay silent and it auto-denies.",
};

// --- Сценарии: что агент пытается сделать. Тексты локализованы на build-time и
//     уезжают в data-* на чипах; скрипт читает активный чип. ---
type Scenario = {
  id: string;
  label: Bi; // человеческий ярлык на чипе
  intent: Bi; // что агент «говорит», что делает
  cmd: string; // сама команда
  kind: Bi; // shell / MCP
  risk: "high" | "critical";
  riskLabel: Bi; // словами
  why: Bi; // почему это опасно, простым языком (на телефоне)
  allow: Bi; // последствие allow на стороне агента
  deny: Bi; // последствие deny на стороне агента
};

const scenarios: Scenario[] = [
  {
    id: "clean",
    label: { ru: "Удалить сборку", en: "Delete the build" },
    intent: { ru: "Чищу артефакты сборки", en: "Cleaning up build artifacts" },
    cmd: "rm -rf dist/",
    kind: { ru: "shell", en: "shell" },
    risk: "high",
    riskLabel: { ru: "рискованно", en: "risky" },
    why: {
      ru: "Снесёт папку целиком, мимо корзины - не вернуть.",
      en: "Wipes the whole folder, no recycle bin - unrecoverable.",
    },
    allow: {
      ru: "dist/ удалена - агент продолжил сборку.",
      en: "dist/ removed - the agent continued the build.",
    },
    deny: {
      ru: "Команда отклонена - агент пошёл дальше без неё.",
      en: "Call denied - the agent moved on without it.",
    },
  },
  {
    id: "force",
    label: { ru: "Переписать main", en: "Rewrite main" },
    intent: { ru: "Поправил коммит, пушу в main", en: "Amended the commit, pushing to main" },
    cmd: "git push --force origin main",
    kind: { ru: "shell", en: "shell" },
    risk: "high",
    riskLabel: { ru: "рискованно", en: "risky" },
    why: {
      ru: "Перезапишет общую ветку main у всей команды.",
      en: "Overwrites the shared main branch for everyone.",
    },
    allow: { ru: "Force-push ушёл в main.", en: "Force-push landed on main." },
    deny: {
      ru: "Пуш отклонён - история main цела.",
      en: "Push denied - main's history is intact.",
    },
  },
  {
    id: "secret",
    label: { ru: "Прочитать .env", en: "Read .env" },
    intent: {
      ru: "Смотрю строку подключения к базе",
      en: "Checking the database connection string",
    },
    cmd: 'read_file(".env")',
    kind: { ru: "MCP", en: "MCP" },
    risk: "critical",
    riskLabel: { ru: "критично", en: "critical" },
    why: {
      ru: "Это файл с паролями и ключами - уедет в контекст модели.",
      en: "That's the secrets file - it would leak into the model's context.",
    },
    allow: {
      ru: "Файл прочитан - секреты попали в контекст.",
      en: "File read - secrets entered the context.",
    },
    deny: { ru: "Доступ к секретам заблокирован.", en: "Access to the secrets blocked." },
  },
];

// --- Режимы демона (вынесены в «Режимы и безопасность»). ---
const modes: { id: string; label: string; gloss: Bi }[] = [
  { id: "remote", label: "remote", gloss: { ru: "спрашивает каждый раз", en: "asks every time" } },
  {
    id: "readonly",
    label: "readonly",
    gloss: { ru: "сам разрешает, только шлёт уведомление", en: "auto-allows, just notifies" },
  },
  {
    id: "standby",
    label: "standby",
    gloss: { ru: "сам отклоняет всё опасное", en: "auto-denies anything risky" },
  },
];

const securityChips: Bi[] = [
  { ru: "passcode argon2id", en: "argon2id passcode" },
  { ru: "HMAC + одноразовый nonce", en: "HMAC + one-shot nonce" },
  { ru: "только владелец", en: "owner-only" },
  { ru: "audit-log решений", en: "audit log of decisions" },
  { ru: "API только 127.0.0.1", en: "API on 127.0.0.1 only" },
  { ru: "env без секретов при спавне", en: "env stripped on spawn" },
];

const stats: Bi[] = [
  { ru: "19k+ строк", en: "19k+ lines" },
  { ru: "132 теста", en: "132 tests" },
  { ru: "3 миграции", en: "3 migrations" },
  { ru: "long-poll 270 c", en: "270s long-poll" },
];

const ui = {
  pickCap: { ru: "Что агент пытается сделать:", en: "What the agent is attempting:" },
  agentName: { ru: "Claude Code · сессия #a3f1", en: "Claude Code · session #a3f1" },
  stPaused: { ru: "на паузе", en: "paused" },
  stRunning: { ru: "выполняет", en: "running" },
  stBlocked: { ru: "заблокирован", en: "blocked" },
  link: { ru: "перехвачено хуком", en: "caught by the hook" },
  botName: { ru: "DotAgents", en: "DotAgents" },
  you: { ru: "твой телефон", en: "your phone" },
  ask: { ru: "Разрешить вызов?", en: "Allow this call?" },
  allow: { ru: "Allow", en: "Allow" },
  deny: { ru: "Deny", en: "Deny" },
  ignore: { ru: "Ничего не делать", en: "Do nothing" },
  ignoreHint: { ru: "тишина → deny через ~4½ мин", en: "silence → deny in ~4½ min" },
  outAllow: { ru: "✓ Разрешено", en: "✓ Allowed" },
  outDeny: { ru: "✕ Заблокировано", en: "✕ Blocked" },
  outTimeout: { ru: "Тишина → deny (fail-closed)", en: "Silence → deny (fail-closed)" },
  invariant: {
    ru: "Канал управления уходит в Telegram. Код, approvals и transcript остаются на машине - API слушает только 127.0.0.1.",
    en: "The control channel goes to Telegram. Code, approvals and transcript stay on the machine - the API listens on 127.0.0.1 only.",
  },
  underLabel: { ru: "Режимы и безопасность", en: "Modes & security" },
  modeTitle: { ru: "Режим демона", en: "Daemon mode" },
  modeNote: {
    ru: "Меняет, как решается тот же запрос.",
    en: "Changes how the same request resolves.",
  },
  noteRemote: {
    ru: "remote: решаешь ты - кнопками на телефоне.",
    en: "remote: you decide - with the phone buttons.",
  },
  noteReadonly: {
    ru: "readonly разрешил сам и просто уведомил.",
    en: "readonly allowed it and just notified you.",
  },
  noteStandby: {
    ru: "standby отклонил сам, ничего не спрашивая.",
    en: "standby denied it without asking.",
  },
  secTitle: { ru: "Безопасность", en: "Security" },
};
---

<section
  class="ab"
  data-ab
  data-locale={locale}
  aria-label={t({ ru: "Интерактивное демо DotAgents", en: "DotAgents interactive demo" })}
>
  <p class="ab__intro">{t(intro)}</p>

  <!-- ============== ВЫБОР СЦЕНАРИЯ ============== -->
  <div class="ab__pick">
    <span class="ab__pick-cap caption">{t(ui.pickCap)}</span>
    <div class="ab__chips" role="group" aria-label={t(ui.pickCap)}>
      {
        scenarios.map((s, i) => (
          <button
            class={`ab__chip${i === 0 ? " is-on" : ""}`}
            type="button"
            data-ab-chip={s.id}
            data-cmd={s.cmd}
            data-kind={t(s.kind)}
            data-risk={s.risk}
            data-risk-label={t(s.riskLabel)}
            data-intent={t(s.intent)}
            data-why={t(s.why)}
            data-allow={t(s.allow)}
            data-deny={t(s.deny)}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <span class={`ab__chip-dot ab__chip-dot--${s.risk}`} aria-hidden="true" />
            <span class="ab__chip-label">{t(s.label)}</span>
          </button>
        ))
      }
    </div>
  </div>

  <!-- ============== СЦЕНА: агент → телефон ============== -->
  <div class="ab__stage" data-stage data-state="pending" data-mode="remote">
    <!-- агент на машине -->
    <div class="ab__agent" data-agent>
      <div class="ab__agent-head">
        <span class="ab__agent-dot" aria-hidden="true"></span>
        <span class="ab__agent-name mono">{t(ui.agentName)}</span>
        <span class="ab__agent-state mono" data-agent-state aria-live="polite"
          >{t(ui.stPaused)}</span
        >
      </div>
      <p class="ab__agent-intent" data-agent-intent>{t(scenarios[0]!.intent)}</p>
      <code class="ab__agent-cmd mono">
        <span class="ab__agent-prompt" aria-hidden="true">$ </span><span data-agent-cmd
          >{scenarios[0]!.cmd}</span
        ><span class="ab__caret" aria-hidden="true"></span>
      </code>
      <p class="ab__agent-out" data-agent-out hidden></p>
    </div>

    <!-- связка: перехват уходит в телефон -->
    <div class="ab__link" aria-hidden="true">
      <span class="ab__link-line"></span>
      <span class="ab__link-tag mono">{t(ui.link)}</span>
      <span class="ab__link-arrow"></span>
    </div>

    <!-- телефон-герой -->
    <div class="ab__phone-wrap">
      <div class="ab__phone">
        <div class="ab__phone-top" aria-hidden="true"><span class="ab__notch"></span></div>
        <div class="ab__phone-screen">
          <div class="ab__phone-bar">
            <span class="ab__ava" aria-hidden="true">⬡</span>
            <span class="ab__bot mono">{t(ui.botName)}</span>
            <span class="ab__you mono">{t(ui.you)}</span>
          </div>

          <div class="ab__msg" data-msg data-state="pending">
            <p class="ab__msg-ask">{t(ui.ask)}</p>
            <code class="ab__msg-cmd mono" data-msg-cmd>{scenarios[0]!.cmd}</code>
            <p class="ab__msg-meta mono">
              <span data-msg-kind>{t(scenarios[0]!.kind)}</span>
              <span class="ab__msg-sep" aria-hidden="true">·</span>
              <span class={`ab__msg-risk ab__msg-risk--${scenarios[0]!.risk}`} data-msg-risk
                >{t(scenarios[0]!.riskLabel)}</span
              >
            </p>
            <p class="ab__msg-why" data-msg-why>{t(scenarios[0]!.why)}</p>

            <div class="ab__btns">
              <button type="button" class="ab__btn ab__btn--allow" data-act="allow"
                >✓ {t(ui.allow)}</button
              >
              <button type="button" class="ab__btn ab__btn--deny" data-act="deny"
                >✕ {t(ui.deny)}</button
              >
            </div>
            <button type="button" class="ab__ignore" data-act="ignore">
              <span class="ab__ignore-label">{t(ui.ignore)}</span>
              <span class="ab__ignore-hint mono">{t(ui.ignoreHint)}</span>
            </button>

            <p class="ab__msg-out mono" data-msg-out aria-live="polite" hidden></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============== ИНВАРИАНТ ============== -->
  <p class="ab__inv">
    <span class="ab__inv-dot" aria-hidden="true"></span>
    {t(ui.invariant)}
  </p>

  <!-- ============== РЕЖИМЫ И БЕЗОПАСНОСТЬ ============== -->
  <div class="ab__under">
    <button
      class="ab__under-toggle"
      type="button"
      data-under-toggle
      aria-expanded="true"
      aria-controls="ab-under"
    >
      <span class="ab__under-chevron" aria-hidden="true"></span>
      <span>{t(ui.underLabel)}</span>
    </button>

    <div class="ab__under-box" id="ab-under">
      <div class="ab__under-inner">
        <!-- режимы -->
        <div class="ab__panel">
          <h4 class="ab__panel-title">{t(ui.modeTitle)}</h4>
          <p class="ab__panel-note">{t(ui.modeNote)}</p>
          <div class="ab__seg" role="radiogroup" aria-label={t(ui.modeTitle)}>
            <span class="ab__glide" data-glide aria-hidden="true"></span>
            {
              modes.map((m, i) => (
                <button
                  class="ab__mode"
                  type="button"
                  role="radio"
                  aria-checked={i === 0 ? "true" : "false"}
                  data-mode={m.id}
                >
                  <span class="ab__mode-id mono">{m.label}</span>
                  <span class="ab__mode-gloss">{t(m.gloss)}</span>
                </button>
              ))
            }
          </div>
          <p class="ab__mode-applied mono" data-mode-note aria-live="polite">{t(ui.noteRemote)}</p>
        </div>

        <!-- безопасность -->
        <div class="ab__panel">
          <h4 class="ab__panel-title">{t(ui.secTitle)}</h4>
          <ul class="ab__sec-chips">
            {securityChips.map((c) => <li class="ab__sec-chip mono">{t(c)}</li>)}
          </ul>
          <ul class="ab__stats">
            {stats.map((s) => <li class="ab__stat mono">{t(s)}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ab {
    --accent: var(--project-accent);
    --ab-line: color-mix(in srgb, var(--accent) 40%, transparent);
    --ab-soft: color-mix(in srgb, var(--accent) 13%, transparent);
    --ab-faint: color-mix(in srgb, var(--accent) 7%, transparent);
    --ab-hot: color-mix(in srgb, var(--accent) 60%, var(--text));
    --ab-warn: var(--state-warn);
    --ab-err: var(--state-error);
    --ab-ok: var(--state-ok);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    container-type: inline-size;
  }
  .ab :global(.mono) {
    font-family: var(--font-stack-mono);
  }

  .ab__intro {
    margin: 0;
    max-width: 64ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* ============== выбор сценария ============== */
  .ab__pick {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .ab__pick-cap {
    color: var(--text-muted);
  }
  .ab__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .ab__chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ab__chip:hover {
    border-color: var(--border-hover);
  }
  .ab__chip:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ab__chip.is-on {
    color: var(--text);
    border-color: var(--ab-line);
    background: var(--ab-soft);
  }
  @media (hover: none) {
    .ab__chip:active {
      transform: scale(0.97);
    }
  }
  .ab__chip-dot {
    width: 8px;
    height: 8px;
    flex: none;
    border-radius: 50%;
    background: var(--accent);
  }
  .ab__chip-dot--critical {
    background: var(--ab-err);
  }
  .ab__chip-label {
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    line-height: 1;
  }

  /* ============== сцена ============== */
  .ab__stage {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 110% at 50% 0%, var(--ab-faint), transparent 60%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }

  /* ----- агент на машине ----- */
  .ab__agent {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-left: 3px solid var(--ab-line);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    min-width: 0;
    transition: border-color var(--dur-med) var(--ease-standard);
  }
  .ab__stage[data-state="allowed"] .ab__agent {
    border-left-color: var(--accent);
  }
  .ab__stage[data-state="denied"] .ab__agent,
  .ab__stage[data-state="timeout"] .ab__agent {
    border-left-color: var(--text-muted);
  }
  .ab__agent-head {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .ab__agent-dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: 50%;
    background: var(--accent);
  }
  .ab.is-inview .ab__stage[data-state="pending"] .ab__agent-dot {
    animation: ab-pulse 1600ms ease-in-out infinite;
  }
  @keyframes ab-pulse {
    0%,
    100% {
      opacity: 0.45;
      transform: scale(0.85);
    }
    50% {
      opacity: 1;
      transform: scale(1.15);
    }
  }
  .ab__agent-name {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .ab__agent-state {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    white-space: nowrap;
    transition:
      color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard);
  }
  .ab__stage[data-state="allowed"] .ab__agent-state {
    color: var(--ab-hot);
    border-color: var(--ab-line);
  }
  .ab__agent-intent {
    margin: 0;
    font-size: var(--fs-13);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
  }
  .ab__agent-cmd {
    font-size: var(--fs-14);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .ab__agent-prompt {
    color: var(--accent);
  }
  .ab__caret {
    display: inline-block;
    width: 7px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    transform: translateY(1px);
  }
  .ab.is-inview .ab__stage[data-state="pending"] .ab__caret {
    animation: ab-blink 1100ms steps(2, jump-none) infinite;
  }
  @keyframes ab-blink {
    from,
    to {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  .ab__stage:not([data-state="pending"]) .ab__caret {
    opacity: 0.2;
  }
  .ab__agent-out {
    margin: 0;
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
  }
  .ab__agent-out[hidden] {
