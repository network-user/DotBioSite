        },
        allow: { ru: "опубликовано · v1.4.0", en: "published · v1.4.0" },
        deny: { ru: "публикация отменена", en: "publish cancelled" },
      },
    ],
    done: { ru: "проект пересобран", en: "project rebuilt" },
  },
  {
    id: "force",
