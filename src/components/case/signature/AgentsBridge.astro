    session: "b7c204",
    task: { ru: "поправь коммит и запушь фикс", en: "amend the commit and push the fix" },
    steps: [
      {
        k: "say",
        text: { ru: "Правлю обработчик и коммичу.", en: "Patching the handler and committing." },
      },
      {
