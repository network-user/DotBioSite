---

<section
  class="ab"
  data-ab
  data-locale={locale}
  aria-label={t({ ru: "Интерактивное демо DotAgents", en: "DotAgents interactive demo" })}
>
  <script
    type="application/json"
    data-ab-data
    is:inline
    set:html={JSON.stringify(sceneData).replace(/</g, "\\u003c")}
  />

  <p class="ab__intro">{t(intro)}</p>

  <!-- ============== СЦЕНА: рабочий стол ↔ телефон ============== -->
  <div class="ab__stage" data-stage data-state="idle" data-kind="shell">
    <!-- --------- ИНТРО-ОВЕРЛЕЙ --------- -->
    <div class="ab__ov" data-intro>
      <div class="ab__ov-card" role="dialog" aria-label={t(ui.introTitle)}>
        <h4 class="ab__ov-title">{t(ui.introTitle)}</h4>
        <ol class="ab__ov-steps">
          <li><span class="ab__ov-num">1</span><span>{t(ui.introStep1)}</span></li>
          <li><span class="ab__ov-num">2</span><span>{t(ui.introStep2)}</span></li>
          <li><span class="ab__ov-num">3</span><span>{t(ui.introStep3)}</span></li>
        </ol>
        <button class="ab__ov-start" type="button" data-intro-start>
          {t(ui.introStart)}
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>

    <!-- --------- ЭКРАН 1: рабочий стол (IDE) --------- -->
    <div class="ab__col ab__col--desk">
      <span class="ab__scr-label caption">{t(ui.labelMachine)}</span>
      <div class="ab__win ab__win--os">
        <div class="ab__win-bar">
          <span class="ab__dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <span class="ab__win-title mono">{t(ui.winTitle)}</span>
          <span class="ab__win-hook mono" aria-hidden="true">{t(ui.winHook)}</span>
        </div>

        <div class="ab__os">
          <aside class="ab__files" aria-hidden="true">
            <div class="ab__files-head mono"><span class="ab__files-caret"></span>{ui.project}</div>
            <ul class="ab__tree">
              {
                tree.slice(1).map((it) => (
                  <li
                    class={`ab__tf${it.dir ? " ab__tf--dir" : " ab__tf--file"} mono`}
                    style={`--d:${it.depth}`}
                    data-file={it.dir ? "" : it.name}
                  >
                    <span class="ab__tf-name">{it.name}</span>
                    <span class="ab__tf-dot" aria-hidden="true" />
                  </li>
                ))
              }
            </ul>
          </aside>

          <div class="ab__term-pane">
            <div class="ab__term" data-term aria-live="polite"></div>
            <div class="ab__term-status mono" data-term-status>
              <span class="ab__term-meta" data-term-meta>claude-opus · 0 tool calls</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- --------- СВЯЗКА (хук) --------- -->
    <div class="ab__wire" aria-hidden="true">
      <span class="ab__wire-line"></span>
      <span class="ab__wire-dot"></span>
      <span class="ab__wire-tag mono" data-wire-label>before_shell</span>
    </div>

    <!-- --------- ЭКРАН 2: телефон с Telegram --------- -->
    <div class="ab__col ab__col--phone">
      <span class="ab__scr-label caption">{t(ui.labelPhone)}</span>
      <div class="ab__phone" data-phone>
        <div class="ab__phone-notch" aria-hidden="true"></div>
        <div class="ab__tg">
          <div class="ab__tg-bar">
            <span class="ab__tg-back" aria-hidden="true"></span>
            <span class="ab__tg-ava" aria-hidden="true">◆</span>
            <span class="ab__tg-id">
              <span class="ab__tg-name">DotAgents</span>
              <span class="ab__tg-sub" data-tg-sub>{t(ui.tgSub)}</span>
            </span>
            <span class="ab__tg-menu" aria-hidden="true"><i></i><i></i><i></i></span>
          </div>

          <div class="ab__tg-body" data-tg>
            <!-- скелетоны истории (плейсхолдеры) -->
            <div class="ab__sk ab__sk--in" aria-hidden="true">
              <span class="ab__sk-line" style="width:70%"></span>
              <span class="ab__sk-line" style="width:45%"></span>
            </div>
            <div class="ab__sk ab__sk--out" aria-hidden="true">
              <span class="ab__sk-line" style="width:55%"></span>
            </div>

            <!-- системный разделитель «/clear» -->
            <div class="ab__sys" data-clear hidden><span data-clear-txt></span></div>

            <!-- исходящее: ты ставишь агенту новую задачу -->
            <div class="ab__bubble ab__bubble--out ab__newmsg" data-newmsg hidden>
              <div class="ab__b-body">
                <p class="ab__newmsg-txt" data-newmsg-txt></p>
                <span class="ab__b-time mono">14:31</span>
              </div>
            </div>

            <!-- живое сообщение сессии -->
            <div class="ab__bubble ab__bubble--in ab__live" data-live hidden>
              <div class="ab__b-body">
                <p class="ab__live-title mono">
                  Claude Code · <span class="ab__live-sid" data-live-sid></span>
                </p>
                <p class="ab__live-task" data-live-task></p>
                <p class="ab__live-status mono" data-live-status></p>
                <p class="ab__live-tool mono" data-live-tool></p>
                <p class="ab__live-foot mono">
                  started just now · <span data-live-tools>0</span> tools ·
                  <span data-live-files>0</span> files · mode: <code data-live-mode>remote</code>
                </p>
                <span class="ab__b-time mono" data-live-time>14:32</span>
              </div>
              <div class="ab__ikb" aria-hidden="true">
                <div class="ab__ikb-row">
                  <span class="ab__ikb-btn">{t(ui.kbReply)}</span>
                  <span class="ab__ikb-btn">{t(ui.kbEvents)}</span>
                </div>
                <div class="ab__ikb-row">
                  <span class="ab__ikb-btn ab__ikb-btn--muted">{t(ui.kbStop)}</span>
                </div>
              </div>
            </div>

            <!-- запрос approve/deny (прилетает и удаляется) -->
            <div class="ab__bubble ab__bubble--in ab__appr" data-appr hidden>
              <div class="ab__b-body">
                <p class="ab__appr-head mono">
                  <b>Approval</b> · <span class="ab__appr-sid" data-appr-sid>a2b3c</span>
                  <span class="ab__b-time" data-appr-time>14:33</span>
                </p>
                <p class="ab__appr-meta mono">
                  kind: <code data-appr-kind></code> · risk:
                  <code class="ab__appr-risk mono" data-appr-risk></code>
                </p>
                <code class="ab__appr-cmd mono" data-appr-cmd></code>
                <p class="ab__appr-what">
                  {t(ui.apprWhatCap)}
                  <span class="mono" data-appr-what></span>
                </p>
                <p class="ab__appr-why" data-appr-why></p>
              </div>
              <div class="ab__ikb" data-appr-actions>
                <div class="ab__ikb-row">
                  <button type="button" class="ab__ikb-btn ab__ikb-btn--act" data-act="allow"
                    >{t(ui.allow)}</button
                  >
                  <button type="button" class="ab__ikb-btn ab__ikb-btn--act" data-act="deny"
                    >{t(ui.deny)}</button
                  >
                </div>
                <div class="ab__ikb-row">
                  <button type="button" class="ab__ikb-btn ab__ikb-btn--muted" data-act="ignore"
                    >{t(ui.ignore)}</button
                  >
                </div>
              </div>
            </div>
          </div>

          <div class="ab__tg-compose" aria-hidden="true">
            <span class="ab__tg-clip"></span>
            <span class="ab__tg-input">{t(ui.compose)}</span>
            <span class="ab__tg-mic"></span>
          </div>

          <!-- модальное уведомление: задача завершена + выбор следующей -->
          <div class="ab__modal" data-modal hidden>
            <div
              class="ab__modal-card"
              role="dialog"
              aria-label={locale === "ru" ? "Задача завершена" : "Task complete"}
            >
              <span class="ab__modal-badge" aria-hidden="true">✓</span>
              <p class="ab__modal-title">
                {locale === "ru" ? "Задача завершена" : "Task complete"}
              </p>
              <p class="ab__modal-sum mono" data-done-sum></p>
              <p class="ab__modal-pick caption">{t(ui.donePick)}</p>
              <div class="ab__modal-btns">
                {
                  scenarios.map((s) => (
                    <button type="button" class="ab__modal-btn" data-scene-go={s.id}>
                      {t(s.label)}
                    </button>
                  ))
                }
              </div>
              <button type="button" class="ab__modal-replay" data-scene-replay
                >{t(ui.doneReplay)}</button
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- прототипы строк терминала (клонируются скриптом; сохраняют scope Astro) -->
    <div class="ab__protos" hidden aria-hidden="true">
      <div class="ab__ln ab__ln--prompt" data-p="prompt">
        <span class="ab__cprompt">&gt;</span><span class="ab__ln-txt mono"></span>
      </div>
      <div class="ab__ln ab__ln--cmd" data-p="cmd">
        <span class="ab__bullet">●</span><span class="ab__tool mono"></span><span
          class="ab__paren mono">(<span class="ab__ln-arg"></span>)</span
        >
      </div>
      <div class="ab__ln ab__ln--res" data-p="res">
        <span class="ab__pipe">⎿</span><span class="ab__ln-txt mono"></span>
      </div>
      <div class="ab__ln ab__ln--say" data-p="say"><span class="ab__ln-txt mono"></span></div>
      <div class="ab__ln ab__ln--wait" data-p="wait">
        <span class="ab__pipe">⎿</span><span class="ab__spin"></span><span class="ab__ln-txt mono"
        ></span>
      </div>
      <div class="ab__ln ab__ln--done" data-p="done">
        <span class="ab__ln-check">✓</span><span class="ab__ln-txt mono"></span>
      </div>
    </div>
  </div>

  <!-- ============== ИНВАРИАНТ ============== -->
  <p class="ab__inv">
    <span class="ab__inv-dot" aria-hidden="true"></span>
    {t(ui.invariant)}
  </p>

  <!-- ============== РЕЖИМЫ И БЕЗОПАСНОСТЬ ============== -->
  <div class="ab__under">
    <button
      class="ab__under-toggle"
      type="button"
      data-under-toggle
      aria-expanded="true"
      aria-controls="ab-under"
    >
      <span class="ab__under-chevron" aria-hidden="true"></span>
      <span>{t(ui.underLabel)}</span>
    </button>

    <div class="ab__under-box" id="ab-under">
      <div class="ab__under-inner">
        <div class="ab__panel">
          <h4 class="ab__panel-title">{t(ui.modeTitle)}</h4>
          <p class="ab__panel-note">{t(ui.modeNote)}</p>
          <div class="ab__seg" role="radiogroup" aria-label={t(ui.modeTitle)}>
            <span class="ab__glide" data-glide aria-hidden="true"></span>
            {
              modes.map((m, i) => (
                <button
                  class="ab__mode"
                  type="button"
                  role="radio"
                  aria-checked={i === 0 ? "true" : "false"}
                  data-mode={m.id}
                >
                  <span class="ab__mode-id mono">{m.label}</span>
                  <span class="ab__mode-gloss">{t(m.gloss)}</span>
                </button>
              ))
            }
          </div>
        </div>

        <div class="ab__panel">
          <h4 class="ab__panel-title">{t(ui.secTitle)}</h4>
          <ul class="ab__sec-chips">
            {securityChips.map((c) => <li class="ab__sec-chip mono">{t(c)}</li>)}
          </ul>
          <ul class="ab__stats">
            {stats.map((s) => <li class="ab__stat mono">{t(s)}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ab {
    --accent: var(--project-accent);
    --ab-line: color-mix(in srgb, var(--accent) 40%, transparent);
    --ab-soft: color-mix(in srgb, var(--accent) 13%, transparent);
    --ab-faint: color-mix(in srgb, var(--accent) 7%, transparent);
    --ab-hot: color-mix(in srgb, var(--accent) 60%, var(--text));
    --ab-warn: var(--state-warn);
    --ab-err: var(--state-error);
    --ab-ok: var(--state-ok);
    --ab-ikb: color-mix(in srgb, var(--text) 7%, transparent);
    --ab-ikb-hi: color-mix(in srgb, var(--text) 13%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    container-type: inline-size;
  }
  .ab :global(.mono) {
    font-family: var(--font-stack-mono);
  }

  .ab__intro {
    margin: 0;
    max-width: 68ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* ============== сцена ============== */
  .ab__stage {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 120% at 15% 0%, var(--ab-faint), transparent 55%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }

  /* ============== интро-оверлей ============== */
  .ab__ov {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-4);
    border-radius: var(--r-lg);
    background: color-mix(in srgb, var(--bg-deep) 82%, transparent);
    cursor: pointer;
  }
  .ab.is-intro-done .ab__ov {
    opacity: 0;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ab__ov {
      transition: opacity var(--dur-med) var(--ease-standard);
    }
  }
  .ab__ov-card {
    max-width: 460px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--ab-line);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
    box-shadow: var(--shadow-2);
    cursor: default;
  }
  .ab__ov-title {
    margin: 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-18);
    color: var(--text);
  }
  .ab__ov-steps {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .ab__ov-steps li {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    font-size: var(--fs-14);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
  }
  .ab__ov-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    flex: none;
    border-radius: 50%;
    background: var(--ab-soft);
    color: var(--accent);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    font-weight: var(--fw-semibold);
  }
  .ab__ov-start {
    align-self: flex-start;
    margin-top: var(--sp-1);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--ab-line);
    border-radius: var(--r-pill);
    background: var(--ab-soft);
    color: var(--text);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ab__ov-start:hover {
    background: var(--ab-ikb-hi);
  }
  .ab__ov-start:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  @media (hover: none) {
    .ab__ov-start:active {
      transform: scale(0.97);
    }
  }

  /* ============== колонки + ярлыки ============== */
  .ab__col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }
  .ab__scr-label {
    color: var(--text-muted);
  }
  .ab__col--phone {
    align-items: center;
  }
  .ab__col--phone .ab__scr-label {
    align-self: flex-start;
  }

  /* ============== рабочий стол (IDE) ============== */
  .ab__win {
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    overflow: hidden;
  }
  .ab__win--os {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .ab__win-bar {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }
  .ab__dots {
    display: inline-flex;
    gap: 5px;
    flex: none;
  }
  .ab__dots i {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-hover);
  }
  .ab__win-title {
    font-size: var(--fs-11);
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .ab__win-hook {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--ab-line);
    border-radius: var(--r-pill);
    font-size: var(--fs-10);
    color: var(--ab-hot);
    white-space: nowrap;
  }
  .ab__win-hook::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .ab.is-inview .ab__win-hook::before {
    animation: ab-pulse 1800ms ease-in-out infinite;
  }
  @keyframes ab-pulse {
    0%,
    100% {
      opacity: 0.45;
      transform: scale(0.85);
    }
    50% {
      opacity: 1;
      transform: scale(1.15);
    }
  }

  .ab__os {
    display: grid;
    grid-template-columns: minmax(104px, 140px) minmax(0, 1fr);
    flex: 1;
    min-height: 0;
  }

  /* дерево файлов */
  .ab__files {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: var(--sp-2) 0;
    border-right: var(--bw-thin) solid var(--border);
    background: var(--surface);
    overflow: hidden;
  }
  .ab__files-head {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 2px var(--sp-3) var(--sp-2);
    font-size: var(--fs-11);
    font-weight: var(--fw-semibold);
    color: var(--text-secondary);
  }
  .ab__files-caret {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 4px 0 4px 5px;
    border-color: transparent transparent transparent var(--text-muted);
  }
  .ab__tree {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .ab__tf {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 3px var(--sp-2) 3px calc(var(--sp-2) + var(--d) * 10px);
    font-size: var(--fs-11);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
  }
  .ab__tf-name {
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ab__tf::before {
    content: "";
    flex: none;
  }
  .ab__tf--dir::before {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 3.5px 0 3.5px 5px;
    border-color: transparent transparent transparent var(--text-faint);
  }
  .ab__tf--file::before {
    width: 5px;
    height: 6px;
    border: var(--bw-thin) solid var(--text-faint);
    border-radius: 1px;
  }
  .ab__tf--dir {
    color: var(--text-secondary);
  }
  .ab__tf.is-active {
    background: var(--ab-soft);
    color: var(--text);
  }
  .ab__tf-dot {
    width: 5px;
    height: 5px;
    flex: none;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
  }
  .ab__tf.is-touched .ab__tf-dot {
    opacity: 1;
  }

  /* терминал */
  .ab__term-pane {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
  }
  .ab__term {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--sp-3) var(--sp-4);
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    min-height: 232px;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .ab__term::-webkit-scrollbar {
    display: none;
  }
  .ab__term-status {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    border-top: var(--bw-thin) solid var(--border);
    font-size: var(--fs-11);
    color: var(--text-muted);
    background: var(--surface);
  }
  .ab__term-status::before {
    content: "";
    width: 6px;
    height: 6px;
    flex: none;
    border-radius: 50%;
    background: var(--text-muted);
  }
  .ab__stage[data-state="working"] .ab__term-status::before {
    background: var(--ab-ok);
  }
  .ab__stage[data-state="pending"] .ab__term-status {
    color: var(--accent);
  }
  .ab__stage[data-state="pending"] .ab__term-status::before {
    background: var(--accent);
  }
  .ab__stage[data-state="done"] .ab__term-status::before {
    background: var(--ab-hot);
  }
  .ab__term-meta {
    margin-left: auto;
    color: var(--text-faint);
  }

  /* строки терминала (клоны прототипов) */
  .ab__protos {
    display: none;
  }
  .ab__ln {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    min-width: 0;
    overflow-wrap: anywhere;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ab__ln {
      animation: ab-ln-in 240ms var(--ease-standard) both;
    }
  }
  .ab__ln.is-noanim {
    animation: none;
  }
  @keyframes ab-ln-in {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
  }
  .ab__cprompt {
    flex: none;
    color: var(--accent);
    font-family: var(--font-stack-mono);
    font-weight: var(--fw-semibold);
  }
  .ab__ln--prompt {
    color: var(--text);
  }
  .ab__ln--say {
    color: var(--text-secondary);
    font-style: italic;
    margin-top: 2px;
  }
  .ab__bullet {
    flex: none;
    font-size: var(--fs-11);
    line-height: 1.4;
    color: var(--ab-ok);
  }
  .ab__bullet--risk {
    color: var(--ab-warn);
  }
  .ab__bullet--crit {
    color: var(--ab-err);
  }
  .ab__tool {
    flex: none;
    color: var(--text);
    font-weight: var(--fw-medium);
  }
  .ab__paren {
    color: var(--text-muted);
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .ab__ln--cmd .ab__ln-arg {
    color: var(--text);
  }
  .ab__pipe {
    flex: none;
    color: var(--text-faint);
  }
  .ab__ln--res .ab__ln-txt {
    color: var(--text-muted);
  }
  .ab__ln--ok .ab__ln-txt {
    color: var(--ab-ok);
  }
  .ab__ln--hot .ab__ln-txt {
    color: var(--ab-hot);
  }
  .ab__ln--wait {
    color: var(--accent);
  }
  .ab__spin {
    flex: none;
    width: 11px;
    height: 11px;
    border: 1.5px solid var(--ab-line);
    border-top-color: var(--accent);
    border-radius: 50%;
    align-self: center;
  }
  .ab.is-inview .ab__ln--wait .ab__spin {
    animation: ab-spin 720ms linear infinite;
  }
  @keyframes ab-spin {
    to {
      transform: rotate(360deg);
    }
  }
  .ab__ln--done {
    margin-top: 2px;
    color: var(--ab-hot);
    font-weight: var(--fw-medium);
  }
  .ab__ln-check {
    flex: none;
    color: var(--ab-ok);
  }

  /* ============== связка (хук) ============== */
  .ab__wire {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    color: var(--text-faint);
  }
  .ab__wire-line {
    position: relative;
    width: var(--bw-thin);
    height: 26px;
    background: var(--ab-line);
  }
  .ab__wire-dot {
    position: absolute;
    top: 0;
    left: 50%;
    width: 6px;
    height: 6px;
    margin-left: -3px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
  }
  .ab.is-inview .ab__stage[data-state="pending"] .ab__wire-dot {
    opacity: 1;
    animation: ab-wire-down 1200ms ease-in-out infinite;
  }
  @keyframes ab-wire-down {
    from {
      transform: translateY(0);
      opacity: 0.3;
    }
    to {
      transform: translateY(20px);
      opacity: 1;
    }
  }
  .ab__wire-tag {
    font-size: var(--fs-10);
    text-align: center;
    max-width: 14ch;
    overflow-wrap: normal;
    word-break: keep-all;
    line-height: var(--lh-snug);
  }

  /* ============== телефон / Telegram ============== */
  .ab__phone {
    width: 100%;
    max-width: 322px;
    height: 604px;
    display: flex;
    flex-direction: column;
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: 26px;
    background: var(--bg-elevated);
    padding: 10px;
    box-shadow: var(--shadow-2);
  }
  .ab__phone-notch {
    width: 46px;
    height: 4px;
    flex: none;
    margin: 0 auto 8px;
    border-radius: var(--r-pill);
    background: var(--border-hover);
  }
  .ab__tg {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: var(--bg-deep);
    overflow: hidden;
  }
  .ab__tg-bar {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }
  .ab__tg-back {
    width: 8px;
    height: 8px;
    flex: none;
    border-left: 1.5px solid var(--text-muted);
    border-bottom: 1.5px solid var(--text-muted);
    transform: rotate(45deg);
  }
  .ab__tg-ava {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    flex: none;
    border-radius: 50%;
    background: var(--ab-soft);
    color: var(--accent);
    font-size: var(--fs-12);
  }
  .ab__tg-id {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
