---
/**
 * AgentsBridge.astro - сигнатурная визуализация .агенты (DotAgents).
 *
 * Концепт: ДВА ЭКРАНА ОДНОЙ ЖИВОЙ СЕССИИ.
 *  - Слева «рабочий стол»: окно IDE (дерево файлов + терминал), в котором
 *    Claude Code ведёт непрерывную работу - читает/правит файлы, гоняет
 *    команды. Транскрипт накапливается и прокручивается, как в реальном CLI.
 *  - Справа телефон: чат в Telegram с ботом DotAgents. Живое сообщение сессии
 *    (редактируемое) + прилетающие как пуш запросы approve/deny с inline-
 *    кнопками. Запрос ПОЯВЛЯЕТСЯ при рискованной команде и УДАЛЯЕТСЯ после
 *    твоего решения - как в настоящем боте.
 *
 * Поток: агент работает → упирается в рискованную команду → хук ставит паузу →
 * в чат прилетает запрос → жмёшь Allow/Deny (запрос исчезает) → агент идёт
 * дальше. Через 2-3 таких решения - «работа завершена». В чате появляется
 * селектор следующей задачи + «Повторить»; выбор новой задачи очищает чат
 * (/clear) и запускает новую сессию с новым уведомлением.
 *
 * Понятность: перед стартом поверх сцены - интро «Как это работает» (1-2-3 +
 * «Попробовать»); на экранах ярлыки «Твоя машина» / «Твой телефон».
 * Fail-closed показан кнопкой «Ничего не делать» (без авто-таймера). Режимы
 * демона remote/readonly/standby и security-инварианты - в сворачиваемом блоке.
 *
 * Перф ([[dotcore-perf-budget]]): только transform/opacity, конечные CSS-
 * анимации (нет вечного rAF). Тайминги - setTimeout-конвейер later() с очисткой
 * офскрин / на скрытой вкладке / при pagehide / astro:before-swap. Всё под
 * IntersectionObserver (.ab.is-inview). Динамические строки терминала - клоны
 * pre-rendered прототипов (сохраняют scope-атрибут Astro). Re-init на
 * astro:page-load (сайт на View Transitions). reduced-motion → мгновенно.
 *
 * Строки/факты сверены по репозиторию DotAgents: live_renderer.py (заголовок
 * «Claude Code · <id>», статусы ⚡/⏳/✏️, «Last tool», «Approval:», футер
 * «started … · N tools · N files · mode: remote»), notifier.py + strings.py
 * («Approval · <sid>», «kind:…·risk:…», «Что вы разрешаете / What you
 * approve», Allow/Deny = Разрешить/Отклонить), before_shell/before_mcp →
 * long-poll до 270 c (fail-closed), режимы remote/readonly/standby,
 * Claude Code stream-json (Read/Grep/Edit/Write/Bash + MCP).
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Два экрана одной сессии: слева Claude Code работает в терминале, справа ты управляешь им из Telegram - разрешаешь или отклоняешь каждую рискованную команду.",
  en: "Two screens, one session: Claude Code runs in the terminal on the left, you drive it from Telegram on the right - approving or denying every risky command.",
};

// ── Сценарии = задачи. Каждая: несколько шагов, среди них 2-3 рискованных
//    (ask), которые ждут решения. Строки локализуются на build-time и уезжают
//    в JSON-блоб; клиент их проигрывает. ──
type Step =
  | { k: "say"; text: Bi }
  | { k: "run"; tool: string; arg: string; res: Bi; file?: string }
  | {
      k: "ask";
      tool: string;
      kind: Bi;
      cmd: string;
      mcp?: boolean;
      risk: "high" | "critical";
      riskLabel: Bi;
      why: Bi;
      allow: Bi;
      deny: Bi;
      file?: string;
    };

type Scenario = { id: string; label: Bi; session: string; task: Bi; steps: Step[]; done: Bi };

const scenarios: Scenario[] = [
