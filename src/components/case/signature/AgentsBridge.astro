        },
      },
      {
        k: "ask",
        tool: "Bash",
        kind: { ru: "shell", en: "shell" },
        cmd: "alembic upgrade head",
        risk: "high",
        riskLabel: { ru: "высокий", en: "high" },
        why: {
          ru: "Изменит схему боевой базы - без бэкапа рискованно.",
          en: "Alters the production DB schema - risky without a backup.",
        },
        allow: { ru: "миграции применены · 3 версии", en: "migrations applied · 3 versions" },
        deny: { ru: "миграции отменены", en: "migrations cancelled" },
      },
    ],
    done: { ru: "бот подключён к базе", en: "bot wired to the database" },
  },
];

// Локализуем сценарии на build-time и сериализуем в JSON для клиента.
const sceneData = scenarios.map((s) => ({
  id: s.id,
  label: t(s.label),
  session: s.session,
  task: t(s.task),
  done: t(s.done),
  steps: s.steps.map((st) => {
    if (st.k === "say") return { k: "say", text: t(st.text) };
    if (st.k === "run")
      return { k: "run", tool: st.tool, arg: st.arg, res: t(st.res), file: st.file ?? "" };
    return {
      k: "ask",
      tool: st.tool,
      kind: t(st.kind),
      cmd: st.cmd,
      mcp: !!st.mcp,
      risk: st.risk,
      riskLabel: t(st.riskLabel),
      why: t(st.why),
      allow: t(st.allow),
      deny: t(st.deny),
      file: st.file ?? "",
    };
  }),
}));

// Дерево файлов «рабочего стола» (декоративное).
type TreeItem = { name: string; depth: number; dir?: boolean };
const tree: TreeItem[] = [
  { name: "my-app", depth: 0, dir: true },
  { name: "app", depth: 1, dir: true },
  { name: "api", depth: 2, dir: true },
  { name: "auth.py", depth: 3 },
  { name: "main.py", depth: 2 },
  { name: "db.py", depth: 2 },
  { name: "tests", depth: 1, dir: true },
  { name: "package.json", depth: 1 },
  { name: ".env", depth: 1 },
];

// Режимы демона (в блоке «Режимы и безопасность»).
const modes: { id: string; label: string; gloss: Bi }[] = [
  { id: "remote", label: "remote", gloss: { ru: "спрашивает каждый раз", en: "asks every time" } },
  {
    id: "readonly",
    label: "readonly",
    gloss: { ru: "сам разрешает, только уведомляет", en: "auto-allows, just notifies" },
  },
  {
    id: "standby",
    label: "standby",
    gloss: { ru: "сам отклоняет всё опасное", en: "auto-denies anything risky" },
  },
];

const securityChips: Bi[] = [
  { ru: "passcode argon2id", en: "argon2id passcode" },
  { ru: "HMAC + одноразовый nonce", en: "HMAC + one-shot nonce" },
  { ru: "только владелец", en: "owner-only" },
  { ru: "audit-log решений", en: "audit log of decisions" },
  { ru: "API только 127.0.0.1", en: "API on 127.0.0.1 only" },
  { ru: "env без секретов при спавне", en: "env stripped on spawn" },
];

const stats: Bi[] = [
  { ru: "19k+ строк", en: "19k+ lines" },
  { ru: "132 теста", en: "132 tests" },
  { ru: "3 миграции", en: "3 migrations" },
  { ru: "long-poll 270 c", en: "270s long-poll" },
];

const ui = {
  introTitle: { ru: "Как это работает", en: "How it works" },
  introStep1: {
    ru: "Claude Code сам работает в терминале на твоей машине",
    en: "Claude Code works on its own in the terminal on your machine",
  },
  introStep2: {
    ru: "Дошёл до опасной команды - хук ставит его на паузу и пишет тебе в Telegram",
    en: "It hits a risky command - the hook pauses it and messages you in Telegram",
  },
  introStep3: {
    ru: "Жмёшь Allow или Deny - и так, пока задача не будет готова",
    en: "You tap Allow or Deny - and so on, until the task is done",
  },
  introStart: { ru: "Попробовать", en: "Try it" },
  labelMachine: { ru: "Твоя машина", en: "Your machine" },
  labelPhone: { ru: "Твой телефон", en: "Your phone" },
  winTitle: { ru: "claude - agent session", en: "claude - agent session" },
  winHook: { ru: "DotAgents · подключён", en: "DotAgents · hooked" },
  project: "my-app",
  tgSub: { ru: "бот", en: "bot" },
  invariant: {
    ru: "Канал управления уходит в Telegram. Код, approvals и transcript остаются на машине - API слушает только 127.0.0.1.",
    en: "The control channel goes to Telegram. Code, approvals and transcript stay on the machine - the API listens on 127.0.0.1 only.",
  },
  underLabel: { ru: "Режимы и безопасность", en: "Modes & security" },
  modeTitle: { ru: "Режим демона", en: "Daemon mode" },
  modeNote: {
    ru: "Меняет, как решается следующий запрос.",
    en: "Changes how the next request resolves.",
  },
  secTitle: { ru: "Безопасность", en: "Security" },
  compose: { ru: "Сообщение", en: "Message" },
  kbReply: { ru: "Ответить", en: "Reply" },
  kbEvents: { ru: "События", en: "Events" },
  kbStop: { ru: "⏹ Остановить агент", en: "⏹ Stop agent" },
