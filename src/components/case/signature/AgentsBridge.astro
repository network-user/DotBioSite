---
/**
 * AgentsBridge.astro — сигнатурная визуализация .агенты (DotAgents).
 *
 * Цель этой версии: ЯСНОСТЬ. Медленный пошаговый рассказ о потоке одобрения
 * рискованной команды, по одному шагу за раз, с крупным заголовком и подробным
 * объяснением «что и почему». Управление полностью у пользователя: пронумерованные
 * вкладки-шаги, prev/next, кнопка «заново». Автопереход медленный (~4.5с/шаг) и
 * ставится на паузу при наведении.
 *
 * Поток (сверен по репозиторию DotAgents):
 *   1. IDE-агент (Cursor / Claude Code / Antigravity) собирается выполнить
 *      рискованную команду; хук перехватывает её.
 *   2. Хук шлёт POST на локальный демон, слушающий ТОЛЬКО 127.0.0.1 (loopback),
 *      с заголовком X-DotAgents-Secret.
 *   3. Демон смотрит на режим сессии: remote=спросить, readonly=авто-allow,
 *      standby=авто-deny.
 *   4. В режиме remote приходит сообщение в Telegram с кнопками Allow / Deny;
 *      агент реально ждёт ответа (HOOK_TIMEOUT_SECONDS, по умолчанию 90с).
 *   5. Нет ответа за отведённое время → fail-closed: demon отвечает deny.
 *   6. Каждый callback подписан HMAC-SHA256 (truncated 16) + одноразовый nonce
 *      и expires_at → подделать и переиграть нельзя.
 *   Инвариант: код, approvals и transcript не покидают машину — облачного релея нет.
 *
 * Перфоманс: анимируем только transform/opacity. Вся анимация под классом
 * .is-inview (IntersectionObserver); за экраном таймеры очищаются.
 * backdrop-filter/blur/box-shadow в циклах не трогаем. reduced-motion →
 * финальное читаемое состояние без движения. Курсорного параллакса нет.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const copy = {
  ru: {
    eyebrow: "Поток одобрения",
    intro:
      "Как .агенты пропускают рискованную команду через тебя: ИИ-агент в IDE хочет что-то выполнить, локальный демон спрашивает разрешение в Telegram, а решение защищено от подделки. Листай по шагам.",
    replay: "Сначала",
    prev: "Назад",
    next: "Дальше",
    stepWord: "Шаг",
    ofWord: "из",
    agent: "IDE-агент",
    agentSub: "Cursor · Claude Code · Antigravity",
    daemon: "локальный демон",
    daemonApi: "FastAPI · 127.0.0.1",
    tg: "Telegram",
    cmd: "rm -rf /tmp/scratch",
    cmdKind: "shell · risk: high",
    approve: "Allow",
    deny: "Deny",
    waiting: "ждёт твоего ответа…",
    approved: "разрешено · команда выполняется",
    denied: "отклонено · команда не запущена",
    timeoutMsg: "нет ответа → deny (fail-closed)",
    loopbackTag: "loopback",
    sigTag: "HMAC + nonce",
    steps: [
      {
        title: "Агент хочет выполнить опасное",
        body: "ИИ-агент прямо в твоём редакторе собирается запустить команду оболочки или вызвать MCP-инструмент. Установленный хук перехватывает вызов ДО запуска и ставит его на паузу. Так агент не может сам, без тебя, сделать что-то разрушительное.",
        tag: "хук перехватывает вызов",
      },
      {
        title: "Хук стучится только в свою машину",
        body: "Хук отправляет запрос локальному демону по адресу 127.0.0.1 — это loopback, петля на саму себя: ничего не уходит в интернет, демон не слушает внешний порт. Запрос ещё и подписан секретным заголовком X-DotAgents-Secret, так что чужой процесс на машине не подсунет фальшивку.",
        tag: "127.0.0.1 = только твой компьютер",
      },
      {
        title: "Режим решает: спросить или ответить сразу",
        body: "У сессии есть один из трёх режимов. remote — спрашивать тебя про каждое защищённое действие. readonly — авто-allow, только уведомить (когда смотришь, как агент работает). standby — авто-deny всего опасного (когда отошёл и не хочешь сюрпризов).",
        tag: "remote · readonly · standby",
      },
      {
        title: "В Telegram приходит запрос",
        body: "В режиме remote демон шлёт тебе сообщение с самой командой и кнопками Allow / Deny. Telegram здесь — только канал доставки: код и контекст остаются на машине, в сообщении лишь то, что ты явно отправляешь своему боту. Агент тем временем реально стоит и ждёт.",
        tag: "ты — пульт",
      },
      {
        title: "Молчание = запрет (fail-closed)",
        body: "Агент ждёт не вечно: до HOOK_TIMEOUT_SECONDS (по умолчанию 90 секунд). Если ты не ответил, демон сам отвечает deny — это «безопасное по умолчанию». Если что-то пошло не так или тебя нет рядом, система запрещает, а не разрешает молча.",
        tag: "таймаут → deny",
      },
      {
        title: "Решение нельзя подделать и переиграть",
        body: "Каждая кнопка несёт callback, подписанный HMAC-SHA256 (общий секрет проверяет подлинность) плюс одноразовый nonce и срок годности expires_at. Подменишь данные — подпись не сойдётся; нажмёшь повторно ту же кнопку — nonce уже сгорел. Подделка и повтор исключены.",
        tag: "tamper-proof · одноразово",
      },
    ],
    invariant: "Код, approvals и transcript не покидают машину — облачного релея нет.",
  },
  en: {
    eyebrow: "Approval flow",
    intro:
      "How .agents route a risky command through you: an AI agent in your IDE wants to run something, a local daemon asks for permission over Telegram, and the answer is tamper-proof. Step through it.",
    replay: "Restart",
    prev: "Back",
    next: "Next",
    stepWord: "Step",
    ofWord: "of",
    agent: "IDE agent",
    agentSub: "Cursor · Claude Code · Antigravity",
    daemon: "local daemon",
    daemonApi: "FastAPI · 127.0.0.1",
    tg: "Telegram",
    cmd: "rm -rf /tmp/scratch",
    cmdKind: "shell · risk: high",
    approve: "Allow",
    deny: "Deny",
    waiting: "waiting for your reply…",
    approved: "allowed · command runs",
    denied: "denied · command never runs",
    timeoutMsg: "no reply → deny (fail-closed)",
    loopbackTag: "loopback",
    sigTag: "HMAC + nonce",
    steps: [
      {
        title: "The agent wants to do something risky",
        body: "An AI agent right inside your editor is about to run a shell command or call an MCP tool. An installed hook intercepts the call BEFORE it runs and pauses it. That means the agent cannot do anything destructive on its own without you.",
        tag: "hook intercepts the call",
      },
      {
        title: "The hook only knocks on your own machine",
        body: "The hook sends the request to a local daemon at 127.0.0.1 — that is loopback, a wire that loops back to itself: nothing goes to the internet and the daemon listens on no public port. The request also carries a secret X-DotAgents-Secret header, so a stray process on the box cannot forge one.",
        tag: "127.0.0.1 = only your computer",
      },
      {
        title: "The mode decides: ask, or answer at once",
        body: "Each session is in one of three modes. remote — ask you about every protected action. readonly — auto-allow, notify only (while you watch the agent work). standby — auto-deny anything dangerous (when you stepped away and want no surprises).",
        tag: "remote · readonly · standby",
      },
      {
        title: "A request lands in Telegram",
        body: "In remote mode the daemon sends you a message with the command itself and Allow / Deny buttons. Telegram is only the delivery channel here: your code and context stay on the machine, the message holds only what you explicitly send your own bot. Meanwhile the agent really sits and waits.",
        tag: "you are the remote",
      },
      {
        title: "Silence means deny (fail-closed)",
        body: "The agent does not wait forever: up to HOOK_TIMEOUT_SECONDS (90s by default). If you do not reply, the daemon answers deny itself — that is the safe default. If something breaks or you are not around, the system blocks rather than silently allowing.",
        tag: "timeout → deny",
      },
      {
        title: "The decision cannot be forged or replayed",
        body: "Every button carries a callback signed with HMAC-SHA256 (a shared secret proves it is genuine) plus a one-time nonce and an expires_at deadline. Tamper with the data and the signature will not match; press the same button twice and the nonce is already spent. Forgery and replay are both ruled out.",
        tag: "tamper-proof · one-shot",
      },
    ],
    invariant: "Code, approvals and transcript stay on the machine — there is no cloud relay.",
  },
}[locale];

const steps = copy.steps;
const total = steps.length;
---

<section class="ab" aria-label={copy.eyebrow} data-ab>
  <header class="ab__head">
    <p class="ab__eyebrow">{copy.eyebrow}</p>
    <p class="ab__intro">{copy.intro}</p>
  </header>

  <!-- ===== Сцена: один фиксированный кадр, состояние меняется по шагам ===== -->
  <div class="ab__stage" data-stage data-step="0" aria-hidden="true">
    <!-- IDE-агент -->
    <article class="ab-node ab-node--agent" data-node="agent">
      <span class="ab-node__head">
        <span class="ab-node__dot"></span>
        <span class="ab-node__title">{copy.agent}</span>
      </span>
      <span class="ab-node__sub">{copy.agentSub}</span>
      <code class="ab-node__cmd">{copy.cmd}</code>
      <span class="ab-node__cmd-kind">{copy.cmdKind}</span>
    </article>

    <!-- провод agent -> daemon -->
    <div class="ab-wire ab-wire--1">
      <span class="ab-wire__line"></span>
      <span class="ab-wire__pulse" data-pulse="1"></span>
      <span class="ab-wire__tag">{copy.loopbackTag}</span>
    </div>

    <!-- локальный демон -->
    <article class="ab-node ab-node--daemon" data-node="daemon">
      <span class="ab-node__head">
        <span class="ab-node__lock">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7">
            <rect x="5" y="11" width="14" height="9" rx="2"></rect>
            <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
          </svg>
        </span>
        <span class="ab-node__title">{copy.daemon}</span>
      </span>
      <span class="ab-node__sub">{copy.daemonApi}</span>
      <span class="ab-node__modes" data-modes>
        <span class="ab-mode" data-mode="remote">remote</span>
        <span class="ab-mode" data-mode="readonly">readonly</span>
        <span class="ab-mode" data-mode="standby">standby</span>
      </span>
    </article>

    <!-- провод daemon -> telegram -->
    <div class="ab-wire ab-wire--2">
      <span class="ab-wire__line"></span>
      <span class="ab-wire__pulse" data-pulse="2"></span>
      <span class="ab-wire__tag" data-sig-tag>{copy.sigTag}</span>
    </div>

    <!-- Telegram -->
    <article class="ab-node ab-node--tg" data-node="tg">
      <span class="ab-node__head">
        <span class="ab-node__dot ab-node__dot--tg"></span>
        <span class="ab-node__title">{copy.tg}</span>
      </span>
      <code class="ab-node__cmd ab-node__cmd--tg">{copy.cmd}</code>
      <span class="ab-status" data-status data-state="idle">{copy.waiting}</span>
      <div class="ab-buttons">
        <span class="ab-btn ab-btn--approve" data-btn="approve">{copy.approve}</span>
        <span class="ab-btn ab-btn--deny" data-btn="deny">{copy.deny}</span>
      </div>
    </article>
  </div>

  <!-- ===== Объяснение текущего шага ===== -->
  <div class="ab__panel" data-panel aria-live="polite">
    <p class="ab__step-meta">
      <span data-step-word>{copy.stepWord}</span>
      <span data-step-num>1</span> {copy.ofWord} {total}
    </p>
    <h3 class="ab__step-title" data-step-title>{steps[0]?.title}</h3>
    <p class="ab__step-body" data-step-body>{steps[0]?.body}</p>
  </div>

  <!-- ===== Управление: вкладки-шаги + prev/next + replay ===== -->
  <nav class="ab__controls" aria-label={copy.eyebrow}>
    <div class="ab__dots" role="tablist" data-dots>
      {
        steps.map((s, i) => (
          <button
            type="button"
            class:list={["ab__dot", { "is-active": i === 0 }]}
            role="tab"
            data-go={i}
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`${copy.stepWord} ${i + 1}: ${s.title}`}
          >
            <span class="ab__dot-num">{i + 1}</span>
          </button>
        ))
      }
    </div>
    <div class="ab__nav">
      <button type="button" class="ab__btn" data-prev>{copy.prev}</button>
      <button type="button" class="ab__btn" data-next>{copy.next}</button>
      <button type="button" class="ab__btn ab__btn--replay" data-replay>{copy.replay}</button>
    </div>
  </nav>

  <p class="ab__invariant">
    <span class="ab__invariant-mark" aria-hidden="true"></span>
    {copy.invariant}
  </p>
</section>

<style>
  .ab {
    --accent: var(--project-accent);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    color: var(--text);
    container-type: inline-size;
  }

  /* ---------- Шапка ---------- */
  .ab__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .ab__eyebrow {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .ab__intro {
    margin: 0;
    max-width: 62ch;
    font-size: var(--fs-15);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* ---------- Сцена ---------- */
  .ab__stage {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
    align-items: stretch;
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background: var(--glass-tint-liquid);
  }

  .ab-node {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    min-width: 0;
    transition:
      border-color var(--dur-med) var(--ease-standard),
      opacity var(--dur-med) var(--ease-standard);
  }
  .ab-node--daemon {
    border-color: color-mix(in srgb, var(--accent) 26%, var(--border));
  }

  .ab-node__head {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .ab-node__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-17);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-tight);
  }

  .ab-node__sub {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }

  .ab-node__cmd {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-secondary);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-elevated);
    word-break: break-all;
  }

  .ab-node__cmd-kind {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
  }

  .ab-node__dot {
    width: 8px;
    height: 8px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transition: background-color var(--dur-med) var(--ease-standard);
  }

  .ab-node__lock {
    display: inline-flex;
    color: var(--accent);
  }

  /* Активный узел текущего шага */
  .ab-node[data-active="true"] {
    border-color: color-mix(in srgb, var(--accent) 58%, var(--glass-edge));
  }
  .ab-node[data-active="true"] .ab-node__dot {
    background: var(--accent);
  }
  /* Узлы, ещё не задействованные на шаге, слегка приглушаем */
  .ab-node[data-dim="true"] { opacity: 0.42; }

  /* ---------- Режимы внутри демона ---------- */
  .ab-node__modes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    margin-top: 2px;
  }

  .ab-mode {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    padding: 3px var(--sp-2);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-muted);
    transition:
      color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard);
  }
  .ab-mode[data-on="true"] {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  /* ---------- Провода ---------- */
  .ab-wire {
    position: relative;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ab-wire__line {
    position: absolute;
    left: 50%;
    top: 0;
    height: 30px;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      color-mix(in srgb, var(--accent) 40%, var(--border)),
      transparent
    );
  }

  .ab-wire__pulse {
    position: absolute;
    left: 50%;
    top: 0;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    border-radius: var(--r-pill);
    background: var(--accent);
    opacity: 0;
  }

  .ab-wire__tag {
    position: absolute;
    left: calc(50% + 12px);
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    white-space: nowrap;
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .ab-wire__tag[data-on="true"] {
    opacity: 1;
    color: color-mix(in srgb, var(--accent) 70%, var(--text-secondary));
  }

  /* ---------- Telegram-карточка ---------- */
  .ab-node__cmd--tg { color: var(--text); }

  .ab-status {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    line-height: var(--lh-snug);
    min-height: 1.3em;
    transition: color var(--dur-med) var(--ease-standard);
  }
  .ab-status[data-state="waiting"] { color: var(--text-secondary); }
  .ab-status[data-state="approved"],
  .ab-status[data-state="denied"],
  .ab-status[data-state="timeout"] { color: var(--text); }
  .ab-status[data-state="approved"]::before { content: "✓ "; color: var(--accent); }
  .ab-status[data-state="denied"]::before,
  .ab-status[data-state="timeout"]::before { content: "✕ "; color: var(--text-secondary); }

  .ab-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-2);
  }

  .ab-btn {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    text-align: center;
    padding: var(--sp-2) var(--sp-2);
    border-radius: var(--r-sm);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    transition:
      border-color var(--dur-med) var(--ease-standard),
      color var(--dur-med) var(--ease-standard),
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .ab-btn--approve { border-color: color-mix(in srgb, var(--accent) 30%, var(--border)); }
  .ab-btn[data-picked="true"] {
    border-color: var(--accent);
    color: var(--text);
    transform: scale(1.04);
  }
  .ab-btn[data-dimmed="true"] { opacity: 0.3; }

  /* ---------- Панель объяснения ---------- */
  .ab__panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-height: 150px;
  }

  .ab__step-meta {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .ab__step-title {
    margin: 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-22);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
  }

  .ab__step-body {
    margin: 0;
    max-width: 64ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* мягкое появление текста при смене шага — только opacity/transform */
  .ab__panel[data-enter="true"] .ab__step-title,
  .ab__panel[data-enter="true"] .ab__step-body {
    animation: ab-fade var(--dur-slow) var(--ease-soft) both;
  }
  .ab__panel[data-enter="true"] .ab__step-body { animation-delay: 60ms; }

  @keyframes ab-fade {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---------- Управление ---------- */
  .ab__controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }

  .ab__dots {
    display: inline-flex;
    gap: var(--sp-2);
  }

  .ab__dot {
    position: relative;
    width: var(--tap-min);
    height: var(--tap-min);
    display: grid;
    place-items: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
  }
  .ab__dot-num {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    transition:
      border-color var(--dur-med) var(--ease-standard),
      color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard);
  }
  .ab__dot:hover .ab__dot-num { border-color: var(--border-hover); color: var(--text-secondary); }
  .ab__dot.is-active { color: var(--text); }
  .ab__dot.is-active .ab__dot-num {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 16%, transparent);
  }
  .ab__dot:focus-visible { outline: none; }
  .ab__dot:focus-visible .ab__dot-num {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .ab__nav {
    display: inline-flex;
    gap: var(--sp-2);
  }

  .ab__btn {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    padding: var(--sp-2) var(--sp-3);
    min-height: 38px;
    border-radius: var(--r-sm);
    border: var(--bw-thin) solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      border-color var(--dur-med) var(--ease-standard),
      color var(--dur-med) var(--ease-standard);
  }
  .ab__btn:hover { border-color: var(--border-hover); color: var(--text); }
  .ab__btn:disabled { opacity: 0.4; cursor: default; }
  .ab__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ab__btn--replay { border-color: color-mix(in srgb, var(--accent) 30%, var(--border)); }

  /* ---------- Инвариант ---------- */
  .ab__invariant {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-15);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }
  .ab__invariant-mark {
    flex: none;
    width: 22px;
    height: 2px;
    border-radius: var(--r-pill);
    background: var(--accent);
  }

  /* ---------- Широкая раскладка: горизонтальный поток ---------- */
  @container (min-width: 640px) {
    .ab__stage {
      grid-template-columns: 1fr auto 1.1fr auto 1fr;
      align-items: stretch;
    }
    .ab-wire { height: auto; width: 48px; }
    .ab-wire__line {
      top: 50%;
      left: 0;
      width: 48px;
      height: 1px;
      transform: translateY(-50%);
      background: linear-gradient(
        to right,
        transparent,
        color-mix(in srgb, var(--accent) 40%, var(--border)),
        transparent
      );
    }
    .ab-wire__pulse { top: 50%; left: 0; margin-top: -4px; margin-left: 0; }
    .ab-wire__tag {
      left: 50%;
      top: auto;
      bottom: -18px;
      transform: translateX(-50%);
    }
  }

  /* ---------- Пульс по проводу: ТОЛЬКО на видимой секции и активном проводе ---------- */
  @media (prefers-reduced-motion: no-preference) {
    .ab.is-inview .ab-wire__pulse[data-run="1"] {
      animation: ab-pulse-v var(--dur-glacial) var(--ease-standard) forwards;
    }
    @container (min-width: 640px) {
      .ab.is-inview .ab-wire__pulse[data-run="1"] {
        animation-name: ab-pulse-h;
      }
    }
  }

  @keyframes ab-pulse-v {
    0% { transform: translateY(0) scale(0.6); opacity: 0; }
    18% { opacity: 1; }
    82% { opacity: 1; }
    100% { transform: translateY(30px) scale(0.6); opacity: 0; }
  }
  @keyframes ab-pulse-h {
    0% { transform: translateX(0) scale(0.6); opacity: 0; }
    18% { opacity: 1; }
    82% { opacity: 1; }
    100% { transform: translateX(48px) scale(0.6); opacity: 0; }
  }

  /* ---------- Reduced motion: финальное читаемое состояние, без движения ---------- */
  @media (prefers-reduced-motion: reduce) {
    .ab-node,
    .ab-wire__tag,
    .ab__panel .ab__step-title,
    .ab__panel .ab__step-body {
      transform: none;
      transition: none;
      animation: none;
    }
  }

  /* ---------- Coarse pointer: без параллакса ---------- */
  @media (pointer: coarse) {
    .ab-node { transform: none; }
  }
</style>

<script>
  // Пошаговый рассказ о потоке одобрения. Дискретные шаги, без rAF: текст и
  // состояния сцены переключаются классами/атрибутами (только transform/opacity).
  // Автопереход ~4.5с/шаг, пауза при наведении/фокусе. Управление: вкладки,
  // prev/next, replay. Анимация загейчена за IntersectionObserver: за экраном
  // таймеры очищаются и .is-inview снимается.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-ab]");
    if (!root) return;

    const stage = root.querySelector<HTMLElement>("[data-stage]");
    const panel = root.querySelector<HTMLElement>("[data-panel]");
    const titleEl = root.querySelector<HTMLElement>("[data-step-title]");
    const bodyEl = root.querySelector<HTMLElement>("[data-step-body]");
    const numEl = root.querySelector<HTMLElement>("[data-step-num]");
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-go]"));
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]");
    const replayBtn = root.querySelector<HTMLButtonElement>("[data-replay]");
    if (!stage || !panel || !titleEl || !bodyEl) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const locale = document.documentElement.lang === "en" ? "en" : "ru";

    // Тексты шагов — параллельный массив к разметке (берём из data-атрибутов панели,
    // но проще держать рядом, синхронно с .astro). Считываем из DOM узлов вкладок,
    // чтобы не дублировать строки: title лежит в aria-label вкладки после ": ".
    const titles = dots.map((d) => {
      const label = d.getAttribute("aria-label") || "";
      const idx = label.indexOf(": ");
      return idx >= 0 ? label.slice(idx + 2) : label;
    });

    // Тела шагов держим здесь (двуязычно), синхронно с разметкой выше.
    const bodies = {
      ru: [
        "ИИ-агент прямо в твоём редакторе собирается запустить команду оболочки или вызвать MCP-инструмент. Установленный хук перехватывает вызов ДО запуска и ставит его на паузу. Так агент не может сам, без тебя, сделать что-то разрушительное.",
        "Хук отправляет запрос локальному демону по адресу 127.0.0.1 — это loopback, петля на саму себя: ничего не уходит в интернет, демон не слушает внешний порт. Запрос ещё и подписан секретным заголовком X-DotAgents-Secret, так что чужой процесс на машине не подсунет фальшивку.",
        "У сессии есть один из трёх режимов. remote — спрашивать тебя про каждое защищённое действие. readonly — авто-allow, только уведомить (когда смотришь, как агент работает). standby — авто-deny всего опасного (когда отошёл и не хочешь сюрпризов).",
        "В режиме remote демон шлёт тебе сообщение с самой командой и кнопками Allow / Deny. Telegram здесь — только канал доставки: код и контекст остаются на машине, в сообщении лишь то, что ты явно отправляешь своему боту. Агент тем временем реально стоит и ждёт.",
        "Агент ждёт не вечно: до HOOK_TIMEOUT_SECONDS (по умолчанию 90 секунд). Если ты не ответил, демон сам отвечает deny — это «безопасное по умолчанию». Если что-то пошло не так или тебя нет рядом, система запрещает, а не разрешает молча.",
        "Каждая кнопка несёт callback, подписанный HMAC-SHA256 (общий секрет проверяет подлинность) плюс одноразовый nonce и срок годности expires_at. Подменишь данные — подпись не сойдётся; нажмёшь повторно ту же кнопку — nonce уже сгорел. Подделка и повтор исключены.",
      ],
      en: [
        "An AI agent right inside your editor is about to run a shell command or call an MCP tool. An installed hook intercepts the call BEFORE it runs and pauses it. That means the agent cannot do anything destructive on its own without you.",
        "The hook sends the request to a local daemon at 127.0.0.1 — that is loopback, a wire that loops back to itself: nothing goes to the internet and the daemon listens on no public port. The request also carries a secret X-DotAgents-Secret header, so a stray process on the box cannot forge one.",
        "Each session is in one of three modes. remote — ask you about every protected action. readonly — auto-allow, notify only (while you watch the agent work). standby — auto-deny anything dangerous (when you stepped away and want no surprises).",
        "In remote mode the daemon sends you a message with the command itself and Allow / Deny buttons. Telegram is only the delivery channel here: your code and context stay on the machine, the message holds only what you explicitly send your own bot. Meanwhile the agent really sits and waits.",
        "The agent does not wait forever: up to HOOK_TIMEOUT_SECONDS (90s by default). If you do not reply, the daemon answers deny itself — that is the safe default. If something breaks or you are not around, the system blocks rather than silently allowing.",
        "Every button carries a callback signed with HMAC-SHA256 (a shared secret proves it is genuine) plus a one-time nonce and an expires_at deadline. Tamper with the data and the signature will not match; press the same button twice and the nonce is already spent. Forgery and replay are both ruled out.",
      ],
    }[locale];

    const status = {
      ru: {
        waiting: "ждёт твоего ответа…",
        approved: "разрешено · команда выполняется",
        denied: "отклонено · команда не запущена",
        timeout: "нет ответа → deny (fail-closed)",
        autoAllow: "readonly: авто-allow, только уведомление",
        autoDeny: "standby: авто-deny, не спрашивает",
      },
      en: {
        waiting: "waiting for your reply…",
        approved: "allowed · command runs",
        denied: "denied · command never runs",
        timeout: "no reply → deny (fail-closed)",
        autoAllow: "readonly: auto-allow, notify only",
        autoDeny: "standby: auto-deny, never asks",
      },
    }[locale];

    const total = titles.length;

    // Узлы и элементы сцены
    const nodeAgent = stage.querySelector<HTMLElement>('[data-node="agent"]');
    const nodeDaemon = stage.querySelector<HTMLElement>('[data-node="daemon"]');
    const nodeTg = stage.querySelector<HTMLElement>('[data-node="tg"]');
    const pulse1 = stage.querySelector<HTMLElement>('[data-pulse="1"]');
    const pulse2 = stage.querySelector<HTMLElement>('[data-pulse="2"]');
    const statusEl = stage.querySelector<HTMLElement>("[data-status]");
    const btnApprove = stage.querySelector<HTMLElement>('[data-btn="approve"]');
    const btnDeny = stage.querySelector<HTMLElement>('[data-btn="deny"]');
    const modeEls = Array.from(stage.querySelectorAll<HTMLElement>(".ab-mode"));
    const loopbackTag = stage.querySelector<HTMLElement>(".ab-wire--1 .ab-wire__tag");
    const sigTag = stage.querySelector<HTMLElement>("[data-sig-tag]");

    const timers: number[] = [];
    const clearTimers = () => {
      timers.forEach((id) => clearTimeout(id));
      timers.length = 0;
    };

    let current = -1;
    let inview = false;

    function firePulse(el: HTMLElement | null) {
      if (!el || reduce || !inview) return;
      el.removeAttribute("data-run");
      void el.offsetWidth; // reflow → рестарт keyframes
      el.setAttribute("data-run", "1");
    }

    function setActiveNode(key: "agent" | "daemon" | "tg" | null) {
      const map = { agent: nodeAgent, daemon: nodeDaemon, tg: nodeTg };
      (Object.keys(map) as Array<keyof typeof map>).forEach((k) => {
        map[k]?.setAttribute("data-active", k === key ? "true" : "false");
      });
    }

    function dim(keys: Array<"agent" | "daemon" | "tg">) {
      const map = { agent: nodeAgent, daemon: nodeDaemon, tg: nodeTg };
      (Object.keys(map) as Array<keyof typeof map>).forEach((k) => {
        map[k]?.setAttribute("data-dim", keys.includes(k) ? "true" : "false");
      });
    }

    function setModes(active: string | null) {
      modeEls.forEach((m) =>
        m.setAttribute("data-on", m.dataset.mode === active ? "true" : "false"),
      );
    }

    function setStatus(state: string, text: string) {
      if (!statusEl) return;
      statusEl.setAttribute("data-state", state);
      statusEl.textContent = text;
    }

    function resetButtons() {
      [btnApprove, btnDeny].forEach((b) => {
        b?.removeAttribute("data-picked");
        b?.removeAttribute("data-dimmed");
      });
    }

    // Привести сцену к состоянию шага i (детерминированно, без случайностей).
    function paintStage(i: number) {
      resetButtons();
      setModes(null);
      loopbackTag?.setAttribute("data-on", "false");
      sigTag?.setAttribute("data-on", "false");
      stage!.setAttribute("data-step", String(i));

      switch (i) {
        case 0: // агент перехвачен
          setActiveNode("agent");
          dim(["daemon", "tg"]);
          setStatus("idle", status.waiting);
          break;
        case 1: // loopback к демону
          setActiveNode("daemon");
          dim(["tg"]);
          loopbackTag?.setAttribute("data-on", "true");
          firePulse(pulse1);
          setStatus("idle", status.waiting);
          break;
        case 2: // режимы
          setActiveNode("daemon");
          dim([]);
          setModes("remote");
          setStatus("idle", status.waiting);
          break;
        case 3: // запрос в Telegram
          setActiveNode("tg");
          dim([]);
          setModes("remote");
          firePulse(pulse2);
          setStatus("waiting", status.waiting);
          break;
        case 4: // fail-closed таймаут
          setActiveNode("tg");
          dim([]);
          setModes("remote");
          setStatus("timeout", status.timeout);
          btnDeny?.setAttribute("data-picked", "true");
          btnApprove?.setAttribute("data-dimmed", "true");
          break;
        case 5: // подпись
          setActiveNode("tg");
          dim([]);
          setModes("remote");
          sigTag?.setAttribute("data-on", "true");
          setStatus("approved", status.approved);
          btnApprove?.setAttribute("data-picked", "true");
          btnDeny?.setAttribute("data-dimmed", "true");
          break;
      }
    }

    function go(i: number, opts: { auto?: boolean } = {}) {
      const idx = ((i % total) + total) % total;
      if (idx === current) return;
      current = idx;

      // текст
      if (titleEl) titleEl.textContent = titles[idx] ?? "";
      if (bodyEl) bodyEl.textContent = bodies[idx] ?? "";
      if (numEl) numEl.textContent = String(idx + 1);

      // мягкое появление текста
      if (!reduce) {
        panel!.removeAttribute("data-enter");
        void panel!.offsetWidth;
        panel!.setAttribute("data-enter", "true");
      }

      // вкладки
      dots.forEach((d, di) => {
        const on = di === idx;
        d.classList.toggle("is-active", on);
        d.setAttribute("aria-selected", on ? "true" : "false");
      });

      // сцена
      paintStage(idx);

      // если пользователь переключил вручную — не сбрасываем автоплей грубо,
      // но перезапускаем таймер от текущего шага
      if (!opts.auto) restartAuto();
    }

    // ---------- Автопереход ----------
    const STEP_MS = 4500;
    let paused = false;
    let autoTimer = 0;

    function clearAuto() {
      if (autoTimer) {
        clearTimeout(autoTimer);
        autoTimer = 0;
      }
    }
    function scheduleAuto() {
      clearAuto();
      if (reduce || !inview || paused) return;
      autoTimer = window.setTimeout(() => {
        go(current + 1, { auto: true });
        scheduleAuto();
      }, STEP_MS);
    }
    function restartAuto() {
      scheduleAuto();
    }

    // ---------- Управление ----------
    dots.forEach((d) =>
      d.addEventListener("click", () => go(Number(d.dataset.go))),
    );
    prevBtn?.addEventListener("click", () => go(current - 1));
    nextBtn?.addEventListener("click", () => go(current + 1));
    replayBtn?.addEventListener("click", () => {
      current = -1;
      go(0);
    });

    // Пауза автоплея при наведении/фокусе внутри секции
    const pause = () => {
      paused = true;
      clearAuto();
    };
    const resume = () => {
      paused = false;
      scheduleAuto();
    };
    root.addEventListener("pointerenter", pause);
    root.addEventListener("pointerleave", resume);
    root.addEventListener("focusin", pause);
    root.addEventListener("focusout", (e) => {
      if (!root.contains(e.relatedTarget as Node)) resume();
    });

    // ---------- Видимость ----------
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            if (!inview) {
              inview = true;
              root.classList.add("is-inview");
              if (current < 0) go(0);
              else paintStage(current); // перерисовать (мог сброситься пульс)
              scheduleAuto();
            }
          } else if (inview) {
            inview = false;
            root.classList.remove("is-inview");
            clearAuto();
            clearTimers();
          }
        }
      },
      { threshold: 0.3 },
    );
    io.observe(root);

    // Под reduced-motion показываем первый шаг сразу и не двигаем; пользователь
    // листает руками. Финальное состояние остаётся читаемым.
    if (reduce && current < 0) go(0);

    window.addEventListener(
      "pagehide",
      () => {
        clearAuto();
        clearTimers();
        io.disconnect();
      },
      { once: true },
    );
  })();
</script>
