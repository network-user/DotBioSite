---
/**
 * AgentsBridge.astro — сигнатурная визуализация DotAgents.
 *
 * Концепция: AI-агент нарвался на рискованную команду — хук перехватил.
 * Посетитель выбирает сценарий (3 варианта) и жмёт Allow / Deny в мок-телефоне.
 * Режим демона меняет поведение: remote — спрашивает, readonly — авто-allow,
 * standby — авто-deny. Никакого HMAC-seal и audit-log — только ключевая история.
 *
 * Перфоманс: только transform/opacity. Никаких rAF — отсчёт через CSS-анимацию +
 * один setInterval на текст. Все анимации под .is-inview (IntersectionObserver),
 * prefers-reduced-motion → финальное статичное состояние.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const scenarios: {
  id: string;
  label: Bi;
  kind: Bi;
  cmd: string;
  transcript: { who: "user" | "agent" | "tool"; text: Bi }[];
}[] = [
  {
    id: "shell-clean",
    label: { ru: "Удали сборку", en: "Clean build" },
    kind: { ru: "shell · risk: high", en: "shell · risk: high" },
    cmd: "rm -rf dist/",
    transcript: [
      { who: "user", text: { ru: "очисти артефакты сборки", en: "clean up build artifacts" } },
      { who: "agent", text: { ru: "Нашёл dist/. Удаляю рекурсивно.", en: "Found dist/. Removing recursively." } },
      { who: "tool", text: { ru: "shell · rm -rf · ждёт решения", en: "shell · rm -rf · awaiting decision" } },
    ],
  },
  {
    id: "git-force",
    label: { ru: "Форс-пуш", en: "Force push" },
    kind: { ru: "shell · risk: high", en: "shell · risk: high" },
    cmd: "git push --force origin main",
    transcript: [
      { who: "user", text: { ru: "поправь коммит и запуш", en: "fix the commit and push" } },
      { who: "agent", text: { ru: "Amend готов. Force push в main.", en: "Amend done. Force pushing to main." } },
      { who: "tool", text: { ru: "shell · git push --force · ждёт", en: "shell · git push --force · waiting" } },
    ],
  },
  {
    id: "mcp-env",
    label: { ru: "Читай .env", en: "Read .env" },
    kind: { ru: "MCP · risk: critical", en: "MCP · risk: critical" },
    cmd: 'read_file(".env")',
    transcript: [
      { who: "user", text: { ru: "покажи настройки подключения к базе", en: "show the database connection settings" } },
      { who: "agent", text: { ru: "Ищу в .env через MCP read_file.", en: "Checking .env via MCP read_file." } },
      { who: "tool", text: { ru: "MCP read_file · .env · ждёт решения", en: "MCP read_file · .env · awaiting decision" } },
    ],
  },
];

const modes: { id: string; label: string; hint: Bi }[] = [
  { id: "remote",   label: "remote",   hint: { ru: "ждёт твоего ответа в Telegram", en: "waits for your answer in Telegram" } },
  { id: "readonly", label: "readonly", hint: { ru: "авто-allow, просто уведомляет", en: "auto-allow, just notifies" } },
  { id: "standby",  label: "standby",  hint: { ru: "авто-deny, не спрашивает", en: "auto-deny, never asks" } },
];

const copy: Record<string, Bi> = {
  intro: {
    ru: "AI-агент нарвался на рискованную команду — хук DotAgents перехватил её и ждёт твоего слова. Выбери сценарий, нажми Allow или Deny.",
    en: "An AI agent hit a risky command — the DotAgents hook caught it and is waiting for your call. Pick a scenario, then tap Allow or Deny.",
  },
  session:      { ru: "сессия #a3f1 · Claude Code", en: "session #a3f1 · Claude Code" },
  intercepted:  { ru: "хук перехватил · ждёт решения", en: "hook caught it · awaiting decision" },
  agAllowed:    { ru: "✓ агент продолжает", en: "✓ agent continues" },
  agDenied:     { ru: "✕ агент заблокирован", en: "✕ agent blocked" },
  tgBot:        { ru: "DotAgents", en: "DotAgents" },
  tgYou:        { ru: "твой телефон", en: "your phone" },
  allow:        { ru: "Allow", en: "Allow" },
  deny:         { ru: "Deny", en: "Deny" },
  outcomeAllow: { ru: "✓ Разрешено — команда выполняется", en: "✓ Allowed — command is running" },
  outcomeDeny:  { ru: "✕ Заблокировано — команда не запустилась", en: "✕ Blocked — command never ran" },
  outcomeTimeout:  { ru: "Тишина → deny (fail-closed)", en: "Silence → deny (fail-closed)" },
  outcomeReadonly: { ru: "авто-allow · уведомление отправлено", en: "auto-allowed · notification sent" },
  outcomeStandby:  { ru: "авто-deny · агент заблокирован", en: "auto-deny · agent blocked" },
  modeLabel:    { ru: "Режим демона", en: "Daemon mode" },
  timerHint:    { ru: "тишина = deny (fail-closed)", en: "silence = deny (fail-closed)" },
  invariant: {
    ru: "Код, approvals и transcript не покидают машину. API слушает только на 127.0.0.1.",
    en: "Code, approvals, and transcript never leave the machine. API listens on 127.0.0.1 only.",
  },
};
---

<section
  class="ab"
  data-ab
  data-locale={locale}
  aria-label={t({ ru: "Интерактивный демо DotAgents", en: "DotAgents interactive demo" })}
>
  <p class="ab__intro">{t(copy.intro)}</p>

  <!-- Сценарии -->
  <div class="ab-tabs" role="tablist" aria-label={t({ ru: "Сценарии", en: "Scenarios" })}>
    {scenarios.map((s, i) => (
      <button
        type="button"
        class="ab-tab"
        role="tab"
        aria-selected={i === 0 ? "true" : "false"}
        data-tab={s.id}
        style={`--i:${i}`}
      >
        <span class="ab-tab__label">{t(s.label)}</span>
        <span class="ab-tab__kind mono">{t(s.kind)}</span>
      </button>
    ))}
  </div>

  <!-- Основная зона: терминал + телефон -->
  <div class="ab__main">
    <!-- Терминал -->
    <div class="ab-term" aria-label={t({ ru: "Терминал агента", en: "Agent terminal" })}>
      <div class="ab-term__chrome">
        <span class="ab-term__dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="ab-term__tab mono">{t(copy.session)}</span>
      </div>
      <div class="ab-term__body">
        {scenarios.map((s, si) => (
          <ol
            class="ab-term__log"
            data-log={s.id}
            aria-hidden="true"
            style={si !== 0 ? "display:none" : undefined}
          >
            {s.transcript.map((l, i) => (
              <li class={`ab-term__line ab-term__line--${l.who}`} style={`--i:${i}`}>
                <span class="ab-term__who mono">
                  {l.who === "user" ? "you" : l.who === "agent" ? " ai" : "  →"}
                </span>
                <span class="ab-term__txt">{t(l.text)}</span>
              </li>
            ))}
          </ol>
        ))}

        <!-- Перехваченный вызов -->
        <div class="ab-call" data-call data-resolved="">
          <div class="ab-call__row">
            <span class="ab-call__dot" aria-hidden="true"></span>
            <span class="ab-call__kind mono" data-call-kind>{t(scenarios[0].kind)}</span>
            <span class="ab-call__state mono" data-call-state aria-live="polite">{t(copy.intercepted)}</span>
          </div>
          <code class="ab-call__cmd mono">
            <span class="ab-call__prompt" aria-hidden="true">$ </span><span
              data-call-cmd>{scenarios[0].cmd}</span><span
              class="ab-call__caret" aria-hidden="true"></span>
          </code>
        </div>
      </div>
    </div>

    <!-- Телефон -->
    <div class="ab-phone-wrap">
      <div class="ab-phone">
        <div class="ab-phone__top" aria-hidden="true">
          <span class="ab-phone__notch"></span>
        </div>
        <div class="ab-phone__screen">
          <div class="ab-phone__bar">
            <span class="ab-phone__ava" aria-hidden="true">⬡</span>
            <span class="ab-phone__name mono">{t(copy.tgBot)}</span>
            <span class="ab-phone__you mono">{t(copy.tgYou)}</span>
          </div>
          <div class="ab-msg" data-msg data-state="pending">
            <code class="ab-msg__cmd mono" data-msg-cmd>{scenarios[0].cmd}</code>
            <span class="ab-msg__kind mono" data-msg-kind>{t(scenarios[0].kind)}</span>
            <div class="ab-timer" data-timer hidden>
              <div class="ab-timer__track">
                <div class="ab-timer__fill" data-timer-fill></div>
              </div>
              <span class="ab-timer__text mono">
                <span data-timer-num>10</span>s · {t(copy.timerHint)}
              </span>
            </div>
            <div class="ab-msg__btns">
              <button type="button" class="ab-btn ab-btn--allow" data-act="allow" disabled>
                ✓ {t(copy.allow)}
              </button>
              <button type="button" class="ab-btn ab-btn--deny" data-act="deny" disabled>
                ✕ {t(copy.deny)}
              </button>
            </div>
            <p class="ab-msg__outcome" data-outcome hidden></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Режим демона -->
  <div class="ab-modes">
    <span class="ab-modes__lbl">{t(copy.modeLabel)}</span>
    <div class="ab-modes__row" role="radiogroup" aria-label={t(copy.modeLabel)}>
      <span class="ab-modes__glide" data-glide aria-hidden="true"></span>
      {modes.map((m, i) => (
        <button
          type="button"
          class="ab-mode"
          role="radio"
          aria-checked={i === 0 ? "true" : "false"}
          data-mode={m.id}
          style={`--i:${i}`}
        >
          <span class="ab-mode__id mono">{m.label}</span>
          <span class="ab-mode__hint">{t(m.hint)}</span>
        </button>
      ))}
    </div>
  </div>

  <p class="ab__inv">
    <span class="ab__inv-dot" aria-hidden="true"></span>
    {t(copy.invariant)}
  </p>
</section>

<style>
  /* === Контейнер === */
  .ab {
    --accent: var(--project-accent);
    --ab-line:  color-mix(in srgb, var(--accent) 40%, transparent);
    --ab-soft:  color-mix(in srgb, var(--accent) 13%, transparent);
    --ab-faint: color-mix(in srgb, var(--accent)  7%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    container-type: inline-size;
  }
  .ab :global(.mono) { font-family: var(--font-stack-mono); }

  .ab__intro {
    margin: 0;
    max-width: 62ch;
    font-size: var(--fs-15);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* === Сценарии === */
  .ab-tabs {
    display: flex;
    gap: var(--sp-2);
    /* Горизонтальный скролл на мобиле вместо переноса */
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px; /* чтобы тень активного таба не обрезалась */
  }
  .ab-tabs::-webkit-scrollbar { display: none; }
  .ab-tab {
    appearance: none;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    cursor: pointer;
    text-align: left;
    flex: none; /* не сжимается при скролле */
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background    var(--dur-fast) var(--ease-standard);
  }
  .ab-tab:hover { border-color: var(--border-hover); }
  .ab-tab[aria-selected="true"] {
    border-color: var(--ab-line);
    background: var(--ab-faint);
  }
  /* Тап-фидбэк на тач-устройствах */
  @media (hover: none) {
    .ab-tab:active { transform: scale(0.97); opacity: 0.8; }
  }
  .ab-tab__label {
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    color: var(--text);
    line-height: 1;
  }
  .ab-tab__kind {
    font-size: var(--fs-11);
    color: var(--text-muted);
    line-height: 1;
  }

  /* === Основной грид === */
  .ab__main {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @container (min-width: 560px) {
    .ab__main {
      grid-template-columns: 1fr minmax(230px, 290px);
      align-items: start;
    }
  }

  /* === Терминал === */
  .ab-term {
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    overflow: hidden;
    min-width: 0;
  }
  .ab-term__chrome {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }
  .ab-term__dots {
    display: inline-flex;
    gap: 5px;
    flex: none;
  }
  .ab-term__dots i {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--surface-3);
  }
  .ab-term__tab {
    font-size: var(--fs-12);
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ab-term__body {
    padding: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .ab-term__log {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .ab-term__line {
    display: grid;
    grid-template-columns: 2.4em 1fr;
    gap: var(--sp-2);
    align-items: baseline;
  }
  /* Анимация строк — только когда лог помечен data-animate и раздел in-view */
  .ab.is-inview .ab-term__log[data-animate] .ab-term__line {
    animation: ab-line-in var(--dur-slow) var(--ease-soft) both;
    animation-delay: calc(var(--i) * 110ms + 150ms);
  }
  @keyframes ab-line-in {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ab-term__line { animation: none !important; }
  }
  .ab-term__who {
    font-size: var(--fs-11);
    color: var(--text-faint);
    text-align: right;
    white-space: nowrap;
  }
  .ab-term__line--agent .ab-term__who {
    color: color-mix(in srgb, var(--accent) 70%, var(--text-faint));
  }
  .ab-term__txt {
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
  }
  .ab-term__line--user .ab-term__txt { color: var(--text); }
  .ab-term__line--tool .ab-term__txt { color: var(--text-muted); }

  /* === Перехваченный вызов === */
  .ab-call {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--ab-line);
    border-left: 3px solid var(--accent);
    border-radius: var(--r-sm);
    background: var(--surface);
    transition:
      border-color var(--dur-med) var(--ease-standard),
      background   var(--dur-med) var(--ease-standard);
  }
  .ab-call[data-resolved="allow"] {
    background: var(--ab-faint);
  }
  .ab-call[data-resolved="deny"] {
    border-left-color: var(--text-muted);
    border-color: var(--border);
  }
  .ab-call__row {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .ab-call__dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: 50%;
    background: var(--accent);
    transition: background var(--dur-med) var(--ease-standard);
  }
  .ab.is-inview .ab-call[data-resolved=""] .ab-call__dot {
    animation: ab-pulse 1500ms ease-in-out infinite;
  }
  @keyframes ab-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.85); }
    50%       { opacity: 1;   transform: scale(1.18); }
  }
  .ab-call[data-resolved="deny"] .ab-call__dot { background: var(--text-muted); }
  .ab-call__kind {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .ab-call__state {
    margin-left: auto;
    font-size: var(--fs-11);
    color: color-mix(in srgb, var(--accent) 65%, var(--text-muted));
    text-align: right;
    transition: color var(--dur-med) var(--ease-standard);
  }
  .ab-call[data-resolved="allow"] .ab-call__state { color: var(--text); }
  .ab-call[data-resolved="deny"]  .ab-call__state { color: var(--text-muted); }

  .ab-call__cmd {
    font-size: var(--fs-14);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .ab-call__prompt { color: var(--accent); }
  .ab-call__caret {
    display: inline-block;
    width: 7px;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    transform: translateY(1px);
  }
  .ab.is-inview .ab-call[data-resolved=""] .ab-call__caret {
    animation: ab-blink 1100ms steps(2, jump-none) infinite;
  }
  @keyframes ab-blink {
    from, to { opacity: 1; }
    50%       { opacity: 0; }
  }
  .ab-call[data-resolved="deny"]  .ab-call__caret { opacity: 0.2; }

  /* === Телефон === */
  .ab-phone-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .ab-phone {
    width: 100%;
    max-width: 290px;
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-xl);
    background: var(--bg-elevated);
    padding: var(--sp-3);
  }
  .ab-phone__top {
    display: flex;
    justify-content: center;
    padding-bottom: var(--sp-2);
  }
  .ab-phone__notch {
    display: block;
    width: 52px;
    height: 4px;
    border-radius: var(--r-pill);
    background: var(--border-hover);
  }
  .ab-phone__screen {
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: var(--bg-deep);
    overflow: hidden;
  }
  .ab-phone__bar {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }
  .ab-phone__ava {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    flex: none;
    border-radius: 50%;
    background: var(--ab-soft);
    color: var(--accent);
    font-size: var(--fs-13);
  }
  .ab-phone__name {
    font-size: var(--fs-13);
    font-weight: var(--fw-semibold);
    color: var(--text);
  }
  .ab-phone__you {
    margin-left: auto;
    font-size: var(--fs-10);
    color: var(--text-faint);
  }

  /* === Сообщение в телефоне === */
  .ab-msg {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3);
    margin: var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    transition: border-color var(--dur-med) var(--ease-standard);
  }
  .ab-msg[data-state="pending"] {
    border-color: var(--ab-line);
  }
  .ab-msg[data-state="allowed"] {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }
  .ab-msg[data-state="denied"] {
    border-color: var(--border);
  }
  .ab-msg__cmd {
    display: block;
    font-size: var(--fs-12);
    color: var(--text);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--r-xs);
    background: var(--bg-elevated);
    overflow-wrap: anywhere;
    align-self: flex-start;
    max-width: 100%;
  }
  .ab-msg__kind {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }

  /* Таймер (progress bar) */
  .ab-timer {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ab-timer[hidden] { display: none; }
  .ab-timer__track {
    height: 2px;
    border-radius: var(--r-pill);
    background: var(--border);
    overflow: hidden;
  }
  .ab-timer__fill {
    height: 100%;
    width: 100%;
    border-radius: var(--r-pill);
    background: var(--accent);
    transform-origin: left;
    transform: scaleX(1);
  }
  .ab.is-inview .ab-timer__fill[data-run] {
    animation: ab-drain var(--timer-ms, 10000ms) linear forwards;
  }
  @keyframes ab-drain {
    from { transform: scaleX(1); }
    to   { transform: scaleX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ab-timer__fill { animation: none !important; }
  }
  .ab-timer__text {
    font-size: var(--fs-10);
    color: var(--text-faint);
  }

  /* Кнопки Allow / Deny */
  .ab-msg__btns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-2);
  }
  .ab-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-1);
    min-height: var(--tap-min, 44px);
    padding: var(--sp-2);
    border-radius: var(--r-md);
    border: var(--bw-thin) solid var(--border);
    background: var(--surface);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    color: var(--text);
    cursor: pointer;
    transition:
      background    var(--dur-fast) var(--ease-standard),
      border-color  var(--dur-fast) var(--ease-standard),
      opacity       var(--dur-fast) var(--ease-standard),
      color         var(--dur-fast) var(--ease-standard);
  }
  .ab-btn:disabled { opacity: 0.35; cursor: default; }
  .ab-btn--allow:not(:disabled):hover {
    background: var(--ab-soft);
    border-color: var(--ab-line);
  }
  .ab-btn--deny:not(:disabled):hover {
    background: color-mix(in srgb, var(--text-muted) 12%, transparent);
  }
  /* Тап-фидбэк */
  @media (hover: none) {
    .ab-btn:not(:disabled):active { transform: scale(0.95); }
  }
  .ab-btn--allow[data-picked] {
    background: var(--ab-soft);
    border-color: var(--ab-line);
    color: var(--accent);
    opacity: 1;
  }
  .ab-btn--deny[data-picked] {
    background: color-mix(in srgb, var(--text-muted) 12%, transparent);
    border-color: var(--text-muted);
    opacity: 1;
  }
  .ab-btn[data-faded] { opacity: 0.2; }

  /* Результат */
  .ab-msg__outcome {
    margin: 0;
    font-size: var(--fs-12);
    line-height: var(--lh-snug);
    font-family: var(--font-stack-mono);
  }
  .ab-msg__outcome[hidden] { display: none; }
  .ab-msg__outcome[data-kind="allow"]   { color: var(--accent); }
  .ab-msg__outcome[data-kind="deny"],
  .ab-msg__outcome[data-kind="timeout"] { color: var(--text-muted); }

  /* === Режим демона === */
  .ab-modes {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .ab-modes__lbl {
    font-size: var(--fs-12);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ab-modes__row {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    overflow: hidden;
  }
  .ab-modes__glide {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 33.333%;
    background: var(--ab-soft);
    border-radius: calc(var(--r-md) - 1px);
    transition: transform var(--dur-med) var(--ease-spring);
    pointer-events: none;
  }
  .ab-mode {
    appearance: none;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--sp-3);
    border: none;
    border-right: var(--bw-thin) solid var(--border);
    background: transparent;
    cursor: pointer;
    text-align: left;
  }
  .ab-mode:last-child { border-right: none; }
  @media (hover: none) {
    .ab-mode:active { opacity: 0.7; }
  }
  .ab-mode__id {
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .ab-mode[aria-checked="true"] .ab-mode__id { color: var(--accent); }
  .ab-mode__hint {
    font-size: var(--fs-11);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }

  /* На узких контейнерах — стек */
  @container (max-width: 420px) {
    .ab-modes__row { grid-template-columns: 1fr; }
    .ab-mode { border-right: none; border-bottom: var(--bw-thin) solid var(--border); }
    .ab-mode:last-child { border-bottom: none; }
    .ab-modes__glide { display: none; }
  }

  /* === Инвариант === */
  .ab__inv {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-13);
    color: var(--text-faint);
  }
  .ab__inv-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    flex: none;
    border-radius: 50%;
    background: var(--ab-line);
    flex-shrink: 0;
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>("[data-ab]");
  if (root) {
    const locale = root.dataset.locale ?? "ru";
    const isEn = locale === "en";
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const TIMER_MS = 10_000;

    // Строки (зеркало фронтматтера)
    const txt = {
      intercepted:    isEn ? "hook caught it · awaiting decision" : "хук перехватил · ждёт решения",
      agAllowed:      isEn ? "✓ agent continues"   : "✓ агент продолжает",
      agDenied:       isEn ? "✕ agent blocked"      : "✕ агент заблокирован",
      outcomeAllow:   isEn ? "✓ Allowed — command is running"       : "✓ Разрешено — команда выполняется",
      outcomeDeny:    isEn ? "✕ Blocked — command never ran"        : "✕ Заблокировано — команда не запустилась",
      outcomeTimeout: isEn ? "Silence → deny (fail-closed)"         : "Тишина → deny (fail-closed)",
      outcomeReadonly:isEn ? "auto-allowed · notification sent"     : "авто-allow · уведомление отправлено",
      outcomeStandby: isEn ? "auto-deny · agent blocked"            : "авто-deny · агент заблокирован",
    };

    // Данные сценариев (зеркало фронтматтера)
    const SCENARIOS: Record<string, { cmd: string; kind: string }> = {
      "shell-clean": { cmd: "rm -rf dist/",                kind: "shell · risk: high" },
      "git-force":   { cmd: "git push --force origin main", kind: "shell · risk: high" },
      "mcp-env":     { cmd: 'read_file(".env")',            kind: isEn ? "MCP · risk: critical" : "MCP · risk: critical" },
    };

    // DOM
    const tabs      = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-tab]"));
    const logs      = Array.from(root.querySelectorAll<HTMLElement>("[data-log]"));
    const callBox   = root.querySelector<HTMLElement>("[data-call]");
    const callKind  = root.querySelector<HTMLElement>("[data-call-kind]");
    const callState = root.querySelector<HTMLElement>("[data-call-state]");
    const callCmd   = root.querySelector<HTMLElement>("[data-call-cmd]");
    const msgEl     = root.querySelector<HTMLElement>("[data-msg]");
    const msgCmd    = root.querySelector<HTMLElement>("[data-msg-cmd]");
    const msgKind   = root.querySelector<HTMLElement>("[data-msg-kind]");
    const timerEl   = root.querySelector<HTMLElement>("[data-timer]");
    const timerFill = root.querySelector<HTMLElement>("[data-timer-fill]");
    const timerNum  = root.querySelector<HTMLElement>("[data-timer-num]");
    const allowBtn  = root.querySelector<HTMLButtonElement>('[data-act="allow"]');
    const denyBtn   = root.querySelector<HTMLButtonElement>('[data-act="deny"]');
    const outcomeEl = root.querySelector<HTMLElement>("[data-outcome]");
    const modeEls   = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));
    const glide     = root.querySelector<HTMLElement>("[data-glide]");

    // Состояние
    let inview          = false;
    let activeScenario  = "shell-clean";
    let activeMode      = "remote";
    let timerHandle     = 0;
    let tickHandle      = 0;
    let pendingHandle   = 0;

    // IntersectionObserver
    const io = new IntersectionObserver(
      ([e]) => {
        inview = !!e?.isIntersecting;
        if (inview) {
          root.classList.add("is-inview");
          // Анимируем первый лог при входе в viewport
          const first = root.querySelector<HTMLElement>("[data-log]");
          if (first) triggerLogAnim(first);
          // Запускаем начальное состояние через 600ms (после анимации строк)
          pendingHandle = window.setTimeout(() => applyMode(activeMode), 600);
        }
      },
      { threshold: 0.1 }
    );
    io.observe(root);

    // Пауза таймера при скрытой вкладке
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopTimer();
    });

    // === Таймер ===
    function stopTimer() {
      if (timerHandle)   { clearTimeout(timerHandle);   timerHandle   = 0; }
      if (tickHandle)    { clearInterval(tickHandle);   tickHandle    = 0; }
      if (pendingHandle) { clearTimeout(pendingHandle); pendingHandle = 0; }
      timerFill?.removeAttribute("data-run");
      if (timerEl) timerEl.hidden = true;
    }

    function startTimer() {
      stopTimer();
      if (!timerEl || !timerFill) return;
      timerEl.hidden = false;
      const totalSec = Math.round(TIMER_MS / 1000);
      if (timerNum) timerNum.textContent = String(totalSec);

      if (!reduce && inview) {
        timerEl.style.setProperty("--timer-ms", `${TIMER_MS}ms`);
        void timerFill.offsetWidth; // restart animation
        timerFill.setAttribute("data-run", "1");
      }

      const startedAt = Date.now();
      tickHandle = window.setInterval(() => {
        const rem = Math.max(0, Math.ceil((TIMER_MS - (Date.now() - startedAt)) / 1000));
        if (timerNum) timerNum.textContent = String(rem);
      }, 400);

      timerHandle = window.setTimeout(() => {
        stopTimer();
        resolve("timeout");
      }, TIMER_MS);
    }

    // === Кнопки ===
    function setEnabled(on: boolean) {
      if (!allowBtn || !denyBtn) return;
      allowBtn.disabled = !on;
      denyBtn.disabled  = !on;
      allowBtn.removeAttribute("data-picked");
      allowBtn.removeAttribute("data-faded");
      denyBtn.removeAttribute("data-picked");
      denyBtn.removeAttribute("data-faded");
    }

    function setOutcome(kind: string, text: string) {
      if (!outcomeEl) return;
      outcomeEl.setAttribute("data-kind", kind);
      outcomeEl.textContent = text;
      outcomeEl.hidden = false;
    }

    // === Резолв ===
    function resolve(action: "allow" | "deny" | "timeout") {
      stopTimer();
      setEnabled(false);

      const allowed = action === "allow";
      callBox?.setAttribute("data-resolved", allowed ? "allow" : "deny");
      if (callState) callState.textContent = allowed ? txt.agAllowed : txt.agDenied;
      msgEl?.setAttribute("data-state", allowed ? "allowed" : "denied");

      if (allowed) {
        allowBtn?.setAttribute("data-picked", "1");
        denyBtn?.setAttribute("data-faded",  "1");
        setOutcome("allow", txt.outcomeAllow);
      } else if (action === "deny") {
        denyBtn?.setAttribute("data-picked",  "1");
        allowBtn?.setAttribute("data-faded", "1");
        setOutcome("deny", txt.outcomeDeny);
      } else {
        denyBtn?.setAttribute("data-picked",  "1");
        allowBtn?.setAttribute("data-faded", "1");
        setOutcome("timeout", txt.outcomeTimeout);
      }
    }

    // === Анимация лога ===
    function triggerLogAnim(logEl: HTMLElement) {
      if (reduce) return;
      logEl.removeAttribute("data-animate");
      void logEl.offsetWidth; // reflow → перезапуск animation
      logEl.setAttribute("data-animate", "1");
    }

    // === Переключение сценария ===
    function selectScenario(id: string) {
      if (!id || !SCENARIOS[id]) return;
      activeScenario = id;

      // Tabs
      tabs.forEach(t => t.setAttribute("aria-selected", t.dataset.tab === id ? "true" : "false"));

      // Логи: показываем нужный, скрываем остальные
      logs.forEach(l => {
        const active = l.dataset.log === id;
        l.style.display = active ? "" : "none";
        if (active) triggerLogAnim(l);
      });

      // Обновляем тексты
      const s = SCENARIOS[id];
      if (callCmd)  callCmd.textContent  = s.cmd;
      if (callKind) callKind.textContent = s.kind;
      if (msgCmd)   msgCmd.textContent   = s.cmd;
      if (msgKind)  msgKind.textContent  = s.kind;

      // Сброс состояния
      callBox?.setAttribute("data-resolved", "");
      if (callState) callState.textContent = txt.intercepted;
      msgEl?.setAttribute("data-state", "pending");
      if (outcomeEl) outcomeEl.hidden = true;

      stopTimer();
      setEnabled(false);

      // Применяем режим после паузы (чтобы транскрипт успел анимироваться)
      pendingHandle = window.setTimeout(() => applyMode(activeMode), 500);
    }

    // === Переключение режима ===
    function applyMode(mode: string) {
      stopTimer();
      setEnabled(false);
      if (outcomeEl) outcomeEl.hidden = true;
      callBox?.setAttribute("data-resolved", "");
      if (callState) callState.textContent = txt.intercepted;
      msgEl?.setAttribute("data-state", "pending");
      allowBtn?.removeAttribute("data-picked");
      allowBtn?.removeAttribute("data-faded");
      denyBtn?.removeAttribute("data-picked");
      denyBtn?.removeAttribute("data-faded");

      if (mode === "remote") {
        setEnabled(true);
        startTimer();
      } else if (mode === "readonly") {
        pendingHandle = window.setTimeout(() => {
          callBox?.setAttribute("data-resolved", "allow");
          if (callState) callState.textContent = txt.agAllowed;
          msgEl?.setAttribute("data-state", "allowed");
          setOutcome("allow", txt.outcomeReadonly);
        }, 700);
      } else {
        // standby
        pendingHandle = window.setTimeout(() => {
          callBox?.setAttribute("data-resolved", "deny");
          if (callState) callState.textContent = txt.agDenied;
          msgEl?.setAttribute("data-state", "denied");
          setOutcome("deny", txt.outcomeStandby);
        }, 500);
      }
    }

    function selectMode(id: string) {
      activeMode = id;
      modeEls.forEach((m, i) => {
        const active = m.dataset.mode === id;
        m.setAttribute("aria-checked", active ? "true" : "false");
        if (active && glide) glide.style.transform = `translateX(${i * 100}%)`;
      });
      applyMode(id);
    }

    // === События ===
    tabs.forEach(t =>
      t.addEventListener("click", () => selectScenario(t.dataset.tab ?? ""))
    );
    modeEls.forEach(m =>
      m.addEventListener("click", () => selectMode(m.dataset.mode ?? "remote"))
    );
    allowBtn?.addEventListener("click", () => { if (!allowBtn.disabled) resolve("allow"); });
    denyBtn?.addEventListener("click",  () => { if (!denyBtn.disabled)  resolve("deny");  });
  }
</script>
