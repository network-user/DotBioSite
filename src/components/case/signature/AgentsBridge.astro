</style>

<script>
  // Оркестратор демо .агенты. Одна петля approve/deny на главном экране; режимы и
  // безопасность - в сворачиваемом блоке. Без вечного rAF: всё через later()
  // (setTimeout-конвейер с очисткой). Гейт - IntersectionObserver. reduced-motion
  // → мгновенные состояния, интеракции работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-ab]");
    if (!root) return;

    const isEn = (root.dataset.locale ?? "ru") === "en";
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    // строки-зеркало (генерик, не зависят от сценария)
    const TXT = {
      paused: tr("на паузе", "paused"),
      running: tr("выполняет", "running"),
      blocked: tr("заблокирован", "blocked"),
      outAllow: tr("✓ Разрешено", "✓ Allowed"),
      outDeny: tr("✕ Заблокировано", "✕ Blocked"),
      outTimeout: tr("Тишина → deny (fail-closed)", "Silence → deny (fail-closed)"),
      noteRemote: tr(
        "remote: решаешь ты - кнопками на телефоне.",
        "remote: you decide - with the phone buttons.",
      ),
      noteReadonly: tr(
        "readonly разрешил сам и просто уведомил.",
        "readonly allowed it and just notified you.",
      ),
      noteStandby: tr(
        "standby отклонил сам, ничего не спрашивая.",
        "standby denied it without asking.",
      ),
    };

    // ----- DOM -----
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ab-chip]"));
    const stage = root.querySelector<HTMLElement>("[data-stage]");
    const agentState = root.querySelector<HTMLElement>("[data-agent-state]");
    const agentIntent = root.querySelector<HTMLElement>("[data-agent-intent]");
    const agentCmd = root.querySelector<HTMLElement>("[data-agent-cmd]");
    const agentOut = root.querySelector<HTMLElement>("[data-agent-out]");
    const msg = root.querySelector<HTMLElement>("[data-msg]");
    const msgCmd = root.querySelector<HTMLElement>("[data-msg-cmd]");
    const msgKind = root.querySelector<HTMLElement>("[data-msg-kind]");
    const msgRisk = root.querySelector<HTMLElement>("[data-msg-risk]");
    const msgWhy = root.querySelector<HTMLElement>("[data-msg-why]");
    const msgOut = root.querySelector<HTMLElement>("[data-msg-out]");
    const allowBtn = root.querySelector<HTMLButtonElement>('[data-act="allow"]');
    const denyBtn = root.querySelector<HTMLButtonElement>('[data-act="deny"]');
    const ignoreBtn = root.querySelector<HTMLButtonElement>('[data-act="ignore"]');
    const modeEls = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));
    const glide = root.querySelector<HTMLElement>("[data-glide]");
    const modeNote = root.querySelector<HTMLElement>("[data-mode-note]");
    const underToggle = root.querySelector<HTMLButtonElement>("[data-under-toggle]");

    if (!stage || !msg) return;

    // ----- инфраструктура таймеров -----
    let inview = false;
    const timers: number[] = [];
    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };
    const D = (ms: number): number => (reduced ? 0 : ms);

    // ----- состояние -----
    let activeChip: HTMLButtonElement = chips[0] ?? document.createElement("button");
    let activeMode = "remote";

    type Sc = {
      cmd: string;
      kind: string;
      risk: string;
      riskLabel: string;
      intent: string;
      why: string;
      allow: string;
      deny: string;
    };
    const read = (c: HTMLElement): Sc => ({
      cmd: c.dataset.cmd ?? "",
      kind: c.dataset.kind ?? "",
      risk: c.dataset.risk ?? "high",
      riskLabel: c.dataset.riskLabel ?? "",
      intent: c.dataset.intent ?? "",
      why: c.dataset.why ?? "",
      allow: c.dataset.allow ?? "",
      deny: c.dataset.deny ?? "",
    });

    // ----- кнопки -----
    const setButtons = (on: boolean): void => {
      [allowBtn, denyBtn].forEach((b) => {
        if (!b) return;
        b.disabled = !on;
        b.removeAttribute("data-picked");
        b.removeAttribute("data-faded");
      });
      if (ignoreBtn) ignoreBtn.hidden = !on;
    };

    // ----- сброс к «ждёт решения» -----
    const toPending = (): void => {
      stage.dataset.state = "pending";
      msg.dataset.state = "pending";
      if (agentState) agentState.textContent = TXT.paused;
      if (agentOut) agentOut.hidden = true;
      if (msgOut) msgOut.hidden = true;
    };

    // ----- разрешение петли -----
    const resolve = (action: "allow" | "deny" | "timeout"): void => {
      clearTimers();
      setButtons(false);
      const sc = read(activeChip);
      const allowed = action === "allow";

      stage.dataset.state = allowed ? "allowed" : action === "deny" ? "denied" : "timeout";
      msg.dataset.state = stage.dataset.state;

      if (agentState) agentState.textContent = allowed ? TXT.running : TXT.blocked;
      if (agentOut) {
        agentOut.textContent = allowed ? sc.allow : sc.deny;
        agentOut.hidden = false;
      }
      if (msgOut) {
        const txt =
          action === "allow" ? TXT.outAllow : action === "deny" ? TXT.outDeny : TXT.outTimeout;
        msgOut.textContent = txt;
        msgOut.dataset.kind = action === "allow" ? "allow" : action === "deny" ? "deny" : "timeout";
        msgOut.hidden = false;
      }

      if (action === "allow") {
        allowBtn?.setAttribute("data-picked", "1");
        denyBtn?.setAttribute("data-faded", "1");
      } else if (action === "deny") {
        denyBtn?.setAttribute("data-picked", "1");
        allowBtn?.setAttribute("data-faded", "1");
      }
    };

    // ----- анимация «прилёта» сообщения -----
    const arrive = (): void => {
      if (reduced) return;
      msg.removeAttribute("data-arrive");
      void msg.offsetWidth; // reflow → перезапуск
      msg.setAttribute("data-arrive", "1");
    };

    // ----- применить режим к текущему сценарию -----
    const applyMode = (): void => {
      clearTimers();
      toPending();
      if (activeMode === "remote") {
        setButtons(true);
        if (modeNote) modeNote.textContent = TXT.noteRemote;
      } else if (activeMode === "readonly") {
        setButtons(false);
        if (modeNote) modeNote.textContent = TXT.noteReadonly;
        later(() => resolve("allow"), D(650));
      } else {
        setButtons(false);
        if (modeNote) modeNote.textContent = TXT.noteStandby;
        later(() => resolve("deny"), D(500));
      }
    };

    // ----- выбрать сценарий -----
    const selectScenario = (chip: HTMLButtonElement): void => {
      activeChip = chip;
      chips.forEach((c) => {
        const on = c === chip;
        c.classList.toggle("is-on", on);
        c.setAttribute("aria-pressed", on ? "true" : "false");
      });
      const sc = read(chip);
      if (agentIntent) agentIntent.textContent = sc.intent;
      if (agentCmd) agentCmd.textContent = sc.cmd;
      if (msgCmd) msgCmd.textContent = sc.cmd;
      if (msgKind) msgKind.textContent = sc.kind;
      if (msgRisk) {
        msgRisk.textContent = sc.riskLabel;
        msgRisk.className = `ab__msg-risk ab__msg-risk--${sc.risk}`;
      }
      if (msgWhy) msgWhy.textContent = sc.why;
      arrive();
      applyMode();
    };

    // ----- выбрать режим -----
    const selectMode = (id: string): void => {
      activeMode = id;
      modeEls.forEach((m, i) => {
        const on = m.dataset.mode === id;
        m.setAttribute("aria-checked", on ? "true" : "false");
        if (on && glide) glide.style.transform = `translateX(${i * 100}%)`;
      });
      applyMode();
    };

    // ----- сворачивание блока «Режимы и безопасность» -----
    if (underToggle) {
      root.classList.add("is-enhanced"); // включает grid-анимацию; по умолчанию свёрнуто
      underToggle.setAttribute("aria-expanded", "false");
      underToggle.addEventListener("click", () => {
        const open = root.classList.toggle("is-under-open");
        underToggle.setAttribute("aria-expanded", open ? "true" : "false");
      });
    }

    // ----- события -----
    chips.forEach((c) => c.addEventListener("click", () => selectScenario(c)));
    modeEls.forEach((m) =>
      m.addEventListener("click", () => selectMode(m.dataset.mode ?? "remote")),
    );
    allowBtn?.addEventListener("click", () => {
      if (!allowBtn.disabled) resolve("allow");
    });
    denyBtn?.addEventListener("click", () => {
      if (!denyBtn.disabled) resolve("deny");
    });
    ignoreBtn?.addEventListener("click", () => {
      if (!ignoreBtn.hidden) resolve("timeout");
    });

    // ----- гейт по видимости + очистка -----
    const io = new IntersectionObserver(
      ([e]) => {
        inview = !!e?.isIntersecting;
        if (inview) {
          root.classList.add("is-inview");
          // первичная раскладка под дефолтный режим
          later(() => applyMode(), D(400));
        } else {
          clearTimers();
        }
      },
      { threshold: 0.1 },
    );
    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) clearTimers();
    });
    window.addEventListener("pagehide", () => {
      clearTimers();
      io.disconnect();
    });

    // стартовое состояние (на случай, если уже во вьюпорте без анимаций)
    setButtons(activeMode === "remote");
  })();
</script>
