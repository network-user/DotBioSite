<script>
  // Оркестратор демо .агенты: непрерывная сессия. Агент проигрывает шаги; на
  // рискованных (ask) ставит паузу и шлёт запрос в чат, ждёт Allow/Deny; запрос
  // удаляется после решения. После всех шагов - «работа завершена» + селектор
  // следующей задачи; выбор очищает чат (/clear) и стартует новую сессию.
  // Перф: только transform/opacity, конечные анимации; тайминги через later()
  // (setTimeout-конвейер с очисткой). Гейт - IntersectionObserver. Клоны
  // прототипов сохраняют scope Astro. Re-init на astro:page-load.
  (() => {
    type StepSay = { k: "say"; text: string };
    type StepRun = { k: "run"; tool: string; arg: string; res: string; file: string };
    type StepAsk = {
      k: "ask";
      tool: string;
      kind: string;
      cmd: string;
      mcp: boolean;
      risk: string;
      riskLabel: string;
      why: string;
      allow: string;
      deny: string;
      file: string;
    };
    type Step = StepSay | StepRun | StepAsk;
    type Scene = {
      id: string;
      label: string;
      session: string;
      task: string;
      done: string;
      steps: Step[];
    };

    const init = (root: HTMLElement): void => {
      if (root.dataset.abReady) return;
      root.dataset.abReady = "1";

      const isEn = (root.dataset.locale ?? "ru") === "en";
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const tr = (ru: string, en: string): string => (isEn ? en : ru);

      const dataEl = root.querySelector<HTMLElement>("[data-ab-data]");
      let scenes: Scene[] = [];
      try {
        scenes = JSON.parse(dataEl?.textContent ?? "[]") as Scene[];
      } catch {
        scenes = [];
      }
      if (!scenes.length) return;

      const TXT = {
        working: tr("Claude Code работает…", "Claude Code is working…"),
        paused: tr(
          "на паузе · ждёт решения в Telegram",
          "paused · waiting for a decision in Telegram",
        ),
        done: tr("работа завершена", "work complete"),
        cleared: tr("/clear · новый контекст", "/clear · new context"),
        subBot: tr("бот", "bot"),
        subTyping: tr("печатает…", "typing…"),
        liveRun: tr("⚡ running…", "⚡ running…"),
        liveWait: tr("⏳ waiting approval", "⏳ waiting approval"),
        liveDone: tr("✅ done", "✅ done"),
        lastTool: tr("Last tool:", "Last tool:"),
        approval: tr("Approval:", "Approval:"),
        wait: tr("ждёт решения · DotAgents", "waiting for a decision · DotAgents"),
        askShell: "before_shell",
        askMcp: "before_mcp",
        meta: (n: number) => `claude-opus · ${n} tool calls`,
      };

      // ── DOM ──
      const stage = root.querySelector<HTMLElement>("[data-stage]");
      const term = root.querySelector<HTMLElement>("[data-term]");
      const termStatusTxt = root.querySelector<HTMLElement>("[data-term-status]");
      const termMeta = root.querySelector<HTMLElement>("[data-term-meta]");
      const files = Array.from(root.querySelectorAll<HTMLElement>("[data-file]"));
      const wireLabel = root.querySelector<HTMLElement>("[data-wire-label]");

      const tgSub = root.querySelector<HTMLElement>("[data-tg-sub]");
      const clearDiv = root.querySelector<HTMLElement>("[data-clear]");
      const clearTxt = root.querySelector<HTMLElement>("[data-clear-txt]");
      const live = root.querySelector<HTMLElement>("[data-live]");
      const liveSid = root.querySelector<HTMLElement>("[data-live-sid]");
      const liveTask = root.querySelector<HTMLElement>("[data-live-task]");
      const liveStatus = root.querySelector<HTMLElement>("[data-live-status]");
      const liveTool = root.querySelector<HTMLElement>("[data-live-tool]");
      const liveTools = root.querySelector<HTMLElement>("[data-live-tools]");
      const liveFiles = root.querySelector<HTMLElement>("[data-live-files]");
      const liveMode = root.querySelector<HTMLElement>("[data-live-mode]");

      const tgBody = root.querySelector<HTMLElement>("[data-tg]");
      const appr = root.querySelector<HTMLElement>("[data-appr]");
      const apprSid = root.querySelector<HTMLElement>("[data-appr-sid]");
      const apprKind = root.querySelector<HTMLElement>("[data-appr-kind]");
      const apprRisk = root.querySelector<HTMLElement>("[data-appr-risk]");
      const apprCmd = root.querySelector<HTMLElement>("[data-appr-cmd]");
      const apprWhat = root.querySelector<HTMLElement>("[data-appr-what]");
      const apprWhy = root.querySelector<HTMLElement>("[data-appr-why]");
      const allowBtn = root.querySelector<HTMLButtonElement>('[data-act="allow"]');
      const denyBtn = root.querySelector<HTMLButtonElement>('[data-act="deny"]');
      const ignoreBtn = root.querySelector<HTMLButtonElement>('[data-act="ignore"]');

      const newmsg = root.querySelector<HTMLElement>("[data-newmsg]");
      const newmsgTxt = root.querySelector<HTMLElement>("[data-newmsg-txt]");
      const modal = root.querySelector<HTMLElement>("[data-modal]");
      const doneSum = root.querySelector<HTMLElement>("[data-done-sum]");
      const sceneGoBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-scene-go]"));
      const replayBtn = root.querySelector<HTMLButtonElement>("[data-scene-replay]");

      const overlay = root.querySelector<HTMLElement>("[data-intro]");
      const introStart = root.querySelector<HTMLButtonElement>("[data-intro-start]");
      const modeEls = Array.from(root.querySelectorAll<HTMLButtonElement>(".ab__seg [data-mode]"));
      const glide = root.querySelector<HTMLElement>("[data-glide]");
      const underToggle = root.querySelector<HTMLButtonElement>("[data-under-toggle]");

      if (!stage || !term || !appr || !live) return;

      root.classList.add("is-enhanced");

      // прототипы строк терминала
      const protoMap: Record<string, HTMLElement> = {};
      root.querySelectorAll<HTMLElement>("[data-p]").forEach((p) => {
        protoMap[p.dataset.p ?? ""] = p;
      });

      // ── таймеры ──
      const timers: number[] = [];
      const clearTimers = (): void => {
        while (timers.length) {
          const id = timers.pop();
          if (id !== undefined) window.clearTimeout(id);
        }
      };
      const later = (fn: () => void, ms: number): void => {
        const id = window.setTimeout(() => {
          const i = timers.indexOf(id);
          if (i >= 0) timers.splice(i, 1);
          fn();
        }, ms);
        timers.push(id);
      };
      const D = (ms: number): number => (reduced ? 0 : ms);

      // ── состояние ──
      let sceneIdx = 0;
      let si = 0; // индекс шага
      let phase: "idle" | "running" | "pending" | "done" = "idle";
      let toolCount = 0;
      let fileCount = 0;
      let curAsk: StepAsk | null = null;
      let curWaitLine: HTMLElement | null = null;
      let apprCount = 0;
      const APPR_IDS = ["a2b3c", "9d4e1", "f70c2", "3b8a5", "c1e07", "6a2d9"];
      let activeMode = "remote";
      let inview = false;
      let started = false;
      let introDone = false;
      let firstRun = true;

      const scene = (): Scene => scenes[sceneIdx] ?? scenes[0]!;

      // ── терминал: клон прототипа ──
      const addLine = (
        type: string,
        opts: { text?: string; tool?: string; arg?: string; bullet?: string; res?: string } = {},
      ): HTMLElement => {
        const proto = protoMap[type];
        const el = (proto ? proto.cloneNode(true) : document.createElement("div")) as HTMLElement;
        el.removeAttribute("data-p");
        el.hidden = false;
        const txt = el.querySelector<HTMLElement>(".ab__ln-txt");
        if (type === "cmd") {
          const tool = el.querySelector<HTMLElement>(".ab__tool");
          const arg = el.querySelector<HTMLElement>(".ab__ln-arg");
          const bullet = el.querySelector<HTMLElement>(".ab__bullet");
          if (tool) tool.textContent = opts.tool ?? "";
          if (arg) arg.textContent = opts.arg ?? "";
          if (bullet && opts.bullet) bullet.classList.add(opts.bullet);
        } else if (txt) {
          txt.textContent = opts.text ?? "";
        }
        if (type === "res" && opts.res) el.classList.add(`ab__ln--${opts.res}`);
        if (reduced) el.classList.add("is-noanim");
        term.appendChild(el);
        term.scrollTop = term.scrollHeight;
        return el;
      };
      const clearTerm = (): void => {
        term.querySelectorAll(".ab__ln").forEach((n) => n.remove());
      };

      // ── подсветка файла в дереве ──
      const touchFile = (name: string): void => {
        if (!name) return;
        const base = name.split("/").pop() ?? name;
        files.forEach((f) => {
          const on = f.dataset.file === base;
          f.classList.toggle("is-active", on);
          if (on) f.classList.add("is-touched");
        });
      };

      // ── статус терминала ──
      const setTermStatus = (label: string): void => {
        if (!termStatusTxt) return;
        // первый текстовый узел — метка статуса; meta остаётся
        const meta = termMeta;
        termStatusTxt.textContent = label + " ";
        if (meta) termStatusTxt.appendChild(meta);
        if (termMeta) termMeta.textContent = TXT.meta(toolCount);
      };

      // ── шапка чата: печатает ──
      const setSub = (typing: boolean): void => {
        if (!tgSub) return;
        tgSub.textContent = typing ? TXT.subTyping : TXT.subBot;
        tgSub.classList.toggle("is-typing", typing);
      };

      // ── live-сообщение ──
      const paintLive = (mode: "run" | "wait" | "done", askCmd?: string): void => {
        const sc = scene();
        if (liveSid) liveSid.textContent = sc.session;
        if (liveTask) liveTask.textContent = sc.task;
        if (liveTools) liveTools.textContent = String(toolCount);
        if (liveFiles) liveFiles.textContent = String(fileCount);
        if (liveMode) liveMode.textContent = activeMode;
        if (liveStatus) {
          liveStatus.textContent =
            mode === "wait" ? TXT.liveWait : mode === "done" ? TXT.liveDone : TXT.liveRun;
        }
        live.dataset.status = mode;
        if (liveTool) {
          liveTool.textContent = "";
          if (mode === "wait" && askCmd) {
            const b = document.createElement("b");
            b.textContent = TXT.approval + " ";
            liveTool.append(b, document.createTextNode(askCmd));
          }
        }
      };

      // ── анимации ──
      const scrollChat = (): void => {
        if (tgBody) tgBody.scrollTop = tgBody.scrollHeight;
      };
      const bubbleIn = (el: HTMLElement): void => {
        el.hidden = false;
        el.removeAttribute("data-leave");
        scrollChat();
        if (reduced) return;
        el.removeAttribute("data-arrive");
        void el.offsetWidth;
        el.setAttribute("data-arrive", "1");
      };
      const bubbleOut = (el: HTMLElement, after: () => void): void => {
        if (reduced) {
          el.hidden = true;
          el.removeAttribute("data-arrive");
          after();
          return;
        }
        el.removeAttribute("data-arrive");
        el.setAttribute("data-leave", "1");
        later(() => {
          el.hidden = true;
          el.removeAttribute("data-leave");
          after();
        }, 220);
      };

      const setButtons = (on: boolean): void => {
        [allowBtn, denyBtn, ignoreBtn].forEach((b) => {
          if (b) b.disabled = !on;
        });
      };

      // ── проигрывание шагов ──
      const next = (): void => {
        const sc = scene();
        if (si >= sc.steps.length) {
          finish();
          return;
        }
        const st = sc.steps[si++]!;
        if (st.k === "say") {
          addLine("say", { text: st.text });
          later(next, D(680));
        } else if (st.k === "run") {
          addLine("cmd", { tool: st.tool, arg: st.arg, bullet: "ab__bullet--ok" });
          if (st.file) {
            touchFile(st.file);
            fileCount += 1;
          }
          toolCount += 1;
          if (termMeta) termMeta.textContent = TXT.meta(toolCount);
          later(() => {
            addLine("res", { text: st.res });
            paintLive("run");
            later(next, D(520));
          }, D(380));
        } else {
          askStep(st);
        }
      };

      const askStep = (st: StepAsk): void => {
        curAsk = st;
        phase = "pending";
        stage.dataset.state = "pending";
        stage.dataset.kind = st.mcp ? "mcp" : "shell";
        if (st.file) touchFile(st.file);
        const bullet = st.mcp ? "ab__bullet--crit" : "ab__bullet--risk";
        addLine("cmd", { tool: st.tool, arg: st.cmd, bullet });
        const waitLine = addLine("wait", { text: TXT.wait });
        curWaitLine = waitLine;
        toolCount += 1;
        if (termMeta) termMeta.textContent = TXT.meta(toolCount);
        setTermStatus(TXT.paused);
        if (wireLabel) wireLabel.textContent = st.mcp ? TXT.askMcp : TXT.askShell;

        const displayCmd = st.mcp ? `${st.tool}(${st.cmd})` : st.cmd;
        paintLive("wait", displayCmd);

        // чат: «печатает…» → прилетает запрос
        setSub(true);
        later(() => {
          setSub(false);
          if (apprSid) apprSid.textContent = APPR_IDS[apprCount++ % APPR_IDS.length]!;
          if (apprKind) apprKind.textContent = st.kind;
          if (apprRisk) {
            apprRisk.textContent = st.riskLabel;
            apprRisk.dataset.risk = st.risk;
          }
          if (apprCmd) apprCmd.textContent = displayCmd;
          if (apprWhat) apprWhat.textContent = st.mcp ? "MCP tool" : "shell command";
          if (apprWhy) apprWhy.textContent = st.why;
          bubbleIn(appr);
          if (activeMode === "readonly") {
            setButtons(false);
            later(() => decide("allow"), D(850));
          } else if (activeMode === "standby") {
            setButtons(false);
            later(() => decide("deny"), D(650));
          } else {
            setButtons(true);
          }
        }, D(820));
      };

      const decide = (action: "allow" | "deny" | "timeout"): void => {
        if (phase !== "pending" || !curAsk) return;
        const st = curAsk;
        curAsk = null;
        phase = "running";
        setButtons(false);
        clearTimers();

        // удалить запрос из чата
        bubbleOut(appr, () => {});

        // терминал: убрать wait-строку, дописать результат
        if (curWaitLine) {
          curWaitLine.remove();
          curWaitLine = null;
        }
        const allowed = action === "allow";
        addLine("res", { text: allowed ? st.allow : st.deny, res: allowed ? "hot" : undefined });
        if (allowed && st.file) fileCount += 1;
        stage.dataset.state = "working";
        setTermStatus(TXT.working);
        paintLive("run");
        later(next, D(620));
      };

      const openModal = (): void => {
        if (!modal) return;
        modal.hidden = false;
        if (reduced) return;
        modal.removeAttribute("data-arrive");
        void modal.offsetWidth;
        modal.setAttribute("data-arrive", "1");
      };
      const closeModal = (): void => {
        if (!modal) return;
        modal.hidden = true;
        modal.removeAttribute("data-arrive");
      };

      const finish = (): void => {
        phase = "done";
        stage.dataset.state = "done";
        const sc = scene();
        addLine("done", { text: `${TXT.done} · ${sc.done}` });
        setTermStatus(TXT.done);
        paintLive("done");
        if (doneSum) doneSum.textContent = sc.done;
        // отдельное модальное уведомление о завершении
        later(openModal, D(420));
      };

      // ── старт новой сессии: ты ставишь задачу → бот подхватывает ──
      const startScene = (idx: number): void => {
        clearTimers();
        closeModal();
        sceneIdx = ((idx % scenes.length) + scenes.length) % scenes.length;
        si = 0;
        toolCount = 0;
        fileCount = 0;
        curAsk = null;
        curWaitLine = null;
        phase = "running";
        clearTerm();
        appr.hidden = true;
        live.hidden = true;
        setButtons(false);
        setSub(false);
        files.forEach((f) => f.classList.remove("is-active", "is-touched"));

        if (!firstRun && clearDiv && clearTxt) {
          clearTxt.textContent = TXT.cleared;
          clearDiv.hidden = false;
        }
        firstRun = false;

        const sc = scene();
        stage.dataset.state = "working";
        stage.dataset.kind = "shell";
        setTermStatus(TXT.working);

        // 1) исходящее: ты ставишь агенту задачу
        if (newmsgTxt) newmsgTxt.textContent = `🆕 ${sc.task}`;
        if (newmsg) bubbleIn(newmsg);

        // 2) бот «печатает…» → 3) прилетает live-сессия → 4) терминал стартует
        setSub(true);
        later(() => {
          setSub(false);
          live.hidden = false;
          paintLive("run");
          bubbleIn(live);
          addLine("prompt", { text: sc.task });
          later(next, D(560));
        }, D(780));
      };

      // ── запуск после интро + во вьюпорте ──
      const maybeStart = (): void => {
        if (started || !introDone || !inview) return;
        started = true;
        later(() => startScene(0), D(220));
      };

      // ── интро ──
      const dismissIntro = (): void => {
        if (introDone) return;
        introDone = true;
        root.classList.add("is-intro-done");
        maybeStart();
      };
      introStart?.addEventListener("click", dismissIntro);
      overlay?.addEventListener("click", (e) => {
        if (e.target === overlay) dismissIntro();
      });

      // ── режимы ──
      const selectMode = (id: string): void => {
        activeMode = id;
        modeEls.forEach((m, i) => {
          const on = m.dataset.mode === id;
          m.setAttribute("aria-checked", on ? "true" : "false");
          if (on && glide) glide.style.transform = `translateX(${i * 100}%)`;
        });
        if (liveMode) liveMode.textContent = id;
        // если сейчас ждём решения, применить авто-режим
        if (phase === "pending" && curAsk) {
          if (id === "readonly") decide("allow");
          else if (id === "standby") decide("deny");
        }
      };

      // ── сворачивание блока ──
      if (underToggle) {
        underToggle.setAttribute("aria-expanded", "false");
        underToggle.addEventListener("click", () => {
          const open = root.classList.toggle("is-under-open");
          underToggle.setAttribute("aria-expanded", open ? "true" : "false");
        });
      }

      // ── события ──
      allowBtn?.addEventListener("click", () => decide("allow"));
      denyBtn?.addEventListener("click", () => decide("deny"));
      ignoreBtn?.addEventListener("click", () => decide("timeout"));
      sceneGoBtns.forEach((b) =>
        b.addEventListener("click", () => {
          const id = b.dataset.sceneGo ?? "";
          const idx = scenes.findIndex((s) => s.id === id);
          if (idx >= 0) startScene(idx);
        }),
      );
      replayBtn?.addEventListener("click", () => startScene(sceneIdx));
      modeEls.forEach((m) =>
        m.addEventListener("click", () => selectMode(m.dataset.mode ?? "remote")),
      );

      // ── гейт по видимости ──
      const io = new IntersectionObserver(
        ([e]) => {
          inview = !!e?.isIntersecting;
          if (inview) {
            root.classList.add("is-inview");
            maybeStart();
          } else {
            clearTimers();
          }
        },
        { threshold: 0.15 },
      );
      io.observe(root);

      const onVis = (): void => {
        if (document.hidden) clearTimers();
      };
      const cleanup = (): void => {
        clearTimers();
        io.disconnect();
        document.removeEventListener("visibilitychange", onVis);
      };
      document.addEventListener("visibilitychange", onVis);
      window.addEventListener("pagehide", cleanup, { once: true });
      document.addEventListener("astro:before-swap", cleanup, { once: true });
    };

    const boot = (): void => {
      document.querySelectorAll<HTMLElement>("[data-ab]").forEach((el) => init(el));
    };
    boot();
    document.addEventListener("astro:page-load", boot);
  })();
</script>
