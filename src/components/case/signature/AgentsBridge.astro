---
/**
 * AgentsBridge.astro — сигнатурная визуализация .агенты (DotAgents).
 *
 * РЕЖИМ: hands-on remote-control demo. Не пошаговый рассказ, а живой пульт,
 * которым РУЛИТ посетитель. Слева — IDE-агент и локальный демон; справа — мок
 * телефона (Telegram). Один и тот же рискованный вызов проходит через демона,
 * а исход зависит от того, что делает посетитель:
 *   1. IDE-агент (Cursor / Claude Code / Antigravity) собирается выполнить
 *      опасный shell/MCP-вызов (rm -rf /tmp/scratch, risk: high); установленный
 *      хук перехватывает его ДО запуска.
 *   2. Хук шлёт POST на локальный демон 127.0.0.1 (loopback) с заголовком
 *      X-DotAgents-Secret. Пакет летит ТОЛЬКО по петле — наружу ничего не уходит.
 *   3. Живой переключатель MODE: remote (спросить) · readonly (авто-allow +
 *      уведомить) · standby (авто-deny). Флип мгновенно меняет исход того же
 *      запроса.
 *   4. В remote — мок Telegram с кнопками Allow / Deny, которые реально тапаются
 *      и резолвят ждущего агента; виден обратный отсчёт до HOOK_TIMEOUT_SECONDS
 *      (по умолчанию 90с — демо-таймер короче), а если истёк → fail-closed (deny).
 *   5. Tamper-proof seal: каждый callback подписан HMAC-SHA256 (truncated 16) +
 *      одноразовый nonce + expires_at. «Replay» падает — nonce уже сгорел;
 *      «tamper» падает — подпись не сходится.
 *   Инвариант: код, approvals и transcript не покидают машину — облачного релея
 *   нет. Факты: 3 агента, 3 режима, argon2id passcode-auth, audit-log, API на
 *   127.0.0.1.
 *
 * Перфоманс: анимируем ТОЛЬКО transform/opacity. Никаких вечных rAF — обратный
 * отсчёт ведёт ОДНА CSS-анимация прогресс-бара (transform: scaleX), а fail-closed
 * срабатывает по её `animationend`. Всё под .is-inview (IntersectionObserver):
 * за экраном / на скрытой вкладке / на pagehide таймеры очищаются. Никаких
 * layout/box-shadow/filter/backdrop-filter в анимациях. prefers-reduced-motion →
 * финальное читаемое состояние без движения; все тапы/переключатели работают.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Это не схема — это пульт. Тот же рискованный вызов агента, но исход решаешь ты: переключи режим демона, ответь в Telegram, проверь печать на подделку. Всё на loopback, наружу ничего не уходит.",
  en: "This isn't a diagram — it's a remote. The same risky agent call, but you decide the outcome: flip the daemon's mode, answer in Telegram, test the seal against forgery. All on loopback, nothing leaves the box.",
};

const cmd = "rm -rf /tmp/scratch";

const copy = {
  agent: { ru: "IDE-агент", en: "IDE agent" },
  agentSub: { ru: "Cursor · Claude Code · Antigravity", en: "Cursor · Claude Code · Antigravity" },
  cmdKind: { ru: "shell · risk: high", en: "shell · risk: high" },
  intercepted: { ru: "перехвачено хуком — ждёт решения", en: "intercepted by hook — awaiting decision" },
  daemon: { ru: "локальный демон", en: "local daemon" },
  daemonApi: { ru: "FastAPI · 127.0.0.1 · argon2id", en: "FastAPI · 127.0.0.1 · argon2id" },
  loopback: { ru: "loopback", en: "loopback" },
  hookPost: { ru: "POST /api/v1 · X-DotAgents-Secret", en: "POST /api/v1 · X-DotAgents-Secret" },
  phone: { ru: "твой телефон", en: "your phone" },
  tgBot: { ru: "DotAgents bot", en: "DotAgents bot" },
  waiting: { ru: "ждёт твоего ответа…", en: "waiting for your reply…" },
  allow: { ru: "Allow", en: "Allow" },
  deny: { ru: "Deny", en: "Deny" },
  // Statuses
  stIdle: { ru: "хук на паузе — выбери режим", en: "hook paused — pick a mode" },
  stWaiting: { ru: "remote: жду — Allow или Deny", en: "remote: waiting — Allow or Deny" },
  stAllowed: { ru: "allow · команда выполняется", en: "allowed · command runs" },
  stDenied: { ru: "deny · команда не запущена", en: "denied · command never runs" },
  stTimeout: { ru: "тишина → deny (fail-closed)", en: "silence → deny (fail-closed)" },
  stAutoAllow: { ru: "readonly: авто-allow, только уведомление", en: "readonly: auto-allow, notify only" },
  stAutoDeny: { ru: "standby: авто-deny, не спрашивает", en: "standby: auto-deny, never asks" },
  // Modes
  modeRemote: { ru: "remote", en: "remote" },
  modeReadonly: { ru: "readonly", en: "readonly" },
  modeStandby: { ru: "standby", en: "standby" },
  modeRemoteHint: { ru: "спросить тебя в Telegram", en: "ask you in Telegram" },
  modeReadonlyHint: { ru: "авто-allow + уведомить", en: "auto-allow + notify" },
  modeStandbyHint: { ru: "авто-deny всего опасного", en: "auto-deny anything risky" },
  modeLabel: { ru: "Режим сессии — флипни на лету", en: "Session mode — flip it on the fly" },
  // Countdown
  countLabel: { ru: "HOOK_TIMEOUT_SECONDS", en: "HOOK_TIMEOUT_SECONDS" },
  countDefault: { ru: "по умолчанию 90с", en: "90s by default" },
  failClosed: { ru: "истёк → fail-closed (deny)", en: "elapsed → fail-closed (deny)" },
  // Seal
  sealLabel: { ru: "Печать ответа — проверь на прочность", en: "Answer seal — try to break it" },
  sealNote: { ru: "callback подписан и одноразовый", en: "callback is signed and one-shot" },
  sealOk: { ru: "подпись сходится · nonce свежий", en: "signature matches · nonce fresh" },
  sealReplay: { ru: "nonce уже сгорел — повтор отклонён", en: "nonce already spent — replay rejected" },
  sealTamper: { ru: "подпись не сходится — подделка отклонена", en: "signature mismatch — tamper rejected" },
  replayBtn: { ru: "Повторить ту же кнопку", en: "Replay same button" },
  tamperBtn: { ru: "Подменить данные", en: "Tamper with data" },
  resetBtn: { ru: "Сбросить", en: "Reset" },
  // Invariant
  invariant: {
    ru: "Код, approvals и transcript не покидают машину — облачного релея нет.",
    en: "Code, approvals and transcript stay on the machine — there is no cloud relay.",
  },
};

// Поля строки подписи callback — точный формат:
// action:resource_id:expires_at:nonce:hmac16 (DotAgents core/security).
const sealFields: { tok: string; note: Bi }[] = [
  { tok: "action", note: { ru: "ap.allow / ap.deny", en: "ap.allow / ap.deny" } },
  { tok: "resource_id", note: { ru: "какой approval", en: "which approval" } },
  { tok: "expires_at", note: { ru: "срок годности", en: "expiry deadline" } },
  { tok: "nonce", note: { ru: "одноразовый код", en: "one-shot code" } },
  { tok: "hmac16", note: { ru: "HMAC-SHA256, обрезан до 16", en: "HMAC-SHA256, truncated 16" } },
];

const modes: { id: string; hint: Bi }[] = [
  { id: "remote", hint: copy.modeRemoteHint },
  { id: "readonly", hint: copy.modeReadonlyHint },
  { id: "standby", hint: copy.modeStandbyHint },
];
---

<section class="ab" data-ab aria-label={t({ ru: "Пульт одобрения .агенты", en: "DotAgents approval remote" })}>
  <p class="ab__intro">{t(intro)}</p>

  <!-- ============ Пульт: машина слева, телефон справа ============ -->
  <div class="ab__stage" data-stage>
    <!-- ---- Колонка «машина»: агент + демон ---- -->
    <div class="ab__machine">
      <article class="ab-node ab-node--agent" data-node="agent">
        <span class="ab-node__head">
          <span class="ab-node__dot" aria-hidden="true"></span>
          <span class="ab-node__title">{t(copy.agent)}</span>
        </span>
        <span class="ab-node__sub mono">{t(copy.agentSub)}</span>
        <code class="ab-node__cmd mono">{cmd}</code>
        <span class="ab-node__kind mono">{t(copy.cmdKind)}</span>
        <span class="ab-node__state mono" data-agent-state>{t(copy.intercepted)}</span>
      </article>

      <!-- провод agent → daemon: пакет летит только по loopback -->
      <div class="ab-wire" aria-hidden="true">
        <span class="ab-wire__line"></span>
        <span class="ab-wire__pkt" data-pkt></span>
        <span class="ab-wire__tag mono">
          <b>127.0.0.1</b> · {t(copy.loopback)}
        </span>
        <span class="ab-wire__post mono">{t(copy.hookPost)}</span>
      </div>

      <article class="ab-node ab-node--daemon" data-node="daemon">
        <span class="ab-node__head">
          <span class="ab-node__lock" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7">
              <rect x="5" y="11" width="14" height="9" rx="2"></rect>
              <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
            </svg>
          </span>
          <span class="ab-node__title">{t(copy.daemon)}</span>
        </span>
        <span class="ab-node__sub mono">{t(copy.daemonApi)}</span>

        <!-- ЖИВОЙ переключатель режима -->
        <span class="ab-modes__label caption">{t(copy.modeLabel)}</span>
        <div class="ab-modes" role="radiogroup" aria-label={t(copy.modeLabel)}>
          {
            modes.map((m, i) => (
              <button
                type="button"
                class="ab-mode"
                role="radio"
                data-mode={m.id}
                aria-checked={i === 0 ? "true" : "false"}
                style={`--i:${i}`}
              >
                <span class="ab-mode__id mono">{m.id}</span>
                <span class="ab-mode__hint">{t(m.hint)}</span>
              </button>
            ))
          }
        </div>
      </article>
    </div>

    <!-- ---- Колонка «телефон»: мок Telegram ---- -->
    <div class="ab__phone-wrap">
      <div class="ab-phone" data-phone>
        <span class="ab-phone__notch" aria-hidden="true"></span>
        <div class="ab-phone__screen">
          <div class="ab-phone__bar">
            <span class="ab-phone__dot" aria-hidden="true"></span>
            <span class="ab-phone__app mono">{t(copy.tgBot)}</span>
            <span class="ab-phone__net mono">{t(copy.phone)}</span>
          </div>

          <div class="ab-msg" data-msg>
            <span class="ab-msg__from mono">{t(copy.daemon)}</span>
            <code class="ab-msg__cmd mono">{cmd}</code>
            <span class="ab-msg__kind mono">{t(copy.cmdKind)}</span>

            <!-- обратный отсчёт до HOOK_TIMEOUT_SECONDS -->
            <div class="ab-count" data-count hidden>
              <span class="ab-count__row">
                <span class="ab-count__label mono">{t(copy.countLabel)}</span>
                <span class="ab-count__val mono" data-count-val>90s</span>
              </span>
              <span class="ab-count__track" aria-hidden="true"><i class="ab-count__fill" data-count-fill></i></span>
              <span class="ab-count__note mono">{t(copy.countDefault)} · {t(copy.failClosed)}</span>
            </div>

            <div class="ab-msg__btns">
              <button type="button" class="ab-tg ab-tg--allow" data-act="allow" disabled>
                <span aria-hidden="true">✓</span> {t(copy.allow)}
              </button>
              <button type="button" class="ab-tg ab-tg--deny" data-act="deny" disabled>
                <span aria-hidden="true">✕</span> {t(copy.deny)}
              </button>
            </div>

            <span class="ab-msg__status mono" data-status data-state="idle" aria-live="polite">
              {t(copy.stIdle)}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============ Tamper-proof seal ============ -->
  <div class="ab__seal" data-seal-block>
    <span class="ab-seal__label caption">{t(copy.sealLabel)}</span>
    <div class="ab-seal__row" data-seal data-state="empty">
      <div class="ab-seal__fields">
        {
          sealFields.map((f, i) => (
            <span class="ab-seal__chip mono" style={`--i:${i}`}>
              {i > 0 && <span class="ab-seal__sep" aria-hidden="true">:</span>}
              <span class="ab-seal__tok" title={t(f.note)}>{f.tok}</span>
            </span>
          ))
        }
      </div>
      <span class="ab-seal__verdict mono" data-seal-verdict>{t(copy.sealNote)}</span>
    </div>
    <div class="ab-seal__btns">
      <button type="button" class="ab-seal__btn" data-seal-act="replay" disabled>{t(copy.replayBtn)}</button>
      <button type="button" class="ab-seal__btn" data-seal-act="tamper" disabled>{t(copy.tamperBtn)}</button>
      <button type="button" class="ab-seal__btn ab-seal__btn--reset" data-seal-act="reset">{t(copy.resetBtn)}</button>
    </div>
  </div>

  <p class="ab__invariant">
    <span class="ab__invariant-mark" aria-hidden="true"></span>
    {t(copy.invariant)}
  </p>
</section>

<style>
  .ab {
    --accent: var(--project-accent);
    --ab-line: color-mix(in srgb, var(--accent) 38%, transparent);
    --ab-soft: color-mix(in srgb, var(--accent) 12%, transparent);
    --ab-glow: color-mix(in srgb, var(--accent) 16%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    color: var(--text);
    container-type: inline-size;
  }

  .ab :global(.mono) {
    font-family: var(--font-stack-mono);
  }
  .ab :global(.caption) {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  .ab__intro {
    margin: 0;
    max-width: 64ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* ========================= Пульт ========================= */
  .ab__stage {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    padding: var(--sp-6);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 130% at 8% 0%, var(--ab-glow), transparent 50%),
      var(--glass-tint-1);
  }

  /* тонкая дотовая подложка (бренд-мотив) */
  .ab__stage::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: radial-gradient(120% 100% at 50% 0%, #000 30%, transparent 92%);
    -webkit-mask-image: radial-gradient(120% 100% at 50% 0%, #000 30%, transparent 92%);
    pointer-events: none;
  }
  .ab__stage > * {
    position: relative;
    z-index: 1;
  }

  .ab__machine {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  /* ---- Узлы ---- */
  .ab-node {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    min-width: 0;
    transition:
      border-color var(--dur-med) var(--ease-standard),
      opacity var(--dur-med) var(--ease-standard);
  }
  .ab-node--daemon {
    border-color: color-mix(in srgb, var(--accent) 26%, var(--border));
  }
  .ab-node[data-active="true"] {
    border-color: color-mix(in srgb, var(--accent) 58%, var(--glass-edge));
    background: var(--surface-2);
  }
  .ab-node[data-active="true"] .ab-node__dot {
    background: var(--accent);
  }
  .ab-node[data-dim="true"] {
    opacity: 0.5;
  }

  .ab-node__head {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .ab-node__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-17);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-tight);
  }
  .ab-node__sub {
    font-size: var(--fs-13);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }
  .ab-node__cmd {
    align-self: flex-start;
    font-size: var(--fs-14);
    color: var(--text);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-elevated);
    word-break: break-all;
  }
  .ab-node__kind {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .ab-node__state {
    font-size: var(--fs-12);
    color: color-mix(in srgb, var(--accent) 60%, var(--text-muted));
    min-height: 1.3em;
    transition: color var(--dur-med) var(--ease-standard);
  }
  .ab-node--agent[data-resolved="allow"] .ab-node__state { color: var(--text); }
  .ab-node--agent[data-resolved="deny"] .ab-node__state { color: var(--text-secondary); }

  .ab-node__dot {
    width: 8px;
    height: 8px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transition: background-color var(--dur-med) var(--ease-standard);
  }
  .ab-node__lock {
    display: inline-flex;
    color: var(--accent);
  }

  /* ---- Провод + loopback-пакет ---- */
  .ab-wire {
    position: relative;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ab-wire__line {
    position: absolute;
    left: 50%;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--ab-line), transparent);
  }
  .ab-wire__pkt {
    position: absolute;
    left: 50%;
    top: 6px;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    border-radius: var(--r-pill);
    background: var(--accent);
    opacity: 0;
    --pkt-dist: 32px;
  }
  .ab-wire__tag {
    position: absolute;
    left: calc(50% + 12px);
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--fs-12);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .ab-wire__tag b {
    color: color-mix(in srgb, var(--accent) 75%, var(--text-secondary));
    font-weight: var(--fw-semibold);
  }
  .ab-wire__post {
    position: absolute;
    right: calc(50% + 12px);
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--fs-11);
    color: var(--text-faint);
    white-space: nowrap;
  }

  /* ---- Живой переключатель режима ---- */
  .ab-modes__label {
    margin-top: var(--sp-1);
  }
  .ab-modes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .ab-mode {
    appearance: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text-muted);
    text-align: left;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ab-mode:hover {
    color: var(--text-secondary);
    border-color: var(--border-hover);
  }
  .ab-mode:active {
    transform: scale(0.97);
  }
  .ab-mode:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ab-mode[aria-checked="true"] {
    color: var(--text);
    border-color: var(--ab-line);
    background: var(--ab-soft);
  }
  .ab-mode__id {
    font-size: var(--fs-14);
    font-weight: var(--fw-semibold);
  }
  .ab-mode[aria-checked="true"] .ab-mode__id {
    color: var(--accent);
  }
  .ab-mode__hint {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  /* ========================= Телефон (мок Telegram) ========================= */
  .ab__phone-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .ab-phone {
    position: relative;
    width: 100%;
    max-width: 320px;
    padding: var(--sp-2);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-xl);
    background: var(--bg-elevated);
  }
  .ab-phone__notch {
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    width: 64px;
    height: 4px;
    border-radius: var(--r-pill);
    background: var(--border-hover);
  }
  .ab-phone__screen {
    margin-top: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: var(--bg-deep);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .ab-phone__bar {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding-bottom: var(--sp-2);
    border-bottom: var(--bw-thin) solid var(--border);
  }
  .ab-phone__dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--accent);
  }
  .ab-phone__app {
    font-size: var(--fs-13);
    color: var(--text);
    font-weight: var(--fw-semibold);
  }
  .ab-phone__net {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-faint);
  }

  /* ---- Сообщение-карточка ---- */
  .ab-msg {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    transition: border-color var(--dur-med) var(--ease-standard);
  }
  .ab-msg[data-lit="true"] {
    border-color: var(--ab-line);
  }
  .ab-msg__from {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .ab-msg__cmd {
    align-self: flex-start;
    font-size: var(--fs-14);
    color: var(--text);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--r-xs);
    background: var(--bg-elevated);
    word-break: break-all;
  }
  .ab-msg__kind {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }

  /* ---- Обратный отсчёт ---- */
  .ab-count {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .ab-count[hidden] {
    display: none;
  }
  .ab-count__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-2);
  }
  .ab-count__label {
    font-size: var(--fs-11);
    color: var(--text-muted);
    letter-spacing: var(--ls-snug);
  }
  .ab-count__val {
    font-size: var(--fs-13);
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .ab-count__track {
    position: relative;
    height: 4px;
    border-radius: var(--r-pill);
    background: var(--border);
    overflow: hidden;
  }
  .ab-count__fill {
    position: absolute;
    inset: 0;
    transform-origin: left center;
    transform: scaleX(1);
    border-radius: inherit;
    background: var(--accent);
  }
  /* Отсчёт ведёт ОДНА css-анимация (scaleX) только когда блок виден и активен;
     её animationend → fail-closed. Длительность задаёт JS через --count-ms. */
  .ab.is-inview .ab-count[data-run="true"] .ab-count__fill {
    animation: ab-count-down var(--count-ms, 8000ms) linear forwards;
  }
  @keyframes ab-count-down {
    to { transform: scaleX(0); }
  }

  /* ---- Кнопки Telegram ---- */
  .ab-msg__btns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-2);
  }
  .ab-tg {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-1);
    min-height: var(--tap-min);
    padding: var(--sp-2);
    border-radius: var(--r-sm);
    border: var(--bw-thin) solid var(--border);
    background: var(--surface-2);
    color: var(--text-secondary);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ab-tg:hover:not(:disabled) {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ab-tg:active:not(:disabled) {
    transform: scale(0.96);
  }
  .ab-tg:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ab-tg:disabled {
    opacity: 0.4;
    cursor: default;
  }
  .ab-tg--allow:not(:disabled) {
    border-color: color-mix(in srgb, var(--accent) 32%, var(--border));
  }
  .ab-tg[data-picked="true"] {
    color: var(--text);
    border-color: var(--accent);
    background: var(--ab-soft);
    transform: scale(1.03);
  }
  .ab-tg[data-faded="true"] {
    opacity: 0.28;
  }

  .ab-msg__status {
    font-size: var(--fs-12);
    color: var(--text-muted);
    line-height: var(--lh-snug);
    min-height: 1.3em;
    transition: color var(--dur-med) var(--ease-standard);
  }
  .ab-msg__status[data-state="waiting"] { color: var(--text-secondary); }
  .ab-msg__status[data-state="allowed"] { color: var(--text); }
  .ab-msg__status[data-state="allowed"]::before { content: "✓ "; color: var(--accent); }
  .ab-msg__status[data-state="denied"],
  .ab-msg__status[data-state="timeout"] { color: var(--text); }
  .ab-msg__status[data-state="denied"]::before,
  .ab-msg__status[data-state="timeout"]::before { content: "✕ "; color: var(--text-secondary); }

  /* ========================= Tamper-proof seal ========================= */
  .ab__seal {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background: var(--glass-tint-1);
  }
  .ab-seal__row {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    transition: border-color var(--dur-med) var(--ease-standard);
  }
  .ab-seal__row[data-state="ok"] {
    border-color: var(--ab-line);
  }
  .ab-seal__row[data-state="replay"],
  .ab-seal__row[data-state="tamper"] {
    border-color: color-mix(in srgb, var(--state-error) 42%, transparent);
  }
  .ab-seal__row[data-state="replay"],
  .ab-seal__row[data-state="tamper"] {
    animation: ab-shake var(--dur-slow) var(--ease-standard);
  }
  @keyframes ab-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  .ab-seal__fields {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-1) 0;
  }
  .ab-seal__chip {
    display: inline-flex;
    align-items: center;
  }
  .ab-seal__sep {
    color: var(--text-faint);
    padding-inline: 2px;
  }
  .ab-seal__tok {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--bg-elevated);
    cursor: help;
    transition: color var(--dur-med) var(--ease-standard), border-color var(--dur-med) var(--ease-standard);
  }
  .ab-seal__row[data-state="ok"] .ab-seal__tok {
    color: var(--text);
    border-color: var(--ab-line);
  }
  /* tamper: пятое поле (подпись) рвётся */
  .ab-seal__row[data-state="tamper"] .ab-seal__chip:last-child .ab-seal__tok {
    color: var(--state-error);
    border-color: color-mix(in srgb, var(--state-error) 50%, transparent);
  }
  /* replay: nonce уже сгорел */
  .ab-seal__row[data-state="replay"] .ab-seal__chip:nth-child(4) .ab-seal__tok {
    color: var(--state-error);
    border-color: color-mix(in srgb, var(--state-error) 50%, transparent);
  }

  .ab-seal__verdict {
    font-size: var(--fs-13);
    color: var(--text-muted);
    transition: color var(--dur-med) var(--ease-standard);
  }
  .ab-seal__row[data-state="ok"] .ab-seal__verdict { color: var(--text); }
  .ab-seal__row[data-state="replay"] .ab-seal__verdict,
  .ab-seal__row[data-state="tamper"] .ab-seal__verdict { color: var(--state-error); }

  .ab-seal__btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .ab-seal__btn {
    appearance: none;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .ab-seal__btn:hover:not(:disabled) {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ab-seal__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ab-seal__btn:disabled {
    opacity: 0.4;
    cursor: default;
  }
  .ab-seal__btn--reset {
    margin-left: auto;
  }

  /* ========================= Инвариант ========================= */
  .ab__invariant {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-15);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }
  .ab__invariant-mark {
    flex: none;
    width: 22px;
    height: 2px;
    border-radius: var(--r-pill);
    background: var(--accent);
  }

  /* ========================= Появление под .is-inview ========================= */
  @keyframes ab-rise {
    from { opacity: 0; transform: translate3d(0, 10px, 0); }
    to { opacity: 1; transform: none; }
  }
  .ab.is-inview .ab-node,
  .ab.is-inview .ab-phone,
  .ab.is-inview .ab__seal {
    animation: ab-rise var(--dur-slower) var(--ease-soft) both;
  }
  .ab.is-inview .ab-node--daemon { animation-delay: 70ms; }
  .ab.is-inview .ab-phone { animation-delay: 140ms; }
  .ab.is-inview .ab__seal { animation-delay: 200ms; }

  /* loopback-пакет: летит ВНИЗ по проводу, только при .is-inview и data-run */
  .ab.is-inview .ab-wire__pkt[data-run="true"] {
    animation: ab-pkt var(--dur-glacial) var(--ease-standard) forwards;
  }
  @keyframes ab-pkt {
    0% { transform: translate3d(0, 0, 0) scale(0.6); opacity: 0; }
    18% { opacity: 1; transform: translate3d(0, 4px, 0) scale(1); }
    82% { opacity: 1; transform: translate3d(0, var(--pkt-dist), 0) scale(1); }
    100% { transform: translate3d(0, var(--pkt-dist), 0) scale(0.6); opacity: 0; }
  }

  /* ========================= Широкая раскладка ========================= */
  @container (min-width: 720px) {
    .ab__stage {
      grid-template-columns: 1.15fr 0.85fr;
      align-items: start;
      gap: var(--sp-6);
    }
    .ab__phone-wrap {
      justify-content: flex-end;
      position: sticky;
      top: var(--sp-5);
    }
  }

  /* ========================= Reduced motion: статика, тапы живут ========================= */
  @media (prefers-reduced-motion: reduce) {
    .ab.is-inview .ab-node,
    .ab.is-inview .ab-phone,
    .ab.is-inview .ab__seal,
    .ab.is-inview .ab-wire__pkt[data-run="true"],
    .ab-seal__row[data-state="replay"],
    .ab-seal__row[data-state="tamper"] {
      animation: none;
    }
    .ab-count[data-run="true"] .ab-count__fill {
      animation: none;
      transform: scaleX(1);
    }
    .ab-node,
    .ab-msg,
    .ab-tg,
    .ab-mode,
    .ab-seal__tok {
      transition: none;
    }
  }
</style>

<script>
  // Hands-on remote-control demo для .агенты.
  //
  // Никакого постоянного rAF. Единственная авто-анимация — обратный отсчёт
  // (CSS scaleX прогресс-бара); его `animationend` срабатывает как fail-closed.
  // Всё движение под .is-inview (IntersectionObserver). За экраном / на скрытой
  // вкладке / на pagehide любой таймер отсчёта снимается, .is-inview убирается.
  // Под prefers-reduced-motion движения нет — финальные читаемые состояния,
  // но все тапы (режим, Allow/Deny, replay/tamper) работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-ab]");
    if (!root) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.lang === "en";

    const txt = {
      stIdle: isEn ? "hook paused — pick a mode" : "хук на паузе — выбери режим",
      stWaiting: isEn ? "remote: waiting — Allow or Deny" : "remote: жду — Allow или Deny",
      stAllowed: isEn ? "allowed · command runs" : "allow · команда выполняется",
      stDenied: isEn ? "denied · command never runs" : "deny · команда не запущена",
      stTimeout: isEn ? "silence → deny (fail-closed)" : "тишина → deny (fail-closed)",
      stAutoAllow: isEn ? "readonly: auto-allow, notify only" : "readonly: авто-allow, только уведомление",
      stAutoDeny: isEn ? "standby: auto-deny, never asks" : "standby: авто-deny, не спрашивает",
      agentIntercepted: isEn ? "intercepted by hook — awaiting decision" : "перехвачено хуком — ждёт решения",
      agentRuns: isEn ? "running — call allowed" : "выполняется — вызов разрешён",
      agentBlocked: isEn ? "blocked — call never ran" : "заблокировано — вызов не запущен",
      sealNote: isEn ? "callback is signed and one-shot" : "callback подписан и одноразовый",
      sealOk: isEn ? "signature matches · nonce fresh" : "подпись сходится · nonce свежий",
      sealReplay: isEn ? "nonce already spent — replay rejected" : "nonce уже сгорел — повтор отклонён",
      sealTamper: isEn ? "signature mismatch — tamper rejected" : "подпись не сходится — подделка отклонена",
    };

    // --- Узлы сцены ---
    const nodeAgent = root.querySelector<HTMLElement>('[data-node="agent"]');
    const nodeDaemon = root.querySelector<HTMLElement>('[data-node="daemon"]');
    const agentState = root.querySelector<HTMLElement>("[data-agent-state]");
    const pkt = root.querySelector<HTMLElement>("[data-pkt]");
    const wire = root.querySelector<HTMLElement>(".ab-wire");
    const modeEls = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));

    const msg = root.querySelector<HTMLElement>("[data-msg]");
    const statusEl = root.querySelector<HTMLElement>("[data-status]");
    const allowBtn = root.querySelector<HTMLButtonElement>('[data-act="allow"]');
    const denyBtn = root.querySelector<HTMLButtonElement>('[data-act="deny"]');
    const countBox = root.querySelector<HTMLElement>("[data-count]");
    const countVal = root.querySelector<HTMLElement>("[data-count-val]");
    const countFill = root.querySelector<HTMLElement>("[data-count-fill]");

    const sealRow = root.querySelector<HTMLElement>("[data-seal]");
    const sealVerdict = root.querySelector<HTMLElement>("[data-seal-verdict]");
    const replayBtn = root.querySelector<HTMLButtonElement>('[data-seal-act="replay"]');
    const tamperBtn = root.querySelector<HTMLButtonElement>('[data-seal-act="tamper"]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-seal-act="reset"]');

    if (!statusEl || !allowBtn || !denyBtn || !sealRow) return;

    let inview = false;
    let countTimer = 0; // безопасная страховка к animationend

    // Пакет летит по реальной высоте провода (а не фикс-смещению).
    const syncPktDist = (): void => {
      if (!pkt || !wire) return;
      const h = wire.clientHeight;
      if (h > 0) pkt.style.setProperty("--pkt-dist", `${Math.max(12, h - 12)}px`);
    };

    const firePacket = (): void => {
      if (!pkt || reduce || !inview) return;
      syncPktDist();
      pkt.removeAttribute("data-run");
      void pkt.offsetWidth; // reflow → рестарт keyframes
      pkt.setAttribute("data-run", "true");
    };

    const setStatus = (state: string, text: string): void => {
      statusEl.setAttribute("data-state", state);
      statusEl.textContent = text;
    };

    const setAgent = (resolved: "" | "allow" | "deny", text: string): void => {
      if (resolved) nodeAgent?.setAttribute("data-resolved", resolved);
      else nodeAgent?.removeAttribute("data-resolved");
      if (agentState) agentState.textContent = text;
    };

    const setButtonsEnabled = (on: boolean): void => {
      [allowBtn, denyBtn].forEach((b) => {
        b.disabled = !on;
        b.removeAttribute("data-picked");
        b.removeAttribute("data-faded");
      });
    };

    const stopCountdown = (): void => {
      if (countTimer) {
        window.clearTimeout(countTimer);
        countTimer = 0;
      }
      if (countBox) {
        countBox.removeAttribute("data-run");
        countBox.hidden = true;
      }
    };

    // Демо-таймер: КОРОТКИЙ (8с), но подписан как 90с по умолчанию.
    const COUNT_MS = 8000;
    const COUNT_LABEL_S = 90;

    const startCountdown = (): void => {
      if (!countBox || !countFill) return;
      stopCountdown();
      if (countVal) countVal.textContent = `${COUNT_LABEL_S}s`;
      countBox.hidden = false;
      countBox.style.setProperty("--count-ms", `${COUNT_MS}ms`);
      // под reduced-motion бар стоит полным, fail-closed по короткому таймауту
      if (reduce || !inview) {
        countTimer = window.setTimeout(failClosed, COUNT_MS);
        return;
      }
      // рестарт CSS-анимации scaleX
      void countFill.offsetWidth;
      countBox.setAttribute("data-run", "true");
      // страховочный таймаут чуть позже animationend
      countTimer = window.setTimeout(failClosed, COUNT_MS + 300);
    };

    function failClosed(): void {
      stopCountdown();
      // нет ответа → deny, fail-closed
      denyBtn!.setAttribute("data-picked", "true");
      allowBtn!.setAttribute("data-faded", "true");
      allowBtn!.disabled = true;
      denyBtn!.disabled = true;
      setStatus("timeout", txt.stTimeout);
      setAgent("deny", txt.agentBlocked);
      armSeal();
    }

    // animationend отсчёта = fail-closed (основной путь под движением).
    countFill?.addEventListener("animationend", () => {
      if (countBox?.getAttribute("data-run") === "true") failClosed();
    });

    // --- Печать (seal) ---
    const armSeal = (): void => {
      sealRow.setAttribute("data-state", "ok");
      if (sealVerdict) sealVerdict.textContent = txt.sealOk;
      if (replayBtn) replayBtn.disabled = false;
      if (tamperBtn) tamperBtn.disabled = false;
      if (msg) msg.setAttribute("data-lit", "true");
    };
    const resetSeal = (): void => {
      sealRow.setAttribute("data-state", "empty");
      if (sealVerdict) sealVerdict.textContent = txt.sealNote;
      if (replayBtn) replayBtn.disabled = true;
      if (tamperBtn) tamperBtn.disabled = true;
    };

    // --- Резолв запроса (вручную или авто по режиму) ---
    const resolveAllow = (auto: boolean): void => {
      stopCountdown();
      allowBtn.setAttribute("data-picked", "true");
      denyBtn.setAttribute("data-faded", "true");
      allowBtn.disabled = true;
      denyBtn.disabled = true;
      setStatus("allowed", auto ? txt.stAutoAllow : txt.stAllowed);
      setAgent("allow", txt.agentRuns);
      armSeal();
    };
    const resolveDeny = (auto: boolean): void => {
      stopCountdown();
      denyBtn.setAttribute("data-picked", "true");
      allowBtn.setAttribute("data-faded", "true");
      allowBtn.disabled = true;
      denyBtn.disabled = true;
      setStatus("denied", auto ? txt.stAutoDeny : txt.stDenied);
      setAgent("deny", txt.agentBlocked);
      armSeal();
    };

    // Применить режим к ТОМУ ЖЕ запросу — мгновенно меняет исход.
    const applyMode = (next: string): void => {
      modeEls.forEach((m) => m.setAttribute("aria-checked", m.dataset.mode === next ? "true" : "false"));
      nodeDaemon?.setAttribute("data-active", "true");
      resetSeal();
      if (msg) msg.removeAttribute("data-lit");

      if (next === "remote") {
        // ждёт твоего тапа + обратный отсчёт
        setButtonsEnabled(true);
        setStatus("waiting", txt.stWaiting);
        setAgent("", txt.agentIntercepted);
        firePacket();
        startCountdown();
      } else if (next === "readonly") {
        setButtonsEnabled(false);
        firePacket();
        resolveAllow(true);
      } else {
        setButtonsEnabled(false);
        firePacket();
        resolveDeny(true);
      }
    };

    // --- Слушатели ---
    modeEls.forEach((m) => {
      m.addEventListener("click", () => applyMode(m.dataset.mode || "remote"));
    });
    allowBtn.addEventListener("click", () => resolveAllow(false));
    denyBtn.addEventListener("click", () => resolveDeny(false));

    replayBtn?.addEventListener("click", () => {
      if (sealRow.getAttribute("data-state") !== "ok") return;
      sealRow.setAttribute("data-state", "empty");
      void sealRow.offsetWidth;
      sealRow.setAttribute("data-state", "replay");
      if (sealVerdict) sealVerdict.textContent = txt.sealReplay;
    });
    tamperBtn?.addEventListener("click", () => {
      if (sealRow.getAttribute("data-state") !== "ok") return;
      sealRow.setAttribute("data-state", "empty");
      void sealRow.offsetWidth;
      sealRow.setAttribute("data-state", "tamper");
      if (sealVerdict) sealVerdict.textContent = txt.sealTamper;
    });
    resetBtn?.addEventListener("click", () => {
      stopCountdown();
      resetSeal();
      setButtonsEnabled(false);
      setStatus("idle", txt.stIdle);
      setAgent("", txt.agentIntercepted);
      nodeDaemon?.setAttribute("data-active", "false");
      modeEls.forEach((m) => m.setAttribute("aria-checked", m.dataset.mode === "remote" ? "true" : "false"));
      if (msg) msg.removeAttribute("data-lit");
    });

    // --- Видимость: гейт всего движения ---
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !inview) {
            inview = true;
            root.classList.add("is-inview");
            syncPktDist();
          } else if (!e.isIntersecting && inview) {
            inview = false;
            root.classList.remove("is-inview");
            stopCountdown();
          }
        }
      },
      { threshold: 0.25 },
    );

    if ("ResizeObserver" in window && wire) {
      new ResizeObserver(syncPktDist).observe(wire);
    }

    // Старт: ничего не разрешено, хук ждёт выбора режима.
    setButtonsEnabled(false);
    setStatus("idle", txt.stIdle);
    nodeDaemon?.setAttribute("data-active", "false");

    if (reduce || !("IntersectionObserver" in window)) {
      // Финальное читаемое состояние без движения. Демонстрируем remote-исход
      // как «застывший» кадр; тапы/переключатели по-прежнему живут.
      root.classList.add("is-inview");
      inview = false; // под reduced пакет/отсчёт не запускаем
      modeEls.forEach((m) => m.setAttribute("aria-checked", m.dataset.mode === "remote" ? "true" : "false"));
      nodeDaemon?.setAttribute("data-active", "true");
      setButtonsEnabled(true);
      setStatus("waiting", txt.stWaiting);
      setAgent("", txt.agentIntercepted);
      return;
    }

    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        inview = false;
        root.classList.remove("is-inview");
        stopCountdown();
      }
    });

    window.addEventListener(
      "pagehide",
      () => {
        stopCountdown();
        io.disconnect();
      },
      { once: true },
    );
  })();
</script>
