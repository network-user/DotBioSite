    .ws__tick-dot {
      background: var(--accent);
    }
    /* весь рейл читается как «пройденный путь» */
    .ws__node {
      opacity: 0.78;
      transition: none;
    }
    .ws__node-mark {
      background: var(--text-secondary);
      transition: none;
    }
    /* лента и токены показываются статично, без transform-проявления */
    .ws__slot-token,
    .ws__offer,
    .ws__offer-row {
      transition: none;
    }
  }
</style>

<script>
  // Пошаговый разбор под полным контролем читателя + ветвление развилки и
  // гонка реплик. Скрипт лишь переключает классы/атрибуты/hidden; всё, что
  // движется, — это transform/opacity в CSS. Анимации/«тик» запускаются только
  // в зоне видимости (.is-inview) и гасятся за экраном, на скрытой вкладке и
  // на pagehide. Авто-режим выключен по умолчанию, шаг ~5с, пауза на hover/focus.
  (() => {
    type Branch = "confirm" | "release" | "";

    function initWorkShifts(): void {
      const roots = Array.from(document.querySelectorAll<HTMLElement>("[data-ws]"));
      if (!roots.length) return;

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");

      roots.forEach((root) => {
        if (root.dataset.wsInit === "1") return; // уже инициализирован
        root.dataset.wsInit = "1";

        const steps = Array.from(root.querySelectorAll<HTMLElement>(".ws__step"));
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ws-dot]"));
        const railNodes = Array.from(root.querySelectorAll<HTMLElement>(".ws__node"));
        const railEl = root.querySelector<HTMLElement>("[data-ws-rail]");
        const stageRail = root.querySelector<HTMLElement>('[data-ws-stage="rail"]');
        const stageEngine = root.querySelector<HTMLElement>('[data-ws-stage="engine"]');
        const counter = root.querySelector<HTMLElement>("[data-ws-counter]");
        const prevBtn = root.querySelector<HTMLButtonElement>("[data-ws-prev]");
        const nextBtn = root.querySelector<HTMLButtonElement>("[data-ws-next]");
        const replayBtn = root.querySelector<HTMLButtonElement>("[data-ws-replay]");
        const toggleBtn = root.querySelector<HTMLButtonElement>("[data-ws-toggle]");

        const branchBox = root.querySelector<HTMLElement>("[data-ws-branch]");
        const confirmBtn = root.querySelector<HTMLButtonElement>("[data-ws-confirm]");
        const noShowBtn = root.querySelector<HTMLButtonElement>("[data-ws-noshow]");
        const branchReset = root.querySelector<HTMLButtonElement>("[data-ws-branch-reset]");
        const slot = root.querySelector<HTMLElement>("[data-ws-slot]");
        const slotState = root.querySelector<HTMLElement>("[data-ws-slot-state]");

        const N = steps.length;
        if (!N) return;

        // scene выводим из соответствия: шаги с рейл-узлом — рейл, прочие — движок.
        const SCENE: ("rail" | "engine")[] = steps.map((_, i) =>
          i < railNodes.length ? "rail" : "engine",
        );
        // ветка шага читаем из data-branch разметки (confirm|release|"").
        const BRANCH: Branch[] = steps.map(
          (s) => (s.dataset.branch as Branch | undefined) ?? "",
        );
        // индекс шага reminder (узел развилки) — последний рейл-шаг перед confirm.
        const remindIdx = BRANCH.indexOf("confirm") - 1;

        const locale = document.documentElement.lang === "en" ? "en" : "ru";
        const L = {
          ru: {
            step: "Шаг",
            of: "из",
            play: "Авто",
            pause: "Пауза",
            slotFilled: "слот занят · назначение",
            slotConfirmed: "подтверждён · confirmed_at",
            slotFreed: "слот свободен · снова в ленте",
          },
          en: {
            step: "Step",
            of: "of",
            play: "Auto",
            pause: "Pause",
            slotFilled: "slot filled · assignment",
            slotConfirmed: "confirmed · confirmed_at",
            slotFreed: "slot freed · back in feed",
          },
        }[locale];

        const AUTO_MS = 5000;
        let idx = 0;
        let auto = false;
        let inview = false;
        let timer = 0;
        let hovered = false;

        const clearTimer = (): void => {
          if (timer) window.clearTimeout(timer);
          timer = 0;
        };

        const scheduleAuto = (): void => {
          clearTimer();
          if (!auto || !inview || hovered || reduced.matches) return;
          timer = window.setTimeout(() => {
            render((idx + 1) % N);
            scheduleAuto();
          }, AUTO_MS);
        };

        // Слот-токен реагирует на выбор развилки.
        const setSlot = (state: "filled" | "confirmed" | "freed"): void => {
          if (slot) slot.dataset.state = state;
          if (slotState) {
            slotState.textContent =
              state === "confirmed"
                ? L.slotConfirmed
                : state === "freed"
                  ? L.slotFreed
                  : L.slotFilled;
          }
        };

        // Применить ветку к рейлу и слот-токену (или сбросить).
        const applyBranch = (b: Branch): void => {
          if (railEl) {
            if (b) railEl.dataset.branch = b;
            else delete railEl.dataset.branch;
          }
          confirmBtn?.setAttribute("aria-pressed", b === "confirm" ? "true" : "false");
          noShowBtn?.setAttribute("aria-pressed", b === "release" ? "true" : "false");
          if (branchReset) branchReset.hidden = b === "";
          // слот: до старта (после reminder) занят; confirm → подтверждён; no-show → свободен.
          setSlot(b === "confirm" ? "confirmed" : b === "release" ? "freed" : "filled");
        };

        const render = (next: number): void => {
          idx = ((next % N) + N) % N;
          const scene = SCENE[idx];

          if (stageRail) stageRail.hidden = scene !== "rail";
          if (stageEngine) stageEngine.hidden = scene !== "engine";
          root.toggleAttribute("data-engine-on", scene === "engine");

          // развилка видна только на шаге reminder
          if (branchBox) branchBox.hidden = !(scene === "rail" && idx === remindIdx);

          if (scene === "rail") {
            railNodes.forEach((n, i) => {
              n.classList.toggle("is-active", i === idx);
              n.classList.toggle("is-done", i < idx);
            });
          } else {
            railNodes.forEach((n) => {
              n.classList.remove("is-active");
              n.classList.add("is-done");
            });
          }

          steps.forEach((s, i) => {
            s.hidden = i !== idx;
          });

          dots.forEach((d, i) => {
            d.setAttribute("aria-selected", i === idx ? "true" : "false");
            d.classList.toggle("is-done", i < idx);
          });

          if (prevBtn) prevBtn.disabled = idx === 0;
          if (nextBtn) nextBtn.disabled = idx === N - 1;

          if (counter) counter.textContent = `${L.step} ${idx + 1} ${L.of} ${N}`;
        };

        // ── Управление ──
        const stopAuto = (): void => {
          auto = false;
          clearTimer();
          setToggle();
        };

        function setToggle(): void {
          if (!toggleBtn) return;
          toggleBtn.setAttribute("aria-pressed", auto ? "true" : "false");
          toggleBtn.textContent = auto ? L.pause : L.play;
        }

        prevBtn?.addEventListener("click", () => {
          stopAuto();
          render(idx - 1);
        });
        nextBtn?.addEventListener("click", () => {
          stopAuto();
          render(idx + 1);
        });
        dots.forEach((d, i) =>
          d.addEventListener("click", () => {
            stopAuto();
            render(i);
          }),
        );

        // ── Интерактив: узлы рейла — прыжок на стадию (li role=button → keydown).
        railNodes.forEach((node, i) => {
          const jump = (): void => {
            stopAuto();
            render(i);
          };
          node.addEventListener("click", jump);
          node.addEventListener("keydown", (e: KeyboardEvent) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              jump();
            }
          });
        });

        // ── Интерактив: развилка confirm | no-show ──
        // confirm → перейти к шагу confirm; no-show → перейти к шагу release.
        const branchConfirmIdx = BRANCH.indexOf("confirm");
        const branchReleaseIdx = BRANCH.indexOf("release");

        confirmBtn?.addEventListener("click", () => {
          stopAuto();
          applyBranch("confirm");
          if (branchConfirmIdx >= 0) render(branchConfirmIdx);
        });
        noShowBtn?.addEventListener("click", () => {
          stopAuto();
          applyBranch("release");
          if (branchReleaseIdx >= 0) render(branchReleaseIdx);
        });
        branchReset?.addEventListener("click", () => {
          applyBranch("");
          if (remindIdx >= 0) render(remindIdx);
        });

        // ── Интерактив: реплики — клик/Enter забирает лидер-лок (ровно один).
        const reps = Array.from(root.querySelectorAll<HTMLElement>(".ws__rep"));
        reps.forEach((rep) => {
          rep.addEventListener("click", () => {
            reps.forEach((r) => {
              const lead = r === rep;
              r.setAttribute("data-lead", lead ? "1" : "0");
              r.setAttribute("aria-pressed", lead ? "true" : "false");
            });
          });
        });

        replayBtn?.addEventListener("click", () => {
          applyBranch("");
          render(0);
          if (auto) scheduleAuto();
        });

        toggleBtn?.addEventListener("click", () => {
          auto = !auto;
          setToggle();
          scheduleAuto();
        });

        // пауза авто-режима на hover/focus
        root.addEventListener("pointerenter", () => {
          hovered = true;
          clearTimer();
        });
        root.addEventListener("pointerleave", () => {
          hovered = false;
          scheduleAuto();
        });
        root.addEventListener("focusin", () => {
          hovered = true;
          clearTimer();
        });
        root.addEventListener("focusout", () => {
          hovered = false;
          scheduleAuto();
        });

        applyBranch("");
        render(0);

        // ── reduced-motion: финальный читаемый кадр, без авто/анимаций ──
        if (reduced.matches) {
          // показываем счастливый путь как «итог» развилки, но статично.
          applyBranch("confirm");
          render(0);
          return;
        }

        // ── Видимость: анимации/авто/«тик» только в зоне видимости ──
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              inview = e.isIntersecting;
              root.classList.toggle("is-inview", inview);
              if (inview) scheduleAuto();
              else clearTimer();
            }
          },
          { threshold: 0.2 },
        );
        io.observe(root);

        const onVisibility = (): void => {
          if (document.hidden) {
            inview = false;
            root.classList.remove("is-inview");
            clearTimer();
          }
        };
        document.addEventListener("visibilitychange", onVisibility);

        const onPageHide = (): void => {
          clearTimer();
          io.disconnect();
          document.removeEventListener("visibilitychange", onVisibility);
        };
        window.addEventListener("pagehide", onPageHide, { once: true });

        const onReduce = (): void => {
          if (reduced.matches) {
            stopAuto();
            root.classList.remove("is-inview");
          }
        };
        reduced.addEventListener?.("change", onReduce);
      });
    }

    initWorkShifts();
    document.addEventListener("astro:page-load", initWorkShifts);
  })();
</script>
