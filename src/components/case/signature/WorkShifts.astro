---

<section
  class="ws"
  data-ws
  data-live="off"
  aria-label={t({ ru: "Диспетчерская доска .работа", en: ".work dispatch board" })}
>
  <p class="ws__intro">{t(ui.intro)}</p>

  <!-- ── Панель управления временем ──────────────────────────────────── -->
  <div class="ws__bar" role="group" aria-label={t(ui.clock)}>
    <div class="ws__clock">
      <span class="ws__clock-cap">{t(ui.clock)}</span>
      <span class="ws__clock-time mono" data-ws-time aria-live="polite">{`${NOW0}:00`}</span>
    </div>

    <div class="ws__step">
      <button class="ws__btn ws__btn--step" type="button" data-ws-back aria-label={t(ui.back)}>
        <span aria-hidden="true">−1ч</span>
      </button>
      <button class="ws__btn ws__btn--step" type="button" data-ws-fwd aria-label={t(ui.fwd)}>
        <span aria-hidden="true">+1ч</span>
      </button>
    </div>

    <label class="ws__scrub">
      <span class="ws__scrub-cap">{t(ui.scrub)}</span>
      <input
        class="ws__scrub-input"
        type="range"
        min={DAY_START}
        max={NOW0}
        step="1"
        value={NOW0}
        data-ws-scrub
        aria-label={t(ui.scrub)}
      />
    </label>

    <div class="ws__bar-actions">
      <button class="ws__btn ws__btn--live" type="button" data-ws-live aria-pressed="false">
        <span class="ws__live-dot" aria-hidden="true"></span>
        <span data-ws-live-label>{t(ui.live)}</span>
      </button>
      <button class="ws__btn ws__btn--create" type="button" data-ws-create aria-expanded="false">
        {t(ui.create)}
      </button>
      <span class="ws__hist mono" data-ws-hist hidden>
        <span class="ws__hist-tag">{t(ui.hist)}</span>
        <button class="ws__hist-btn" type="button" data-ws-tonow>{t(ui.toNow)}</button>
      </span>
    </div>
  </div>

  <!-- ── Композер новой смены (скрыт до «Создать») ───────────────────── -->
  <div class="ws__composer" data-ws-composer hidden>
    <span class="ws__composer-cap">{t(ui.composerCap)}</span>
    <p class="ws__composer-hint">{t(ui.composerHint)}</p>
    <div class="ws__presets" role="group" aria-label={t(ui.composerCap)}>
      {
        presets.map((p, i) => (
          <button
            class="ws__preset"
            type="button"
            data-ws-preset={p.id}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <span class="ws__preset-title">{t(p.title)}</span>
            <span class="ws__preset-meta mono">
              {t(p.city)} · {p.rate}
            </span>
          </button>
        ))
      }
    </div>
    <p class="ws__preview mono">
      <span class="ws__preview-cap">{t(ui.preview)}:</span>
      <span data-ws-preview>—</span>
    </p>
    <div class="ws__composer-btns">
      <button class="ws__btn ws__btn--publish" type="button" data-ws-publish>{t(ui.publish)}</button
      >
      <button class="ws__btn ws__btn--ghost" type="button" data-ws-cancel>{t(ui.cancel)}</button>
    </div>
  </div>

  <!-- ── Доска: три колонки ──────────────────────────────────────────── -->
  <div class="ws__board" data-ws-board>
    {
      (
        [
          ["open", ui.colOpen, ui.emptyOpen],
          ["progress", ui.colProgress, ui.emptyProgress],
          ["done", ui.colDone, ui.emptyDone],
        ] as const
      ).map(([col, cap, empty]) => (
        <section class="ws__col" data-col={col} aria-label={t(cap)}>
          <span class="ws__col-cap">
            <span class="ws__col-dot" aria-hidden="true" data-col-dot={col} />
            {t(cap)}
            <span class="ws__col-count mono" data-ws-colcount={col}>
              0
            </span>
          </span>
          <ul class="ws__col-body" data-ws-colbody={col} />
          <span class="ws__col-empty" data-ws-empty>
            {t(empty)}
          </span>
        </section>
      ))
    }
  </div>

  <!-- ── Ростер работников ───────────────────────────────────────────── -->
  <div class="ws__roster" data-ws-roster aria-label={t(ui.roster)}>
    <span class="ws__roster-cap">{t(ui.roster)}</span>
    <ul class="ws__roster-list">
      {
        workers.map((w) => (
          <li class="ws__wk" data-worker={w.id}>
            <span class="ws__wk-dot" aria-hidden="true" data-ws-wk-dot />
            <span class="ws__wk-name mono">{w.id}</span>
            <span class="ws__wk-meta mono">
              {w.dist} · ★{w.rating}
            </span>
            <span class="ws__wk-state mono" data-ws-wk-state>
              {t(ui.free)}
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- ── Журнал воркера ──────────────────────────────────────────────── -->
  <div class="ws__logwrap">
    <span class="ws__log-cap">{t(ui.log)}</span>
    <pre class="ws__log mono" data-ws-log aria-live="polite" tabindex="0">{t(ui.logIdle)}</pre>
  </div>

  <!-- ── «Под капотом»: гонка реплик за лидер-лок ────────────────────── -->
  <div class="ws__under" data-ws-under>
    <button
      class="ws__under-toggle"
      type="button"
      data-ws-engine-toggle
      aria-expanded="false"
      aria-controls="ws-engine"
    >
      <span class="ws__under-chev" aria-hidden="true">▸</span>
      <span>{t(ui.under)}</span>
    </button>
    <div class="ws__engine" id="ws-engine" data-ws-engine hidden>
      <div class="ws__lock-key">
        <span class="ws__lock-cmd mono">{t(ui.lockKey)}</span>
        <span class="ws__tick" aria-hidden="true">
          <span class="ws__tick-dot"></span>
          <span class="ws__tick-label mono">{t(ui.tickTag)}</span>
        </span>
      </div>
      <span class="ws__loop mono">{t(ui.loop)}</span>
      <div class="ws__replicas">
        {
          replicas.map((r) => (
            <button
              type="button"
              class="ws__rep"
              data-rep={r.id}
              data-lead={r.lead ? "1" : "0"}
              aria-pressed={r.lead ? "true" : "false"}
              aria-label={t(ui.makeLeader)}
            >
              <span class="ws__rep-dot" aria-hidden="true" />
              <span class="ws__rep-name mono">{r.id}</span>
              <span class="ws__rep-tag ws__rep-tag--lead mono">{t(ui.leaderTag)}</span>
              <span class="ws__rep-tag ws__rep-tag--idle mono">{t(ui.idleTag)}</span>
            </button>
          ))
        }
      </div>
      <p class="ws__hint">{t(ui.underHint)}</p>
    </div>
  </div>

  <!-- Колофон фактов (статичный, читаем и при reduced-motion) -->
  <p class="ws__facts">
    <span class="mono">{t(ui.roles)}</span>
    <span class="ws__facts-sep" aria-hidden="true">·</span>
    <span class="mono">{t(ui.stack)}</span>
  </p>

  <!-- Слой тостов + слой drag-клона -->
  <div class="ws__toasts" data-ws-toasts aria-live="polite"></div>
  <div class="ws__draglayer" data-ws-draglayer aria-hidden="true"></div>

  <script is:inline type="application/json" data-ws-payload set:html={JSON.stringify(payload)} />
</section>

<style>
  .ws {
    --accent: var(--accent-work);
    --line: color-mix(in srgb, var(--accent) 40%, var(--border));
    --soft: color-mix(in srgb, var(--accent) 12%, transparent);
    --soft-2: color-mix(in srgb, var(--accent) 7%, transparent);
    --glow: color-mix(in srgb, var(--accent) 18%, transparent);
    --warn: color-mix(in srgb, var(--state-warn) 60%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    color: var(--text);
    container-type: inline-size;
  }

  .mono {
    font-family: var(--font-stack-mono);
  }

  .ws__intro {
    margin: 0;
    max-width: 70ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  .ws__hint {
    margin: var(--sp-4) 0 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: color-mix(in srgb, var(--accent) 58%, var(--text-muted));
  }

  /* Общие подписи-eyebrow */
  .ws__clock-cap,
  .ws__scrub-cap,
  .ws__composer-cap,
  .ws__roster-cap,
  .ws__log-cap,
  .ws__col-cap {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Кнопки (общая база) ─────────────────────────────────────────── */
  .ws__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws__btn:active {
    transform: scale(0.96);
  }
  .ws__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }
  .ws__btn--step {
    min-width: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
  }
  .ws__btn--create,
  .ws__btn--publish {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws__btn--publish:hover,
  .ws__btn--create:hover {
    border-color: var(--accent);
  }

  /* ── Панель управления временем ──────────────────────────────────── */
  .ws__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--sp-4);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background: radial-gradient(120% 130% at 6% 0%, var(--glow), transparent 46%), var(--surface);
  }

  .ws__clock {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .ws__clock-time {
    font-size: var(--fs-28);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-snug);
    color: var(--text);
    font-variant-numeric: tabular-nums;
    transform: scale(1);
    transition: transform var(--dur-med) var(--ease-spring);
  }
  .ws.is-tick .ws__clock-time {
    transform: scale(1.06);
  }

  .ws__step {
    display: inline-flex;
    gap: var(--sp-2);
  }

  .ws__scrub {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    flex: 1 1 180px;
    min-width: 160px;
  }
  .ws__scrub-input {
    width: 100%;
    accent-color: var(--accent);
    min-height: var(--tap-min);
    cursor: pointer;
  }
  .ws__scrub-input:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 4px;
    border-radius: var(--r-pill);
  }

  .ws__bar-actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
    margin-left: auto;
  }

  .ws__live-dot {
    width: 9px;
    height: 9px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transform: scale(1);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws[data-live="on"] .ws__btn--live {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws[data-live="on"] .ws__live-dot {
    background: var(--accent);
  }
  /* Пульс «в эфире» — только когда виден и играет */
  .ws.is-inview[data-live="on"] .ws__live-dot {
    animation: ws-breathe 1.5s var(--ease-drift) infinite;
  }

  .ws__hist {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-11);
    color: var(--warn);
  }
  .ws__hist[hidden] {
    display: none;
  }
  .ws__hist-tag {
    letter-spacing: var(--ls-snug);
  }
  .ws__hist-btn {
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--warn);
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-12);
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-standard);
  }
  .ws__hist-btn:hover {
    border-color: var(--accent);
  }
  .ws__hist-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  /* ── Композер ────────────────────────────────────────────────────── */
  .ws__composer {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--line);
    border-radius: var(--r-md);
    background: var(--soft-2);
  }
  .ws__composer[hidden] {
    display: none;
  }
  .ws__composer-hint {
    margin: 0;
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: var(--text-muted);
  }
  .ws__presets {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--sp-2);
  }
  .ws__preset {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    text-align: left;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__preset:hover {
    border-color: var(--border-hover);
  }
  .ws__preset:active {
    transform: scale(0.98);
  }
  .ws__preset:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__preset[aria-pressed="true"] {
    border-color: var(--line);
    background: var(--soft);
    color: var(--text);
  }
  .ws__preset-title {
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
  }
  .ws__preset-meta {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .ws__preview {
    margin: 0;
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }
  .ws__preview-cap {
    color: var(--text-muted);
    margin-right: var(--sp-2);
  }
  .ws__composer-btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  /* ── Доска ───────────────────────────────────────────────────────── */
  .ws__board {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-3);
  }
  .ws__col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
    min-height: 130px;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .ws__col.is-droptarget {
    border-color: var(--accent);
    background: var(--soft);
  }
  .ws__col-cap {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .ws__col-dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--text-faint);
  }
  .ws__col-dot[data-col-dot="open"] {
    background: var(--text-secondary);
  }
  .ws__col-dot[data-col-dot="progress"] {
    background: var(--accent);
  }
  .ws__col-dot[data-col-dot="done"] {
    background: var(--state-ok);
  }
  .ws__col-count {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 1px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
  }
  .ws__col-body {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
    flex: 1 1 auto;
  }
  .ws__col-empty {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    color: var(--text-faint);
    padding: var(--sp-2) 0;
  }
  .ws__col:has(.ws__card) .ws__col-empty {
    display: none;
  }

  /* ── Карточка смены ──────────────────────────────────────────────── */
  .ws__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    min-width: 0;
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-spring),
      border-color var(--dur-med) var(--ease-standard);
  }
  .ws__card[data-hero="1"] {
    border-color: var(--line);
    background: var(--soft-2);
  }
  .ws__card[data-col="done"] {
    opacity: 0.62;
  }
  .ws__card.is-ghost {
    opacity: 0.35;
  }
  .ws.is-inview .ws__card.is-moved {
    animation: ws-pop var(--dur-slow) var(--ease-spring);
  }
  @keyframes ws-pop {
    0% {
      transform: scale(0.9) translateY(6px);
      opacity: 0.4;
    }
    100% {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }

  .ws__card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-2);
  }
  .ws__card-grip {
    position: absolute;
    top: var(--sp-2);
    right: var(--sp-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--text-faint);
    cursor: grab;
    touch-action: none;
    border-radius: var(--r-xs);
    transition:
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .ws__card-grip:hover {
    color: var(--text-secondary);
    background: var(--border);
  }
  .ws__card-grip:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 1px;
  }
  .ws__card-grip:active {
    cursor: grabbing;
  }
  .ws__card[data-locked="1"] .ws__card-grip {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .ws__card-id {
    font-size: var(--fs-11);
    color: var(--text-muted);
    letter-spacing: var(--ls-snug);
  }
  .ws__card-window {
    font-size: var(--fs-11);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
    margin-right: 26px;
  }
  .ws__card-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-14);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
    overflow-wrap: anywhere;
    padding-right: 26px;
  }
  .ws__card-city {
    font-size: var(--fs-12);
    color: var(--text-muted);
    line-height: var(--lh-snug);
    overflow-wrap: anywhere;
  }
  .ws__card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
    flex-wrap: wrap;
    margin-top: 2px;
  }
  .ws__card-rate {
    font-size: var(--fs-11);
    color: var(--accent);
  }
  .ws__card-worker {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-11);
    color: var(--text-muted);
    opacity: 0;
    transform: translateY(3px);
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .ws__card[data-worker-set="1"] .ws__card-worker {
    opacity: 1;
    transform: translateY(0);
  }
  .ws__card-status {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-10);
    line-height: var(--lh-snug);
    color: var(--text-muted);
  }
  .ws__card[data-state="confirmed"] .ws__card-status {
    color: color-mix(in srgb, var(--accent) 60%, var(--text-secondary));
  }
  .ws__card[data-state="released"] .ws__card-status,
  .ws__card[data-state="cancelled"] .ws__card-status {
    color: var(--state-warn);
  }

  .ws__card-remind {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 9px 9px 0 0;
    border-color: var(--accent) transparent transparent transparent;
    opacity: 0;
    transform: scale(0.6);
    transform-origin: top left;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws__card[data-reminded="1"] .ws__card-remind {
    opacity: 0.95;
    transform: scale(1);
  }

  .ws__card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-1);
  }
  .ws__card-btn {
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-12);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__card-btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws__card-btn:active {
    transform: scale(0.96);
  }
  .ws__card-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__card-btn--primary {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws__card-btn--warn {
    border-color: var(--warn);
  }
  .ws__card[data-locked="1"] .ws__card-btn {
    opacity: 0.4;
    pointer-events: none;
  }

  /* ── Ростер ──────────────────────────────────────────────────────── */
  .ws__roster {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
  }
  .ws__roster-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--sp-2);
  }
  .ws__wk {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    font-size: var(--fs-12);
    transition: border-color var(--dur-med) var(--ease-standard);
  }
  .ws__wk[data-busy="1"] {
    border-color: var(--line);
  }
  .ws__wk-dot {
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--state-ok);
    transform: scale(1);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws__wk[data-busy="1"] .ws__wk-dot {
    background: var(--accent);
    transform: scale(1.15);
  }
  .ws__wk-name {
    color: var(--text);
    font-size: var(--fs-13);
  }
  .ws__wk-meta {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .ws__wk-state {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    text-align: right;
  }
  .ws__wk[data-busy="1"] .ws__wk-state {
    color: var(--text-secondary);
  }

  /* ── Журнал ──────────────────────────────────────────────────────── */
  .ws__logwrap {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .ws__log {
    margin: 0;
    height: 148px;
    overflow: auto;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    font-size: var(--fs-12);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .ws__log:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__log :global(.ws-l) {
    display: block;
    opacity: 0;
    transform: translateY(3px);
  }
  .ws__log :global(.ws-l.is-in) {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .ws__log :global(.ws-acc) {
    color: var(--accent);
  }
  .ws__log :global(.ws-warn) {
    color: var(--state-warn);
  }
  .ws__log :global(.ws-dim) {
    color: var(--text-faint);
  }

  /* ── «Под капотом» ───────────────────────────────────────────────── */
  .ws__under {
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
    overflow: hidden;
  }
  .ws__under-toggle {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3) var(--sp-4);
    border: none;
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .ws__under-toggle:hover {
    color: var(--text);
  }
  .ws__under-toggle:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: -2px;
  }
  .ws__under-chev {
    display: inline-block;
    transform: rotate(0deg);
    transition: transform var(--dur-med) var(--ease-standard);
    color: var(--accent);
  }
  .ws__under-toggle[aria-expanded="true"] .ws__under-chev {
    transform: rotate(90deg);
  }
  .ws__engine {
    padding: 0 var(--sp-4) var(--sp-4);
  }
  .ws__engine[hidden] {
    display: none;
  }
  .ws__lock-key {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
  }
  .ws__lock-cmd {
    font-size: var(--fs-12);
    color: var(--text-muted);
    margin-right: auto;
    overflow-wrap: anywhere;
  }
  .ws__tick {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    flex: none;
  }
