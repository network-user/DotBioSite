  .ws__lock-key-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-elevated);
  }

  .ws__lock-cmd {
    font-size: var(--fs-13);
    color: var(--accent);
  }

  .ws__lock-name {
    font-size: var(--fs-12);
    color: var(--text-muted);
    margin-right: auto;
    word-break: break-all;
  }

  /* «тик» цикла: пип, который пульсирует, пока лидер держит лок */
  .ws__tick {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .ws__tick-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transform: scale(1);
  }
  .ws__tick-label {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  .ws__replicas {
    display: grid;
    gap: var(--sp-3);
  }

  .ws__rep {
    position: relative;
    appearance: none;
    width: 100%;
    text-align: left;
    font: inherit;
    color: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    min-height: var(--tap-min);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    font-size: var(--fs-14);
    opacity: 0.45;
    transition:
      opacity var(--dur-slow) var(--ease-standard),
      border-color var(--dur-slow) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__rep:hover {
    opacity: 1;
    border-color: var(--border-hover);
  }
  .ws__rep:active {
    transform: scale(0.99);
  }
  .ws__rep:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  /* лидер подсвечивается только когда сцена движка активна */
  .ws[data-engine-on] .ws__rep[data-lead="1"] {
    opacity: 1;
    border-color: var(--line);
    background: var(--soft);
  }

  .ws__rep-dot {
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transform: scale(1);
    transition:
      transform var(--dur-slow) var(--ease-spring),
      background-color var(--dur-slow) var(--ease-standard);
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-dot {
    background: var(--accent);
  }

  .ws__rep-name {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-secondary);
    margin-right: auto;
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-name {
    color: var(--text);
  }

  .ws__rep-tag {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    letter-spacing: var(--ls-snug);
  }
  .ws__rep-tag--lead {
    color: var(--accent);
    display: none;
  }
  .ws__rep-tag--idle {
    color: var(--text-muted);
    display: inline;
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-tag--lead {
    display: inline;
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-tag--idle {
    display: none;
  }

  /* медленный мягкий «пульс» точки лидера И «тик» цикла — только когда блок
     в зоне видимости И сцена движка активна. Никаких циклов вне экрана. */
  @media (prefers-reduced-motion: no-preference) {
    .ws.is-inview[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-dot {
      animation: ws-breathe 3.6s var(--ease-drift) infinite;
    }
    .ws.is-inview[data-engine-on] .ws__tick-dot {
      animation: ws-tick 2.2s var(--ease-standard) infinite;
    }
  }

  @keyframes ws-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.35);
    }
  }

  /* «тик»: точка вспыхивает и гаснет — читается как такт цикла */
  @keyframes ws-tick {
    0%,
    100% {
      transform: scale(1);
      background: var(--text-faint);
    }
    14% {
      transform: scale(1.6);
      background: var(--accent);
    }
    40% {
      transform: scale(1);
      background: var(--text-faint);
    }
  }

  /* ── Объяснение текущего шага ────────────────────────────────────── */
  .ws__explain {
    min-height: 168px;
  }

  .ws__step[hidden] {
    display: none;
  }

  .ws__step-tag {
    display: inline-block;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-2);
  }

  .ws__step-title {
    margin: 0 0 var(--sp-2);
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-20);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
  }

  .ws__step-body {
    margin: 0;
    max-width: 64ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* мягкое проявление текста при смене шага (только когда в зоне видимости) */
  @media (prefers-reduced-motion: no-preference) {
    .ws.is-inview .ws__step:not([hidden]) {
      animation: ws-step-in var(--dur-slow) var(--ease-soft) both;
    }
  }
  @keyframes ws-step-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Управление ──────────────────────────────────────────────────── */
  .ws__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .ws__dots {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
    justify-content: center;
  }

  .ws__dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--tap-min);
    height: var(--tap-min);
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
