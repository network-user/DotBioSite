// Полезная нагрузка для клиента: локализованные строки + seed (без ru/en в JS).
const payload = {
  locale,
  dayStart: DAY_START,
  dayEnd: DAY_END,
  now0: NOW0,
  ui: Object.fromEntries(Object.entries(ui).map(([k, v]) => [k, t(v)])),
