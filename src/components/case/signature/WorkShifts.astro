---
/**
 * WorkShifts.astro — сигнатурная визуализация .работа (DotWorkBot).
 *
 * Концепция: ДИСПЕТЧЕРСКАЯ ДОСКА смен с управляемыми ЧАСАМИ («машина времени»)
 * и панелью гонки реплик. Это НЕ нумерованный степпер и НЕ «Шаг N из M»:
 * посетитель крутит время, ветвит исход и тыкает реплики — а доска живёт сама.
 *
 * Сцена «доска»: карточки заказов-смен в трёх дорожках (open / in progress /
 * done) + аватар работника. Большие ЧАСЫ с кнопкой «+1 час» и скраб-ползунком.
 * Пока посетитель ПРОМАТЫВАЕТ ВРЕМЯ, отдельный taskiq-воркер авто-действует:
 *   - примерно за 3 часа до старта шлёт РОВНО ОДНО напоминание (флаг ставится
 *     атомарно — повторно не уйдёт никогда);
 *   - если к моменту старта работник не подтвердился — слот ОСВОБОЖДАЕТСЯ,
 *     карточка анимируется обратно в «open» и пере-предлагается другим
 *     работникам города;
 *   - просроченные заказы (прошёл end_time) авто-закрываются.
 * Посетитель сам выбирает Confirm / No-show для работника и ветвит исход.
 * Статусы строго: OrderStatus OPEN / IN_PROGRESS / CANCELLED;
 * OrderAssignment.confirmed_at; мульти-слот заказ закрывается другим только
 * когда набраны ВСЕ нужные работники.
 *
 * Сцена «движок»: несколько taskiq-реплик. Тап по любой реплике заставляет
 * ИМЕННО ЕЁ забрать Redis-лидер-лок `SET nx ex` (ключ
 * dotworkbot:operational_control:leader); остальные становятся idle; ровно
 * ОДИН лидер видимо «тикает» _operational_control_loop (интервал ≥15с).
 * Всегда ровно один лидер даже при многих репликах.
 *
 * Факты: 3 роли (worker/employer/admin); реляционное ядро PostgreSQL + Redis
 * (FSM/throttle/lock) + MinIO/S3 для фото; AES-шифрованные бэкапы; авто-деплой
 * на VPS с health-check откатом; ~11k строк. Акцент var(--accent-work).
 *
 * Перф-бюджет: анимируем ТОЛЬКО transform/opacity. Никакого постоянного rAF —
 * авто-тики ведёт setTimeout-конвейер, который ОЧИЩАЕТСЯ за кадром, на скрытой
 * вкладке и на pagehide. Единственные infinite-CSS («тик» лидера, пульс часов)
 * scoped под .ws.is-inview[data-engine-on] / .ws.is-inview и замирают офскрин.
 * Всё гейтится IntersectionObserver. reduced-motion → финальный читаемый кадр
 * без движения; все интеракции (часы, ветвление, реплики) работают.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const ui = {
  intro: {
    ru: "Это диспетчерская биржи разовых смен. Крутите часы — и отдельный фоновый воркер оживает: за три часа до старта шлёт одно напоминание, освобождает слот, если работник не подтвердился, и сам закрывает просроченные заказы. Выберите на развилке, выйдет работник или пропадёт, а ниже — гонка реплик за один лидер-лок.",
    en: "This is the dispatch room of a gig-shift marketplace. Wind the clock and a separate background worker wakes up: it sends one reminder three hours before start, frees the slot if the worker hasn't confirmed, and auto-closes expired orders. Pick at the fork whether the worker shows or vanishes, and below — replicas racing for a single leader-lock.",
  },
  boardCap: { ru: "Диспетчерская доска", en: "Dispatch board" },
  engineCap: { ru: "Движок под капотом", en: "The engine underneath" },
  clockCap: { ru: "Часы города", en: "City clock" },
  advance: { ru: "+1 час", en: "+1 hour" },
  scrub: { ru: "Перемотать время дня", en: "Scrub the time of day" },
  laneOpen: { ru: "Открыто", en: "Open" },
  laneProgress: { ru: "В работе", en: "In progress" },
  laneDone: { ru: "Закрыто", en: "Done" },
  worker: { ru: "Работник", en: "Worker" },
  workerIdle: { ru: "свободен · ждёт смену", en: "free · waiting for a shift" },
  branchPrompt: {
    ru: "Что сделает работник со сменой в 18:00?",
    en: "What does the worker do with the 18:00 shift?",
  },
  doConfirm: { ru: "Подтвердить выход", en: "Confirm arrival" },
  doNoShow: { ru: "Пропасть (no-show)", en: "Go silent (no-show)" },
  hintClock: {
    ru: "Тыкай часы: «+1 час» или ползунок гонят время — воркер срабатывает сам.",
    en: "Poke the clock: “+1 hour” or the slider move time — the worker acts on its own.",
  },
  hintEngine: {
    ru: "Тыкай реплику: она заберёт лок. Лидер всегда ровно один — он и «тикает» цикл.",
    en: "Tap a replica: it grabs the lock. Always exactly one leader — and it ticks the loop.",
  },
  log: { ru: "Журнал воркера", en: "Worker log" },
  logIdle: {
    ru: "_operational_control_loop спит · ждёт такта",
    en: "_operational_control_loop sleeps · awaiting a tick",
  },
  roles: { ru: "3 роли: worker · employer · admin", en: "3 roles: worker · employer · admin" },
  stack: {
    ru: "PostgreSQL · Redis (FSM/throttle/lock) · MinIO/S3 фото · AES-бэкапы · VPS-деплой с откатом",
    en: "PostgreSQL · Redis (FSM/throttle/lock) · MinIO/S3 photos · AES backups · VPS deploy with rollback",
  },
  loop: { ru: "_operational_control_loop · ≥15с", en: "_operational_control_loop · ≥15s" },
  lockKey: {
    ru: "SET nx ex · dotworkbot:operational_control:leader",
    en: "SET nx ex · dotworkbot:operational_control:leader",
  },
  once: { ru: "ровно один раз", en: "exactly once" },
  tickTag: { ru: "тик цикла", en: "loop tick" },
  leaderTag: { ru: "лидер · держит лок", en: "leader · holds lock" },
  idleTag: { ru: "idle · пропускает такт", en: "idle · skips tick" },
  makeLeader: {
    ru: "Сделать эту реплику лидером (забрать лок)",
    en: "Make this replica the leader (grab the lock)",
  },
  slots: { ru: "слотов", en: "slots" },
};

/**
 * Заказы-смены на доске. start/end — час дня (24ч), needed — сколько работников
 * нужно (мульти-слот), filled — уже набрано. `fork` помечает заказ-героя, исход
 * которого ветвит посетитель (confirm / no-show). Остальные — фон, который
 * оживает сам при проматывании времени (напоминание / авто-закрытие).
 */
type Order = {
  id: string;
  title: Bi;
  city: Bi;
  start: number; // час старта (0..24)
  end: number; // час конца
  needed: number; // нужно работников (слотов)
  filled: number; // уже набрано
  rate: Bi; // ставка (декоративно)
  status: "open" | "progress" | "done"; // стартовая дорожка
  fork?: boolean; // заказ-герой развилки
  remindable?: boolean; // воркер шлёт ему напоминание (есть неподтверждённый слот)
};

const orders: Order[] = [
  {
    id: "WB-3041",
    title: { ru: "Разгрузка склада", en: "Warehouse unload" },
    city: { ru: "Казань · Кировский", en: "Kazan · Kirovsky" },
    start: 18,
    end: 22,
    needed: 2,
    filled: 1,
    rate: { ru: "350 ₽/ч", en: "350 ₽/h" },
    status: "progress",
    fork: true,
    remindable: true,
  },
  {
    id: "WB-3038",
    title: { ru: "Промоутер у ТЦ", en: "Mall promoter" },
    city: { ru: "Казань · Центр", en: "Kazan · Center" },
    start: 16,
    end: 20,
    needed: 1,
    filled: 1,
    rate: { ru: "300 ₽/ч", en: "300 ₽/h" },
    status: "progress",
    remindable: true,
  },
  {
    id: "WB-3052",
    title: { ru: "Курьер на день", en: "Courier for a day" },
    city: { ru: "Казань · Авиастрой", en: "Kazan · Aviastroy" },
    start: 20,
    end: 23,
    needed: 1,
    filled: 0,
    rate: { ru: "400 ₽/ч", en: "400 ₽/h" },
    status: "open",
  },
  {
    id: "WB-2999",
    title: { ru: "Уборка после ивента", en: "Post-event cleanup" },
    city: { ru: "Казань · Вахитово", en: "Kazan · Vakhitovo" },
    start: 9,
    end: 14,
    needed: 1,
    filled: 1,
    rate: { ru: "320 ₽/ч", en: "320 ₽/h" },
    status: "progress", // истечёт по времени → авто-close
  },
];

// Город, которому пере-предлагается освободившийся слот (демо-токены).
const cityWorkers: Bi[] = [
  { ru: "@ramil · 1.2 км", en: "@ramil · 1.2 km" },
  { ru: "@dilara · 2.0 км", en: "@dilara · 2.0 km" },
  { ru: "@artur · 3.4 км", en: "@artur · 3.4 km" },
];

// Реплики воркера для сцены «движок».
const replicas = [
  { id: "r1", lead: true },
  { id: "r2", lead: false },
  { id: "r3", lead: false },
];

// Часовые отметки на циферблате-скрабе (для подписей).
const DAY_START = 8;
const DAY_END = 24;
---

<section
  class="ws"
  data-ws
  data-engine-on
  aria-label={t({ ru: "Диспетчерская DotWorkBot", en: "DotWorkBot dispatch room" })}
>
  <p class="ws__intro">{t(ui.intro)}</p>

  <!-- ── СЦЕНА: ДИСПЕТЧЕРСКАЯ ДОСКА ──────────────────────────────────── -->
  <div class="ws__board" data-ws-board aria-label={t(ui.boardCap)}>
    <!-- Шапка: часы-машина времени + аватар работника -->
    <header class="ws__head">
      <div class="ws__clock" data-ws-clock>
        <span class="ws__clock-cap">{t(ui.clockCap)}</span>
        <div class="ws__clock-row">
          <span class="ws__clock-dial" aria-hidden="true">
            <svg viewBox="0 0 64 64" preserveAspectRatio="xMidYMid meet" class="ws__dial-svg">
              <circle cx="32" cy="32" r="29" class="ws__dial-ring"></circle>
              <line
                x1="32"
                y1="32"
                x2="32"
                y2="13"
                class="ws__dial-hand ws__dial-hand--h"
                data-ws-hand-h></line>
              <line
                x1="32"
                y1="32"
                x2="32"
                y2="8"
                class="ws__dial-hand ws__dial-hand--m"
                data-ws-hand-m></line>
              <circle cx="32" cy="32" r="2.4" class="ws__dial-cap"></circle>
            </svg>
          </span>
          <span class="ws__clock-time mono" data-ws-time aria-live="polite">18:00</span>
          <button class="ws__advance" type="button" data-ws-advance aria-label={t(ui.advance)}>
            <span class="ws__advance-glyph" aria-hidden="true">+1ч</span>
            <span class="ws__advance-t">{t(ui.advance)}</span>
          </button>
        </div>
        <label class="ws__scrub">
          <span class="ws__scrub-cap">{t(ui.scrub)}</span>
          <input
            class="ws__scrub-input"
            type="range"
            min={DAY_START}
            max={DAY_END}
            step="1"
            value="18"
            data-ws-scrub
            aria-label={t(ui.scrub)}
          />
        </label>
      </div>

      <div class="ws__worker" data-ws-worker>
        <span class="ws__worker-cap">{t(ui.worker)}</span>
        <span class="ws__worker-card">
          <span class="ws__avatar" aria-hidden="true">
            <svg viewBox="0 0 40 40" preserveAspectRatio="xMidYMid meet">
              <circle cx="20" cy="15" r="7" class="ws__avatar-head"></circle>
              <path d="M6 36c0-8 6.5-13 14-13s14 5 14 13" class="ws__avatar-body"></path>
            </svg>
            <span class="ws__avatar-dot" aria-hidden="true"></span>
          </span>
          <span class="ws__worker-state mono" data-ws-worker-state>{t(ui.workerIdle)}</span>
        </span>
      </div>
    </header>

    <!-- Три дорожки заказов -->
    <div class="ws__lanes">
      {
        (
          [
            ["open", ui.laneOpen],
            ["progress", ui.laneProgress],
            ["done", ui.laneDone],
          ] as const
        ).map(([lane, cap]) => (
          <section class="ws__lane" data-lane={lane} aria-label={t(cap)}>
            <span class="ws__lane-cap">
              <span class="ws__lane-dot" aria-hidden="true" data-lane-dot={lane} />
              {t(cap)}
              <span class="ws__lane-count mono" data-lane-count={lane}>
                0
              </span>
            </span>
            <ul class="ws__lane-body" data-lane-body={lane} />
          </section>
        ))
      }
    </div>

    <!-- Скрытый «склад» карточек: скрипт раскладывает их по дорожкам -->
    <template data-ws-cards>
      {
        orders.map((o) => (
          <li
            class={`ws__order${o.fork ? " is-fork" : ""}`}
            data-order={o.id}
            data-status={o.status}
            data-start={o.start}
            data-end={o.end}
            data-needed={o.needed}
            data-filled={o.filled}
            data-fork={o.fork ? "1" : "0"}
            data-remindable={o.remindable ? "1" : "0"}
          >
            <span class="ws__order-top">
              <span class="ws__order-id mono">{o.id}</span>
              <span class="ws__order-window mono" data-ws-window>
                {`${o.start}:00–${o.end}:00`}
              </span>
            </span>
            <span class="ws__order-title">{t(o.title)}</span>
            <span class="ws__order-city">{t(o.city)}</span>
            <span class="ws__order-foot">
              <span class="ws__order-rate mono">{t(o.rate)}</span>
              <span class="ws__order-slots mono" data-ws-slots aria-hidden="true">
                <span class="ws__slot-pips" data-ws-pips>
                  {Array.from({ length: o.needed }).map((_, k) => (
                    <span class={`ws__pip${k < o.filled ? " is-filled" : ""}`} data-pip={k} />
                  ))}
                </span>
                <span data-ws-slot-text>
                  {o.filled}/{o.needed} {t(ui.slots)}
                </span>
              </span>
            </span>
            <span class="ws__order-flag" data-ws-flag aria-hidden="true" />
            <ul class="ws__order-offer" data-ws-offer aria-hidden="true">
              {cityWorkers.map((w, k) => (
                <li class="ws__offer-row" data-offer={k} style={`--i:${k}`}>
                  <span class="ws__offer-dot" aria-hidden="true" />
                  <span class="ws__offer-name mono">{t(w)}</span>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </template>

    <!-- Развилка: confirm | no-show для заказа-героя (только пока он in_progress) -->
    <div class="ws__branch" data-ws-branch hidden>
      <span class="ws__branch-prompt">{t(ui.branchPrompt)}</span>
      <div class="ws__branch-btns">
        <button
          class="ws__branch-btn ws__branch-btn--ok"
          type="button"
          data-ws-confirm
          aria-pressed="false"
        >
          {t(ui.doConfirm)}
        </button>
        <button
          class="ws__branch-btn ws__branch-btn--no"
          type="button"
          data-ws-noshow
          aria-pressed="false"
        >
          {t(ui.doNoShow)}
        </button>
      </div>
    </div>

    <!-- Журнал воркера: что он сделал, проматывая время -->
    <div class="ws__logwrap">
      <span class="ws__log-cap">{t(ui.log)}</span>
      <pre class="ws__log mono" data-ws-log aria-live="polite" tabindex="0">{t(ui.logIdle)}</pre>
    </div>

    <p class="ws__hint">{t(ui.hintClock)}</p>
  </div>

  <!-- ── СЦЕНА: ДВИЖОК (реплики + лидер-лок) ─────────────────────────── -->
  <div class="ws__engine" data-ws-engine>
    <span class="ws__engine-cap">{t(ui.engineCap)}</span>

    <div class="ws__lock">
      <span class="ws__lock-loop mono">{t(ui.loop)}</span>
      <span class="ws__lock-once">{t(ui.once)}</span>
    </div>

    <div class="ws__lock-key">
      <span class="ws__lock-cmd mono">{t(ui.lockKey)}</span>
      <span class="ws__tick" data-ws-tick aria-hidden="true">
        <span class="ws__tick-dot"></span>
        <span class="ws__tick-label mono">{t(ui.tickTag)}</span>
      </span>
    </div>

    <div class="ws__replicas">
      {
        replicas.map((r) => (
          <button
            type="button"
            class="ws__rep"
            data-rep={r.id}
            data-lead={r.lead ? "1" : "0"}
            aria-pressed={r.lead ? "true" : "false"}
            aria-label={t(ui.makeLeader)}
          >
            <span class="ws__rep-dot" aria-hidden="true" />
            <span class="ws__rep-name mono">
              {r.id} · {t(ui.worker)}
            </span>
            <span class="ws__rep-tag ws__rep-tag--lead mono">{t(ui.leaderTag)}</span>
            <span class="ws__rep-tag ws__rep-tag--idle mono">{t(ui.idleTag)}</span>
          </button>
        ))
      }
    </div>
    <p class="ws__hint">{t(ui.hintEngine)}</p>
  </div>

  <!-- Колофон фактов (статичный, читаемый и при reduced-motion) -->
  <p class="ws__facts">
    <span class="mono">{t(ui.roles)}</span>
    <span class="ws__facts-sep" aria-hidden="true">·</span>
    <span class="mono">{t(ui.stack)}</span>
  </p>
</section>

<style>
  .ws {
    --accent: var(--accent-work);
    --line: color-mix(in srgb, var(--accent) 40%, var(--border));
    --soft: color-mix(in srgb, var(--accent) 12%, transparent);
    --soft-2: color-mix(in srgb, var(--accent) 7%, transparent);
    --glow: color-mix(in srgb, var(--accent) 18%, transparent);
    --warn: color-mix(in srgb, var(--state-warn) 60%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    color: var(--text);
    container-type: inline-size;
  }

  .mono {
    font-family: var(--font-stack-mono);
  }

  .ws__intro {
    margin: 0;
    max-width: 70ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  .ws__hint {
    margin: var(--sp-4) 0 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: color-mix(in srgb, var(--accent) 58%, var(--text-muted));
  }

  /* ── Общий контейнер сцены ───────────────────────────────────────── */
  .ws__board,
  .ws__engine {
    position: relative;
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background: radial-gradient(120% 130% at 6% 0%, var(--glow), transparent 46%), var(--surface);
  }

  .ws__board::before,
  .ws__engine::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: radial-gradient(120% 100% at 50% 0%, #000 26%, transparent 90%);
    -webkit-mask-image: radial-gradient(120% 100% at 50% 0%, #000 26%, transparent 90%);
    pointer-events: none;
  }

  .ws__board > *,
  .ws__engine > * {
    position: relative;
    z-index: 1;
  }

  .ws__engine-cap,
  .ws__lane-cap,
  .ws__clock-cap,
  .ws__worker-cap,
  .ws__log-cap,
  .ws__scrub-cap {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .ws__engine-cap {
    display: block;
    margin-bottom: var(--sp-4);
  }

  /* ── Шапка доски: часы + аватар ──────────────────────────────────── */
  .ws__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(150px, auto);
    gap: var(--sp-4) var(--sp-5);
    align-items: stretch;
    margin-bottom: var(--sp-5);
  }

  .ws__clock {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--line);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
  }

  .ws__clock-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .ws__clock-dial {
    flex: none;
    width: 52px;
    height: 52px;
  }

  .ws__dial-svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .ws__dial-ring {
    fill: none;
    stroke: var(--border-hover);
    stroke-width: 2;
  }

  .ws__dial-hand {
    stroke: var(--accent);
    stroke-linecap: round;
    transform-box: fill-box;
    transform-origin: bottom center;
    /* поворот стрелок — только transform */
    transform: rotate(var(--rot, 0deg));
    transition: transform var(--dur-slow) var(--ease-soft);
  }

  .ws__dial-hand--h {
    stroke-width: 3;
  }

  .ws__dial-hand--m {
    stroke-width: 2;
    stroke: color-mix(in srgb, var(--accent) 70%, var(--text-muted));
  }

  .ws__dial-cap {
    fill: var(--accent);
  }

  .ws__clock-time {
    font-size: var(--fs-28);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-snug);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .ws__advance {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--line);
    border-radius: var(--r-pill);
    background: var(--soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .ws__advance:hover {
    border-color: var(--accent);
  }

  .ws__advance:active {
    transform: scale(0.96);
  }

  .ws__advance:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .ws__advance-glyph {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--accent);
  }

  .ws__scrub {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .ws__scrub-input {
    width: 100%;
    accent-color: var(--accent);
    min-height: var(--tap-min);
    cursor: pointer;
  }

  .ws__scrub-input:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 4px;
    border-radius: var(--r-pill);
  }

  /* ── Аватар работника ────────────────────────────────────────────── */
  .ws__worker {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
  }

  .ws__worker-card {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .ws__avatar {
    position: relative;
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: var(--r-pill);
    overflow: visible;
    border: var(--bw-thin) solid var(--border);
    background: var(--surface-2);
  }

  .ws__avatar svg {
    width: 100%;
    height: 100%;
  }

  .ws__avatar-head,
  .ws__avatar-body {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 2;
    transition: stroke var(--dur-slow) var(--ease-standard);
  }

  .ws__avatar-body {
    fill: none;
  }

  .ws__avatar-dot {
    position: absolute;
    right: -2px;
    bottom: -2px;
    width: 11px;
    height: 11px;
    border-radius: var(--r-pill);
    border: 2px solid var(--surface);
    background: var(--text-faint);
    transform: scale(1);
    transition:
      background-color var(--dur-slow) var(--ease-standard),
      transform var(--dur-slow) var(--ease-spring);
  }

  .ws__worker-state {
    font-size: var(--fs-12);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
  }

  /* состояния работника: подтверждён / no-show */
  .ws__worker[data-state="confirmed"] .ws__avatar-head,
  .ws__worker[data-state="confirmed"] .ws__avatar-body {
    stroke: var(--accent);
  }
  .ws__worker[data-state="confirmed"] .ws__avatar-dot {
    background: var(--state-ok);
    transform: scale(1.15);
  }
  .ws__worker[data-state="confirmed"] .ws__worker-state {
    color: var(--text);
  }
  .ws__worker[data-state="noshow"] .ws__avatar-head,
  .ws__worker[data-state="noshow"] .ws__avatar-body {
    stroke: var(--text-faint);
  }
  .ws__worker[data-state="noshow"] .ws__avatar-dot {
    background: var(--warn);
  }
  .ws__worker[data-state="noshow"] .ws__worker-state {
    color: var(--text-muted);
  }

  /* ── Дорожки ─────────────────────────────────────────────────────── */
  .ws__lanes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-3);
  }

  .ws__lane {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
    min-height: 120px;
  }

  .ws__lane-cap {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .ws__lane-dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--text-faint);
  }
  .ws__lane-dot[data-lane-dot="open"] {
    background: var(--text-secondary);
  }
  .ws__lane-dot[data-lane-dot="progress"] {
    background: var(--accent);
  }
  .ws__lane-dot[data-lane-dot="done"] {
    background: var(--state-ok);
  }

  .ws__lane-count {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 1px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
  }

  .ws__lane-body {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  /* ── Карточка заказа ─────────────────────────────────────────────── */
  .ws__order {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    min-width: 0;
    /* появление/перенос между дорожками — opacity + transform, без layout-анимаций */
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-spring),
      border-color var(--dur-med) var(--ease-standard);
  }

  /* карточка-герой развилки слегка выделена */
  .ws__order.is-fork {
    border-color: var(--line);
    background: var(--soft-2);
  }

  /* «впрыг» карточки при смене дорожки (transform-only) */
  .ws.is-inview .ws__order.is-moved {
    animation: ws-pop var(--dur-slow) var(--ease-spring);
  }

  @keyframes ws-pop {
    0% {
      transform: scale(0.9) translateY(6px);
      opacity: 0.4;
    }
    100% {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }

  .ws__order[data-status="done"] {
    opacity: 0.6;
  }

  .ws__order-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-2);
  }

  .ws__order-id {
    font-size: var(--fs-11);
    color: var(--text-muted);
    letter-spacing: var(--ls-snug);
  }

  .ws__order-window {
    font-size: var(--fs-11);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .ws__order-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-14);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
    overflow-wrap: anywhere;
  }

  .ws__order-city {
    font-size: var(--fs-12);
    color: var(--text-muted);
    line-height: var(--lh-snug);
    overflow-wrap: anywhere;
  }

  .ws__order-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
    flex-wrap: wrap;
    margin-top: 2px;
  }

  .ws__order-rate {
    font-size: var(--fs-11);
    color: var(--accent);
  }

  .ws__order-slots {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-10);
    color: var(--text-muted);
  }

  .ws__slot-pips {
    display: inline-flex;
    gap: 3px;
  }

  .ws__pip {
    width: 7px;
    height: 7px;
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border-hover);
    background: transparent;
    transform: scale(1);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws__pip.is-filled {
    background: var(--accent);
    border-color: var(--accent);
  }

  /* флаг «напоминание отправлено» — opacity-only появление, без layout */
  .ws__order-flag {
    position: absolute;
    top: var(--sp-2);
    right: var(--sp-2);
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 9px 9px 0;
    border-color: transparent var(--accent) transparent transparent;
    opacity: 0;
    transform: scale(0.6);
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws__order[data-reminded="1"] .ws__order-flag {
    opacity: 0.95;
    transform: scale(1);
  }

  /* лента «пере-предложения» города (показывается на no-show / release) */
  .ws__order-offer {
    list-style: none;
    margin: 2px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
    opacity: 0;
    transform: translateY(5px);
    pointer-events: none;
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-soft);
  }
  .ws__order[data-offering="1"] .ws__order-offer {
    opacity: 1;
    transform: translateY(0);
  }

  .ws__offer-row {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-10);
    color: var(--text-muted);
    opacity: 0;
    transform: translateY(3px);
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-soft);
  }
  .ws__order[data-offering="1"] .ws__offer-row {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(100ms + var(--i) * 110ms);
  }

  .ws__offer-dot {
    flex: none;
    width: 5px;
    height: 5px;
    border-radius: var(--r-pill);
    background: var(--accent);
    opacity: 0.7;
  }

  /* ── Развилка confirm | no-show ──────────────────────────────────── */
  .ws__branch {
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: var(--bw-thin) solid var(--border);
  }
  .ws__branch[hidden] {
    display: none;
  }

  .ws__branch-prompt {
    display: block;
    font-family: var(--font-stack-display);
    font-size: var(--fs-15);
    font-weight: var(--fw-medium);
    color: var(--text);
    margin-bottom: var(--sp-3);
  }

  .ws__branch-btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .ws__branch-btn {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__branch-btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws__branch-btn:active {
    transform: scale(0.97);
  }
  .ws__branch-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__branch-btn--ok[aria-pressed="true"] {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws__branch-btn--no[aria-pressed="true"] {
    color: var(--text);
    border-color: var(--warn);
    background: color-mix(in srgb, var(--state-warn) 10%, transparent);
  }

  /* ── Журнал воркера ──────────────────────────────────────────────── */
  .ws__logwrap {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-top: var(--sp-5);
  }

  .ws__log {
    margin: 0;
    height: 132px;
    overflow: auto;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    font-size: var(--fs-12);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .ws__log:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .ws__log :global(.ws-l) {
    display: block;
    opacity: 0;
    transform: translateY(3px);
  }
  .ws__log :global(.ws-l.is-in) {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .ws__log :global(.ws-acc) {
    color: var(--accent);
  }
  .ws__log :global(.ws-warn) {
    color: var(--state-warn);
  }
  .ws__log :global(.ws-dim) {
    color: var(--text-faint);
  }

  /* ── Сцена движка ────────────────────────────────────────────────── */
  .ws__lock {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .ws__lock-loop {
    font-size: var(--fs-13);
    letter-spacing: var(--ls-snug);
    color: var(--text-secondary);
  }

  .ws__lock-once {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--accent);
  }

  .ws__lock-key {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    margin-top: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-elevated);
  }

  .ws__lock-cmd {
    font-size: var(--fs-12);
    color: var(--text-muted);
    margin-right: auto;
    overflow-wrap: anywhere;
  }

  .ws__tick {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    flex: none;
  }
  .ws__tick-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--accent);
    transform: scale(1);
    opacity: 0.45;
  }
  .ws__tick-label {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  .ws__replicas {
    display: grid;
    gap: var(--sp-3);
    margin-top: var(--sp-4);
  }

  .ws__rep {
    position: relative;
    appearance: none;
    width: 100%;
    text-align: left;
    font: inherit;
    color: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    min-height: var(--tap-min);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    font-size: var(--fs-14);
    opacity: 0.45;
    transition:
      opacity var(--dur-slow) var(--ease-standard),
      border-color var(--dur-slow) var(--ease-standard),
      background-color var(--dur-slow) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__rep:hover {
    opacity: 1;
    border-color: var(--border-hover);
  }
  .ws__rep:active {
    transform: scale(0.99);
  }
  .ws__rep:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .ws[data-engine-on] .ws__rep[data-lead="1"] {
    opacity: 1;
    border-color: var(--line);
    background: var(--soft);
  }

  .ws__rep-dot {
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transform: scale(1);
    transition:
      transform var(--dur-slow) var(--ease-spring),
      background-color var(--dur-slow) var(--ease-standard);
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-dot {
    background: var(--accent);
  }

  .ws__rep-name {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    margin-right: auto;
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-name {
    color: var(--text);
  }

  .ws__rep-tag {
    font-size: var(--fs-12);
    letter-spacing: var(--ls-snug);
  }
  .ws__rep-tag--lead {
    color: var(--accent);
    display: none;
  }
  .ws__rep-tag--idle {
    color: var(--text-muted);
    display: inline;
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-tag--lead {
    display: inline;
  }
  .ws[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-tag--idle {
    display: none;
  }

  /* «тик» лидера и пульс точки — ТОЛЬКО когда виден И сцена движка активна */
  .ws.is-inview[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-dot {
    animation: ws-breathe 3.6s var(--ease-drift) infinite;
  }
  .ws.is-inview[data-engine-on] .ws__tick-dot {
    animation: ws-tick 2.2s var(--ease-standard) infinite;
  }

  @keyframes ws-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.35);
    }
  }

  @keyframes ws-tick {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.45;
    }
    14% {
      transform: scale(1.6);
      opacity: 1;
    }
    40% {
      transform: scale(1);
      opacity: 0.45;
    }
  }

  /* ── Колофон фактов ──────────────────────────────────────────────── */
  .ws__facts {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-2) var(--sp-3);
    font-size: var(--fs-11);
    line-height: var(--lh-snug);
    color: var(--text-muted);
  }
  .ws__facts-sep {
    color: var(--text-faint);
  }

  /* ── Узкие экраны ────────────────────────────────────────────────── */
  @container (max-width: 620px) {
    .ws__head {
      grid-template-columns: minmax(0, 1fr);
    }
    .ws__lanes {
      grid-template-columns: minmax(0, 1fr);
    }
    .ws__lane {
      min-height: auto;
    }
  }

  @container (max-width: 420px) {
    .ws__advance {
      margin-left: 0;
    }
    .ws__clock-time {
      font-size: var(--fs-24);
    }
  }

  /* ── reduced-motion: финальный читаемый кадр, без движения ───────── */
  @media (prefers-reduced-motion: reduce) {
    .ws__dial-hand,
    .ws__order,
    .ws__pip,
    .ws__order-flag,
    .ws__order-offer,
    .ws__offer-row,
    .ws__avatar-dot,
    .ws__avatar-head,
    .ws__avatar-body,
    .ws__rep,
    .ws__rep-dot {
      transition: none;
    }
    .ws__order.is-moved {
      animation: none;
    }
    .ws.is-inview[data-engine-on] .ws__rep[data-lead="1"] .ws__rep-dot,
    .ws.is-inview[data-engine-on] .ws__tick-dot {
      animation: none;
    }
    .ws__tick-dot {
      opacity: 1;
    }
    .ws__log :global(.ws-l) {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Диспетчерская доска .работа: часы-машина времени, фоновый taskiq-воркер и
  // гонка реплик за лидер-лок. Скрипт лишь переключает классы/атрибуты; всё, что
  // движется, — transform/opacity в CSS. Нет постоянного rAF: авто-тики ведёт
  // setTimeout-конвейер, который полностью чистится за кадром, на скрытой вкладке
  // и на pagehide. Единственные infinite-CSS («тик» лидера, пульс часов) scoped
  // под .ws.is-inview[data-engine-on] и замирают офскрин. Всё гейтится
  // IntersectionObserver. reduced-motion → финальный читаемый кадр, интеракции
  // работают (часы переставляют доску мгновенно, без анимаций).
  (() => {
    function initWorkShifts(): void {
      const roots = Array.from(document.querySelectorAll<HTMLElement>("[data-ws]"));
      if (!roots.length) return;

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");

      roots.forEach((root) => {
        if (root.dataset.wsInit === "1") return;
        root.dataset.wsInit = "1";

        const isEn = document.documentElement.dataset.locale === "en";
        const tr = (ru: string, en: string): string => (isEn ? en : ru);

        // ── DOM-узлы ──
        const timeEl = root.querySelector<HTMLElement>("[data-ws-time]");
        const handH = root.querySelector<SVGLineElement>("[data-ws-hand-h]");
        const handM = root.querySelector<SVGLineElement>("[data-ws-hand-m]");
        const advanceBtn = root.querySelector<HTMLButtonElement>("[data-ws-advance]");
        const scrub = root.querySelector<HTMLInputElement>("[data-ws-scrub]");
        const worker = root.querySelector<HTMLElement>("[data-ws-worker]");
        const workerState = root.querySelector<HTMLElement>("[data-ws-worker-state]");
        const tmpl = root.querySelector<HTMLTemplateElement>("[data-ws-cards]");
        const lanes: Record<string, HTMLElement | null> = {
          open: root.querySelector<HTMLElement>('[data-lane-body="open"]'),
          progress: root.querySelector<HTMLElement>('[data-lane-body="progress"]'),
          done: root.querySelector<HTMLElement>('[data-lane-body="done"]'),
        };
        const counts: Record<string, HTMLElement | null> = {
          open: root.querySelector<HTMLElement>('[data-lane-count="open"]'),
          progress: root.querySelector<HTMLElement>('[data-lane-count="progress"]'),
          done: root.querySelector<HTMLElement>('[data-lane-count="done"]'),
        };
        const branchBox = root.querySelector<HTMLElement>("[data-ws-branch]");
        const confirmBtn = root.querySelector<HTMLButtonElement>("[data-ws-confirm]");
        const noShowBtn = root.querySelector<HTMLButtonElement>("[data-ws-noshow]");
        const logEl = root.querySelector<HTMLElement>("[data-ws-log]");

        if (!tmpl || !timeEl || !scrub) return;

        const DAY_START = 8;
        const DAY_END = 24;

        // ── Состояние ──
        let hour = 18; // текущий час дня
        let inview = false;
        let forkChoice: "none" | "confirm" | "noshow" = "none";
        const timers: number[] = [];

        const clearTimers = (): void => {
          while (timers.length) {
            const id = timers.pop();
            if (id !== undefined) window.clearTimeout(id);
          }
        };
        const later = (fn: () => void, ms: number): void => {
          const id = window.setTimeout(() => {
            const i = timers.indexOf(id);
            if (i >= 0) timers.splice(i, 1);
            fn();
          }, ms);
          timers.push(id);
        };

        // ── Карточки заказов: вынимаем из template, держим в Map ──
        type Card = {
          id: string;
          el: HTMLLIElement;
          start: number;
          end: number;
          needed: number;
          filled: number;
          fork: boolean;
          remindable: boolean;
          status: "open" | "progress" | "done";
          reminded: boolean;
        };
        const cards: Card[] = [];
        const frag = tmpl.content.cloneNode(true) as DocumentFragment;
        frag.querySelectorAll<HTMLLIElement>(".ws__order").forEach((el) => {
          cards.push({
            id: el.dataset.order ?? "",
            el,
            start: Number(el.dataset.start ?? "0"),
            end: Number(el.dataset.end ?? "0"),
            needed: Number(el.dataset.needed ?? "1"),
            filled: Number(el.dataset.filled ?? "0"),
            fork: el.dataset.fork === "1",
            remindable: el.dataset.remindable === "1",
            status: (el.dataset.status as Card["status"]) ?? "open",
            reminded: false,
          });
        });

        const placeCard = (c: Card, animate: boolean): void => {
          const lane = lanes[c.status];
          if (!lane) return;
          if (c.el.parentElement !== lane) {
            lane.appendChild(c.el);
            if (animate && !reduced.matches) {
              c.el.classList.remove("is-moved");
              // reflow, чтобы перезапустить keyframes
              void c.el.offsetWidth;
              c.el.classList.add("is-moved");
            }
          }
          c.el.dataset.status = c.status;
        };

        const refreshCardUI = (c: Card): void => {
          c.el.dataset.reminded = c.reminded ? "1" : "0";
          // пипсы слотов
          const pips = c.el.querySelectorAll<HTMLElement>("[data-pip]");
          pips.forEach((p, k) => p.classList.toggle("is-filled", k < c.filled));
          const txt = c.el.querySelector<HTMLElement>("[data-ws-slot-text]");
          if (txt) txt.textContent = `${c.filled}/${c.needed} ${tr("слотов", "slots")}`;
          // лента пере-предложения видна, когда слот освобождён и заказ снова open
          const offering =
            c.status === "open" && c.filled < c.needed && c.fork && forkChoice === "noshow";
          c.el.dataset.offering = offering ? "1" : "0";
        };

        const renderCounts = (): void => {
          (["open", "progress", "done"] as const).forEach((lane) => {
            const n = cards.filter((c) => c.status === lane).length;
            const el = counts[lane];
            if (el) el.textContent = String(n);
          });
        };

        // ── Журнал воркера ──
        type Tone = "" | "acc" | "warn" | "dim";
        let logSeeded = false;
        const ensureLogReady = (): void => {
          if (!logSeeded && logEl) {
            logEl.textContent = "";
            logSeeded = true;
          }
        };
        const log = (text: string, tone: Tone = ""): void => {
          if (!logEl) return;
          ensureLogReady();
          const line = document.createElement("span");
          line.className = "ws-l" + (tone ? " ws-" + tone : "");
          line.textContent = text;
          logEl.appendChild(line);
          if (reduced.matches) line.classList.add("is-in");
          else requestAnimationFrame(() => line.classList.add("is-in"));
          logEl.scrollTop = logEl.scrollHeight;
        };

        // ── Часы ──
        const fmt = (h: number): string => `${String(Math.min(h, 23)).padStart(2, "0")}:00`;
        const setClock = (): void => {
          if (timeEl) timeEl.textContent = fmt(hour);
          // стрелки: часовая — 30°/час, минутная держим на 12 (целые часы)
          const hRot = ((hour % 12) / 12) * 360;
          if (handH) handH.style.setProperty("--rot", `${hRot}deg`);
          if (handM) handM.style.setProperty("--rot", "0deg");
          if (scrub) scrub.value = String(hour);
        };

        const setWorker = (state: "idle" | "confirmed" | "noshow"): void => {
          if (worker) worker.dataset.state = state === "idle" ? "" : state;
          if (workerState) {
            workerState.textContent =
              state === "confirmed"
                ? tr("подтвердил · confirmed_at", "confirmed · confirmed_at")
                : state === "noshow"
                  ? tr("молчит · слот вернётся в ленту", "silent · slot returns to feed")
                  : tr("свободен · ждёт смену", "free · waiting for a shift");
          }
        };

        // ── Видна ли развилка: заказ-герой ещё in_progress и до старта <3ч,
        //    но старт ещё не прошёл (или ровно наступил без выбора). ──
        const updateBranch = (): void => {
          const hero = cards.find((c) => c.fork);
          if (!branchBox || !hero) return;
          const inWindow = hour >= hero.start - 3 && hour < hero.start && forkChoice === "none";
          branchBox.hidden = !inWindow;
        };

        // ── Воркер срабатывает на текущий час: напоминание / release / close ──
        const workerTick = (animate: boolean): void => {
          const logs: { text: string; tone: Tone }[] = [];

          cards.forEach((c) => {
            // 1) напоминание ровно за ~3ч до старта — один раз (атомарный флаг)
            if (
              c.remindable &&
              !c.reminded &&
              c.status === "progress" &&
              hour >= c.start - 3 &&
              hour < c.start
            ) {
              c.reminded = true; // SET nx — ставится атомарно, повторно не уйдёт
              logs.push({
                text: `${fmt(hour)}  remind ${c.id} → SET nx reminder_sent (atomic, once)`,
                tone: "acc",
              });
            }

            // 2) старт наступил без подтверждения → освободить слот заказа-героя
            if (c.fork && c.status === "progress" && hour >= c.start && forkChoice === "noshow") {
              c.filled = Math.max(0, c.filled - 1);
              c.status = "open"; // снова OPEN, слот в ленту города
              logs.push({
                text: `${fmt(hour)}  no confirm by start → release slot ${c.id} → OPEN, re-offer city`,
                tone: "warn",
              });
            }

            // 3) подтверждённый герой: набраны все слоты → закрытие другим, идёт к done позже
            if (
              c.fork &&
              c.status === "progress" &&
              forkChoice === "confirm" &&
              c.filled >= c.needed &&
              hour >= c.end
            ) {
              c.status = "done";
              logs.push({
                text: `${fmt(hour)}  end_time passed → close ${c.id} (all slots filled)`,
                tone: "dim",
              });
            }

            // 4) просрочка: прошёл end_time → авто-CANCELLED/закрытие (фоновый заказ)
            if (!c.fork && c.status === "progress" && hour >= c.end) {
              c.status = "done";
              logs.push({
                text: `${fmt(hour)}  expired ${c.id} (end ${c.end}:00) → auto-close`,
                tone: "dim",
              });
            }
          });

          // применяем визуал
          cards.forEach((c) => {
            placeCard(c, animate);
            refreshCardUI(c);
          });
          renderCounts();
          updateBranch();

          // печать журнала (по одной строке, лёгкий каскад)
          if (logs.length === 0) {
            log(`${fmt(hour)}  loop tick · nothing due`, "dim");
          } else if (reduced.matches || !animate) {
            logs.forEach((l) => log(l.text, l.tone));
          } else {
            clearTimers();
            logs.forEach((l, i) => later(() => log(l.text, l.tone), 90 * i));
          }
        };

        const setHour = (h: number, animate: boolean): void => {
          hour = Math.max(DAY_START, Math.min(DAY_END, Math.round(h)));
          setClock();
          workerTick(animate);
        };

        // ── Развилка confirm | no-show ──
        const applyFork = (choice: "confirm" | "noshow"): void => {
          forkChoice = choice;
          confirmBtn?.setAttribute("aria-pressed", choice === "confirm" ? "true" : "false");
          noShowBtn?.setAttribute("aria-pressed", choice === "noshow" ? "true" : "false");
          const hero = cards.find((c) => c.fork);
          if (hero) {
            if (choice === "confirm") {
              // confirmed_at проставлен → слот закрыт, аватар подтверждён
              setWorker("confirmed");
              log(`${fmt(hour)}  worker confirm ${hero.id} → confirmed_at set`, "acc");
            } else {
              setWorker("noshow");
              log(`${fmt(hour)}  worker no-show ${hero.id} → awaiting start to release`, "warn");
            }
          }
          // развилка спрятана после выбора; эффект проявится воркером у старта
          updateBranch();
          // если время уже на старте/после — воркер сразу применит исход
          cards.forEach((c) => {
            placeCard(c, false);
            refreshCardUI(c);
          });
          renderCounts();
        };

        confirmBtn?.addEventListener("click", () => applyFork("confirm"));
        noShowBtn?.addEventListener("click", () => applyFork("noshow"));

        // ── Часы: +1 час и скраб ──
        advanceBtn?.addEventListener("click", () => setHour(hour + 1, true));
        scrub.addEventListener("input", () => setHour(Number(scrub.value), false));

        // ── Реплики: тап забирает лидер-лок (ровно один) ──
        const reps = Array.from(root.querySelectorAll<HTMLElement>(".ws__rep"));
        reps.forEach((rep) => {
          rep.addEventListener("click", () => {
            reps.forEach((r) => {
              const lead = r === rep;
              r.setAttribute("data-lead", lead ? "1" : "0");
              r.setAttribute("aria-pressed", lead ? "true" : "false");
            });
          });
        });

        // ── Первичная раскладка доски ──
        cards.forEach((c) => {
          placeCard(c, false);
          refreshCardUI(c);
        });
        renderCounts();
        setClock();
        setWorker("idle");
        updateBranch();

        // ── reduced-motion / без IO: статичный читаемый кадр ──
        // Покажем в журнале, что воркер уже сделал к 18:00, и завершим.
        if (reduced.matches || !("IntersectionObserver" in window)) {
          if (logEl) {
            logEl.textContent = "";
            logSeeded = true;
          }
          // прогон по часам без анимаций — доска приходит в согласованный кадр
          for (let h = DAY_START; h <= hour; h++) {
            hour = h;
            // тихий проход: только применяем эффекты, без журнала каждого часа
            cards.forEach((c) => {
              if (
                c.remindable &&
                !c.reminded &&
                c.status === "progress" &&
                h >= c.start - 3 &&
                h < c.start
              ) {
                c.reminded = true;
              }
              if (!c.fork && c.status === "progress" && h >= c.end) c.status = "done";
            });
          }
          hour = 18;
          setClock();
          cards.forEach((c) => {
            placeCard(c, false);
            refreshCardUI(c);
          });
          renderCounts();
          updateBranch();
          log(
            tr(
              "18:00  воркер активен · напоминания разосланы (по разу)",
              "18:00  worker active · reminders sent (once each)",
            ),
            "acc",
          );
          log(
            tr(
              "крутите «+1 час» или ползунок — слоты освобождаются, заказы закрываются",
              "advance “+1 hour” or the slider — slots release, orders close",
            ),
            "dim",
          );
          return;
        }

        // ── Видимость: авто-тики/анимации только в зоне видимости ──
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              inview = e.isIntersecting;
              root.classList.toggle("is-inview", inview);
              if (!inview) clearTimers();
              else if (!logSeeded)
                log(tr("воркер на связи · крутите часы", "worker online · wind the clock"), "dim");
            }
          },
          { threshold: 0.2 },
        );
        io.observe(root);

        const stopAll = (): void => {
          inview = false;
          clearTimers();
          root.classList.remove("is-inview");
        };
        const onVisibility = (): void => {
          if (document.hidden) stopAll();
        };
        document.addEventListener("visibilitychange", onVisibility);
        const onPageHide = (): void => {
          stopAll();
          io.disconnect();
          document.removeEventListener("visibilitychange", onVisibility);
        };
        window.addEventListener("pagehide", onPageHide, { once: true });
      });
    }

    initWorkShifts();
    document.addEventListener("astro:page-load", initWorkShifts);
  })();
</script>
