---

<section
  class="ws"
  data-ws
  data-live="off"
  aria-label={t({ ru: "Диспетчерская доска .работа", en: ".work dispatch board" })}
>
  <p class="ws__intro">{t(ui.intro)}</p>

  <!-- ── Панель управления временем ──────────────────────────────────── -->
  <div class="ws__bar" role="group" aria-label={t(ui.clock)}>
    <div class="ws__clock">
      <span class="ws__clock-cap">{t(ui.clock)}</span>
      <span class="ws__clock-time mono" data-ws-time aria-live="polite">{`${NOW0}:00`}</span>
    </div>

    <div class="ws__step">
      <button class="ws__btn ws__btn--step" type="button" data-ws-back aria-label={t(ui.back)}>
        <span aria-hidden="true">−1ч</span>
      </button>
      <button class="ws__btn ws__btn--step" type="button" data-ws-fwd aria-label={t(ui.fwd)}>
        <span aria-hidden="true">+1ч</span>
      </button>
    </div>

    <div class="ws__timeline" aria-hidden="true">
      <span class="ws__tl-cap">{t(ui.dayProgress)}</span>
      <span class="ws__tl-track">
        <span class="ws__tl-fill" data-ws-tl></span>
      </span>
      <span class="ws__tl-marks">
        <span>08:00</span>
        <span>16:00</span>
        <span>24:00</span>
      </span>
    </div>

    <div class="ws__bar-actions">
      <button class="ws__btn ws__btn--live" type="button" data-ws-live aria-pressed="false">
        <span class="ws__live-dot" aria-hidden="true"></span>
        <span data-ws-live-label>{t(ui.live)}</span>
      </button>
      <button
        class="ws__btn ws__btn--create"
        type="button"
        data-ws-create
        aria-expanded="false"
        aria-controls="ws-composer"
      >
        {t(ui.create)}
      </button>
      <span class="ws__hist mono" data-ws-hist hidden>
        <span class="ws__hist-tag">{t(ui.hist)}</span>
        <button class="ws__hist-btn" type="button" data-ws-tonow>{t(ui.toNow)}</button>
      </span>
    </div>
  </div>

  <!-- ── Композер новой смены (скрыт до «Создать») ───────────────────── -->
  <div class="ws__composer" id="ws-composer" data-ws-composer hidden>
    <span class="ws__composer-cap">{t(ui.composerCap)}</span>
    <p class="ws__composer-hint">{t(ui.composerHint)}</p>
    <div class="ws__presets" role="group" aria-label={t(ui.composerCap)}>
      {
        presets.map((p, i) => (
          <button
            class="ws__preset"
            type="button"
            data-ws-preset={p.id}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <span class="ws__preset-title">{t(p.title)}</span>
            <span class="ws__preset-meta mono">
              {t(p.city)} · {p.rate}
            </span>
          </button>
        ))
      }
    </div>
    <p class="ws__preview mono">
      <span class="ws__preview-cap">{t(ui.preview)}:</span>
      <span data-ws-preview>·</span>
    </p>
    <div class="ws__composer-btns">
      <button class="ws__btn ws__btn--publish" type="button" data-ws-publish>{t(ui.publish)}</button
      >
      <button class="ws__btn ws__btn--ghost" type="button" data-ws-cancel>{t(ui.cancel)}</button>
    </div>
  </div>

  <!-- ── Доска: три колонки ──────────────────────────────────────────── -->
  <div class="ws__board" data-ws-board>
    <div class="ws__toasts" data-ws-toasts aria-live="polite"></div>
    {
      (
        [
          ["open", ui.colOpen, ui.emptyOpen],
          ["progress", ui.colProgress, ui.emptyProgress],
          ["review", ui.colReview, ui.emptyReview],
          ["done", ui.colDone, ui.emptyDone],
        ] as const
      ).map(([col, cap, empty]) => (
        <section class="ws__col" data-col={col} aria-label={t(cap)}>
          <span class="ws__col-cap">
            <span class="ws__col-dot" aria-hidden="true" data-col-dot={col} />
            {t(cap)}
            <span class="ws__col-count mono" data-ws-colcount={col}>
              0
            </span>
          </span>
          <ul class="ws__col-body" data-ws-colbody={col} />
          <span class="ws__col-empty" data-ws-empty>
            {t(empty)}
          </span>
        </section>
      ))
    }
  </div>

  <!-- ── Ростер работников ───────────────────────────────────────────── -->
  <div class="ws__roster" data-ws-roster aria-label={t(ui.roster)}>
    <span class="ws__roster-cap">{t(ui.roster)}</span>
    <ul class="ws__roster-list">
      {
        workers.map((w) => (
          <li class="ws__wk" data-worker={w.id}>
            <span class="ws__wk-dot" aria-hidden="true" data-ws-wk-dot />
            <span class="ws__wk-name mono">{w.id}</span>
            <span class="ws__wk-meta mono">
              {w.dist} · ★{w.rating}
            </span>
            <span class="ws__wk-state mono" data-ws-wk-state>
              {t(ui.free)}
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- ── Журнал воркера ──────────────────────────────────────────────── -->
  <div class="ws__logwrap">
    <span class="ws__log-cap">{t(ui.log)}</span>
    <pre class="ws__log mono" data-ws-log tabindex="0">{t(ui.logIdle)}</pre>
  </div>

  <!-- Колофон фактов (статичный, читаем и при reduced-motion) -->
  <p class="ws__facts">
    <span class="mono">{t(ui.roles)}</span>
    <span class="ws__facts-sep" aria-hidden="true">·</span>
    <span class="mono">{t(ui.stack)}</span>
  </p>

  <script
    is:inline
    type="application/json"
    data-ws-payload
    set:html={JSON.stringify(payload).replace(/</g, "\\u003c")}
  />
</section>

<style>
  .ws {
    --accent: var(--accent-work);
    --line: color-mix(in srgb, var(--accent) 40%, var(--border));
    --soft: color-mix(in srgb, var(--accent) 12%, transparent);
    --soft-2: color-mix(in srgb, var(--accent) 7%, transparent);
    --glow: color-mix(in srgb, var(--accent) 18%, transparent);
    --warn: color-mix(in srgb, var(--state-warn) 60%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    color: var(--text);
    container-type: inline-size;
  }

  .mono {
    font-family: var(--font-stack-mono);
  }

  .ws__intro {
    margin: 0;
    max-width: 70ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* Общие подписи-eyebrow */
  .ws__clock-cap,
  .ws__tl-cap,
  .ws__composer-cap,
  .ws__roster-cap,
  .ws__log-cap,
  .ws__col-cap {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Кнопки (общая база) ─────────────────────────────────────────── */
  .ws__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws__btn:active {
    transform: scale(0.96);
  }
  .ws__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }
  .ws__btn--step {
    min-width: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
  }
  .ws__btn--create,
  .ws__btn--publish {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws__btn--publish:hover,
  .ws__btn--create:hover {
    border-color: var(--accent);
  }

  /* ── Панель управления временем ──────────────────────────────────── */
  .ws__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--sp-4);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background: radial-gradient(120% 130% at 6% 0%, var(--glow), transparent 46%), var(--surface);
  }

  .ws__clock {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .ws__clock-time {
    font-size: var(--fs-28);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-snug);
    color: var(--text);
    font-variant-numeric: tabular-nums;
    transform: scale(1);
    transition: transform var(--dur-med) var(--ease-spring);
  }
  .ws.is-tick .ws__clock-time {
    transform: scale(1.06);
  }

  .ws__step {
    display: inline-flex;
    gap: var(--sp-2);
  }

  /* Индикатор хода дня (не интерактивный: заполняет полосу к текущему часу) */
  .ws__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    flex: 1 1 180px;
    min-width: 150px;
    align-self: center;
  }
  .ws__tl-track {
    position: relative;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface-2);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .ws__tl-fill {
    position: absolute;
    inset: 0;
    transform-origin: left center;
    transform: scaleX(var(--tl, 0));
    border-radius: var(--r-pill);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent) 35%, transparent),
      var(--accent)
    );
    transition: transform var(--dur-slow) var(--ease-soft);
  }
  .ws__tl-marks {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-10);
    color: var(--text-faint);
  }

  .ws__bar-actions {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
    margin-left: auto;
  }

  .ws__live-dot {
    width: 9px;
    height: 9px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transform: scale(1);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws[data-live="on"] .ws__btn--live {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws[data-live="on"] .ws__live-dot {
    background: var(--accent);
  }
  /* Пульс «в эфире» — только когда виден и играет */
  .ws.is-inview[data-live="on"] .ws__live-dot {
    animation: ws-breathe 1.5s var(--ease-drift) infinite;
  }

  .ws__hist {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-11);
    color: var(--warn);
  }
  .ws__hist[hidden] {
    display: none;
  }
  .ws__hist-tag {
    letter-spacing: var(--ls-snug);
  }
  .ws__hist-btn {
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--warn);
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-12);
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-standard);
  }
  .ws__hist-btn:hover {
    border-color: var(--accent);
  }
  .ws__hist-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  /* ── Композер ────────────────────────────────────────────────────── */
  .ws__composer {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--line);
    border-radius: var(--r-md);
    background: var(--soft-2);
  }
  .ws__composer[hidden] {
    display: none;
  }
  .ws__composer-hint {
    margin: 0;
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: var(--text-muted);
  }
  .ws__presets {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--sp-2);
  }
  .ws__preset {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    text-align: left;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__preset:hover {
    border-color: var(--border-hover);
  }
  .ws__preset:active {
    transform: scale(0.98);
  }
  .ws__preset:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__preset[aria-pressed="true"] {
    border-color: var(--line);
    background: var(--soft);
    color: var(--text);
  }
  .ws__preset-title {
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
  }
  .ws__preset-meta {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .ws__preview {
    margin: 0;
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }
  .ws__preview-cap {
    color: var(--text-muted);
    margin-right: var(--sp-2);
  }
  .ws__composer-btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  /* ── Доска ───────────────────────────────────────────────────────── */
  .ws__board {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: start;
    gap: var(--sp-3);
  }
  .ws__col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
    min-height: 130px;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .ws__col-cap {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .ws__col-dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--text-faint);
  }
  .ws__col-dot[data-col-dot="open"] {
    background: var(--text-secondary);
  }
  .ws__col-dot[data-col-dot="progress"] {
    background: var(--accent);
  }
  .ws__col-dot[data-col-dot="review"] {
    background: color-mix(in srgb, var(--accent) 70%, #fff);
  }
  .ws__col-dot[data-col-dot="done"] {
    background: var(--state-ok);
  }
  .ws__col-count {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 1px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
  }
  .ws__col-body {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
    flex: 1 1 auto;
  }
  .ws__col-empty {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    color: var(--text-faint);
    padding: var(--sp-2) 0;
  }
  .ws__col:has(.ws__card) .ws__col-empty {
    display: none;
  }

  /* ── Карточка смены ──────────────────────────────────────────────── */
  .ws :global(.ws__card) {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: var(--sp-3) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    min-width: 0;
    user-select: none;
    -webkit-user-select: none;
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-spring),
      border-color var(--dur-med) var(--ease-standard);
  }
  .ws :global(.ws__card[data-hero="1"]) {
    border-color: var(--line);
    background: var(--soft-2);
  }
  .ws :global(.ws__card[data-col="done"]) {
    opacity: 0.58;
  }
  .ws.is-inview :global(.ws__card.is-moved) {
    animation: ws-pop var(--dur-slow) var(--ease-spring);
  }
  @keyframes ws-pop {
    0% {
      transform: scale(0.94) translateY(6px);
      opacity: 0.4;
    }
    100% {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }

  .ws :global(.ws__card-head) {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .ws :global(.ws__card-id) {
    font-size: var(--fs-11);
    color: var(--text-muted);
    letter-spacing: var(--ls-snug);
  }
  .ws :global(.ws__card-time) {
    margin-right: auto;
    font-size: var(--fs-11);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }
  .ws :global(.ws__card-title) {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-15);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
    overflow-wrap: anywhere;
  }
  .ws :global(.ws__card-sub) {
    font-size: var(--fs-12);
    color: var(--text-muted);
    line-height: var(--lh-snug);
    overflow-wrap: anywhere;
  }
  .ws :global(.ws__card-status) {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-12);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
  }
  .ws :global(.ws__card-status::before) {
    content: "";
    flex: none;
    width: 7px;
    height: 7px;
    border-radius: var(--r-pill);
    background: var(--text-secondary);
  }
  .ws :global(.ws__card[data-col="progress"] .ws__card-status::before),
  .ws :global(.ws__card[data-col="review"] .ws__card-status::before) {
    background: var(--accent);
  }
  .ws :global(.ws__card[data-col="done"] .ws__card-status::before),
  .ws :global(.ws__card[data-state="accepted"] .ws__card-status::before) {
    background: var(--state-ok);
  }
  .ws :global(.ws__card[data-state="released"] .ws__card-status::before),
  .ws :global(.ws__card[data-state="cancelled"] .ws__card-status::before),
  .ws :global(.ws__card[data-state="rejected"] .ws__card-status::before) {
    background: var(--warn);
  }
  .ws :global(.ws__card[data-state="confirmed"] .ws__card-status),
  .ws :global(.ws__card[data-state="accepted"] .ws__card-status) {
    color: var(--text);
  }
  .ws :global(.ws__card[data-state="submitted"] .ws__card-status) {
    color: color-mix(in srgb, var(--accent) 72%, var(--text));
  }
  .ws :global(.ws__card[data-state="released"] .ws__card-status),
  .ws :global(.ws__card[data-state="cancelled"] .ws__card-status),
  .ws :global(.ws__card[data-state="rejected"] .ws__card-status) {
    color: var(--state-warn);
  }

  .ws :global(.ws__card-worker) {
    display: none;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-11);
    color: var(--text-muted);
    overflow-wrap: anywhere;
  }
  .ws :global(.ws__card[data-worker-set="1"] .ws__card-worker) {
    display: inline-flex;
  }

  .ws :global(.ws__card-remind) {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 10px 10px 0 0;
    border-color: var(--accent) transparent transparent transparent;
    opacity: 0;
    transform: scale(0.6);
    transform-origin: top left;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws :global(.ws__card[data-reminded="1"] .ws__card-remind) {
    opacity: 0.95;
    transform: scale(1);
  }

  .ws :global(.ws__card-actions) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-1);
  }
  .ws :global(.ws__card-actions:empty) {
    display: none;
  }
  .ws :global(.ws__card-btn) {
    flex: 1 1 auto;
    min-height: 40px;
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface-2);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws :global(.ws__card-btn:hover) {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws :global(.ws__card-btn:active) {
    transform: scale(0.97);
  }
  .ws :global(.ws__card-btn:focus-visible) {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws :global(.ws__card-btn--primary) {
    color: var(--bg);
    border-color: var(--accent);
    background: var(--accent);
  }
  .ws :global(.ws__card-btn--primary:hover) {
    color: var(--bg);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 88%, #ffffff);
  }
  .ws :global(.ws__card-btn--warn) {
    color: var(--state-warn);
    border-color: var(--warn);
    background: transparent;
  }
  .ws :global(.ws__card-btn:disabled) {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ── Ростер ──────────────────────────────────────────────────────── */
  .ws__roster {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
  }
  .ws__roster-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--sp-2);
  }
  .ws__wk {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    min-width: 0;
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    font-size: var(--fs-12);
    transition: border-color var(--dur-med) var(--ease-standard);
  }
  .ws__wk[data-busy="1"] {
    border-color: var(--line);
  }
  .ws__wk-dot {
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--state-ok);
    transform: scale(1);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .ws__wk[data-busy="1"] .ws__wk-dot {
    background: var(--accent);
    transform: scale(1.15);
  }
  .ws__wk-name {
    flex: none;
    white-space: nowrap;
    color: var(--text);
    font-size: var(--fs-13);
  }
  .ws__wk-meta {
    flex: 0 1 auto;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .ws__wk-state {
    flex: none;
    margin-left: auto;
    white-space: nowrap;
    font-size: var(--fs-11);
    color: var(--text-muted);
    text-align: right;
  }
  .ws__wk[data-busy="1"] .ws__wk-state {
    color: var(--text-secondary);
  }

  /* ── Журнал ──────────────────────────────────────────────────────── */
  .ws__logwrap {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .ws__log {
    margin: 0;
    height: 112px;
    overflow: auto;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    font-size: var(--fs-12);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .ws__log:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__log :global(.ws-l) {
    display: block;
    opacity: 0;
    transform: translateY(3px);
  }
  .ws__log :global(.ws-l.is-in) {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .ws__log :global(.ws-acc) {
    color: var(--accent);
  }
  .ws__log :global(.ws-warn) {
    color: var(--state-warn);
  }
  .ws__log :global(.ws-dim) {
    color: var(--text-faint);
  }

  @keyframes ws-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.35);
    }
  }
  /* ── Колофон фактов ──────────────────────────────────────────────── */
  .ws__facts {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--sp-2) var(--sp-3);
    font-size: var(--fs-11);
    line-height: var(--lh-snug);
    color: var(--text-muted);
  }
  .ws__facts-sep {
    color: var(--text-faint);
  }

  /* ── Тосты ───────────────────────────────────────────────────────── */
  .ws__toasts {
    position: fixed;
    bottom: max(var(--sp-4), env(safe-area-inset-bottom));
    right: var(--sp-4);
    display: flex;
    flex-direction: column-reverse;
    gap: var(--sp-2);
    max-width: min(340px, 80vw);
    z-index: var(--z-toast);
    pointer-events: none;
  }
  .ws :global(.ws__toast) {
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--line);
    border-radius: var(--r-sm);
    background: var(--glass-tint-ultra);
    color: var(--text);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    line-height: var(--lh-snug);
    box-shadow: var(--shadow-3);
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .ws :global(.ws__toast.is-in) {
    opacity: 1;
    transform: translateY(0);
  }
  .ws :global(.ws__toast--warn) {
    border-color: var(--warn);
    color: var(--state-warn);
  }

  /* ── Узкие экраны ────────────────────────────────────────────────── */
  @container (max-width: 1040px) {
    .ws__board {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @container (max-width: 620px) {
    .ws__board {
      grid-template-columns: minmax(0, 1fr);
    }
    .ws__col {
      min-height: auto;
    }
    .ws :global(.ws__card-btn) {
      min-height: var(--tap-min);
    }
    .ws__bar {
      padding: var(--sp-3);
    }
    .ws__bar-actions {
      margin-left: 0;
      width: 100%;
    }
    .ws__log {
      height: 120px;
    }
  }
  @container (max-width: 420px) {
    .ws__clock-time {
      font-size: var(--fs-24);
    }
    .ws__timeline {
      flex-basis: 100%;
    }
  }

  /* ── reduced-motion: финальный читаемый кадр, без движения ───────── */
  @media (prefers-reduced-motion: reduce) {
    .ws__card,
    .ws__card-remind,
    .ws__card-worker,
    .ws__clock-time,
    .ws__wk-dot,
    .ws__live-dot,
    .ws__tl-fill,
    .ws__toast {
      transition: none;
    }
    .ws__card.is-moved {
      animation: none;
    }
    .ws.is-inview[data-live="on"] .ws__live-dot {
      animation: none;
    }
    .ws__log :global(.ws-l) {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .ws__toast {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Живая диспетчерская доска .работа. Часы — событийная машина времени: now
  // только растёт (+1ч / «В эфире» дописывают события), view можно мотать назад
  // и переигрывать. derive(shift,T) — чистый кадр; render(view) раскладывает
  // карточки. Скрипт лишь переключает классы/атрибуты и позиции; всё, что
  // движется, — transform/opacity в CSS. Нет постоянного rAF: автоплей ведёт
  // setTimeout-конвейер, чистящийся офскрин, на скрытой вкладке и на pagehide.
  // Всё гейтится IntersectionObserver; reduced-motion → читаемый кадр, интеракции
  // применяются мгновенно.
  (() => {
    const DAY_START = 8;
    const DAY_END = 24;
    const REMIND_LEAD = 3;
    const MAX_CONCURRENT = 9;
    const LIVE_MS = 1500;
    const TOAST_MS = 2600;
    const MAX_TOASTS = 3;

    type Tone = "" | "acc" | "warn" | "dim";
    type Col = "open" | "progress" | "review" | "done";

    type WorkerJSON = { id: string; dist: string; rating: string };
    type SeedJSON = {
      id: string;
      title: string;
      city: string;
      start: number;
      end: number;
      rate: string;
      bornAt: number;
      claimedAt: number | null;
      claimWorker: string | null;
      confirmedAt: number | null;
      submittedAt: number | null;
      autoAcceptAt: number | null;
      willConfirm: boolean;
      willLeave: boolean;
      noAutoClaim: boolean;
    };
    type PresetJSON = { id: string; title: string; city: string; rate: string; dur: number };
    // Локализованные строки: серверный ui-словарь сериализуется в payload.
    type UI = {
      intro: string;
      clock: string;
      back: string;
      fwd: string;
      dayProgress: string;
      live: string;
      livePause: string;
      create: string;
      toNow: string;
      hist: string;
      composerCap: string;
      composerHint: string;
      preview: string;
      publish: string;
      cancel: string;
      colOpen: string;
      colProgress: string;
      colReview: string;
      colDone: string;
      emptyOpen: string;
      emptyProgress: string;
      emptyReview: string;
      emptyDone: string;
      assign: string;
      accept: string;
      reject: string;
      drag: string;
      stOpen: string;
      stAssigned: string;
      stReminded: string;
      stOnShift: string;
      stSubmitted: string;
      stNoShow: string;
      stLeft: string;
      stPostpone: string;
      stAccepted: string;
      stRejected: string;
      stExpired: string;
      tSubmitted: string;
      tAccepted: string;
      tRejected: string;
      roster: string;
      free: string;
      busy: string;
      log: string;
      logIdle: string;
      under: string;
      underHint: string;
      lockKey: string;
      loop: string;
      leaderTag: string;
      idleTag: string;
      makeLeader: string;
      tickTag: string;
      roles: string;
      stack: string;
      atLive: string;
      reachedEnd: string;
      noFree: string;
      slot: string;
      by: string;
    };
    type Payload = {
      dayStart: number;
      dayEnd: number;
      now0: number;
      ui: UI;
      workers: WorkerJSON[];
      seed: SeedJSON[];
      presets: PresetJSON[];
    };

    // Смена — событийная запись. Метки null, пока событие не произошло.
    type Shift = {
      id: string;
      title: string;
      city: string;
      start: number;
      end: number;
      rate: string;
      bornAt: number;
      claimedAt: number | null;
      claimWorker: string | null;
      confirmedAt: number | null;
      releasedAt: number | null;
      releaseReason: "" | "noshow" | "left" | "postpone";
      reclaimedAt: number | null;
      reclaimWorker: string | null;
      reconfirmedAt: number | null;
      submittedAt: number | null;
      autoAcceptAt: number | null;
      acceptedAt: number | null;
      rejectedAt: number | null;
      cancelledAt: number | null;
      willConfirm: boolean;
      willLeave: boolean;
      noAutoClaim: boolean;
      remindLogged: boolean;
      el: HTMLLIElement | null;
    };

    type Derived = {
      present: boolean;
      col: Col;
      worker: string | null;
      confirmed: boolean;
      released: boolean;
      reason: "" | "noshow" | "left" | "postpone";
      submitted: boolean;
      // released-слот, старт которого уже прошёл: sim его больше не пере-берёт
      // (auto-claim гейтится h < start), карточка истекает — не «пере-предложено».
      expiring: boolean;
      reminded: boolean;
      done: "" | "accepted" | "rejected" | "cancelled";
    };

    function q<T extends Element>(root: Element | Document, sel: string): T | null {
      return root.querySelector<T>(sel);
    }

    function initWorkShifts(): void {
      const roots = Array.from(document.querySelectorAll<HTMLElement>("[data-ws]"));
      if (!roots.length) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");

      roots.forEach((root) => {
        if (root.dataset.wsInit === "1") return;
        root.dataset.wsInit = "1";

        const payloadEl = q<HTMLScriptElement>(root, "[data-ws-payload]");
        if (!payloadEl?.textContent) return;
        let data: Payload;
        try {
          data = JSON.parse(payloadEl.textContent) as Payload;
        } catch {
          return;
        }
        const U = data.ui;

        // ── DOM ──
        const timeEl = q<HTMLElement>(root, "[data-ws-time]");
        const backBtn = q<HTMLButtonElement>(root, "[data-ws-back]");
        const fwdBtn = q<HTMLButtonElement>(root, "[data-ws-fwd]");
        const tlFill = q<HTMLElement>(root, "[data-ws-tl]");
        const liveBtn = q<HTMLButtonElement>(root, "[data-ws-live]");
        const liveLabel = q<HTMLElement>(root, "[data-ws-live-label]");
        const createBtn = q<HTMLButtonElement>(root, "[data-ws-create]");
        const histBox = q<HTMLElement>(root, "[data-ws-hist]");
        const toNowBtn = q<HTMLButtonElement>(root, "[data-ws-tonow]");
        const composer = q<HTMLElement>(root, "[data-ws-composer]");
        const previewEl = q<HTMLElement>(root, "[data-ws-preview]");
        const publishBtn = q<HTMLButtonElement>(root, "[data-ws-publish]");
        const cancelBtn = q<HTMLButtonElement>(root, "[data-ws-cancel]");
        const presetBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ws-preset]"));
        const cols: Record<Col, HTMLElement | null> = {
          open: q<HTMLElement>(root, '[data-ws-colbody="open"]'),
          progress: q<HTMLElement>(root, '[data-ws-colbody="progress"]'),
          review: q<HTMLElement>(root, '[data-ws-colbody="review"]'),
          done: q<HTMLElement>(root, '[data-ws-colbody="done"]'),
        };
        const counts: Record<Col, HTMLElement | null> = {
          open: q<HTMLElement>(root, '[data-ws-colcount="open"]'),
          progress: q<HTMLElement>(root, '[data-ws-colcount="progress"]'),
          review: q<HTMLElement>(root, '[data-ws-colcount="review"]'),
          done: q<HTMLElement>(root, '[data-ws-colcount="done"]'),
        };
        const logEl = q<HTMLElement>(root, "[data-ws-log]");
        const toastLayer = q<HTMLElement>(root, "[data-ws-toasts]");

        if (!timeEl) return;

        // ── Состояние ──
        const state = { now: data.now0, view: data.now0, live: false };
        let inview = false;
        let seq = 1000;
        let selectedPreset = data.presets[0]?.id ?? "";
        const timers: number[] = [];
        let liveTimer: number | null = null;

        const clearTimers = (): void => {
          while (timers.length) {
            const id = timers.pop();
            if (id !== undefined) window.clearTimeout(id);
          }
          if (liveTimer !== null) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }
        };
        const later = (fn: () => void, ms: number): void => {
          const id = window.setTimeout(() => {
            const i = timers.indexOf(id);
            if (i >= 0) timers.splice(i, 1);
            fn();
          }, ms);
          timers.push(id);
        };

        // ── Смены ──
        const workers = data.workers;
        const shifts: Shift[] = data.seed.map((s) => ({
          id: s.id,
          title: s.title,
          city: s.city,
          start: s.start,
          end: s.end,
          rate: s.rate,
          bornAt: s.bornAt,
          claimedAt: s.claimedAt,
          claimWorker: s.claimWorker,
          confirmedAt: s.confirmedAt,
          releasedAt: null,
          releaseReason: "",
          reclaimedAt: null,
          reclaimWorker: null,
          reconfirmedAt: null,
          submittedAt: s.submittedAt,
          autoAcceptAt: s.autoAcceptAt,
          acceptedAt: null,
          rejectedAt: null,
          cancelledAt: null,
          willConfirm: s.willConfirm,
          willLeave: s.willLeave,
          noAutoClaim: s.noAutoClaim,
          remindLogged: false,
          el: null,
        }));

        const fmt = (h: number): string =>
          `${String(Math.max(0, Math.min(h, 24))).padStart(2, "0")}:00`;
        const canEdit = (): boolean => !state.live && state.view === state.now;

        // ── derive(shift, T): чистый кадр состояния под время T ──
        const base = (): Derived => ({
          present: true,
          col: "open",
          worker: null,
          confirmed: false,
          released: false,
          reason: "",
          submitted: false,
          expiring: false,
          reminded: false,
          done: "",
        });
        const derive = (s: Shift, T: number): Derived => {
          if (T < s.bornAt) return { ...base(), present: false };
          const activeWorker = s.reclaimWorker ?? s.claimWorker;
          // финальные состояния (Закрыто)
          if (s.acceptedAt !== null && T >= s.acceptedAt)
            return {
              ...base(),
              col: "done",
              worker: activeWorker,
              confirmed: true,
              done: "accepted",
            };
          if (s.rejectedAt !== null && T >= s.rejectedAt)
            return { ...base(), col: "done", worker: activeWorker, done: "rejected" };
          if (s.cancelledAt !== null && T >= s.cancelledAt)
            return { ...base(), col: "done", done: "cancelled" };
          // сдал работу → На приёмке (ждёт решения работодателя)
          if (s.submittedAt !== null && T >= s.submittedAt)
            return {
              ...base(),
              col: "review",
              worker: activeWorker,
              confirmed: true,
              submitted: true,
            };
          const confirmed =
            (s.confirmedAt !== null && s.confirmedAt <= T) ||
            (s.reconfirmedAt !== null && s.reconfirmedAt <= T);
          // reclaim-сегмент (позже release)
          if (s.reclaimedAt !== null && T >= s.reclaimedAt) {
            const reminded = !confirmed && T >= s.start - REMIND_LEAD && T < s.start;
            return { ...base(), col: "progress", worker: s.reclaimWorker, confirmed, reminded };
          }
          // released-сегмент → снова Открыто (no-show / ушёл / снялся)
          if (s.releasedAt !== null && T >= s.releasedAt) {
            return { ...base(), released: true, reason: s.releaseReason, expiring: T >= s.start };
          }
          // claimed-сегмент → назначен / на смене
          if (s.claimedAt !== null && T >= s.claimedAt) {
            const reminded = !confirmed && T >= s.start - REMIND_LEAD && T < s.start;
            return { ...base(), col: "progress", worker: s.claimWorker, confirmed, reminded };
          }
          return base();
        };

        // ── Построить/получить карточку (один элемент на смену) ──
        const buildCard = (s: Shift): HTMLLIElement => {
          const li = document.createElement("li");
          li.className = "ws__card";
          li.dataset.shift = s.id;
          li.innerHTML = `
            <span class="ws__card-remind" aria-hidden="true"></span>
            <div class="ws__card-head">
              <span class="ws__card-id mono">${s.id}</span>
              <span class="ws__card-time mono">${s.start}:00–${s.end}:00</span>
            </div>
            <div class="ws__card-title">${s.title}</div>
            <div class="ws__card-sub mono">${s.city} · ${s.rate}</div>
            <div class="ws__card-status" data-ws-card-status></div>
            <div class="ws__card-worker mono"><span data-ws-card-worker></span></div>
            <div class="ws__card-actions" data-ws-card-actions></div>`;
          s.el = li;
          return li;
        };

        // ── Кнопки действий карточки под текущим derived-состоянием ──
        const renderActions = (s: Shift, d: Derived): void => {
          const el = s.el;
          if (!el) return;
          const box = q<HTMLElement>(el, "[data-ws-card-actions]");
          if (!box) return;
          box.textContent = "";
          const edit = canEdit();
          const mk = (action: string, label: string, variant: "" | "primary" | "warn"): void => {
            const b = document.createElement("button");
            b.type = "button";
            b.className = "ws__card-btn" + (variant ? " ws__card-btn--" + variant : "");
            b.dataset["ws" + action] = "1";
            b.textContent = label;
            b.disabled = !edit;
            b.addEventListener("click", () => onCardAction(s, action));
            box.appendChild(b);
          };
          if (d.done) return;
          if (d.col === "open") {
            mk("Assign", U.assign, "primary");
          } else if (d.col === "review") {
            mk("Accept", U.accept, "primary");
            mk("Reject", U.reject, "warn");
          }
        };

        const statusText = (d: Derived): string => {
          if (d.done === "accepted") return U.stAccepted;
          if (d.done === "rejected") return U.stRejected;
          if (d.done === "cancelled") return U.stExpired;
          if (d.submitted) return U.stSubmitted;
          if (d.released)
            return d.reason === "left"
              ? U.stLeft
              : d.reason === "postpone"
                ? U.stPostpone
                : U.stNoShow;
          if (d.col === "progress")
            return d.confirmed ? U.stOnShift : d.reminded ? U.stReminded : U.stAssigned;
          return U.stOpen;
        };

        // ── render(view): чистая раскладка под view ──
        const render = (): void => {
          const T = state.view;
          const tally: Record<Col, number> = { open: 0, progress: 0, review: 0, done: 0 };
          const busyBy: Record<string, string> = {};

          shifts.forEach((s) => {
            const d = derive(s, T);
            if (!d.present) {
              if (s.el && s.el.parentElement) s.el.remove();
              return;
            }
            let el = s.el;
            if (!el) el = buildCard(s);
            const target = cols[d.col];
            if (!target) return;
            const changedCol = el.dataset.col !== d.col;
            if (el.parentElement !== target || changedCol) {
              target.appendChild(el);
              if (changedCol && el.dataset.col && inview && !reduced.matches) {
                el.classList.remove("is-moved");
                void el.offsetWidth;
                el.classList.add("is-moved");
              }
            }
            el.dataset.col = d.col;
            el.dataset.reminded = d.reminded ? "1" : "0";
            el.dataset.state = d.done
              ? d.done === "accepted"
                ? "accepted"
                : d.done
              : d.submitted
                ? "submitted"
                : d.released
                  ? "released"
                  : d.confirmed
                    ? "confirmed"
                    : "claimed";
            el.dataset.workerSet = d.worker ? "1" : "0";
            el.dataset.locked = canEdit() ? "0" : "1";
            const w = q<HTMLElement>(el, "[data-ws-card-worker]");
            if (w) w.textContent = d.worker ? `${U.by}: ${d.worker}` : "";
            const st = q<HTMLElement>(el, "[data-ws-card-status]");
            if (st) st.textContent = statusText(d);
            renderActions(s, d);
            tally[d.col] += 1;
            if (d.col === "progress" && d.worker) busyBy[d.worker] = s.id;
          });

          (["open", "progress", "review", "done"] as Col[]).forEach((c) => {
            const el = counts[c];
            if (el) el.textContent = String(tally[c]);
          });

          // ростер: занятость
          root.querySelectorAll<HTMLElement>("[data-worker]").forEach((chip) => {
            const id = chip.dataset.worker ?? "";
            const shiftId = busyBy[id];
            chip.dataset.busy = shiftId ? "1" : "0";
            const stEl = q<HTMLElement>(chip, "[data-ws-wk-state]");
            if (stEl) stEl.textContent = shiftId ? `${U.busy} · ${shiftId}` : U.free;
          });

          // часы + индикатор хода дня
          timeEl.textContent = fmt(T);
          if (tlFill) {
            const frac = (T - DAY_START) / (DAY_END - DAY_START);
            tlFill.style.setProperty("--tl", String(Math.max(0, Math.min(1, frac))));
          }

          // история
          const viewingPast = state.view < state.now;
          root.toggleAttribute("data-view-history", viewingPast);
          if (histBox) histBox.hidden = !viewingPast;
        };

        // ── Логи / тосты ──
        let logSeeded = false;
        const log = (text: string, tone: Tone = ""): void => {
          if (!logEl) return;
          if (!logSeeded) {
            logEl.textContent = "";
            logSeeded = true;
          }
          const line = document.createElement("span");
          line.className = "ws-l" + (tone ? " ws-" + tone : "");
          line.textContent = text;
          logEl.appendChild(line);
          if (reduced.matches || !inview) line.classList.add("is-in");
          else requestAnimationFrame(() => line.classList.add("is-in"));
          logEl.scrollTop = logEl.scrollHeight;
        };

        const toast = (text: string, warn = false): void => {
          if (!toastLayer) return;
          while (toastLayer.children.length >= MAX_TOASTS && toastLayer.firstElementChild) {
            toastLayer.firstElementChild.remove();
          }
          const el = document.createElement("div");
          el.className = "ws__toast" + (warn ? " ws__toast--warn" : "");
          el.textContent = text;
          toastLayer.appendChild(el);
          if (reduced.matches) el.classList.add("is-in");
          else requestAnimationFrame(() => el.classList.add("is-in"));
          later(() => {
            el.classList.remove("is-in");
            later(() => el.remove(), 260);
          }, TOAST_MS);
        };

        // ── Ближайший свободный работник (по дистанции) под T ──
        const busySet = (T: number): Set<string> => {
          const busy = new Set<string>();
          shifts.forEach((s) => {
            const d = derive(s, T);
            if (d.col === "progress" && d.worker) busy.add(d.worker);
          });
          return busy;
        };
        const nearestFree = (T: number): string | null => {
          const busy = busySet(T);
          let best: WorkerJSON | null = null;
          for (const w of workers) {
            if (busy.has(w.id)) continue;
            if (!best || parseFloat(w.dist) < parseFloat(best.dist)) best = w;
          }
          return best ? best.id : null;
        };

        // ── stepHour(h): продвинуть симуляцию на час вперёд (мутирует события) ──
        const stepHour = (h: number): void => {
          // 1. spawn — иногда рождается новая смена (кап по concurrency)
          const active = shifts.filter((s) => {
            const d = derive(s, h);
            return d.present && !d.done;
          }).length;
          if (active < MAX_CONCURRENT && Math.random() < 0.3 && h < DAY_END - 3) {
            const p = data.presets[Math.floor(Math.random() * data.presets.length)];
            if (p) {
              seq += 1;
              const start = Math.min(DAY_END - 1, h + 1 + Math.floor(Math.random() * 3));
              const sh: Shift = {
                id: "WB-" + seq,
                title: p.title,
                city: p.city,
                start,
                end: Math.min(DAY_END, start + p.dur),
                rate: p.rate,
                bornAt: h,
                claimedAt: null,
                claimWorker: null,
                confirmedAt: null,
                releasedAt: null,
                releaseReason: "",
                reclaimedAt: null,
                reclaimWorker: null,
                reconfirmedAt: null,
                submittedAt: null,
                autoAcceptAt: null,
                acceptedAt: null,
                rejectedAt: null,
                cancelledAt: null,
                willConfirm: Math.random() > 0.2,
                willLeave: Math.random() < 0.15,
                noAutoClaim: false,
                remindLogged: false,
                el: null,
              };
              shifts.push(sh);
              log(`${fmt(h)}  новая смена ${sh.id} → Открыто`, "dim");
            }
          }

          shifts.forEach((s) => {
            const d = derive(s, h);
            if (!d.present || d.done) return;
            const claimedSeg = d.col === "progress";

            // 2. auto-claim: работник сам берёт открытую смену
            if (d.col === "open" && !s.noAutoClaim && !d.expiring && h < s.start) {
              const w = nearestFree(h);
              if (w) {
                if (s.releasedAt !== null) {
                  s.reclaimedAt = h;
                  s.reclaimWorker = w;
                } else {
                  s.claimedAt = h;
                  s.claimWorker = w;
                }
                log(`${fmt(h)}  ${w} взял ${s.id}`, "");
                return;
              }
            }

            // 3. reminder — ровно раз при входе в [start-LEAD, start)
            if (
              claimedSeg &&
              !d.confirmed &&
              !s.remindLogged &&
              h >= s.start - REMIND_LEAD &&
              h < s.start
            ) {
              s.remindLogged = true;
              log(`${fmt(h)}  напоминание ${s.id} → SET nx (once)`, "acc");
              toast(`${U.stReminded}: ${s.id}`);
            }

            // 4. до старта — небольшой шанс сняться
            if (claimedSeg && !d.confirmed && h < s.start - 1 && Math.random() < 0.1) {
              s.releasedAt = h;
              s.releaseReason = "postpone";
              log(`${fmt(h)}  ${d.worker ?? ""} снялся с ${s.id} → Открыто`, "warn");
              toast(`${U.stPostpone}: ${s.id}`, true);
              return;
            }

            // 5. старт: вышел на смену или не вышел
            if (claimedSeg && !d.confirmed && h >= s.start) {
              if (s.willConfirm) {
                if (s.reclaimedAt !== null) s.reconfirmedAt = s.start;
                else s.confirmedAt = s.start;
                log(`${fmt(h)}  ${d.worker ?? ""} вышел на ${s.id}`, "");
              } else {
                s.releasedAt = s.start;
                s.releaseReason = "noshow";
                log(`${fmt(h)}  ${d.worker ?? ""} не вышел на ${s.id} → Открыто`, "warn");
                toast(`${U.stNoShow}: ${s.id}`, true);
              }
              return;
            }

            // 6. ушёл со смены (посреди работы)
            if (
              claimedSeg &&
              d.confirmed &&
              s.willLeave &&
              s.releasedAt === null &&
              h >= s.start + 1 &&
              h < s.end
            ) {
              s.releasedAt = h;
              s.releaseReason = "left";
              log(`${fmt(h)}  ${d.worker ?? ""} ушёл со смены ${s.id} → Открыто`, "warn");
              toast(`${U.stLeft}: ${s.id}`, true);
              return;
            }

            // 7. доработал до конца → сдал на приёмку
            if (claimedSeg && d.confirmed && h >= s.end && s.submittedAt === null) {
              s.submittedAt = s.end;
              s.autoAcceptAt = Math.min(DAY_END, s.end + 2);
              log(`${fmt(h)}  ${d.worker ?? ""} сдал ${s.id} → На приёмке`, "acc");
              toast(`${U.tSubmitted}: ${s.id}`);
              return;
            }

            // 8. авто-приёмка на автоплее (работодатель одобряет по умолчанию)
            if (d.col === "review" && s.autoAcceptAt !== null && h >= s.autoAcceptAt) {
              s.acceptedAt = h;
              log(`${fmt(h)}  ${s.id} принято (авто)`, "dim");
              return;
            }

            // 9. открытая/сорванная к end_time → просрочена
            if (d.col === "open" && h >= s.end) {
              s.cancelledAt = s.end;
              log(`${fmt(h)}  ${s.id} просрочено → авто-отмена`, "dim");
            }
          });
        };

        // ── advanceTo(target): проиграть новые часы вперёд ──
        const advanceTo = (target: number): void => {
          const clamped = Math.min(DAY_END, Math.round(target));
          for (let h = state.now + 1; h <= clamped; h += 1) stepHour(h);
          state.now = Math.max(state.now, clamped);
          state.view = state.now;
          render();
        };

        // ── Замена view (реплей, без дописи) ──
        const setView = (v: number): void => {
          state.view = Math.max(DAY_START, Math.min(state.now, Math.round(v)));
          render();
        };

        const pulseClock = (): void => {
          if (reduced.matches) return;
          root.classList.add("is-tick");
          later(() => root.classList.remove("is-tick"), 240);
        };

        // ── Действия работодателя по кнопкам карточки ──
        const onCardAction = (s: Shift, action: string): void => {
          if (!canEdit()) return;
          const T = state.now;
          const d = derive(s, T);
          if (action === "Assign") {
            if (d.col !== "open") return;
            const w = nearestFree(T);
            if (!w) {
              toast(U.noFree, true);
              return;
            }
            if (s.releasedAt !== null) {
              s.reclaimedAt = T;
              s.reclaimWorker = w;
            } else {
              s.claimedAt = T;
              s.claimWorker = w;
            }
            log(`${fmt(T)}  вы назначили ${w} на ${s.id}`, "acc");
          } else if (action === "Accept") {
            if (!d.submitted) return;
            s.acceptedAt = T;
            log(`${fmt(T)}  вы приняли работу ${s.id}`, "acc");
            toast(`${U.tAccepted}: ${s.id}`);
          } else if (action === "Reject") {
            if (!d.submitted) return;
            s.rejectedAt = T;
            log(`${fmt(T)}  вы отклонили работу ${s.id}`, "warn");
            toast(`${U.tRejected}: ${s.id}`, true);
          }
          render();
        };

        // ── Панель управления ──
        fwdBtn?.addEventListener("click", () => {
          if (state.live) return;
          if (state.now >= DAY_END) {
            toast(U.reachedEnd);
            return;
          }
          advanceTo(state.now + 1);
          pulseClock();
        });
        backBtn?.addEventListener("click", () => {
          if (state.live) return;
          setView(state.view - 1);
        });
        toNowBtn?.addEventListener("click", () => setView(state.now));

        const setLive = (on: boolean): void => {
          state.live = on;
          root.dataset.live = on ? "on" : "off";
          liveBtn?.setAttribute("aria-pressed", on ? "true" : "false");
          if (liveLabel) liveLabel.textContent = on ? U.livePause : U.live;
          if (on) {
            if (state.view < state.now) state.view = state.now;
            log(U.atLive, "acc");
            tickLive();
          } else if (liveTimer !== null) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }
          render();
        };
        const tickLive = (): void => {
          if (liveTimer !== null) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }
          if (!state.live || !inview) return;
          liveTimer = window.setTimeout(() => {
            liveTimer = null;
            if (!state.live || !inview) return;
            if (state.now >= DAY_END) {
              toast(U.reachedEnd);
              setLive(false);
              return;
            }
            advanceTo(state.now + 1);
            pulseClock();
            tickLive();
          }, LIVE_MS);
        };
        liveBtn?.addEventListener("click", () => {
          if (reduced.matches) {
            // reduced-motion: автоплей запрещён — просто шаг вперёд
            if (state.now < DAY_END) {
              advanceTo(state.now + 1);
            } else {
              toast(U.reachedEnd);
            }
            return;
          }
          setLive(!state.live);
        });

        // ── Композер ──
        const presetById = (id: string): PresetJSON | undefined =>
          data.presets.find((p) => p.id === id);
        const updatePreview = (): void => {
          const p = presetById(selectedPreset);
          if (!previewEl || !p) return;
          const start = Math.min(DAY_END - 1, Math.max(state.now, DAY_START) + 1);
          const end = Math.min(DAY_END, start + p.dur);
          previewEl.textContent = `${p.title} · ${p.city} · ${start}:00–${end}:00 · ${p.rate}`;
        };
        const openComposer = (open: boolean): void => {
          if (composer) composer.hidden = !open;
          createBtn?.setAttribute("aria-expanded", open ? "true" : "false");
          if (open) updatePreview();
        };
        createBtn?.addEventListener("click", () => openComposer(composer?.hidden ?? true));
        cancelBtn?.addEventListener("click", () => openComposer(false));
        presetBtns.forEach((b) => {
          b.addEventListener("click", () => {
            selectedPreset = b.dataset.wsPreset ?? selectedPreset;
            presetBtns.forEach((o) => o.setAttribute("aria-pressed", o === b ? "true" : "false"));
            updatePreview();
          });
        });
        publishBtn?.addEventListener("click", () => {
          const p = presetById(selectedPreset);
          if (!p) return;
          if (!canEdit()) {
            setView(state.now);
          }
          seq += 1;
          const start = Math.min(DAY_END - 1, Math.max(state.now, DAY_START) + 1);
          const sh: Shift = {
            id: "WB-" + seq,
            title: p.title,
            city: p.city,
            start,
            end: Math.min(DAY_END, start + p.dur),
            rate: p.rate,
            bornAt: state.now,
            claimedAt: null,
            claimWorker: null,
            confirmedAt: null,
            releasedAt: null,
            releaseReason: "",
            reclaimedAt: null,
            reclaimWorker: null,
            reconfirmedAt: null,
            submittedAt: null,
            autoAcceptAt: null,
            acceptedAt: null,
            rejectedAt: null,
            cancelledAt: null,
            willConfirm: true,
            willLeave: false,
            noAutoClaim: false,
            remindLogged: false,
            el: null,
          };
          shifts.push(sh);
          log(`${fmt(state.now)}  вы опубликовали ${sh.id} → Открыто`, "acc");
          toast(`${U.publish}: ${sh.id}`);
          openComposer(false);
          render();
        });

        // ── Первичный кадр ──
        render();

        // ── reduced-motion / без IO: статичный читаемый кадр ──
        if (reduced.matches || !("IntersectionObserver" in window)) {
          inview = true;
          if (logEl) {
            logEl.textContent = "";
            logSeeded = true;
          }
          log(`${fmt(state.now)}  ${U.atLive}`, "acc");
          render();
          return;
        }

        // ── Видимость ──
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              inview = e.isIntersecting;
              root.classList.toggle("is-inview", inview);
              if (!inview) {
                clearTimers();
              } else {
                if (!logSeeded) log(U.atLive, "dim");
                if (state.live) tickLive();
              }
            }
          },
          { threshold: 0.2 },
        );
        io.observe(root);

        const stopAll = (): void => {
          inview = false;
          clearTimers();
          root.classList.remove("is-inview");
        };
        const onVisibility = (): void => {
          if (document.hidden) stopAll();
        };
        document.addEventListener("visibilitychange", onVisibility);
        const onPageHide = (): void => {
          stopAll();
          io.disconnect();
          document.removeEventListener("visibilitychange", onVisibility);
        };
        window.addEventListener("pagehide", onPageHide, { once: true });
      });
    }

    initWorkShifts();
    document.addEventListener("astro:page-load", initWorkShifts);
  })();
</script>
