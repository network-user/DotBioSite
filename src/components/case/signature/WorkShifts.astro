---
/**
 * WorkShifts.astro — сигнатурная визуализация .работа (DotWorkBot).
 *
 * Концепция: ЖИВАЯ ДИСПЕТЧЕРСКАЯ ДОСКА (kanban) разовых смен, посетитель — за
 * РАБОТОДАТЕЛЯ. Колонки: Открыто → В работе → На приёмке → Закрыто. Часы —
 * событийная «машина времени»: now = максимум достигнутого времени (только
 * вперёд, +1ч и «Авто» ДОПИСЫВАЮТ события), view = плейхед, который можно мотать
 * назад кнопкой −1ч и только ПЕРЕИГРЫВАТЬ (без дописи). Индикатор «Ход дня» —
 * не интерактивная полоса, заполняется к текущему часу. Каждая смена хранит лишь
 * метки событий (bornAt/claimedAt/confirmedAt/releasedAt/submittedAt/acceptedAt/
 * rejectedAt/…); derive(shift,T) — ЧИСТАЯ функция кадра. Пока крутишь время,
 * работники сами берут открытые смены; кто-то не выходит (no-show), кто-то уходит
 * посреди смены, большинство отрабатывают и сдают работу «На приёмку». Работодатель
 * (вы) назначает открытые смены (кнопка) и на приёмке жмёт «Принять работу» или
 * «Отклонить»; на автоплее («Авто») приёмка одобряется сама. Фоновый воркер за
 * REMIND_LEAD часов шлёт РОВНО ОДНО напоминание, возвращает сорванные слоты в
 * «Открыто» и авто-отменяет просроченные. Перемещение — только кнопками карточек.
 *
 * Роли: worker / employer / admin. Ядро: PostgreSQL · Redis (FSM/throttle/lock)
 * · MinIO/S3 фото · AES-бэкапы · VPS-деплой с откатом. Акцент var(--accent-work).
 *
 * Перф-бюджет: анимируем ТОЛЬКО transform/opacity, никогда layout. Нет постоянного
 * rAF — автоплей («Авто») ведёт setTimeout-конвейер, полностью очищаемый офскрин,
 * на скрытой вкладке (visibilitychange) и на pagehide; тосты гасятся
 * отслеживаемыми таймерами. Единственная infinite-CSS (пульс точки «Авто») scoped
 * под .ws.is-inview[data-live="on"] и замирает за кадром. Всё гейтится
 * IntersectionObserver. reduced-motion → финальный читаемый кадр без движения,
 * автоплей выключен, но ВСЕ интеракции (кнопки, шаг времени) применяются мгновенно.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const DAY_START = 8;
const DAY_END = 24;
const NOW0 = 9;

