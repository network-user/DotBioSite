  claimWorker: string | null;
  confirmedAt: number | null;
  submittedAt: number | null;
  autoAcceptAt: number | null;
  willConfirm: boolean; // выйдет ли работник на смену
  willLeave: boolean; // уйдёт ли посреди смены
  noAutoClaim: boolean; // sim не берёт её сам (истечёт)
};
