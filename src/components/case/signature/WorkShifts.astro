---
/**
 * WorkShifts.astro — сигнатурная визуализация .работа (DotWorkBot).
 *
 * Язык: «lifecycle rail + replica race». Две интерактивные сцены, которые
 * можно потыкать, но в строгом перф-бюджете (анимируем только transform/opacity).
 *
 * Сцена A — жизненный цикл заказа, который читатель ВЕТВИТ:
 *   open → taken → reminder (≈3ч до старта, шлётся один раз, флаг ставится
 *   атомарно) → РАЗВИЛКА: confirm (confirmed_at заполнен → заказ идёт к закрытию)
 *   ИЛИ no-show (старт прошёл без подтверждения → слот освобождается, заказ
 *   снова open, освободившийся слот предлагается другим работникам в городе).
 *   Кнопки «Подтвердить» / «No-show» гонят рейл и слот-токен (слот освобождается
 *   и пере-предлагается на no-show). Статусы: OrderStatus OPEN / IN_PROGRESS /
 *   CANCELLED; OrderAssignment.confirmed_at; мульти-слот заказ закрывается только
 *   когда набраны все нужные работники.
 *
 * Сцена B — движок: отдельный taskiq-воркер крутит _operational_control_loop
 *   (интервал ≥15с). Несколько реплик конкурируют; Redis-лидер-лок `SET nx ex`
 *   (ключ dotworkbot:operational_control:leader) выбирает РОВНО ОДНОГО лидера,
 *   чтобы напоминания/закрытия срабатывали один раз даже при многих репликах.
 *   Тап по любой реплике передаёт ей лок, остальные становятся idle, лидер
 *   видимо «тикает» цикл. Всегда ровно один лидер.
 *
 * Факты: 3 роли (worker/employer/admin), реляционное ядро на PostgreSQL + Redis
 * (FSM/throttle/lock) + MinIO/S3 для фото, AES-шифрованные бэкапы, авто-деплой
 * на VPS с health-check откатом.
 *
 * Перф-бюджет: анимируем ТОЛЬКО transform/opacity. Никаких постоянных rAF.
 * Циклы («тик» лидера) — CSS-keyframes, играющие ТОЛЬКО когда блок виден
 * (.is-inview) и сцена движка активна; гасятся за экраном, на скрытой вкладке
 * и на pagehide. reduced-motion → финальный читаемый кадр без движения; все
 * тапы/ветвление/вкладки работают.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi) => b[locale];

const ui = {
  intro: {
    ru: "Биржа разовых смен: разберём по шагам, как заказ проходит свой путь — и на развилке сами выберете, подтвердит работник выход или пропадёт. Под капотом крутится невидимый движок: несколько реплик, но лидер всегда один.",
    en: "A gig-shift marketplace: a step-by-step look at how one order travels its lifecycle — and at the fork you decide whether the worker confirms or vanishes. Underneath runs an invisible engine: several replicas, but always exactly one leader.",
  },
  prev: { ru: "Назад", en: "Back" },
  next: { ru: "Дальше", en: "Next" },
  replay: { ru: "Сначала", en: "Replay" },
  hintRail: {
    ru: "Тыкай: нажми стадию на рейле, чтобы перейти к ней.",
    en: "Poke it: tap a stage on the rail to jump to it.",
  },
  hintBranch: {
    ru: "Развилка: выберите исход — слот-токен и рейл отреагируют.",
    en: "Fork: pick the outcome — the slot token and the rail react.",
  },
  hintEngine: {
    ru: "Тыкай: нажми реплику — она заберёт лок. Лидер всегда ровно один, он и «тикает» цикл.",
    en: "Poke it: tap a replica to make it grab the lock. Always exactly one leader — and it ticks the loop.",
  },
  stepOf: { ru: "Шаг", en: "Step" },
  of: { ru: "из", en: "of" },
  play: { ru: "Авто", en: "Auto" },
  pause: { ru: "Пауза", en: "Pause" },
  partFlow: { ru: "Жизненный цикл заказа", en: "Order lifecycle" },
  partEngine: { ru: "Движок под капотом", en: "The engine underneath" },
  branchPrompt: { ru: "Что сделает работник?", en: "What will the worker do?" },
  doConfirm: { ru: "Подтвердить выход", en: "Confirm arrival" },
  doNoShow: { ru: "Пропасть (no-show)", en: "Go silent (no-show)" },
  branchReset: { ru: "Сбросить развилку", en: "Reset the fork" },
};

/**
 * Шаги. Первые шесть — жизненный цикл заказа (рисуем рейл-состояния),
 * последние два — движок (воркер + лидер-лок). `scene` управляет тем,
 * какую сцену подсвечивает скрипт. `branch` помечает развилку.
 */
type Step = {
  key: string;
  scene: "rail" | "engine";
  /** индекс узла на рейле, который активен на этом шаге (для scene=rail) */
  railIndex?: number;
  /** ветка развилки: confirm — счастливый путь, release — no-show */
  branch?: "confirm" | "release";
  tag: Bi; // крошечный декоративный eyebrow
  title: Bi; // заголовок шага
  body: Bi; // подробное объяснение
};

const steps: Step[] = [
  {
    key: "open",
    scene: "rail",
    railIndex: 0,
    tag: { ru: "статус: open", en: "status: open" },
    title: { ru: "Работодатель публикует смену", en: "Employer posts a shift" },
    body: {
      ru: "Заказ появляется со статусом «открыт»: город, время начала и конца, ставка и сколько человек нужно. Пока он открыт, его видят свободные работники и могут занять место.",
      en: "An order appears with the status “open”: city, start and end time, the rate, and how many workers are needed. While it is open, available workers can see it and claim a slot.",
    },
  },
  {
    key: "taken",
    scene: "rail",
    railIndex: 1,
    tag: { ru: "статус: in_progress", en: "status: in_progress" },
    title: { ru: "Работник занимает слот", en: "A worker takes a slot" },
    body: {
      ru: "Работник берёт смену — создаётся «назначение» (одна запись на человека), и заказ переходит в работу. Слотов может быть несколько: заказ закрывается для остальных только когда набраны все нужные люди.",
      en: "A worker claims the shift — an assignment row is created (one per worker) and the order moves to “in progress”. There can be several slots: the order closes to others only once every required worker is filled.",
    },
  },
  {
    key: "remind",
    scene: "rail",
    railIndex: 2,
    tag: { ru: "за 3 часа до старта", en: "3 hours before start" },
    title: { ru: "Напоминание: подтвердите выход", en: "Reminder: confirm arrival" },
    body: {
      ru: "Примерно за три часа до начала система один раз пишет тем, кто ещё не подтвердился: «вы выходите?». Отметка о напоминании ставится атомарно — это значит, что повторно одно и то же напоминание не уйдёт, даже если цикл сработает снова. Дальше — развилка: выберите ниже, что сделает работник.",
      en: "About three hours before the start, the system pings everyone who hasn’t confirmed yet — once: “are you coming?”. The reminder flag is set atomically (all-or-nothing), so the same reminder is never sent twice even if the loop runs again. Then comes the fork: choose below what the worker does.",
    },
  },
  {
    key: "confirm",
    scene: "rail",
    railIndex: 3,
    branch: "confirm",
    tag: { ru: "confirmed_at заполнен", en: "confirmed_at is set" },
    title: { ru: "Работник подтвердил — заказ идёт дальше", en: "Confirmed — the order proceeds" },
    body: {
      ru: "Работник нажимает «подтверждаю» — в его назначении проставляется время подтверждения. Работодатель получает уведомление «исполнитель выйдет», и смена спокойно идёт к выполнению. Хороший путь.",
      en: "The worker taps “confirm” — a confirmation timestamp is written on their assignment. The employer is notified that the worker is coming, and the shift proceeds calmly toward completion. The happy path.",
    },
  },
  {
    key: "release",
    scene: "rail",
    railIndex: 4,
    branch: "release",
    tag: { ru: "no-show → слот свободен", en: "no-show → slot freed" },
    title: { ru: "Молчание — слот возвращается людям", en: "Silence — the slot is released" },
    body: {
      ru: "Если время старта прошло, а подтверждения нет (человек пропал) — его место освобождается, ему уходит уведомление, а заказ снова становится открытым. Свободный слот тут же предлагается другим работникам в городе. Никто не остаётся «висеть» из-за чужого no-show.",
      en: "If the start time passes with no confirmation (the person went silent), their slot is freed, they get notified, and the order becomes open again. The freed slot is immediately offered to other workers in the city. Nobody is left stuck because of someone else’s no-show.",
    },
  },
  {
    key: "close",
    scene: "rail",
    railIndex: 5,
    tag: { ru: "end_time прошёл → cancelled", en: "end_time passed → cancelled" },
    title: { ru: "Срок истёк — заказ закрывается сам", en: "Expired — the order auto-closes" },
    body: {
      ru: "Заказы, у которых прошло время окончания, закрываются автоматически: никто не подбирает «мёртвые» объявления вручную. Оставшиеся работники получают уведомление, что заказ завершён. Лента остаётся чистой и актуальной.",
      en: "Orders whose end time has passed are closed automatically — no one has to clean up stale listings by hand. Any remaining workers are notified the order is finished. The feed stays clean and current.",
    },
  },
  {
    key: "worker",
    scene: "engine",
    tag: { ru: "taskiq-воркер", en: "taskiq worker" },
    title: { ru: "Кто всё это делает: фоновый воркер", en: "Who does all this: a background worker" },
    body: {
      ru: "Напоминания, освобождение слотов и закрытие заказов крутит не бот, отвечающий на сообщения, а отдельный фоновый процесс — taskiq-воркер с циклом _operational_control_loop (интервал ≥15с). Он просыпается по таймеру, проверяет базу (PostgreSQL) и делает нужные действия — тихо и сам по себе.",
      en: "Reminders, slot releases and order closings are run not by the chat bot but by a separate background process — a taskiq worker running _operational_control_loop (interval ≥15s). It wakes on a timer, checks the database (PostgreSQL), and performs the due actions — quietly, on its own.",
    },
  },
  {
    key: "lock",
    scene: "engine",
    tag: { ru: "Redis · SET nx ex", en: "Redis · SET nx ex" },
    title: { ru: "Лидер-лок: ровно один раз", en: "Leader-lock: exactly once" },
    body: {
      ru: "На проде может работать несколько реплик воркера. Чтобы напоминание не ушло трижды, реплики борются за один ключ в Redis командой «SET nx ex» (ключ dotworkbot:operational_control:leader): nx = «запиши, только если ключа ещё нет», ex = «сам исчезни через срок». Ключ достаётся одной реплике — она и есть лидер, она и тикает цикл. Остальные видят занятый ключ и пропускают такт. Тапни любую реплику ниже — лок перейдёт к ней.",
      en: "In production several worker replicas may run. So a reminder isn’t sent three times, the replicas race for one Redis key using “SET nx ex” (key dotworkbot:operational_control:leader): nx = “write only if the key doesn’t exist yet”, ex = “expire on your own after a TTL”. One replica wins the key — that replica is the leader and ticks the loop. The others see the key taken and skip the tick. Tap any replica below to hand it the lock.",
    },
  },
];

// Узлы рейла жизненного цикла (порядок совпадает с railIndex выше).
const rail: { key: string; label: Bi; sub: Bi }[] = [
  { key: "open", label: { ru: "Открыт", en: "Open" }, sub: { ru: "опубликован", en: "posted" } },
  { key: "taken", label: { ru: "В работе", en: "In progress" }, sub: { ru: "слот занят", en: "slot taken" } },
  { key: "remind", label: { ru: "Напоминание", en: "Reminder" }, sub: { ru: "подтвердите выход", en: "confirm arrival" } },
  { key: "confirm", label: { ru: "Подтверждено", en: "Confirmed" }, sub: { ru: "выход в срок", en: "arrival in time" } },
  { key: "release", label: { ru: "Слот освобождён", en: "Slot released" }, sub: { ru: "no-show → в ленту", en: "no-show → feed" } },
  { key: "close", label: { ru: "Закрыт", en: "Closed" }, sub: { ru: "срок истёк", en: "expired" } },
];

// Состояния слот-токена для развилки.
const slotStates = {
  filled: { ru: "слот занят · назначение", en: "slot filled · assignment" },
  confirmed: { ru: "подтверждён · confirmed_at", en: "confirmed · confirmed_at" },
  freed: { ru: "слот свободен · снова в ленте", en: "slot freed · back in feed" },
};

// Город, которому пере-предлагается освободившийся слот (демо-токены).
const cityWorkers = ["@worker · город", "@worker · город", "@worker · город"];

// Реплики воркера для сцены «движок».
const replicas = [
  { id: "r1", lead: true },
  { id: "r2", lead: false },
  { id: "r3", lead: false },
];

const replicaName = { ru: "реплика воркера", en: "worker replica" };
const leaderTag = { ru: "лидер · держит лок", en: "leader · holds lock" };
const idleTag = { ru: "ждёт · пропускает такт", en: "idle · skips tick" };
const onceTag = { ru: "ровно один раз", en: "exactly once" };
const lockKey = { ru: "Redis · SET nx ex", en: "Redis · SET nx ex" };
const lockName = { ru: "dotworkbot:operational_control:leader", en: "dotworkbot:operational_control:leader" };
const loopName = { ru: "_operational_control_loop · ≥15с", en: "_operational_control_loop · ≥15s" };
const tickTag = { ru: "тик цикла", en: "loop tick" };
---

<section
  class="ws"
  data-ws
  aria-label={t({ ru: "Как работает DotWorkBot", en: "How DotWorkBot works" })}
>
  <p class="ws__intro">{t(ui.intro)}</p>

  <!-- ── Сцена жизненного цикла (рейл + слот-токен) ──────────────────── -->
  <div class="ws__stage" data-ws-stage="rail">
    <span class="ws__stage-cap">{t(ui.partFlow)}</span>

    <div class="ws__flow">
      <ol class="ws__rail" data-ws-rail>
        {
          rail.map((s, i) => (
            <li class="ws__node" data-node={i} role="button" tabindex="0">
              <span class="ws__node-mark" aria-hidden="true" />
              <span class="ws__node-body">
                <span class="ws__node-label">{t(s.label)}</span>
                <span class="ws__node-sub">{t(s.sub)}</span>
              </span>
            </li>
          ))
        }
      </ol>

      <!-- Слот-токен: реагирует на развилку (занят → подтверждён | свободен) -->
      <aside class="ws__slot" data-ws-slot aria-live="polite">
        <span class="ws__slot-cap">{t({ ru: "слот заказа", en: "order slot" })}</span>
        <span class="ws__slot-token" data-ws-token>
          <span class="ws__slot-dot" aria-hidden="true" />
          <span class="ws__slot-state" data-ws-slot-state>{t(slotStates.filled)}</span>
        </span>
        <!-- освободившийся слот пере-предлагается работникам города -->
        <ul class="ws__offer" data-ws-offer aria-hidden="true">
          {
            cityWorkers.map((w, k) => (
              <li class="ws__offer-row" data-offer={k} style={`--i:${k}`}>
                <span class="ws__offer-dot" aria-hidden="true" />
                <span class="ws__offer-name mono">{w}</span>
              </li>
            ))
          }
        </ul>
      </aside>
    </div>

    <!-- Развилка: confirm | no-show. Видна только на шаге reminder. -->
    <div class="ws__branch" data-ws-branch hidden>
      <span class="ws__branch-prompt">{t(ui.branchPrompt)}</span>
      <div class="ws__branch-btns">
        <button class="ws__branch-btn ws__branch-btn--ok" type="button" data-ws-confirm>
          {t(ui.doConfirm)}
        </button>
        <button class="ws__branch-btn ws__branch-btn--no" type="button" data-ws-noshow>
          {t(ui.doNoShow)}
        </button>
        <button class="ws__branch-btn ws__branch-btn--reset" type="button" data-ws-branch-reset hidden>
          {t(ui.branchReset)}
        </button>
      </div>
    </div>

    <p class="ws__hint" data-ws-rail-hint>{t(ui.hintRail)}</p>
  </div>

  <!-- ── Сцена движка (воркер + лидер-лок + тик цикла) ───────────────── -->
  <div class="ws__stage" data-ws-stage="engine" hidden>
    <span class="ws__stage-cap">{t(ui.partEngine)}</span>
    <div class="ws__engine">
      <div class="ws__lock">
        <span class="ws__lock-loop mono">{t(loopName)}</span>
        <span class="ws__lock-once">{t(onceTag)}</span>
      </div>

      <div class="ws__lock-key-row">
        <span class="ws__lock-cmd mono">{t(lockKey)}</span>
        <span class="ws__lock-name mono">{t(lockName)}</span>
        <!-- «тик» цикла: пип, который пульсирует, пока лидер держит лок -->
        <span class="ws__tick" data-ws-tick aria-hidden="true">
          <span class="ws__tick-dot" />
          <span class="ws__tick-label mono">{t(tickTag)}</span>
        </span>
      </div>

      <div class="ws__replicas">
        {
          replicas.map((r) => (
            <button
              type="button"
              class="ws__rep"
              data-rep={r.id}
              data-lead={r.lead ? "1" : "0"}
              aria-pressed={r.lead ? "true" : "false"}
              aria-label={t({
                ru: "Сделать эту реплику лидером (забрать лок)",
                en: "Make this replica the leader (grab the lock)",
              })}
            >
              <span class="ws__rep-dot" aria-hidden="true" />
              <span class="ws__rep-name">{t(replicaName)}</span>
              <span class="ws__rep-tag ws__rep-tag--lead">{t(leaderTag)}</span>
              <span class="ws__rep-tag ws__rep-tag--idle">{t(idleTag)}</span>
            </button>
          ))
        }
      </div>
    </div>
    <p class="ws__hint">{t(ui.hintEngine)}</p>
  </div>

  <!-- ── Текстовое объяснение текущего шага ─────────────────────────── -->
  <div class="ws__explain" data-ws-explain aria-live="polite">
    {
      steps.map((s, i) => (
        <article class="ws__step" data-step={i} data-branch={s.branch ?? ""} hidden={i !== 0}>
          <span class="ws__step-tag">{t(s.tag)}</span>
          <h3 class="ws__step-title">{t(s.title)}</h3>
          <p class="ws__step-body">{t(s.body)}</p>
        </article>
      ))
    }
  </div>

  <!-- ── Управление: prev / точки / next + авто/пауза ───────────────── -->
  <div class="ws__controls">
    <button class="ws__btn ws__btn--nav" type="button" data-ws-prev>
      <span aria-hidden="true">←</span> {t(ui.prev)}
    </button>

    <div class="ws__dots" role="tablist" aria-label={t({ ru: "Шаги", en: "Steps" })}>
      {
        steps.map((_s, i) => (
          <button
            class="ws__dot"
            type="button"
            role="tab"
            data-ws-dot={i}
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`${t(ui.stepOf)} ${i + 1} ${t(ui.of)} ${steps.length}`}
          >
            <span class="ws__dot-mark" aria-hidden="true" />
          </button>
        ))
      }
    </div>

    <button class="ws__btn ws__btn--nav" type="button" data-ws-next>
      {t(ui.next)} <span aria-hidden="true">→</span>
    </button>
  </div>

  <div class="ws__meta">
    <span class="ws__counter" data-ws-counter>
      {t(ui.stepOf)} 1 {t(ui.of)} {steps.length}
    </span>
    <button class="ws__btn ws__btn--ghost" type="button" data-ws-toggle aria-pressed="false">
      {t(ui.play)}
    </button>
    <button class="ws__btn ws__btn--ghost" type="button" data-ws-replay>
      {t(ui.replay)}
    </button>
  </div>
</section>

<style>
  .ws {
    --accent: var(--project-accent);
    --line: color-mix(in srgb, var(--accent) 40%, var(--border));
    --soft: color-mix(in srgb, var(--accent) 12%, transparent);
    --glow: color-mix(in srgb, var(--accent) 18%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    color: var(--text);
    container-type: inline-size;
  }

  /* ── Вступление ──────────────────────────────────────────────────── */
  .ws__intro {
    margin: 0;
    max-width: 64ch;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }

  /* Подсказка «потыкай» внутри сцены */
  .ws__hint {
    margin: var(--sp-4) 0 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: color-mix(in srgb, var(--accent) 60%, var(--text-muted));
  }

  .mono {
    font-family: var(--font-stack-mono);
  }

  /* ── Общий контейнер сцены ───────────────────────────────────────── */
  .ws__stage {
    position: relative;
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 130% at 8% 0%, var(--glow), transparent 46%),
      var(--surface);
  }
  .ws__stage[hidden] {
    display: none;
  }

  /* тонкая дотовая подложка (бренд-мотив) */
  .ws__stage::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: radial-gradient(120% 100% at 50% 0%, #000 26%, transparent 90%);
    -webkit-mask-image: radial-gradient(120% 100% at 50% 0%, #000 26%, transparent 90%);
    pointer-events: none;
  }
  .ws__stage > * {
    position: relative;
    z-index: 1;
  }

  .ws__stage-cap {
    display: block;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-4);
  }

  /* ── Рейл + слот-токен в одну строку ─────────────────────────────── */
  .ws__flow {
    display: grid;
    grid-template-columns: 1fr minmax(180px, 240px);
    gap: var(--sp-5) var(--sp-6);
    align-items: start;
  }

  /* ── Рейл жизненного цикла ───────────────────────────────────────── */
  .ws__rail {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0 0 0 var(--sp-5);
    display: grid;
    gap: var(--sp-4);
  }

  /* вертикальная линия рейла */
  .ws__rail::before {
    content: "";
    position: absolute;
    left: 4px;
    top: 12px;
    bottom: 12px;
    width: var(--bw-thin);
    background: var(--border);
  }

  .ws__node {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    opacity: 0.34;
    cursor: pointer;
    transition: opacity var(--dur-slow) var(--ease-standard);
  }
  .ws__node:hover {
    opacity: 0.85;
  }
  .ws__node:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
    border-radius: var(--r-sm);
  }

  .ws__node-mark {
    position: absolute;
    left: calc(var(--sp-5) * -1 + 4px);
    width: 9px;
    height: 9px;
    margin-left: -4px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transform: scale(1);
    transition:
      transform var(--dur-slow) var(--ease-spring),
      background-color var(--dur-slow) var(--ease-standard);
  }

  .ws__node-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ws__node-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-17);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
  }

  .ws__node-sub {
    font-size: var(--fs-13);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }

  /* пройденные шаги — тускло-белые */
  .ws__node.is-done {
    opacity: 0.62;
  }
  .ws__node.is-done .ws__node-mark {
    background: var(--text-secondary);
  }

  /* активный шаг */
  .ws__node.is-active {
    opacity: 1;
  }
  .ws__node.is-active .ws__node-mark {
    background: var(--accent);
    transform: scale(1.7);
  }

  /* ветка confirm (узел 3) и no-show (узел 4) подсвечиваются по выбору развилки */
  .ws__rail[data-branch="confirm"] .ws__node[data-node="3"] .ws__node-mark {
    background: var(--accent);
  }
  .ws__rail[data-branch="release"] .ws__node[data-node="4"] .ws__node-mark {
    background: var(--state-warn);
  }
  /* приглушаем не выбранную ветку, чтобы путь читался однозначно */
  .ws__rail[data-branch="confirm"] .ws__node[data-node="4"],
  .ws__rail[data-branch="release"] .ws__node[data-node="3"] {
    opacity: 0.22;
  }

  /* ── Слот-токен ──────────────────────────────────────────────────── */
  .ws__slot {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-elevated);
  }

  .ws__slot-cap {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .ws__slot-token {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--line);
    border-radius: var(--r-sm);
    background: var(--surface);
    transition: opacity var(--dur-slow) var(--ease-standard);
  }

  .ws__slot-dot {
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: var(--r-pill);
    background: var(--accent);
    transform: scale(1);
    transition:
      transform var(--dur-slow) var(--ease-spring),
      background-color var(--dur-slow) var(--ease-standard);
  }

  .ws__slot-state {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-secondary);
  }

  /* подтверждён: токен «застывает» зелёно-нейтрально */
  .ws__slot[data-state="confirmed"] .ws__slot-dot {
    background: var(--state-ok);
    transform: scale(1.25);
  }
  .ws__slot[data-state="confirmed"] .ws__slot-state {
    color: var(--text);
  }

  /* освобождён: токен «отпускается», слот летит в ленту города */
  .ws__slot[data-state="freed"] .ws__slot-token {
    opacity: 0.5;
  }
  .ws__slot[data-state="freed"] .ws__slot-dot {
    background: var(--text-faint);
    transform: scale(0.85);
  }
  .ws__slot[data-state="freed"] .ws__slot-state {
    color: var(--text-muted);
  }

  /* лента «пере-предложения» города */
  .ws__offer {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    /* скрыта до no-show: opacity + transform, без layout-анимаций */
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-soft);
  }
  .ws__slot[data-state="freed"] .ws__offer {
    opacity: 1;
    transform: translateY(0);
  }

  .ws__offer-row {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-12);
    color: var(--text-muted);
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity var(--dur-slow) var(--ease-soft),
      transform var(--dur-slow) var(--ease-soft);
  }
  .ws__slot[data-state="freed"] .ws__offer-row {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(120ms + var(--i) * 120ms);
  }

  .ws__offer-dot {
    flex: none;
    width: 6px;
    height: 6px;
    border-radius: var(--r-pill);
    background: var(--accent);
    opacity: 0.7;
  }

  /* ── Развилка confirm | no-show ──────────────────────────────────── */
  .ws__branch {
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: var(--bw-thin) solid var(--border);
  }
  .ws__branch[hidden] {
    display: none;
  }

  .ws__branch-prompt {
    display: block;
    font-family: var(--font-stack-display);
    font-size: var(--fs-15);
    font-weight: var(--fw-medium);
    color: var(--text);
    margin-bottom: var(--sp-3);
  }

  .ws__branch-btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .ws__branch-btn {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .ws__branch-btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws__branch-btn:active {
    transform: scale(0.97);
  }
  .ws__branch-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .ws__branch-btn--ok[aria-pressed="true"] {
    color: var(--text);
    border-color: var(--line);
    background: var(--soft);
  }
  .ws__branch-btn--no[aria-pressed="true"] {
    color: var(--text);
    border-color: color-mix(in srgb, var(--state-warn) 50%, transparent);
    background: color-mix(in srgb, var(--state-warn) 10%, transparent);
  }
  .ws__branch-btn--reset {
    color: var(--text-muted);
    border-color: transparent;
  }
  .ws__branch-btn--reset[hidden] {
    display: none;
  }

  /* ── Сцена движка ────────────────────────────────────────────────── */
  .ws__engine {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .ws__lock {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .ws__lock-loop {
    font-size: var(--fs-13);
    letter-spacing: var(--ls-snug);
    color: var(--text-secondary);
  }

  .ws__lock-once {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    letter-spacing: var(--ls-snug);
    color: var(--accent);
    opacity: 0.9;
