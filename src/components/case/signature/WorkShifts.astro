      word-break: break-word;
    }
  }

  /* ── reduced-motion: финальный читаемый кадр, без движения ───────── */
  @media (prefers-reduced-motion: reduce) {
    .ws__card,
    .ws__card-remind,
    .ws__card-worker,
    .ws__clock-time,
    .ws__wk-dot,
    .ws__live-dot,
    .ws__rep,
    .ws__rep-dot,
    .ws__toast {
      transition: none;
    }
    .ws__card.is-moved {
      animation: none;
    }
    .ws.is-inview[data-live="on"] .ws__live-dot,
    .ws.is-inview[data-engine-open] .ws__rep[data-lead="1"] .ws__rep-dot,
    .ws.is-inview[data-engine-open] .ws__tick-dot {
      animation: none;
    }
    .ws__tick-dot {
      opacity: 1;
    }
    .ws__log :global(.ws-l) {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .ws__toast {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Живая диспетчерская доска .работа. Часы — событийная машина времени: now
  // только растёт (+1ч / «В эфире» дописывают события), view можно мотать назад
  // и переигрывать. derive(shift,T) — чистый кадр; render(view) раскладывает
  // карточки. Скрипт лишь переключает классы/атрибуты и позиции; всё, что
  // движется, — transform/opacity в CSS. Нет постоянного rAF: автоплей ведёт
  // setTimeout-конвейер, чистящийся офскрин, на скрытой вкладке и на pagehide.
  // Всё гейтится IntersectionObserver; reduced-motion → читаемый кадр, интеракции
  // применяются мгновенно.
  (() => {
    const DAY_START = 8;
    const DAY_END = 24;
    const REMIND_LEAD = 3;
    const MAX_CONCURRENT = 9;
    const LIVE_MS = 1500;
    const TOAST_MS = 3200;
    const MAX_TOASTS = 4;

    type Tone = "" | "acc" | "warn" | "dim";
    type Col = "open" | "progress" | "done";

    type WorkerJSON = { id: string; dist: string; rating: string };
    type SeedJSON = {
      id: string;
      title: string;
      city: string;
      start: number;
      end: number;
      rate: string;
      bornAt: number;
      claimedAt: number | null;
      claimWorker: string | null;
      confirmedAt: number | null;
      willConfirm: boolean;
      userControlled: boolean;
      noAutoClaim: boolean;
      hero: boolean;
      forceNoShow: boolean;
    };
    type PresetJSON = { id: string; title: string; city: string; rate: string; dur: number };
    // Локализованные строки: серверный ui-словарь сериализуется в payload.
    type UI = {
      intro: string;
      clock: string;
      back: string;
      fwd: string;
      scrub: string;
      live: string;
      livePause: string;
      create: string;
      toNow: string;
      hist: string;
      composerCap: string;
      composerHint: string;
      preview: string;
      publish: string;
      cancel: string;
      colOpen: string;
      colProgress: string;
      colDone: string;
      emptyOpen: string;
      emptyProgress: string;
      emptyDone: string;
      take: string;
      confirm: string;
      noshow: string;
      close: string;
      reclaim: string;
      drag: string;
      stOpen: string;
      stClaimed: string;
      stConfirmed: string;
      stReleased: string;
      stReminded: string;
      stDone: string;
      stCancelled: string;
      roster: string;
      free: string;
      busy: string;
      log: string;
      logIdle: string;
      under: string;
      underHint: string;
      lockKey: string;
      loop: string;
      leaderTag: string;
      idleTag: string;
      makeLeader: string;
      tickTag: string;
      roles: string;
      stack: string;
      atLive: string;
      reachedEnd: string;
      noFree: string;
      slot: string;
      by: string;
    };
    type Payload = {
      dayStart: number;
      dayEnd: number;
      now0: number;
      ui: UI;
      workers: WorkerJSON[];
      seed: SeedJSON[];
      presets: PresetJSON[];
    };

    // Смена — событийная запись. Метки null, пока событие не произошло.
    type Shift = {
      id: string;
      title: string;
      city: string;
      start: number;
      end: number;
      rate: string;
      bornAt: number;
      claimedAt: number | null;
      claimWorker: string | null;
      confirmedAt: number | null;
      releasedAt: number | null;
      reclaimedAt: number | null;
      reclaimWorker: string | null;
      reconfirmedAt: number | null;
      closedAt: number | null;
      cancelledAt: number | null;
      willConfirm: boolean;
      userControlled: boolean;
      noAutoClaim: boolean;
      hero: boolean;
      forceNoShow: boolean;
      remindLogged: boolean;
      el: HTMLLIElement | null;
    };

    type Derived = {
      present: boolean;
      col: Col;
      worker: string | null;
      confirmed: boolean;
      released: boolean;
      reminded: boolean;
      done: "" | "completed" | "cancelled";
    };

    function q<T extends Element>(root: Element | Document, sel: string): T | null {
      return root.querySelector<T>(sel);
    }

    function initWorkShifts(): void {
      const roots = Array.from(document.querySelectorAll<HTMLElement>("[data-ws]"));
      if (!roots.length) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");

      roots.forEach((root) => {
        if (root.dataset.wsInit === "1") return;
        root.dataset.wsInit = "1";

        const payloadEl = q<HTMLScriptElement>(root, "[data-ws-payload]");
        if (!payloadEl?.textContent) return;
        let data: Payload;
        try {
          data = JSON.parse(payloadEl.textContent) as Payload;
        } catch {
          return;
        }
        const U = data.ui;

        // ── DOM ──
        const timeEl = q<HTMLElement>(root, "[data-ws-time]");
        const backBtn = q<HTMLButtonElement>(root, "[data-ws-back]");
        const fwdBtn = q<HTMLButtonElement>(root, "[data-ws-fwd]");
        const scrub = q<HTMLInputElement>(root, "[data-ws-scrub]");
        const liveBtn = q<HTMLButtonElement>(root, "[data-ws-live]");
        const liveLabel = q<HTMLElement>(root, "[data-ws-live-label]");
        const createBtn = q<HTMLButtonElement>(root, "[data-ws-create]");
        const histBox = q<HTMLElement>(root, "[data-ws-hist]");
        const toNowBtn = q<HTMLButtonElement>(root, "[data-ws-tonow]");
        const composer = q<HTMLElement>(root, "[data-ws-composer]");
        const previewEl = q<HTMLElement>(root, "[data-ws-preview]");
        const publishBtn = q<HTMLButtonElement>(root, "[data-ws-publish]");
        const cancelBtn = q<HTMLButtonElement>(root, "[data-ws-cancel]");
        const presetBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ws-preset]"));
        const cols: Record<Col, HTMLElement | null> = {
          open: q<HTMLElement>(root, '[data-ws-colbody="open"]'),
          progress: q<HTMLElement>(root, '[data-ws-colbody="progress"]'),
          done: q<HTMLElement>(root, '[data-ws-colbody="done"]'),
        };
        const colSections: Record<Col, HTMLElement | null> = {
          open: q<HTMLElement>(root, '.ws__col[data-col="open"]'),
          progress: q<HTMLElement>(root, '.ws__col[data-col="progress"]'),
          done: q<HTMLElement>(root, '.ws__col[data-col="done"]'),
        };
        const counts: Record<Col, HTMLElement | null> = {
          open: q<HTMLElement>(root, '[data-ws-colcount="open"]'),
          progress: q<HTMLElement>(root, '[data-ws-colcount="progress"]'),
          done: q<HTMLElement>(root, '[data-ws-colcount="done"]'),
        };
        const logEl = q<HTMLElement>(root, "[data-ws-log]");
        const toastLayer = q<HTMLElement>(root, "[data-ws-toasts]");
        const dragLayer = q<HTMLElement>(root, "[data-ws-draglayer]");
        const engineToggle = q<HTMLButtonElement>(root, "[data-ws-engine-toggle]");
        const enginePanel = q<HTMLElement>(root, "[data-ws-engine]");
        const reps = Array.from(root.querySelectorAll<HTMLElement>(".ws__rep"));

        if (!timeEl || !scrub) return;

        // ── Состояние ──
        const state = { now: data.now0, view: data.now0, live: false };
        let inview = false;
        let seq = 1000;
        let selectedPreset = data.presets[0]?.id ?? "";
        const timers: number[] = [];
        let liveTimer: number | null = null;

        const clearTimers = (): void => {
          while (timers.length) {
            const id = timers.pop();
            if (id !== undefined) window.clearTimeout(id);
          }
          if (liveTimer !== null) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }
        };
        const later = (fn: () => void, ms: number): void => {
          const id = window.setTimeout(() => {
            const i = timers.indexOf(id);
            if (i >= 0) timers.splice(i, 1);
            fn();
          }, ms);
          timers.push(id);
        };

        // ── Смены ──
        const workers = data.workers;
        const shifts: Shift[] = data.seed.map((s) => ({
          id: s.id,
          title: s.title,
          city: s.city,
          start: s.start,
          end: s.end,
          rate: s.rate,
          bornAt: s.bornAt,
          claimedAt: s.claimedAt,
          claimWorker: s.claimWorker,
          confirmedAt: s.confirmedAt,
          releasedAt: null,
          reclaimedAt: null,
          reclaimWorker: null,
          reconfirmedAt: null,
          closedAt: null,
          cancelledAt: null,
          willConfirm: s.willConfirm,
          userControlled: s.userControlled,
          noAutoClaim: s.noAutoClaim,
          hero: s.hero,
          forceNoShow: s.forceNoShow,
          remindLogged: false,
          el: null,
        }));

        const fmt = (h: number): string => `${String(Math.min(h, 23)).padStart(2, "0")}:00`;
        const canEdit = (): boolean => !state.live && state.view === state.now;

        // ── derive(shift, T): чистый кадр ──
        const derive = (s: Shift, T: number): Derived => {
          if (T < s.bornAt) {
            return {
              present: false,
              col: "open",
              worker: null,
              confirmed: false,
              released: false,
              reminded: false,
              done: "",
            };
          }
          if (s.closedAt !== null && T >= s.closedAt) {
            return {
              present: true,
              col: "done",
              worker: s.reclaimWorker ?? s.claimWorker,
              confirmed: true,
              released: false,
              reminded: false,
              done: "completed",
            };
          }
          if (s.cancelledAt !== null && T >= s.cancelledAt) {
            return {
              present: true,
              col: "done",
              worker: null,
              confirmed: false,
              released: false,
              reminded: false,
              done: "cancelled",
            };
          }
          const confirmed =
            (s.confirmedAt !== null && s.confirmedAt <= T) ||
            (s.reconfirmedAt !== null && s.reconfirmedAt <= T);

          // reclaim-сегмент
          if (s.reclaimedAt !== null && T >= s.reclaimedAt) {
            const reminded = !confirmed && T >= s.start - REMIND_LEAD && T < s.start;
            return {
              present: true,
              col: "progress",
              worker: s.reclaimWorker,
              confirmed,
              released: false,
              reminded,
              done: "",
            };
          }
          // released-сегмент → снова open
          if (s.releasedAt !== null && T >= s.releasedAt) {
            return {
              present: true,
              col: "open",
              worker: null,
              confirmed: false,
              released: true,
              reminded: false,
              done: "",
            };
          }
          // claimed-сегмент
          if (s.claimedAt !== null && T >= s.claimedAt) {
            const reminded = !confirmed && T >= s.start - REMIND_LEAD && T < s.start;
            return {
              present: true,
              col: "progress",
              worker: s.claimWorker,
              confirmed,
              released: false,
              reminded,
              done: "",
            };
          }
          return {
            present: true,
            col: "open",
            worker: null,
            confirmed: false,
            released: false,
            reminded: false,
            done: "",
          };
        };

        // ── Построить/получить карточку (один элемент на смену) ──
        const buildCard = (s: Shift): HTMLLIElement => {
          const li = document.createElement("li");
          li.className = "ws__card";
          li.dataset.shift = s.id;
          if (s.hero) li.dataset.hero = "1";
          li.innerHTML = `
            <span class="ws__card-remind" aria-hidden="true"></span>
            <button class="ws__card-grip" type="button" data-ws-grip aria-label="${U.drag} ${s.id}">⠿</button>
            <span class="ws__card-top">
              <span class="ws__card-id mono">${s.id}</span>
              <span class="ws__card-window mono">${s.start}:00–${s.end}:00</span>
            </span>
            <span class="ws__card-title">${s.title}</span>
            <span class="ws__card-city">${s.city}</span>
            <span class="ws__card-worker mono"><span data-ws-card-worker></span></span>
            <span class="ws__card-status mono" data-ws-card-status></span>
            <span class="ws__card-foot">
              <span class="ws__card-rate mono">${s.rate}</span>
            </span>
            <span class="ws__card-actions" data-ws-card-actions></span>`;
          const grip = q<HTMLButtonElement>(li, "[data-ws-grip]");
          if (grip) attachDrag(grip, s, li);
          s.el = li;
          return li;
        };

        // ── Кнопки действий карточки под текущим derived-состоянием ──
        const renderActions = (s: Shift, d: Derived): void => {
          const el = s.el;
          if (!el) return;
          const box = q<HTMLElement>(el, "[data-ws-card-actions]");
          if (!box) return;
          box.textContent = "";
          const edit = canEdit();
          const mk = (action: string, label: string, variant: "" | "primary" | "warn"): void => {
            const b = document.createElement("button");
            b.type = "button";
            b.className = "ws__card-btn" + (variant ? " ws__card-btn--" + variant : "");
            b.dataset["ws" + action] = "1";
            b.textContent = label;
            b.disabled = !edit;
            b.addEventListener("click", () => onCardAction(s, action));
            box.appendChild(b);
          };
          if (d.done) return;
          if (d.col === "open") {
            mk("Take", d.released ? U.reclaim : U.take, "primary");
          } else if (d.col === "progress") {
            if (d.confirmed) {
              mk("Close", U.close, "primary");
            } else {
              mk("Confirm", U.confirm, "primary");
              if (s.hero) mk("Noshow", U.noshow, "warn");
            }
          }
        };

        const statusText = (d: Derived): string => {
          if (d.done === "completed") return U.stDone;
          if (d.done === "cancelled") return U.stCancelled;
          if (d.released) return U.stReleased;
          if (d.col === "progress")
            return d.confirmed ? U.stConfirmed : d.reminded ? U.stReminded : U.stClaimed;
          return U.stOpen;
        };

        // ── render(view): чистая раскладка под view ──
        const render = (): void => {
          const T = state.view;
          const tally: Record<Col, number> = { open: 0, progress: 0, done: 0 };
          const busyBy: Record<string, string> = {};

          shifts.forEach((s) => {
            const d = derive(s, T);
            if (!d.present) {
              if (s.el && s.el.parentElement) s.el.remove();
              return;
            }
            let el = s.el;
            if (!el) el = buildCard(s);
            const target = cols[d.col];
            if (!target) return;
            const changedCol = el.dataset.col !== d.col;
            if (el.parentElement !== target || changedCol) {
              target.appendChild(el);
              if (changedCol && el.dataset.col && inview && !reduced.matches) {
                el.classList.remove("is-moved");
                void el.offsetWidth;
                el.classList.add("is-moved");
              }
            }
            el.dataset.col = d.col;
            el.dataset.reminded = d.reminded ? "1" : "0";
            el.dataset.state = d.done
              ? d.done === "completed"
                ? "confirmed"
                : "cancelled"
              : d.released
                ? "released"
                : d.confirmed
                  ? "confirmed"
                  : "claimed";
            el.dataset.workerSet = d.worker ? "1" : "0";
            el.dataset.locked = canEdit() ? "0" : "1";
            const w = q<HTMLElement>(el, "[data-ws-card-worker]");
            if (w) w.textContent = d.worker ? `${U.by}: ${d.worker}` : "";
            const st = q<HTMLElement>(el, "[data-ws-card-status]");
            if (st) st.textContent = statusText(d);
            renderActions(s, d);
            tally[d.col] += 1;
            if (d.col === "progress" && d.worker) busyBy[d.worker] = s.id;
          });

          (["open", "progress", "done"] as Col[]).forEach((c) => {
            const el = counts[c];
            if (el) el.textContent = String(tally[c]);
          });

          // ростер: занятость
          root.querySelectorAll<HTMLElement>("[data-worker]").forEach((chip) => {
            const id = chip.dataset.worker ?? "";
            const shiftId = busyBy[id];
            chip.dataset.busy = shiftId ? "1" : "0";
            const stEl = q<HTMLElement>(chip, "[data-ws-wk-state]");
            if (stEl) stEl.textContent = shiftId ? `${U.busy} · ${shiftId}` : U.free;
          });

          // часы + слайдер
          timeEl.textContent = fmt(T);
          scrub.max = String(state.now);
          if (Number(scrub.value) !== T) scrub.value = String(T);

          // история
          const viewingPast = state.view < state.now;
          root.toggleAttribute("data-view-history", viewingPast);
          if (histBox) histBox.hidden = !viewingPast;
        };

        // ── Логи / тосты ──
        let logSeeded = false;
        const log = (text: string, tone: Tone = ""): void => {
          if (!logEl) return;
          if (!logSeeded) {
            logEl.textContent = "";
            logSeeded = true;
          }
          const line = document.createElement("span");
          line.className = "ws-l" + (tone ? " ws-" + tone : "");
          line.textContent = text;
          logEl.appendChild(line);
          if (reduced.matches || !inview) line.classList.add("is-in");
          else requestAnimationFrame(() => line.classList.add("is-in"));
          logEl.scrollTop = logEl.scrollHeight;
        };

        const toast = (text: string, warn = false): void => {
          if (!toastLayer) return;
          while (toastLayer.children.length >= MAX_TOASTS && toastLayer.firstElementChild) {
            toastLayer.firstElementChild.remove();
          }
          const el = document.createElement("div");
          el.className = "ws__toast" + (warn ? " ws__toast--warn" : "");
          el.textContent = text;
          toastLayer.appendChild(el);
          if (reduced.matches) el.classList.add("is-in");
          else requestAnimationFrame(() => el.classList.add("is-in"));
          later(() => {
            el.classList.remove("is-in");
            later(() => el.remove(), 260);
          }, TOAST_MS);
        };

        // ── Ближайший свободный работник (по дистанции) под T ──
        const busySet = (T: number): Set<string> => {
          const busy = new Set<string>();
          shifts.forEach((s) => {
            const d = derive(s, T);
            if (d.col === "progress" && d.worker) busy.add(d.worker);
          });
          return busy;
        };
        const nearestFree = (T: number): string | null => {
          const busy = busySet(T);
          let best: WorkerJSON | null = null;
          for (const w of workers) {
            if (busy.has(w.id)) continue;
            if (!best || parseFloat(w.dist) < parseFloat(best.dist)) best = w;
          }
          return best ? best.id : null;
        };

        // ── stepHour(h): продвинуть симуляцию на час вперёд (мутирует события) ──
        const stepHour = (h: number): void => {
          // 1. spawn — иногда рождается новая смена (кап по concurrency)
          const active = shifts.filter((s) => {
            const d = derive(s, h);
            return d.present && !d.done;
          }).length;
          if (active < MAX_CONCURRENT && Math.random() < 0.3 && h < DAY_END - 2) {
            const p = data.presets[Math.floor(Math.random() * data.presets.length)];
            if (p) {
              seq += 1;
              const start = Math.min(DAY_END - 1, h + 1 + Math.floor(Math.random() * 3));
              const sh: Shift = {
                id: "WB-" + seq,
                title: p.title,
                city: p.city,
                start,
                end: Math.min(DAY_END, start + p.dur),
                rate: p.rate,
                bornAt: h,
                claimedAt: null,
                claimWorker: null,
                confirmedAt: null,
                releasedAt: null,
                reclaimedAt: null,
                reclaimWorker: null,
                reconfirmedAt: null,
                closedAt: null,
                cancelledAt: null,
                willConfirm: Math.random() > 0.25,
                userControlled: false,
                noAutoClaim: false,
                hero: false,
                forceNoShow: false,
                remindLogged: false,
                el: null,
              };
              shifts.push(sh);
              log(`${fmt(h)}  new shift ${sh.id} → OPEN`, "dim");
            }
          }

          shifts.forEach((s) => {
            const d = derive(s, h);
            if (!d.present || d.done) return;

            // 2. auto-claim открытых
            if (d.col === "open" && !s.userControlled && !s.noAutoClaim && h < s.start) {
              const w = nearestFree(h);
              if (w) {
                if (d.released) {
                  s.reclaimedAt = h;
                  s.reclaimWorker = w;
                } else {
                  s.claimedAt = h;
                  s.claimWorker = w;
                }
                log(`${fmt(h)}  claim ${s.id} → ${w} (nearest free)`, "");
                return;
              }
            }

            // 3. reminder — ровно один раз при входе в [start-LEAD, start)
            const claimedSeg = d.col === "progress";
            if (
              claimedSeg &&
              !d.confirmed &&
              !s.remindLogged &&
              h >= s.start - REMIND_LEAD &&
              h < s.start
            ) {
              s.remindLogged = true;
              log(`${fmt(h)}  remind ${s.id} → SET nx reminder_sent (once)`, "acc");
              toast(`${U.stReminded}: ${s.id}`);
            }

            // 4. auto-confirm
            if (claimedSeg && !d.confirmed && !s.userControlled && h < s.start && !s.forceNoShow) {
              // небольшой шанс отложить (postpone), если ещё есть запас
              if (h < s.start - 1 && Math.random() < 0.12) {
                s.releasedAt = h;
                log(`${fmt(h)}  postpone ${s.id} → release slot → OPEN`, "warn");
                toast(`${U.stReleased}: ${s.id}`, true);
                return;
              }
              if (Math.random() > 0.4) {
                if (s.reclaimedAt !== null) s.reconfirmedAt = h;
                else s.confirmedAt = h;
                log(`${fmt(h)}  confirm ${s.id} → confirmed_at set`, "");
              }
            }

            // 5. start-resolution: у старта claimed-unconfirmed сегмента
            if (claimedSeg && !d.confirmed && h >= s.start) {
              if (s.userControlled) {
                // hero ведёт визитёр — sim не трогает
              } else if (s.willConfirm && !s.forceNoShow) {
                if (s.reclaimedAt !== null) s.reconfirmedAt = s.start;
                else s.confirmedAt = s.start;
                log(`${fmt(h)}  ${s.id} confirmed at start`, "");
              } else {
                s.releasedAt = s.start;
                log(`${fmt(h)}  no-show ${s.id} at start → release → OPEN`, "warn");
                toast(`${U.stReleased}: ${s.id}`, true);
              }
            }

            // 6. completion — прошёл end_time
            if (h >= s.end) {
              const dEnd = derive(s, s.end);
              if (dEnd.col === "progress" && dEnd.confirmed) {
                s.closedAt = s.end;
                log(`${fmt(h)}  end_time → close ${s.id} (completed)`, "dim");
              } else {
                s.cancelledAt = s.end;
                log(`${fmt(h)}  expired ${s.id} (end ${s.end}:00) → auto-close`, "dim");
              }
            }
          });
        };

        // ── advanceTo(target): проиграть новые часы вперёд ──
        const advanceTo = (target: number): void => {
          const clamped = Math.min(DAY_END, Math.round(target));
          for (let h = state.now + 1; h <= clamped; h += 1) stepHour(h);
          state.now = Math.max(state.now, clamped);
          state.view = state.now;
          render();
        };

        // ── Замена view (реплей, без дописи) ──
        const setView = (v: number): void => {
          state.view = Math.max(DAY_START, Math.min(state.now, Math.round(v)));
          render();
        };

        const pulseClock = (): void => {
          if (reduced.matches) return;
          root.classList.add("is-tick");
          later(() => root.classList.remove("is-tick"), 240);
        };

        // ── Действия по кнопкам карточки ──
        const onCardAction = (s: Shift, action: string): void => {
          if (!canEdit()) return;
          const T = state.now;
          const d = derive(s, T);
          if (action === "Take") {
            const w = nearestFree(T);
            if (!w) {
              toast(U.noFree, true);
              return;
            }
            if (d.released) {
              s.reclaimedAt = T;
              s.reclaimWorker = w;
            } else {
              s.claimedAt = T;
              s.claimWorker = w;
            }
            log(`${fmt(T)}  you assign ${s.id} → ${w}`, "acc");
          } else if (action === "Confirm") {
            if (s.reclaimedAt !== null) s.reconfirmedAt = T;
            else s.confirmedAt = T;
            log(`${fmt(T)}  confirm ${s.id} → confirmed_at`, "acc");
          } else if (action === "Noshow") {
            s.releasedAt = T;
            log(`${fmt(T)}  no-show ${s.id} → release slot → OPEN`, "warn");
            toast(`${U.stReleased}: ${s.id}`, true);
          } else if (action === "Close") {
            s.closedAt = T;
            log(`${fmt(T)}  close ${s.id} (completed)`, "dim");
          }
          render();
        };

        // ── Drag (pointer events, transform-only клон) ──
        type DragState = {
          shift: Shift;
          origin: HTMLLIElement;
          clone: HTMLElement;
          w: number;
          dx: number;
          dy: number;
          over: Col | null;
        };
        let drag: DragState | null = null;

        const validDrop = (from: Col, to: Col): boolean =>
          (from === "open" && to === "progress") ||
          (from === "progress" && to === "done") ||
          (from === "progress" && to === "open");

        const colUnder = (x: number, y: number): Col | null => {
          for (const c of ["open", "progress", "done"] as Col[]) {
            const sec = colSections[c];
            if (!sec) continue;
            const r = sec.getBoundingClientRect();
            if (x >= r.left && x <= r.right && y >= r.top && y <= r.bottom) return c;
          }
          return null;
        };

        const attachDrag = (grip: HTMLElement, s: Shift, li: HTMLLIElement): void => {
          grip.addEventListener("pointerdown", (ev: PointerEvent) => {
            if (!canEdit() || reduced.matches) return;
            const d = derive(s, state.now);
            if (d.done) return;
            ev.preventDefault();
            startDrag(s, li, ev, d.col);
          });
        };

        const onPointerMove = (ev: PointerEvent): void => {
          if (!drag) return;
          drag.clone.style.setProperty("--drag-x", ev.clientX - drag.dx + "px");
          drag.clone.style.setProperty("--drag-y", ev.clientY - drag.dy + "px");
          const from = drag.origin.dataset.col as Col;
          const over = colUnder(ev.clientX, ev.clientY);
          (["open", "progress", "done"] as Col[]).forEach((c) => {
            const sec = colSections[c];
            if (sec) sec.classList.toggle("is-droptarget", c === over && validDrop(from, c));
          });
          drag.over = over;
        };

        const endDrag = (): void => {
          if (!drag) return;
          const d = drag;
          drag = null;
          window.removeEventListener("pointermove", onPointerMove);
          window.removeEventListener("pointerup", endDrag);
          window.removeEventListener("pointercancel", endDrag);
          (["open", "progress", "done"] as Col[]).forEach((c) => {
            colSections[c]?.classList.remove("is-droptarget");
          });
          d.clone.remove();
          d.origin.classList.remove("is-ghost");
          const from = d.origin.dataset.col as Col;
          if (d.over && d.over !== from && validDrop(from, d.over)) {
            if (from === "open" && d.over === "progress") onCardAction(d.shift, "Take");
            else if (from === "progress" && d.over === "done") onCardAction(d.shift, "Close");
            else if (from === "progress" && d.over === "open") onCardAction(d.shift, "Noshow");
          }
        };

        const startDrag = (s: Shift, li: HTMLLIElement, ev: PointerEvent, col: Col): void => {
          if (!dragLayer) return;
          const rect = li.getBoundingClientRect();
          const clone = li.cloneNode(true) as HTMLElement;
          clone
            .querySelectorAll("[data-ws-grip],[data-ws-card-actions] *")
            .forEach((n) => (n as HTMLElement).remove());
          clone.style.setProperty("--drag-w", rect.width + "px");
          clone.style.setProperty("--drag-x", rect.left + "px");
          clone.style.setProperty("--drag-y", rect.top + "px");
          dragLayer.appendChild(clone);
          li.classList.add("is-ghost");
          li.dataset.col = col;
          drag = {
            shift: s,
            origin: li,
            clone,
            w: rect.width,
            dx: ev.clientX - rect.left,
            dy: ev.clientY - rect.top,
            over: null,
          };
          window.addEventListener("pointermove", onPointerMove);
          window.addEventListener("pointerup", endDrag);
          window.addEventListener("pointercancel", endDrag);
        };

        // ── Панель управления ──
        fwdBtn?.addEventListener("click", () => {
          if (state.live) return;
          if (state.now >= DAY_END) {
            toast(U.reachedEnd);
            return;
          }
          advanceTo(state.now + 1);
          pulseClock();
        });
        backBtn?.addEventListener("click", () => {
          if (state.live) return;
          setView(state.view - 1);
        });
        scrub.addEventListener("input", () => {
          if (state.live) return;
          setView(Number(scrub.value));
        });
        toNowBtn?.addEventListener("click", () => setView(state.now));

        const setLive = (on: boolean): void => {
          state.live = on;
          root.dataset.live = on ? "on" : "off";
          liveBtn?.setAttribute("aria-pressed", on ? "true" : "false");
          if (liveLabel) liveLabel.textContent = on ? U.livePause : U.live;
          if (on) {
            if (state.view < state.now) state.view = state.now;
            log(U.atLive, "acc");
            tickLive();
          } else if (liveTimer !== null) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }
          render();
        };
        const tickLive = (): void => {
          if (liveTimer !== null) {
            window.clearTimeout(liveTimer);
            liveTimer = null;
          }
          if (!state.live || !inview) return;
          liveTimer = window.setTimeout(() => {
            liveTimer = null;
            if (!state.live || !inview) return;
            if (state.now >= DAY_END) {
              toast(U.reachedEnd);
              setLive(false);
              return;
            }
            advanceTo(state.now + 1);
            pulseClock();
            tickLive();
          }, LIVE_MS);
        };
        liveBtn?.addEventListener("click", () => {
          if (reduced.matches) {
            // reduced-motion: автоплей запрещён — просто шаг вперёд
            if (state.now < DAY_END) {
              advanceTo(state.now + 1);
            } else {
              toast(U.reachedEnd);
            }
            return;
          }
          setLive(!state.live);
        });

        // ── Композер ──
        const presetById = (id: string): PresetJSON | undefined =>
          data.presets.find((p) => p.id === id);
        const updatePreview = (): void => {
          const p = presetById(selectedPreset);
          if (!previewEl || !p) return;
          const start = Math.min(DAY_END - 1, Math.max(state.now, DAY_START) + 1);
          const end = Math.min(DAY_END, start + p.dur);
          previewEl.textContent = `${p.title} · ${p.city} · ${start}:00–${end}:00 · ${p.rate}`;
        };
        const openComposer = (open: boolean): void => {
          if (composer) composer.hidden = !open;
          createBtn?.setAttribute("aria-expanded", open ? "true" : "false");
          if (open) updatePreview();
        };
        createBtn?.addEventListener("click", () => openComposer(composer?.hidden ?? true));
        cancelBtn?.addEventListener("click", () => openComposer(false));
        presetBtns.forEach((b) => {
          b.addEventListener("click", () => {
            selectedPreset = b.dataset.wsPreset ?? selectedPreset;
            presetBtns.forEach((o) => o.setAttribute("aria-pressed", o === b ? "true" : "false"));
            updatePreview();
          });
        });
        publishBtn?.addEventListener("click", () => {
          const p = presetById(selectedPreset);
          if (!p) return;
          if (!canEdit()) {
            setView(state.now);
          }
          seq += 1;
          const start = Math.min(DAY_END - 1, Math.max(state.now, DAY_START) + 1);
          const sh: Shift = {
            id: "WB-" + seq,
            title: p.title,
            city: p.city,
            start,
            end: Math.min(DAY_END, start + p.dur),
            rate: p.rate,
            bornAt: state.now,
            claimedAt: null,
            claimWorker: null,
            confirmedAt: null,
            releasedAt: null,
            reclaimedAt: null,
            reclaimWorker: null,
            reconfirmedAt: null,
            closedAt: null,
            cancelledAt: null,
            willConfirm: true,
            userControlled: false,
            noAutoClaim: false,
            hero: false,
            forceNoShow: false,
            remindLogged: false,
            el: null,
          };
          shifts.push(sh);
          log(`${fmt(state.now)}  you publish ${sh.id} → OPEN`, "acc");
          toast(`${U.publish}: ${sh.id}`);
          openComposer(false);
          render();
        });

        // ── Движок: реплики + раскрытие ──
        engineToggle?.addEventListener("click", () => {
          const open = engineToggle.getAttribute("aria-expanded") !== "true";
          engineToggle.setAttribute("aria-expanded", open ? "true" : "false");
          if (enginePanel) enginePanel.hidden = !open;
          root.toggleAttribute("data-engine-open", open);
        });
        reps.forEach((rep) => {
          rep.addEventListener("click", () => {
            reps.forEach((r) => {
              const lead = r === rep;
              r.setAttribute("data-lead", lead ? "1" : "0");
              r.setAttribute("aria-pressed", lead ? "true" : "false");
            });
          });
        });

        // ── Первичный кадр ──
        render();

        // ── reduced-motion / без IO: статичный читаемый кадр ──
        if (reduced.matches || !("IntersectionObserver" in window)) {
          inview = true;
          if (logEl) {
            logEl.textContent = "";
            logSeeded = true;
          }
          log(`${fmt(state.now)}  ${U.atLive}`, "acc");
          log(U.underHint, "dim");
          render();
          return;
        }

        // ── Видимость ──
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              inview = e.isIntersecting;
              root.classList.toggle("is-inview", inview);
              if (!inview) {
                clearTimers();
              } else {
                if (!logSeeded) log(U.atLive, "dim");
                if (state.live) tickLive();
              }
            }
          },
          { threshold: 0.2 },
        );
        io.observe(root);

        const stopAll = (): void => {
          inview = false;
          clearTimers();
          root.classList.remove("is-inview");
        };
        const onVisibility = (): void => {
          if (document.hidden) stopAll();
        };
        document.addEventListener("visibilitychange", onVisibility);
        const onPageHide = (): void => {
          stopAll();
          io.disconnect();
          document.removeEventListener("visibilitychange", onVisibility);
        };
        window.addEventListener("pagehide", onPageHide, { once: true });
      });
    }

    initWorkShifts();
    document.addEventListener("astro:page-load", initWorkShifts);
  })();
</script>
