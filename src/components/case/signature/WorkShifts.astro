    height: 9px;
    border-radius: var(--r-pill);
    background: var(--text-faint);
    transition:
      transform var(--dur-med) var(--ease-spring),
      background-color var(--dur-med) var(--ease-standard);
  }
  .ws__dot:hover .ws__dot-mark {
    background: var(--text-muted);
  }
  .ws__dot.is-done .ws__dot-mark {
    background: var(--text-secondary);
  }
  .ws__dot[aria-selected="true"] .ws__dot-mark {
    background: var(--accent);
    transform: scale(1.55);
  }
  .ws__dot:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
    border-radius: var(--r-pill);
  }

  .ws__btn {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-secondary);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    padding: var(--sp-2) var(--sp-4);
    min-height: var(--tap-min);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .ws__btn:hover:not(:disabled) {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .ws__btn:disabled {
    opacity: 0.38;
    cursor: default;
  }
  .ws__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .ws__btn--ghost {
    border-color: transparent;
    padding: var(--sp-2) var(--sp-3);
  }
  .ws__btn--ghost[aria-pressed="true"] {
    color: var(--text);
    border-color: var(--line);
  }

  .ws__meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .ws__counter {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    margin-right: auto;
    font-variant-numeric: tabular-nums;
  }

  /* ── Узкие экраны ────────────────────────────────────────────────── */
  @container (max-width: 560px) {
    .ws__flow {
      grid-template-columns: 1fr;
    }
  }
  @container (max-width: 520px) {
    .ws__btn--nav {
      padding: var(--sp-2) var(--sp-3);
    }
  }

  /* ── coarse pointer: без параллакса ──────────────────────────────── */
  @media (pointer: coarse) {
    .ws {
      transform: none;
    }
