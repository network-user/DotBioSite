---
/**
 * WorkShifts.astro — сигнатурная визуализация .работа (DotWorkBot).
 *
 * Концепция: ЖИВАЯ ДИСПЕТЧЕРСКАЯ ДОСКА (kanban) разовых смен-подработок.
 * Три колонки: Открыто → В работе → Закрыто. Часы — событийная «машина
 * времени»: now = максимум достигнутого времени (только вперёд, +1ч и «В эфире»
 * ДОПИСЫВАЮТ события), view = плейхед, который можно мотать назад скрабом/−1ч и
 * только ПЕРЕИГРЫВАТЬ (без дописи). Каждая смена хранит лишь метки событий
 * (bornAt/claimedAt/confirmedAt/releasedAt/closedAt/…); derive(shift,T) — ЧИСТАЯ
 * функция кадра. Пока крутишь время, фоновый воркер сам: авто-берёт открытые
 * смены ближайшим свободным работником, за REMIND_LEAD часов до старта шлёт
 * РОВНО ОДНО напоминание, освобождает слот при no-show (карточка едет обратно в
 * «Открыто» и пере-предлагается), закрывает выполненные и авто-отменяет
 * просроченные незаполненные. Посетитель сам создаёт смену (композер),
 * перетаскивает карточку между колонками (взять/закрыть/освободить — у каждого
 * действия есть tap+клавиатурная кнопка), берёт смену-героя WB-3041 и решает её
 * исход (Принять/Пропасть). «Под капотом» — свёрнутая сцена гонки реплик за один
 * Redis-лидер-лок (SET nx ex · dotworkbot:operational_control:leader): тап по
 * реплике заставляет ИМЕННО ЕЁ забрать лок, остальные idle, ровно один «тикает».
 *
 * Роли: worker / employer / admin. Ядро: PostgreSQL · Redis (FSM/throttle/lock)
 * · MinIO/S3 фото · AES-бэкапы · VPS-деплой с откатом. Акцент var(--accent-work).
 *
 * Перф-бюджет: анимируем ТОЛЬКО transform/opacity, никогда layout. Нет
 * постоянного rAF — авто-проигрывание («В эфире») ведёт setTimeout-конвейер,
 * полностью очищаемый офскрин, на скрытой вкладке (visibilitychange) и на
 * pagehide; тосты гасятся отслеживаемыми таймерами. Все infinite-CSS (пульс
 * доски, тик движка) scoped под .ws.is-inview[data-live] / [data-engine-open] и
 * замирают за кадром и в свёрнутом состоянии. Всё гейтится IntersectionObserver.
 * reduced-motion → финальный читаемый кадр без движения, автоплей выключен, но
 * ВСЕ интеракции (кнопки, шаг времени, drag) применяются мгновенно.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const DAY_START = 8;
const DAY_END = 24;
const NOW0 = 9;

