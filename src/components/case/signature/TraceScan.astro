</style>

<script>
  // Оркестратор досье .след. Без степпера и без постоянного rAF: трассировка и
  // скан списком ведутся одним setTimeout-конвейером later(), который чистится
  // офскрин / на скрытой вкладке / при pagehide. Индикатор угрозы — CSS-переход
  // (composited). Всё гейтится IntersectionObserver. prefers-reduced-motion —
  // финальный статичный кадр, интеракции работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-td]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.dataset.locale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    const stage = root.querySelector<HTMLElement>(".td__stage");
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-chip]"));
    const srcEls = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-src]"));
    const ipEl = root.querySelector<HTMLElement>("[data-td-ip]");
    const statusEl = root.querySelector<HTMLElement>("[data-td-status]");
    const fieldEls = Array.from(root.querySelectorAll<HTMLElement>("[data-td-field]"));
    const threatEl = root.querySelector<HTMLElement>("[data-td-threat]");
    const scoreEl = root.querySelector<HTMLElement>("[data-td-score]");
    const verdictEl = root.querySelector<HTMLElement>("[data-td-verdict]");
    const gaugeEl = root.querySelector<HTMLElement>("[data-td-gauge]");
    const traceBtn = root.querySelector<HTMLButtonElement>("[data-td-trace]");
    const traceT = root.querySelector<HTMLElement>("[data-td-trace-t]");
    const noteEl = root.querySelector<HTMLElement>("[data-td-note]");
    const hintT = root.querySelector<HTMLElement>("[data-td-hint-t]");

    if (!stage || !ipEl) return;

    // Темп анимации (мс). Намеренно неспешный — чтобы было видно, как каждый
    // источник по очереди «отчитывается».
    const START = 500;
    const STEP = 540;
    const REP = 640;
    const SILENT = 1000;
    const FINAL = 760;

    type Dos = {
      ip: string;
      cc: string;
      country: string;
      city: string;
      asn: string;
      op: string;
      net: string;
      host: string;
      abuse: number;
    };
    const read = (c: HTMLElement): Dos => ({
      ip: c.dataset.ip ?? "",
      cc: c.dataset.cc ?? "",
      country: c.dataset.country ?? "",
      city: c.dataset.city ?? "",
      asn: c.dataset.asn ?? "",
      op: c.dataset.op ?? "",
      net: c.dataset.net ?? "",
      host: c.dataset.host ?? "",
      abuse: Number(c.dataset.abuse) || 0,
    });

    let current: Dos = read(chips[0] ?? document.createElement("div"));

    // ---- инфраструктура таймеров ----
    let inview = false;
    let tracing = false;
    const timers: number[] = [];
    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };
    const D = (ms: number): number => (reduced ? 0 : ms);

    // ---- угроза → band/вердикт ----
    const band = (abuse: number): { band: string; verdict: string } => {
      if (abuse >= 80) return { band: "high", verdict: tr("опасный", "high risk") };
      if (abuse >= 40) return { band: "mid", verdict: tr("подозрительный", "suspicious") };
      if (abuse >= 10) return { band: "low", verdict: tr("замечен", "flagged") };
      return { band: "clean", verdict: tr("низкий риск", "low risk") };
    };

    // ---- значение поля карточки ----
    const fieldValue = (id: string, d: Dos): string => {
      if (id === "country") {
        const city = d.city && d.city !== "—" ? ` · ${d.city}` : "";
        return `<span class="td__cc">${d.cc}</span>${d.country}${city}`;
      }
      if (id === "operator") return `<span class="td__asn">${d.asn}</span> · ${d.op}`;
      if (id === "network") return d.net;
      if (id === "host") return d.host && d.host !== "—" ? d.host : tr("нет PTR-записи", "no PTR record");
      return "";
    };

    const setField = (id: string, on: boolean): void => {
      const el = fieldEls.find((f) => f.dataset.tdField === id);
      if (!el) return;
      const v = el.querySelector<HTMLElement>("[data-td-field-v]");
      el.classList.toggle("is-filled", on);
      if (v) {
        if (on) v.innerHTML = fieldValue(id, current);
        else v.innerHTML = '<span class="td__field-ph" aria-hidden="true">—</span>';
      }
    };

    const setThreat = (on: boolean): void => {
      if (!threatEl || !scoreEl || !verdictEl || !gaugeEl) return;
      if (on) {
        const b = band(current.abuse);
        threatEl.dataset.band = b.band;
        scoreEl.textContent = `${current.abuse} / 100`;
        verdictEl.textContent = b.verdict;
        verdictEl.hidden = false;
        gaugeEl.style.setProperty("--score", (current.abuse / 100).toFixed(2));
      } else {
        threatEl.dataset.band = "idle";
        scoreEl.textContent = "—";
        verdictEl.hidden = true;
        gaugeEl.style.setProperty("--score", "0");
      }
    };

    const lightSrc = (id: string, state: "off" | "on" | "silent"): void => {
      const el = srcEls.find((s) => s.dataset.tdSrc === id);
      if (!el) return;
      el.classList.toggle("is-on", state === "on");
      el.classList.toggle("is-silent-on", state === "silent");
      el.setAttribute("aria-pressed", state === "off" ? "false" : "true");
      if (!reduced && state !== "off") {
        el.classList.remove("is-report");
        void el.offsetWidth;
        el.classList.add("is-report");
      }
      const st = el.querySelector<HTMLElement>("[data-td-src-state]");
      if (st) st.textContent = state === "silent" ? tr("таймаут", "timeout") : state === "on" ? "ok" : "";
    };

    const resetCard = (): void => {
      ipEl.textContent = current.ip;
      if (statusEl) {
        statusEl.textContent = tr("не собрано", "not assembled");
        statusEl.classList.remove("is-done", "is-scan");
      }
      fieldEls.forEach((f) => setField(f.dataset.tdField ?? "", false));
      setThreat(false);
      srcEls.forEach((s) => lightSrc(s.dataset.tdSrc ?? "", "off"));
      if (noteEl) noteEl.textContent = "";
    };

    const setTraceUI = (state: "idle" | "running"): void => {
      stage.dataset.state = state === "running" ? "tracing" : "idle";
      tracing = state === "running";
      if (traceT) traceT.textContent = state === "running" ? tr("Слежу…", "Tracing…") : tr("Проследить заново", "Trace again");
      if (traceBtn) traceBtn.disabled = state === "running";
      if (statusEl && state === "running") {
        statusEl.textContent = tr("сканирую…", "scanning…");
        statusEl.classList.add("is-scan");
        statusEl.classList.remove("is-done");
      }
    };

    // порядок отчёта источников (последний — молчащий Spamhaus)
    const order = ["geo", "asn", "owner", "host", "rep", "dnsbl"];
    const fillOf: Record<string, string | null> = {
      geo: "country",
      asn: "operator",
      owner: "network",
      host: "host",
      rep: "threat",
      dnsbl: null,
    };

    const runTrace = (): void => {
      clearTimers();
      resetCard();
      setTraceUI("running");

      const blocked = stage.dataset.mode === "blocked";
      let ms = START;
      let answered = 0;

      order.forEach((id) => {
        const silent = id === "dnsbl";
        const isHttp = srcEls.find((s) => s.dataset.tdSrc === id)?.dataset.http === "1";
        ms += silent ? SILENT : id === "rep" ? REP : STEP;
        later(() => {
          if (silent) {
            lightSrc(id, "silent");
            return;
          }
          if (blocked && isHttp) {
            lightSrc(id, "silent");
            return;
          }
          lightSrc(id, "on");
          const f = fillOf[id];
          if (f === "threat") setThreat(true);
          else if (f) setField(f, true);
          answered += 1;
        }, D(ms));
      });

      later(() => {
        setTraceUI("idle");
        if (statusEl) {
          statusEl.textContent = tr(`собрано · ${answered}/6`, `assembled · ${answered}/6`);
          statusEl.classList.add("is-done");
          statusEl.classList.remove("is-scan");
        }
        if (noteEl) {
          noteEl.textContent = blocked
            ? tr(
                "Прокси-guard: HTTP-источники не ушли в direct — досье собрано только из DNS и RDAP, реальный IP не утёк.",
                "Proxy guard: HTTP sources didn't fall back to direct — the dossier came from DNS and RDAP only, the real IP never leaked.",
              )
            : tr(
                "Готово: ответили 5 из 6. Spamhaus молчит, но через asyncio.gather(return_exceptions=True) это значение, а не падение — досье собрано.",
                "Done: 5 of 6 answered. Spamhaus is silent, but via asyncio.gather(return_exceptions=True) that's a value, not a crash — the dossier is assembled.",
              );
        }
      }, D(ms + FINAL));
    };

    // мгновенное финальное состояние (reduced / офскрин-старт)
    const fillInstant = (): void => {
      clearTimers();
      ipEl.textContent = current.ip;
      const blocked = stage.dataset.mode === "blocked";
      let answered = 0;
      order.forEach((id) => {
        const isHttp = srcEls.find((s) => s.dataset.tdSrc === id)?.dataset.http === "1";
        if (id === "dnsbl" || (blocked && isHttp)) {
          lightSrc(id, "silent");
          return;
        }
        lightSrc(id, "on");
        const f = fillOf[id];
        if (f === "threat") setThreat(true);
        else if (f) setField(f, true);
        answered += 1;
      });
      if (statusEl) {
        statusEl.textContent = tr(`собрано · ${answered}/6`, `assembled · ${answered}/6`);
        statusEl.classList.add("is-done");
        statusEl.classList.remove("is-scan");
      }
      setTraceUI("idle");
    };

    traceBtn?.addEventListener("click", runTrace);

    // ---- выбор адреса ----
    const selectChip = (i: number, trace: boolean): void => {
      const c = chips[i];
      if (!c) return;
      chips.forEach((x, k) => {
        const on = k === i;
        x.classList.toggle("is-on", on);
        x.setAttribute("aria-pressed", on ? "true" : "false");
      });
      current = read(c);
      resetCard();
      updateExport();
      if (trace && inview) {
        if (reduced) fillInstant();
        else runTrace();
      }
    };
    chips.forEach((c, i) => c.addEventListener("click", () => selectChip(i, true)));

    // ---- тап по источнику: подсказка ----
    const srcDefaultHint = hintT?.textContent ?? "";
    srcEls.forEach((s) => {
      s.addEventListener("click", () => {
        const text = s.dataset.hint ?? "";
        if (!hintT) return;
        const same = hintT.textContent === text;
        hintT.textContent = same ? srcDefaultHint : text;
      });
    });

    // ---- экспорт ----
    const fmtChips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-fmt]"));
    const exportPre = root.querySelector<HTMLElement>("[data-td-export-preview]");
    const fileNameEl = root.querySelector<HTMLElement>("[data-td-file]");
    const fileNoteEl = root.querySelector<HTMLElement>("[data-td-file-note]");
    const asnNum = (asn: string): string => asn.replace(/\D/g, "");
    const esc = (s: string): string => s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

    const buildPreview = (fmt: string, d: Dos): string => {
      const host = d.host && d.host !== "—" ? d.host : tr("нет PTR", "no PTR");
      const cityPart = d.city && d.city !== "—" ? `, ${d.city}` : "";
      if (fmt === "TXT") {
        const L = isEn
          ? { ip: "IP", country: "Country", asn: "ASN", net: "Network", host: "Hostname", threat: "Threat" }
          : { ip: "IP", country: "Страна", asn: "ASN", net: "Сеть", host: "Хост", threat: "Угроза" };
        const pad = (k: string): string => (k + ":").padEnd(9, " ");
        const rows = [
          `<span class="td-k">${pad(L.ip)}</span><span class="td-v">${d.ip}</span>`,
          `<span class="td-k">${pad(L.country)}</span><span class="td-v">${d.cc} — ${esc(d.country)}${esc(cityPart)}</span>`,
          `<span class="td-k">${pad(L.asn)}</span><span class="td-v">${d.asn} — ${esc(d.op)}</span>`,
          `<span class="td-k">${pad(L.net)}</span><span class="td-v">${d.net}</span>`,
          `<span class="td-k">${pad(L.host)}</span><span class="td-v">${esc(host)}</span>`,
          `<span class="td-k">${pad(L.threat)}</span><span class="td-accent">${d.abuse} / 100</span>`,
        ];
        return rows.join("\n");
      }
      if (fmt === "JSON") {
        return [
          "{",
          `  <span class="td-k">"ip"</span>: <span class="td-v">"${d.ip}"</span>,`,
          `  <span class="td-k">"country"</span>: <span class="td-v">"${d.cc}"</span>,`,
          `  <span class="td-k">"asn"</span>: <span class="td-v">${asnNum(d.asn)}</span>,`,
          `  <span class="td-k">"network"</span>: <span class="td-v">"${d.net}"</span>,`,
          `  <span class="td-k">"hostname"</span>: <span class="td-v">"${esc(host)}"</span>,`,
          `  <span class="td-k">"abuse"</span>: <span class="td-accent">${d.abuse}</span>`,
          "}",
        ].join("\n");
      }
      if (fmt === "CSV") {
        return [
          `<span class="td-k">ip,country,asn,network,hostname,abuse</span>`,
          `${d.ip},${d.cc},${asnNum(d.asn)},${d.net},${esc(host)},<span class="td-accent">${d.abuse}</span>`,
        ].join("\n");
      }
      // HTML
      return [
        `<span class="td-k">&lt;tr&gt;</span>`,
        `  &lt;td&gt;<span class="td-v">${d.ip}</span>&lt;/td&gt;`,
        `  &lt;td&gt;<span class="td-v">${d.cc}</span>&lt;/td&gt;`,
        `  &lt;td&gt;<span class="td-v">${d.asn}</span>&lt;/td&gt;`,
        `  &lt;td&gt;<span class="td-v">${d.net}</span>&lt;/td&gt;`,
        `  &lt;td class="abuse"&gt;<span class="td-accent">${d.abuse}</span>&lt;/td&gt;`,
        `<span class="td-k">&lt;/tr&gt;</span>`,
      ].join("\n");
    };

    let curFmt = "TXT";
    let curExt = "txt";
    const updateExport = (): void => {
      if (!exportPre) return;
      exportPre.innerHTML = buildPreview(curFmt, current);
      if (fileNameEl) fileNameEl.textContent = `results.${curExt}`;
      const note = fmtChips.find((c) => c.dataset.tdFmt === curFmt)?.dataset.note ?? "";
      if (fileNoteEl) fileNoteEl.textContent = note;
    };
    fmtChips.forEach((c) => {
      c.addEventListener("click", () => {
        curFmt = c.dataset.tdFmt ?? "TXT";
        curExt = c.dataset.ext ?? "txt";
        fmtChips.forEach((x) => {
          const on = x === c;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", on ? "true" : "false");
        });
        updateExport();
      });
    });
    updateExport();

    // ---- под капотом: раскрытие (по умолчанию открыто) ----
    root.classList.add("is-enhanced");
    const underToggle = root.querySelector<HTMLButtonElement>("[data-td-under-toggle]");
    let underOpen = true;
    const syncUnder = (): void => {
      root.classList.toggle("is-under-open", underOpen);
      underToggle?.setAttribute("aria-expanded", underOpen ? "true" : "false");
    };
    underToggle?.addEventListener("click", () => {
      underOpen = !underOpen;
      syncUnder();
    });
    syncUnder();

    // ---- прокси-guard ----
    const proxyPanel = root.querySelector<HTMLElement>("[data-td-proxy]");
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-mode]"));
    const breakBtn = root.querySelector<HTMLButtonElement>("[data-td-break]");
    const proxyNote = root.querySelector<HTMLElement>("[data-td-proxy-note]");

    const setMode = (mode: "direct" | "proxied" | "blocked"): void => {
      stage.dataset.mode = mode;
      if (proxyPanel) proxyPanel.dataset.mode = mode;
      modeBtns.forEach((b) => {
        const on = b.dataset.tdMode === mode || (mode === "blocked" && b.dataset.tdMode === "proxied");
        b.classList.toggle("is-on", on);
        b.setAttribute("aria-pressed", on ? "true" : "false");
      });
      if (breakBtn) breakBtn.disabled = mode === "direct";
      if (proxyNote) {
        proxyNote.textContent =
          mode === "direct"
            ? tr("Прямое соединение: реальный IP виден источникам.", "Direct connection: the real IP is visible to the sources.")
            : mode === "proxied"
              ? tr(
                  "Запросы идут через пул HTTP/SOCKS, креды замаскированы. Реальный IP скрыт.",
                  "Requests go through an HTTP/SOCKS pool, credentials masked. The real IP is hidden.",
                )
              : tr(
                  "Коннектор не собрался. HTTP-источники не уходят в прямое соединение — реальный IP не утёк. Идут только DNS и RDAP.",
                  "The connector failed to build. HTTP sources don't fall back to direct — the real IP never leaked. Only DNS and RDAP run.",
                );
      }
    };
    modeBtns.forEach((b) => {
      const mode = b.dataset.tdMode as "direct" | "proxied";
      b.addEventListener("click", () => setMode(mode));
    });
    breakBtn?.addEventListener("click", () => {
      if (stage.dataset.mode !== "direct") setMode("blocked");
    });
    setMode("direct");

    // ---- скан списком ----
    const bulkRun = root.querySelector<HTMLButtonElement>("[data-td-bulk-run]");
    const bulkRows = Array.from(root.querySelectorAll<HTMLElement>("[data-td-bulk-row]"));
    const bulkSem = root.querySelector<HTMLElement>("[data-td-sem]");
    const bulkNote = root.querySelector<HTMLElement>("[data-td-bulk-note]");
    const SEM = 3;

    const runBulk = (): void => {
      clearTimers();
      bulkRows.forEach((r) => r.classList.remove("is-in"));
      if (bulkNote) bulkNote.textContent = "";
      if (bulkSem) bulkSem.textContent = tr(`семафор: до ${SEM} одновременно`, `semaphore: up to ${SEM} at once`);
      bulkRows.forEach((r, i) => {
        later(() => r.classList.add("is-in"), D(420) * (i + 1));
      });
      later(
        () => {
          if (bulkNote)
            bulkNote.textContent = tr(
              "asyncio.gather опрашивает 6 источников на адрес, семафор держит нагрузку. Сбой источника не рушит скан — из логов сразу видно худших нарушителей. Отсортировано по уровню угрозы.",
              "asyncio.gather queries 6 sources per address, the semaphore caps the load. A failing source never breaks the scan — the worst offenders surface straight from the logs. Sorted by threat level.",
            );
        },
        D(420) * (bulkRows.length + 1),
      );
    };
    const bulkInstant = (): void => {
      bulkRows.forEach((r) => r.classList.add("is-in"));
    };
    bulkRun?.addEventListener("click", runBulk);

    // ---- IntersectionObserver-гейтинг ----
    const stopAll = (): void => {
      inview = false;
      clearTimers();
      root.classList.remove("is-inview");
    };

    const onEnter = (): void => {
      if (reduced) {
        fillInstant();
        bulkInstant();
      } else if (!tracing) {
        runTrace();
      }
    };

    if (typeof IntersectionObserver === "undefined") {
      inview = true;
      root.classList.add("is-inview");
      onEnter();
    } else {
      let entered = false;
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            inview = e.isIntersecting;
            root.classList.toggle("is-inview", inview);
            if (!inview) {
              clearTimers();
            } else if (!entered) {
              entered = true;
              onEnter();
            }
          }
        },
        { threshold: 0.2 },
      );
      io.observe(root);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
