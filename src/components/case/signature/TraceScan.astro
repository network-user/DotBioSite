---
/**
 * TraceScan.astro — сигнатурная визуализация .след (DotTraceIP).
 *
 * Метафора: ЖИВОЙ СКАН-ТЕРМИНАЛ, в котором крутится сам CLI. Один связный
 * «терминал» (тайтлбар, строка-приглашение с командой dottraceip --format html
 * target_ips.txt, потоковый вывод, сетка из 6 параллельных проб-нод и
 * сортируемая таблица результатов). Это НЕ нумерованный степпер: нет вкладок
 * шагов и «Шаг N из M» — посетитель жмёт Run, тыкает ноды, заголовки таблицы,
 * чипы экспорта и тоггл прокси, и вся консоль откликается как живая.
 *
 * Сигнатурный момент: по фокус-IP идёт fan-out к 6 источникам через
 * asyncio.gather(return_exceptions=True). Один источник (Spamhaus) видимо
 * падает по таймауту — но это становится значением, а не падением: его поля
 * остаются дефолтами empty_info(ip), нода гаснет, остальные пять дозаполняют
 * строку. Прокси-guard: «сломать сборку прокси» → HTTP-источники НЕ откатятся
 * в прямой коннект, реальный IP не утечёт (состояние blocked).
 *
 * Движение: только transform/opacity, конечные CSS-анимации. Постоянного rAF
 * нет — стрим вывода и fan-out ведутся одним setTimeout-конвейером, который
 * ОЧИЩАЕТСЯ за кадром / на скрытой вкладке / при pagehide; единственные
 * infinite-анимации (мигающая каретка, спиннер Run, ротация пула) scoped под
 * .ts.is-inview и замирают офскрин. Всё гейтится IntersectionObserver. При
 * prefers-reduced-motion — финальное статичное читаемое состояние, все
 * интеракции работают.
 *
 * Факты сверены по репозиторию DotTraceIP (точные имена/числа):
 *  - 6 источников на IP: ip-api (geo + ASN), Team Cymru по DNS → bgpview.io
 *    (HTTP-фолбэк, BGP-префикс + имя AS), RDAP (сеть владельца / CIDR),
 *    reverse DNS (PTR), AbuseIPDB (репутация), Spamhaus DNSBL.
 *  - движок: asyncio + aiohttp; per-IP сбор — asyncio.gather(return_exceptions
 *    =True), HTTP через aiohttp, блокирующие DNS/RDAP — в thread pool.
 *  - сбой источника → значение, поля остаются дефолтами empty_info(ip).
 *  - семафор ограничивает конкурентность (несколько IP одновременно).
 *  - 4 формата экспорта: TXT/JSON/CSV/HTML. 3 типа прокси: HTTP/SOCKS4/SOCKS5.
 *  - guard приватности: прокси запрошен, но коннектор не построился → прямого
 *    HTTP-коннекта нет, реальный IP не утекает.
 *  - 64 теста pytest-asyncio + mypy в CI.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Это живой терминал .след: запустите скан списка IP. Для каждого адреса движок разворачивается к шести источникам параллельно — тыкайте ноды, сортируйте таблицу, переключайте прокси и смотрите, как один источник падает, а результат всё равно собирается.",
  en: "This is the live .след terminal: run a scan over a list of IPs. For each address the engine fans out to six sources in parallel — poke the nodes, sort the table, flip the proxy, and watch one source fail while the result still assembles.",
};

// --- Команда в строке-приглашении ---
const cmd = "dottraceip --format html target_ips.txt";

// --- Целевые адреса (стримятся в очередь под семафором) ---
const targetIps = ["185.220.101.4", "45.155.205.233", "193.32.162.7", "104.244.76.13", "5.188.206.18"];
const SEM = 3; // семафор: до 3 IP одновременно
const FOCUS = targetIps[0]; // фокус-IP для fan-out

// --- Шесть источников на один IP (точные имена/назначения; Spamhaus падает) ---
const sources: { key: string; via: Bi; note: Bi; fail?: boolean }[] = [
  { key: "ip-api", via: { ru: "aiohttp", en: "aiohttp" }, note: { ru: "geo + ASN", en: "geo + ASN" } },
  {
    key: "Team Cymru → bgpview",
    via: { ru: "dns → http", en: "dns → http" },
    note: { ru: "BGP-префикс + имя AS", en: "BGP prefix + AS name" },
  },
  { key: "RDAP", via: { ru: "thread-pool", en: "thread-pool" }, note: { ru: "сеть владельца (CIDR)", en: "owner network (CIDR)" } },
  { key: "reverse DNS", via: { ru: "thread-pool", en: "thread-pool" }, note: { ru: "PTR-запись", en: "PTR record" } },
  { key: "AbuseIPDB", via: { ru: "aiohttp", en: "aiohttp" }, note: { ru: "репутация", en: "reputation" } },
  { key: "Spamhaus DNSBL", via: { ru: "dns", en: "dns" }, note: { ru: "DNSBL — таймаут", en: "DNSBL — timeout" }, fail: true },
];

// --- Строки результатов (сортируемая таблица) ---
type Row = { ip: string; cc: string; asn: number; net: string; abuse: number };
const rows: Row[] = [
  { ip: "185.220.101.4", cc: "DE", asn: 205100, net: "185.220.100.0/22", abuse: 100 },
  { ip: "45.155.205.233", cc: "RU", asn: 49505, net: "45.155.204.0/23", abuse: 92 },
  { ip: "193.32.162.7", cc: "NL", asn: 209605, net: "193.32.162.0/24", abuse: 64 },
  { ip: "104.244.76.13", cc: "US", asn: 53667, net: "104.244.76.0/24", abuse: 31 },
  { ip: "5.188.206.18", cc: "SC", asn: 35048, net: "5.188.206.0/23", abuse: 8 },
];

const cols: { key: keyof Row; label: Bi; num?: boolean }[] = [
  { key: "ip", label: { ru: "IP", en: "IP" } },
  { key: "cc", label: { ru: "страна", en: "country" } },
  { key: "asn", label: { ru: "ASN", en: "ASN" }, num: true },
  { key: "net", label: { ru: "сеть", en: "network" } },
  { key: "abuse", label: { ru: "abuse", en: "abuse" }, num: true },
];

// --- Форматы экспорта (4 штуки) с превью-телом ---
const exports: { fmt: string; note: Bi; preview: string }[] = [
  {
    fmt: "TXT",
    note: { ru: "построчно во время скана", en: "line by line during the scan" },
    preview:
      "185.220.101.4   DE  AS205100  185.220.100.0/22  abuse=100\n45.155.205.233  RU  AS49505   45.155.204.0/23   abuse=92",
  },
  {
    fmt: "JSON",
    note: { ru: "полный объект на адрес", en: "full object per address" },
    preview:
      '{\n  "ip": "185.220.101.4",\n  "country": "DE",\n  "asn": 205100,\n  "network": "185.220.100.0/22",\n  "abuse": 100\n}',
  },
  {
    fmt: "CSV",
    note: { ru: "столбцы для таблиц", en: "columns for spreadsheets" },
    preview: "ip,country,asn,network,abuse\n185.220.101.4,DE,205100,185.220.100.0/22,100",
  },
  {
    fmt: "HTML",
    note: { ru: "самодостаточный отчёт", en: "self-contained report" },
    preview: '<table id="report" data-sortable>\n  <thead>…</thead>\n  <tbody>…185.220.101.4…</tbody>\n</table>',
  },
];

// --- Типы прокси (3 штуки) для пула ротации ---
const proxyTypes = ["HTTP", "SOCKS4", "SOCKS5"];

const ui = {
  run: { ru: "Запустить скан", en: "Run scan" },
  exportLabel: { ru: "Экспорт", en: "Export" },
  breakProxy: { ru: "Сломать сборку прокси", en: "Break proxy build" },
  output: { ru: "поток вывода", en: "output stream" },
  rack: { ru: "Шесть источников", en: "Six sources" },
  results: { ru: "Результаты", en: "Results" },
  semaphore: { ru: "семафор", en: "semaphore" },
  focus: { ru: "fan-out · asyncio.gather", en: "fan-out · asyncio.gather" },
  proxyOff: { ru: "Прокси: выкл", en: "Proxy: off" },
};
---

<section class="ts" data-ts aria-label={t({ ru: "Живой скан-терминал DotTraceIP", en: "DotTraceIP live scan terminal" })}>
  <p class="ts__intro">{t(intro)}</p>

  <!-- ===================== ТЕРМИНАЛ ===================== -->
  <div class="ts__term" data-mode="direct" data-state="idle">
    <!-- Тайтлбар окна -->
    <div class="ts__bar">
      <span class="ts__dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <span class="ts__bar-title mono">.след — dottraceip</span>
      <span class="ts__sem mono">{t(ui.semaphore)} {SEM}/{targetIps.length}</span>
    </div>

    <!-- Строка-приглашение с командой + Run -->
    <div class="ts__prompt">
      <span class="ts__cwd mono" aria-hidden="true">~/intel</span>
      <span class="ts__sigil mono" aria-hidden="true">$</span>
      <code class="ts__cmd mono">{cmd}<span class="ts__caret" aria-hidden="true"></span></code>
      <button class="ts__run" type="button" data-ts-run aria-label={t(ui.run)}>
        <span class="ts__run-glyph" aria-hidden="true"></span>
        <span class="ts__run-t" data-ts-run-t>{t(ui.run)}</span>
      </button>
    </div>

    <!-- Контрольная панель: прокси-тоггл, break-proxy, чипы экспорта -->
    <div class="ts__controls">
      <button class="ts__toggle" type="button" data-ts-proxy aria-pressed="false">
        <span class="ts__toggle-track" aria-hidden="true"><span class="ts__toggle-knob"></span></span>
        <span class="ts__toggle-t" data-ts-proxy-t>{t(ui.proxyOff)}</span>
      </button>

      <span class="ts__pool mono" data-ts-pool aria-hidden="true">
        {proxyTypes.map((p, k) => <span class="ts__ptype" data-ptype={k} style={`--i:${k}`}>{p}</span>)}
        <span class="ts__cred" data-ts-cred>user:••••@—</span>
      </span>

      <button class="ts__break" type="button" data-ts-break disabled>{t(ui.breakProxy)}</button>

      <div class="ts__exports" role="group" aria-label={t(ui.exportLabel)}>
        <span class="ts__exports-cap caption" aria-hidden="true">{t(ui.exportLabel)}</span>
        {
          exports.map((e, k) => (
            <button
              class={`ts__chip${k === 0 ? " is-live" : ""}`}
              type="button"
              data-ts-export={k}
              data-preview={e.preview}
              data-note={t(e.note)}
              aria-pressed={k === 0 ? "true" : "false"}
            >
              <span class="ts__chip-fmt mono">{e.fmt}</span>
            </button>
          ))
        }
      </div>
    </div>

    <!-- Тело: поток вывода + сетка источников -->
    <div class="ts__body">
      <div class="ts__stream-wrap">
        <div class="ts__stream-head">
          <span class="caption" data-ts-stream-cap>{t(ui.output)}</span>
          <span class="ts__guard mono" data-ts-guard data-guard="direct">
            <i class="ts__guard-dot" aria-hidden="true"></i>
            <span data-ts-guard-t>{t({ ru: "прямое соединение", en: "direct connection" })}</span>
          </span>
        </div>
        <pre class="ts__stream mono" data-ts-stream aria-live="polite" tabindex="0"></pre>
      </div>

      <div class="ts__rack" aria-label={t(ui.rack)}>
        <div class="ts__focus">
          <span class="ts__focus-ip mono">{FOCUS}</span>
          <span class="ts__focus-cap caption">{t(ui.focus)}</span>
        </div>
        <ul class="ts__probes">
          {
            sources.map((src, k) => (
              <li>
                <button
                  class={`ts__probe${src.fail ? " is-fail" : ""}`}
                  type="button"
                  data-ts-probe={k}
                  data-fail={src.fail ? "1" : "0"}
                  style={`--i:${k}`}
                  aria-pressed="false"
                >
                  <span class="ts__probe-dot" aria-hidden="true" />
                  <span class="ts__probe-key mono">{src.key}</span>
                  <span class="ts__probe-note">{t(src.note)}</span>
                  <span class="ts__probe-via mono" aria-hidden="true">{t(src.via)}</span>
                  <span class="ts__probe-state mono" data-ts-probe-state aria-hidden="true" />
                </button>
              </li>
            ))
          }
        </ul>
        <p class="ts__rack-hint">
          {
            t({
              ru: "Тап по ноде — её ответ в поток. Spamhaus отвечает таймаутом → серый, но через return_exceptions=True это значение, а не падение.",
              en: "Tap a node to print its return. Spamhaus times out → greyed, but via return_exceptions=True that's a value, not a crash.",
            })
          }
        </p>
      </div>
    </div>

    <!-- Сортируемая таблица результатов -->
    <div class="ts__results">
      <span class="caption ts__results-cap">{t(ui.results)}</span>
      <div class="ts__table" role="table" aria-label={t(ui.results)}>
        <div class="ts__trow ts__trow--head" role="row">
          {
            cols.map((c, k) => (
              <button
                class={`ts__th${c.num ? " is-num" : ""}`}
                type="button"
                role="columnheader"
                data-ts-col={c.key}
                data-num={c.num ? "1" : "0"}
                aria-sort="none"
                style={`--c:${k}`}
              >
                <span class="ts__th-label">{t(c.label)}</span>
                <span class="ts__th-arrow mono" aria-hidden="true" />
              </button>
            ))
          }
        </div>
        <div class="ts__tbody" data-ts-tbody>
          {
            rows.map((r, k) => (
              <div class="ts__trow" role="row" data-ts-trow={k} style={`--i:${k}`}>
                <span class="ts__td mono" role="cell">{r.ip}</span>
                <span class="ts__td" role="cell">{r.cc}</span>
                <span class="ts__td mono is-num" role="cell">AS{r.asn}</span>
                <span class="ts__td mono" role="cell">{r.net}</span>
                <span class="ts__td mono is-num" role="cell" data-abuse={r.abuse}>{r.abuse}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ts {
    --ts-accent: var(--project-accent);
    --ts-line: color-mix(in srgb, var(--ts-accent) 36%, transparent);
    --ts-glow: color-mix(in srgb, var(--ts-accent) 18%, transparent);
    --ts-soft: color-mix(in srgb, var(--ts-accent) 12%, transparent);
    --ts-faint: color-mix(in srgb, var(--ts-accent) 8%, transparent);
    --ts-err: color-mix(in srgb, var(--state-error) 42%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .ts__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 68ch;
  }

  /* ====================== ОКНО ТЕРМИНАЛА ====================== */
  .ts__term {
    position: relative;
    display: flex;
    flex-direction: column;
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 120% at 0% 0%, var(--ts-glow), transparent 50%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }

  .ts__term::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: radial-gradient(140% 90% at 50% 0%, #000 24%, transparent 86%);
    -webkit-mask-image: radial-gradient(140% 90% at 50% 0%, #000 24%, transparent 86%);
    pointer-events: none;
  }

  .ts__term > * {
    position: relative;
    z-index: 1;
  }

  /* ---------- Тайтлбар ---------- */
  .ts__bar {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-4);
    border-bottom: var(--bw-thin) solid var(--border);
    background: color-mix(in srgb, var(--surface-2) 70%, transparent);
  }

  .ts__dots {
    display: inline-flex;
    gap: 6px;
    flex: none;
  }

  .ts__dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--surface-3);
    border: var(--bw-thin) solid var(--border);
  }

  .ts__dots i:first-child {
    background: var(--ts-faint);
    border-color: var(--ts-line);
  }

  .ts__bar-title {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  .ts__sem {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--ts-accent);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--ts-line);
    border-radius: var(--r-pill);
    white-space: nowrap;
  }

  /* ---------- Строка-приглашение ---------- */
  .ts__prompt {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-4);
    border-bottom: var(--bw-thin) solid var(--border);
  }

  .ts__cwd {
    font-size: var(--fs-13);
    color: var(--ts-accent);
    flex: none;
  }

  .ts__sigil {
    font-size: var(--fs-14);
    color: var(--text-muted);
    flex: none;
  }

  .ts__cmd {
    flex: 1;
    min-width: 0;
    font-size: var(--fs-13);
    color: var(--text);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .ts__caret {
    display: inline-block;
    width: 8px;
    height: 1.05em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--ts-accent);
    opacity: 0;
  }

  /* мигающая каретка — только когда видно и в покое; opacity-only */
  .ts.is-inview .ts__term[data-state="idle"] .ts__caret {
    animation: ts-blink 1100ms steps(1, end) infinite;
  }

  @keyframes ts-blink {
    0%,
    50% {
      opacity: 0.85;
    }
    51%,
    100% {
      opacity: 0;
    }
  }

  .ts__run {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    flex: none;
    border: var(--bw-thin) solid var(--ts-line);
    border-radius: var(--r-pill);
    background: var(--ts-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .ts__run:hover {
    border-color: var(--ts-accent);
  }

  .ts__run:active {
    transform: scale(0.96);
  }

  .ts__run:disabled {
    cursor: progress;
  }

  .ts__run-glyph {
    width: 0;
    height: 0;
    flex: none;
    border-style: solid;
    border-width: 5px 0 5px 9px;
    border-color: transparent transparent transparent currentColor;
  }

  .ts__term[data-state="running"] .ts__run-glyph {
    width: 11px;
    height: 11px;
    border: var(--bw-med) solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
  }

  .ts.is-inview .ts__term[data-state="running"] .ts__run-glyph {
    animation: ts-spin 700ms linear infinite;
  }

  @keyframes ts-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ---------- Контрольная панель ---------- */
  .ts__controls {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    border-bottom: var(--bw-thin) solid var(--border);
    background: color-mix(in srgb, var(--surface) 40%, transparent);
  }

  .ts__toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .ts__toggle:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }

  .ts__toggle[aria-pressed="true"] {
    border-color: var(--ts-line);
    color: var(--text);
  }

  .ts__toggle-track {
    position: relative;
    width: 34px;
    height: 18px;
    flex: none;
    border-radius: var(--r-pill);
    background: var(--surface-3);
    transition: background-color var(--dur-med) var(--ease-standard);
  }

  .ts__toggle[aria-pressed="true"] .ts__toggle-track {
    background: var(--ts-soft);
  }

  .ts__toggle-knob {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--text-muted);
    transform: translateX(0);
    transition:
      transform var(--dur-med) var(--ease-spring),
      background-color var(--dur-med) var(--ease-standard);
  }

  .ts__toggle[aria-pressed="true"] .ts__toggle-knob {
    transform: translateX(16px);
    background: var(--ts-accent);
  }

  .ts__pool {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    opacity: 0.4;
    transition: opacity var(--dur-med) var(--ease-standard);
  }

  .ts__term[data-mode="proxied"] .ts__pool,
  .ts__term[data-mode="blocked"] .ts__pool {
    opacity: 1;
  }

  .ts__ptype {
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    transition:
      color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }

  .ts__ptype.is-active {
    color: var(--ts-accent);
    border-color: var(--ts-line);
    transform: scale(1.08);
  }

  .ts__term[data-mode="blocked"] .ts__ptype {
    color: var(--text-faint);
    border-color: var(--border);
    transform: none;
  }

  .ts__cred {
    font-size: var(--fs-11);
    color: var(--text-faint);
    letter-spacing: var(--ls-wide);
    overflow-wrap: anywhere;
  }

  .ts__break {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard);
