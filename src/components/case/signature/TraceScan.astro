  .ts__probe {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    grid-template-areas:
      "dot key"
      "dot note"
      "via state";
    align-items: center;
    gap: 2px var(--sp-2);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    text-align: left;
    cursor: pointer;
    opacity: 0.55;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard);
  }

  .ts__probe:hover {
    border-color: var(--border-hover);
    opacity: 0.9;
  }

  .ts__probe.is-on {
    opacity: 1;
    border-color: var(--ts-line);
    background: var(--ts-soft);
  }

  /* сбойная нода: гаснет в серый, скан продолжается */
  .ts__probe.is-fail.is-on {
    border-color: var(--ts-err);
    background: transparent;
    opacity: 0.5;
  }

  .ts__probe-dot {
    grid-area: dot;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-faint);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }

  .ts__probe.is-on .ts__probe-dot {
    background: var(--ts-accent);
    transform: scale(1.15);
  }

  .ts__probe.is-fail.is-on .ts__probe-dot {
    background: transparent;
    border: 1.5px solid var(--text-faint);
    transform: none;
  }

  .ts__probe-key {
    grid-area: key;
    font-size: var(--fs-13);
    color: var(--text);
    overflow-wrap: anywhere;
  }

  .ts__probe.is-fail.is-on .ts__probe-key {
    color: var(--text-muted);
    text-decoration: line-through;
    text-decoration-color: var(--text-faint);
  }

  .ts__probe-note {
    grid-area: note;
    font-size: var(--fs-11);
    color: var(--text-muted);
  }

  .ts__probe-via {
    grid-area: via;
    font-size: var(--fs-10);
    color: var(--text-faint);
    letter-spacing: var(--ls-wide);
  }

  .ts__probe-state {
    grid-area: state;
    justify-self: end;
    font-size: var(--fs-10);
    color: var(--ts-accent);
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-standard);
  }

  .ts__probe.is-on .ts__probe-state {
    opacity: 1;
  }

  .ts__probe.is-fail.is-on .ts__probe-state {
    color: var(--state-warn);
  }

  .ts__rack-hint {
    font-size: var(--fs-12);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }

  /* ---------- Сортируемая таблица ---------- */
  .ts__results {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: 0 var(--sp-4) var(--sp-4);
  }

  .ts__results-cap {
    color: var(--text-muted);
  }

  .ts__table {
    display: flex;
    flex-direction: column;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .ts__trow {
    display: grid;
    grid-template-columns: 1.5fr 0.7fr 1fr 1.6fr 0.7fr;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
  }

  .ts__trow--head {
    background: var(--surface-2);
    border-bottom: var(--bw-thin) solid var(--border);
  }

  .ts__th {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    min-height: var(--tap-min);
    padding: var(--sp-1);
    margin: calc(-1 * var(--sp-1));
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-11);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease-standard);
  }

  .ts__th.is-num {
    justify-content: flex-end;
  }

  .ts__th:hover {
    color: var(--text);
  }

  .ts__th[aria-sort="ascending"],
  .ts__th[aria-sort="descending"] {
    color: var(--ts-accent);
  }

  .ts__th-arrow {
    font-size: var(--fs-10);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-standard);
  }

  .ts__th[aria-sort="ascending"] .ts__th-arrow,
  .ts__th[aria-sort="descending"] .ts__th-arrow {
    opacity: 1;
  }

  .ts__th[aria-sort="ascending"] .ts__th-arrow::after {
    content: "▲";
  }

  .ts__th[aria-sort="descending"] .ts__th-arrow::after {
    content: "▼";
  }

  .ts__tbody {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* строки переупорядочиваются ТОЛЬКО через translateY (transform), не reflow */
  .ts__trow:not(.ts__trow--head) {
    transition: transform var(--dur-slow) var(--ease-soft);
    will-change: transform;
  }

  .ts__trow:not(.ts__trow--head):nth-child(odd) {
    background: color-mix(in srgb, var(--surface) 50%, transparent);
  }

  .ts__td {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ts__td.is-num {
    text-align: right;
    color: var(--text);
  }

  .ts__td[data-abuse] {
    position: relative;
  }

  /* ====================== Появление (под .is-run) ====================== */
  .ts.is-run .ts__probe {
    animation: ts-rise var(--dur-slow) var(--ease-soft) both;
    animation-delay: calc(var(--i) * 80ms);
  }

  .ts.is-run .ts__trow:not(.ts__trow--head) {
    animation: ts-rise var(--dur-slow) var(--ease-soft) both;
    animation-delay: calc(var(--i) * 60ms);
  }

  @keyframes ts-rise {
    from {
      opacity: 0;
      transform: translate3d(0, 8px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ====================== Адаптив ====================== */
  @media (max-width: 760px) {
    .ts__body {
      grid-template-columns: minmax(0, 1fr);
    }

    .ts__exports {
      margin-left: 0;
    }

    .ts__stream {
      height: 184px;
    }
  }

  @media (max-width: 460px) {
    .ts__probes {
      grid-template-columns: minmax(0, 1fr);
    }

    .ts__trow {
      grid-template-columns: 1.6fr 0.9fr 0.7fr;
      gap: var(--sp-1) var(--sp-2);
    }

    /* на узком экране прячем «страна» и «сеть», оставляя IP / ASN / abuse */
    .ts__th[data-ts-col="cc"],
    .ts__th[data-ts-col="net"],
    .ts__td:nth-child(2),
    .ts__td:nth-child(4) {
      display: none;
    }

    .ts__pool {
      display: none;
    }
  }

  /* ====================== prefers-reduced-motion ====================== */
  @media (prefers-reduced-motion: reduce) {
    .ts__caret {
      opacity: 0.85;
      animation: none;
    }

    .ts.is-run .ts__probe,
    .ts.is-run .ts__trow:not(.ts__trow--head) {
      animation: none;
    }

    .ts__stream :global(.ts-l) {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .ts__trow:not(.ts__trow--head) {
      transition: none;
    }
  }
</style>

<script>
  // Оркестратор живого скан-терминала .след. Один связный «терминал»; нет
  // степпера. Нет постоянного rAF: стрим вывода и fan-out ведёт ОДИН
  // setTimeout-конвейер (очередь шагов), который полностью чистится за кадром /
  // на скрытой вкладке / при pagehide. Единственные infinite-CSS (мигающая
  // каретка, спиннер Run, ротация пула) scoped под .ts.is-inview и замирают
  // офскрин. Всё движение гейтится IntersectionObserver. При prefers-reduced-
  // motion — финальное статичное читаемое состояние, все интеракции работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-ts]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.dataset.locale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    const term = root.querySelector<HTMLElement>(".ts__term");
    const runBtn = root.querySelector<HTMLButtonElement>("[data-ts-run]");
    const runT = root.querySelector<HTMLElement>("[data-ts-run-t]");
    const stream = root.querySelector<HTMLElement>("[data-ts-stream]");
    const streamCap = root.querySelector<HTMLElement>("[data-ts-stream-cap]");
    const probes = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ts-probe]"));
    const proxyBtn = root.querySelector<HTMLButtonElement>("[data-ts-proxy]");
    const proxyT = root.querySelector<HTMLElement>("[data-ts-proxy-t]");
    const breakBtn = root.querySelector<HTMLButtonElement>("[data-ts-break]");
    const ptypes = Array.from(root.querySelectorAll<HTMLElement>("[data-ptype]"));
    const credEl = root.querySelector<HTMLElement>("[data-ts-cred]");
    const guard = root.querySelector<HTMLElement>("[data-ts-guard]");
    const guardT = root.querySelector<HTMLElement>("[data-ts-guard-t]");
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ts-export]"));
    const headers = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-ts-col]"));
    const tbody = root.querySelector<HTMLElement>("[data-ts-tbody]");
    const trows = Array.from(root.querySelectorAll<HTMLElement>("[data-ts-trow]"));

    if (!term || !stream) return;

    const FOCUS = "185.220.101.4";
    const SEM = 3;
    const queueIps = ["185.220.101.4", "45.155.205.233", "193.32.162.7", "104.244.76.13", "5.188.206.18"];

    // Строки fan-out для потока вывода (порядок = data-ts-probe; последняя падает).
    type SrcLine = { key: string; via: string; ok: string; field: string; fail: boolean };
    const srcLines: SrcLine[] = [
      { key: "ip-api", via: "aiohttp", ok: "200 OK", field: "country=DE asn=AS205100", fail: false },
      { key: "Team Cymru → bgpview", via: "dns → http", ok: tr("dns miss → http fallback", "dns miss → http fallback"), field: "prefix=185.220.100.0/22", fail: false },
      { key: "RDAP", via: "thread-pool", ok: "rdap.db.ripe.net", field: "cidr=185.220.100.0/22", fail: false },
      { key: "reverse DNS", via: "thread-pool", ok: "PTR ok", field: "ptr=tor-exit.relay", fail: false },
      { key: "AbuseIPDB", via: "aiohttp", ok: "200 OK", field: "abuse=100/100", fail: false },
      { key: "Spamhaus DNSBL", via: "dns", ok: "TimeoutError → value", field: "listed=∅ (empty_info)", fail: true },
    ];

    // ---- Состояние ----
    let inview = false;
    const timers: number[] = [];

    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };

    // setTimeout-конвейер: планирует шаг; не запускает ничего офскрин.
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };

    // ---- Поток вывода ----
    type Tone = "" | "acc" | "dim" | "err";
    const print = (text: string, tone: Tone = ""): void => {
      const line = document.createElement("span");
      line.className = "ts-l" + (tone ? " ts-" + tone : "");
      line.textContent = text;
      stream.appendChild(line);
      if (reduced) {
        line.classList.add("is-in");
      } else {
        requestAnimationFrame(() => line.classList.add("is-in"));
      }
      stream.scrollTop = stream.scrollHeight;
    };

    const clearStream = (): void => {
      stream.textContent = "";
    };

    const setRunUI = (state: "idle" | "running" | "done"): void => {
      term.dataset.state = state === "running" ? "running" : "idle";
      const label = state === "running" ? tr("Сканирую…", "Scanning…") : tr("Сканировать заново", "Scan again");
      if (runT) runT.textContent = label;
      if (runBtn) {
        runBtn.setAttribute("aria-label", label);
        runBtn.disabled = state === "running";
      }
    };

    // Подсветить пробу (вернулась / упала).
    const lightProbe = (i: number, on: boolean): void => {
      const p = probes[i];
      if (!p) return;
      p.classList.toggle("is-on", on);
      p.setAttribute("aria-pressed", on ? "true" : "false");
      const st = p.querySelector<HTMLElement>("[data-ts-probe-state]");
      const meta = srcLines[i];
      if (st && meta) st.textContent = on ? (meta.fail ? "value" : "ok") : "";
    };

    const resetProbes = (): void => {
      probes.forEach((_, i) => lightProbe(i, false));
    };

    // ---- Главный прогон скана (fan-out по фокус-IP) ----
    const runScan = (): void => {
      clearTimers();
      clearStream();
      resetProbes();
      root.classList.remove("is-run");
      void root.offsetWidth;
      root.classList.add("is-run");
      setRunUI("running");

      const mode = term.dataset.mode ?? "direct";
      const step = reduced ? 0 : 1;
      let tms = 0;

      print("$ dottraceip --format html target_ips.txt", "acc");

      // guard: коннектор не построился → прямого фолбэка нет, real IP не утекает.
      if (mode === "blocked") {
        later(() => print(tr("proxy build failed → connector=None", "proxy build failed → connector=None"), "err"), (tms += 220) * step);
        later(() => print(tr("guard: HTTP-источники НЕ откатываются в direct", "guard: HTTP sources do NOT fall back to direct"), "err"), (tms += 240) * step);
        later(() => {
          print(tr("would have leaked → real IP withheld · скан остановлен", "would have leaked → real IP withheld · scan halted"), "dim");
          setRunUI("done");
        }, (tms += 240) * step);
        return;
      }

      const route =
        mode === "proxied"
          ? tr("route: pool HTTP/SOCKS4/SOCKS5 (rotating) · creds masked", "route: pool HTTP/SOCKS4/SOCKS5 (rotating) · creds masked")
          : tr("route: direct", "route: direct");
      later(() => print(route, "dim"), (tms += 200) * step);
      later(() => print(`semaphore=${SEM} · queue: ${queueIps.join(" ")}`, "dim"), (tms += 200) * step);
      later(() => print(`▸ focus ${FOCUS} → asyncio.gather(*6, return_exceptions=True)`, "acc"), (tms += 240) * step);

      // Fan-out: каждая нода «возвращается» вразнобой; Spamhaus падает.
      srcLines.forEach((s, i) => {
        const delay = (tms += s.fail ? 520 : 180 + i * 30) * step;
        later(() => {
          lightProbe(i, true);
          if (s.fail) {
            print(`  x ${s.key.padEnd(22)} ${s.ok}`, "err");
            print(`    ${s.field}  # default, row still assembled`, "dim");
          } else {
            print(`  + ${s.key.padEnd(22)} ${s.ok}  ${s.field}`, "");
          }
        }, delay);
      });

      // Итоговая строка TXT (построчно во время скана) + завершение.
      later(() => {
        print(`${FOCUS}  DE  AS205100  185.220.100.0/22  abuse=100`, "acc");
        print(tr("5/6 источников ответили · строка собрана · TXT записан", "5/6 sources answered · row assembled · TXT written"), "dim");
        print(tr("→ +JSON +CSV +HTML report (no external deps)", "→ +JSON +CSV +HTML report (no external deps)"), "dim");
        setRunUI("done");
      }, (tms += 360) * step);
    };

    runBtn?.addEventListener("click", runScan);

    // ---- Тык по ноде: печатает её ответ в поток ----
    probes.forEach((p, i) => {
      p.addEventListener("click", () => {
        const on = !p.classList.contains("is-on");
        lightProbe(i, on);
        const s = srcLines[i];
        if (on && s) {
          if (s.fail) print(`  x ${s.key}: ${s.ok} → ${s.field}`, "err");
          else print(`  + ${s.key}: ${s.field} (${s.via})`, "");
        }
      });
    });

    // ---- Экспорт-чипы: превью формата в поток ----
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.setAttribute("aria-pressed", "false"));
        chip.setAttribute("aria-pressed", "true");
        const fmt = chip.querySelector(".ts__chip-fmt")?.textContent ?? "";
        const preview = chip.dataset.preview ?? "";
        const note = chip.dataset.note ?? "";
        if (streamCap) streamCap.textContent = tr(`превью · ${fmt}`, `preview · ${fmt}`);
        clearStream();
        print(`# ${fmt} — ${note}`, "acc");
        preview.split("\n").forEach((ln) => print(ln, "dim"));
      });
    });

    // ---- Прокси-тоггл + break-proxy guard + ротация пула ----
    let rotTimer = 0;
    const stopRotation = (): void => {
      if (rotTimer) {
        window.clearInterval(rotTimer);
        rotTimer = 0;
      }
    };

    const masks = ["http://user:••••@10.0.5.7:8080", "socks4://user:••••@10.0.9.1:1080", "socks5://user:••••@10.0.2.4:1080"];
    const rotateActive = (): void => {
      if (ptypes.length === 0) return;
      const k = Math.floor(Math.random() * ptypes.length);
      ptypes.forEach((el, i) => el.classList.toggle("is-active", i === k));
      if (credEl) credEl.textContent = masks[k] ?? "user:••••@—";
    };

    const setMode = (mode: "direct" | "proxied" | "blocked"): void => {
      term.dataset.mode = mode;
      stopRotation();
      if (proxyBtn) proxyBtn.setAttribute("aria-pressed", mode === "direct" ? "false" : "true");
      if (proxyT) proxyT.textContent = mode === "direct" ? tr("Прокси: выкл", "Proxy: off") : tr("Прокси: вкл", "Proxy: on");
      if (breakBtn) breakBtn.disabled = mode === "direct";

      if (mode === "direct") {
        ptypes.forEach((el) => el.classList.remove("is-active"));
        if (credEl) credEl.textContent = "user:••••@—";
        if (guard) guard.dataset.guard = "direct";
        if (guardT) guardT.textContent = tr("прямое соединение — real IP виден источнику", "direct connection — real IP visible to the source");
      } else if (mode === "proxied") {
        rotateActive();
        if (!reduced && inview) rotTimer = window.setInterval(rotateActive, 1400);
        if (guard) guard.dataset.guard = "proxied";
        if (guardT) guardT.textContent = tr("через пул · креды замаскированы · real IP скрыт", "via pool · credentials masked · real IP hidden");
      } else {
        // blocked: коннектор не построился → прямого коннекта НЕТ, IP не утекает
        ptypes.forEach((el) => el.classList.remove("is-active"));
        if (credEl) credEl.textContent = tr("connector=None (unparseable)", "connector=None (unparseable)");
        if (guard) guard.dataset.guard = "blocked";
        if (guardT) guardT.textContent = tr("заблокировано: HTTP не уходит в direct — would have leaked, real IP withheld", "blocked: HTTP won't fall back to direct — would have leaked, real IP withheld");
      }
    };

    proxyBtn?.addEventListener("click", () => {
      setMode(term.dataset.mode === "direct" ? "proxied" : "direct");
    });
    breakBtn?.addEventListener("click", () => {
      if (term.dataset.mode !== "direct") setMode("blocked");
    });

    // ---- Сортируемая таблица (transform-reorder, реальный aria-sort) ----
    type SortKey = "ip" | "cc" | "asn" | "net" | "abuse";
    const cellIndex: Record<SortKey, number> = { ip: 0, cc: 1, asn: 2, net: 3, abuse: 4 };
    const numeric: SortKey[] = ["asn", "abuse"];

    const cellText = (row: HTMLElement, key: SortKey): string => {
      const cells = row.querySelectorAll<HTMLElement>(".ts__td");
      return cells[cellIndex[key]]?.textContent?.trim() ?? "";
    };

    let sortKey: SortKey | null = null;
    let sortDir: 1 | -1 = 1;

    const applyOrder = (order: HTMLElement[]): void => {
      // Высоту строки меряем в момент сортировки (transform-only reorder).
      const h = trows[0]?.getBoundingClientRect().height ?? 0;
      order.forEach((row, pos) => {
        const from = trows.indexOf(row);
        row.style.transform = `translateY(${(pos - from) * h}px)`;
      });
    };

    const renderSort = (key: SortKey): void => {
      const isNum = numeric.includes(key);
      const order = [...trows].sort((a, b) => {
        let cmp: number;
        if (isNum) {
          const av = Number(cellText(a, key).replace(/\D/g, "")) || 0;
          const bv = Number(cellText(b, key).replace(/\D/g, "")) || 0;
          cmp = av - bv;
        } else {
          cmp = cellText(a, key).localeCompare(cellText(b, key));
        }
        return cmp * sortDir;
      });
      applyOrder(order);
      headers.forEach((h) => {
        const hk = h.dataset.tsCol as SortKey | undefined;
        h.setAttribute("aria-sort", hk === key ? (sortDir === 1 ? "ascending" : "descending") : "none");
      });
    };

    const sortBy = (key: SortKey): void => {
      if (sortKey === key) sortDir = sortDir === 1 ? -1 : 1;
      else {
        sortKey = key;
        sortDir = 1;
      }
      renderSort(key);
    };

    headers.forEach((h) => {
      const key = h.dataset.tsCol as SortKey | undefined;
      if (key) h.addEventListener("click", () => sortBy(key));
    });

    // Пересчёт активной сортировки при resize (высота строки меняется).
    if ("ResizeObserver" in window && tbody) {
      let first = true;
      new ResizeObserver(() => {
        if (first) {
          first = false;
          return;
        }
        if (sortKey) renderSort(sortKey);
      }).observe(tbody);
    }

    // ---- Старт ----
    setMode("direct");
    setRunUI("idle");

    // Reduced motion / нет IO → финальное статичное читаемое состояние.
    if (reduced || !("IntersectionObserver" in window)) {
      clearStream();
      print("$ dottraceip --format html target_ips.txt", "acc");
      print(`▸ focus ${FOCUS} → asyncio.gather(*6, return_exceptions=True)`, "acc");
      srcLines.forEach((s, i) => {
        lightProbe(i, true);
        if (s.fail) print(`  x ${s.key}: ${s.ok} → ${s.field} (default, row still assembled)`, "err");
        else print(`  + ${s.key}: ${s.field}`, "");
      });
      print(`${FOCUS}  DE  AS205100  185.220.100.0/22  abuse=100`, "acc");
      print(tr("5/6 источников ответили · строка собрана · TXT/JSON/CSV/HTML", "5/6 sources answered · row assembled · TXT/JSON/CSV/HTML"), "dim");
      root.classList.add("is-run");
      setRunUI("done");
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          inview = e.isIntersecting;
          root.classList.toggle("is-inview", inview);
          if (!inview) {
            clearTimers();
            stopRotation();
          } else if (term.dataset.mode === "proxied" && !rotTimer && !reduced) {
            rotateActive();
            rotTimer = window.setInterval(rotateActive, 1400);
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(root);

    const stopAll = (): void => {
      inview = false;
      clearTimers();
      stopRotation();
      root.classList.remove("is-inview");
    };

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
