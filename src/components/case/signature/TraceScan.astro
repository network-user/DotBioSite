    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .ts__stream:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .ts__stream :global(.ts-l) {
    display: block;
    opacity: 0;
    transform: translateY(4px);
  }

  .ts__stream :global(.ts-l.is-in) {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
