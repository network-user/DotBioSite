  /* ---------- Тело: поток + сетка проб ---------- */
  .ts__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--sp-4);
    padding: var(--sp-4);
  }

  .ts__stream-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  .ts__stream-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }

  .ts__stream-head .caption {
    color: var(--text-muted);
  }

  .ts__guard {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    transition:
      color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard);
  }

  .ts__guard-dot {
    width: 7px;
    height: 7px;
    flex: none;
    border-radius: 50%;
    background: var(--text-faint);
  }

  .ts__guard[data-guard="proxied"] {
    color: var(--ts-accent);
    border-color: var(--ts-line);
  }

  .ts__guard[data-guard="proxied"] .ts__guard-dot {
    background: var(--ts-accent);
