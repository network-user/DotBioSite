  .ts__focus {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--sp-1) var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--ts-line);
    border-radius: var(--r-sm);
    background: var(--surface);
