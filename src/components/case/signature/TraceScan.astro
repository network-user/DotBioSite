  }

  .ts__guard[data-guard="blocked"] .ts__guard-dot {
    background: transparent;
    border: 1.5px solid var(--state-error);
  }

  .ts.is-inview .ts__term[data-mode="blocked"] .ts__guard {
    animation: ts-shake var(--dur-slow) var(--ease-standard);
  }

  @keyframes ts-shake {
    0%,
    100% {
      transform: translateX(0);
