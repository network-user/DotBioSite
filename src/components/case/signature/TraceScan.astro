---
/**
 * TraceScan.astro — сигнатурная визуализация .след (DotTraceIP).
 *
 * Концепт: ДОСЬЕ НА АДРЕС. Голый IP из логов брутфорса превращается в живую
 * карточку-досье. Посетитель выбирает адрес, жмёт «Проследить» — и шесть
 * источников опрашиваются параллельно, сходясь в одну карточку: страна,
 * оператор/ASN, сеть, имя хоста и крупный индикатор угрозы с вердиктом.
 * Один источник (Spamhaus) отвечает таймаутом, но досье всё равно собирается —
 * это и есть asyncio.gather(return_exceptions=True) на простом языке.
 *
 * Главный экран — карточка досье (одно понятное действие). Ниже: «Сохранить
 * досье» (тот же результат в 4 форматах, как настоящий файл) и «Под капотом» —
 * два механизма, делающие .след рабочим инструментом: прокси-приватность и
 * скан целого списка.
 *
 * Движение: только transform/opacity, конечные CSS-переходы. Постоянного rAF
 * нет — анимация ведётся одним setTimeout-конвейером later(), который чистится
 * офскрин / на скрытой вкладке / при pagehide. Всё гейтится IntersectionObserver
 * (.td.is-inview). prefers-reduced-motion → финальный статичный кадр, интеракции
 * работают.
 *
 * Факты сверены по репозиторию DotTraceIP:
 *  - 6 источников на IP через asyncio.gather: ip-api (geo+ASN), Team Cymru DNS →
 *    bgpview HTTP (BGP-префикс/ASN), RDAP (CIDR владельца), reverse DNS (PTR),
 *    AbuseIPDB (репутация), Spamhaus DNSBL. Сбой одного → дефолты empty_info.
 *  - семафор ограничивает конкурентность по IP; as_completed + Rich Live.
 *  - прокси HTTP/SOCKS4/SOCKS5, ротация пула, маскировка кредов; guard: если
 *    коннектор не собрался — HTTP-источники не уходят в direct, реальный IP не
 *    утекает (идут только DNS/RDAP в thread-pool).
 *  - экспорт TXT (построчно в скане) + JSON/CSV/HTML (самодостаточный, сортируемый).
 *  - 64 теста pytest-asyncio + ruff + mypy в CI.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Шесть источников опрашиваются параллельно и собирают из голого адреса досье: страна, оператор, сеть, имя хоста и уровень угрозы. Если один источник молчит, досье всё равно собирается.",
  en: "Six sources are queried in parallel and turn a bare address into a dossier: country, operator, network, hostname, and a threat level. If one source goes silent, the dossier still assembles.",
};

// --- Адреса-«улики»: реальные по форме IP из логов SSH/RDP-брутфорса. ---
// Поля локализованы на build-time; band угрозы считается в скрипте по abuse.
type Dossier = {
  ip: string;
  cc: string;
  country: Bi;
  city: Bi;
  asn: string;
  operator: Bi;
  network: string;
  host: string;
  abuse: number;
};
const dossiers: Dossier[] = [
  {
    ip: "185.220.101.4",
    cc: "DE",
    country: { ru: "Германия", en: "Germany" },
    city: { ru: "Франкфурт", en: "Frankfurt" },
    asn: "AS205100",
    operator: { ru: "Tor-сеть · выходной узел", en: "Tor network · exit node" },
    network: "185.220.100.0/22",
    host: "tor-exit.relay",
    abuse: 100,
  },
  {
    ip: "45.155.205.233",
    cc: "RU",
    country: { ru: "Россия", en: "Russia" },
    city: { ru: "Москва", en: "Moscow" },
    asn: "AS49505",
    operator: { ru: "облачный хостинг", en: "cloud hosting" },
    network: "45.155.204.0/23",
    host: "—",
    abuse: 92,
  },
  {
    ip: "193.32.162.7",
    cc: "NL",
    country: { ru: "Нидерланды", en: "Netherlands" },
    city: { ru: "Амстердам", en: "Amsterdam" },
    asn: "AS209605",
    operator: { ru: "хостинг / VPS", en: "hosting / VPS" },
    network: "193.32.162.0/24",
    host: "scan-07.probe",
    abuse: 64,
  },
  {
    ip: "104.244.76.13",
    cc: "US",
    country: { ru: "США", en: "USA" },
    city: { ru: "Лас-Вегас", en: "Las Vegas" },
    asn: "AS53667",
    operator: { ru: "VPS-провайдер", en: "VPS provider" },
    network: "104.244.76.0/24",
    host: "tor.exit.us",
    abuse: 31,
  },
  {
    ip: "5.188.206.18",
    cc: "SC",
    country: { ru: "Сейшелы", en: "Seychelles" },
    city: { ru: "—", en: "—" },
    asn: "AS35048",
    operator: { ru: "офшорный хостинг", en: "offshore hosting" },
    network: "5.188.206.0/23",
    host: "—",
    abuse: 8,
  },
];

// --- Шесть источников-нод. side: колонка; fills: какое поле карточки заполняет
//     (null = «молчит», демонстрирует отказоустойчивость). http: идёт через прокси. ---
type Src = {
  id: string;
  side: "l" | "r";
  label: Bi;
  via: string;
  fills: string | null;
  http: boolean;
  silent?: boolean;
  hint: Bi;
};
const sources: Src[] = [
  {
    id: "geo",
    side: "l",
    label: { ru: "Геолокация", en: "Geolocation" },
    via: "ip-api",
    fills: "country",
    http: true,
    hint: {
      ru: "Страна, город и интернет-провайдер. HTTP-запрос к ip-api.",
      en: "Country, city, and ISP. An HTTP request to ip-api.",
    },
  },
  {
    id: "asn",
    side: "l",
    label: { ru: "Сеть и ASN", en: "Network & ASN" },
    via: "Team Cymru → bgpview",
    fills: "operator",
    http: true,
    hint: {
      ru: "Номер и имя автономной системы плюс BGP-префикс. Сначала по DNS (Team Cymru), если молчит — по HTTP (bgpview).",
      en: "AS number and name plus the BGP prefix. DNS first (Team Cymru), HTTP fallback (bgpview).",
    },
  },
  {
    id: "owner",
    side: "l",
    label: { ru: "Владелец сети", en: "Network owner" },
    via: "RDAP",
    fills: "network",
    http: false,
    hint: {
      ru: "Диапазон сети владельца (CIDR) из официальных регистраторов через RDAP.",
      en: "The owner's network range (CIDR) from official registries via RDAP.",
    },
  },
  {
    id: "host",
    side: "r",
    label: { ru: "Имя хоста", en: "Hostname" },
    via: "reverse DNS",
    fills: "host",
    http: false,
    hint: {
      ru: "Обратный DNS: PTR-запись, какое имя стоит за адресом.",
      en: "Reverse DNS: the PTR record — the name behind the address.",
    },
  },
  {
    id: "rep",
    side: "r",
    label: { ru: "Репутация", en: "Reputation" },
    via: "AbuseIPDB",
    fills: "threat",
    http: true,
    hint: {
      ru: "Оценка опасности и число жалоб из AbuseIPDB (нужен бесплатный ключ).",
      en: "An abuse score and report count from AbuseIPDB (a free key is needed).",
    },
  },
  {
    id: "dnsbl",
    side: "r",
    label: { ru: "Чёрные списки", en: "Blocklists" },
    via: "Spamhaus DNSBL",
    fills: null,
    http: false,
    silent: true,
    hint: {
      ru: "Spamhaus DNSBL: в спам- и ботнет-списках ли адрес. В демо отвечает таймаутом, и досье всё равно собирается.",
      en: "Spamhaus DNSBL: is the address in spam/botnet lists? It times out in the demo, and the dossier still assembles.",
    },
  },
];
const leftSrc = sources.filter((s) => s.side === "l");
const rightSrc = sources.filter((s) => s.side === "r");

// Поля карточки в порядке заполнения.
const fields: { id: string; label: Bi }[] = [
  { id: "country", label: { ru: "Страна", en: "Country" } },
  { id: "operator", label: { ru: "Оператор", en: "Operator" } },
  { id: "network", label: { ru: "Сеть", en: "Network" } },
  { id: "host", label: { ru: "Имя хоста", en: "Hostname" } },
];

// Экспорт: 4 формата.
const exports: { fmt: string; ext: string; note: Bi }[] = [
  {
    fmt: "TXT",
    ext: "txt",
    note: { ru: "пишется построчно прямо во время скана", en: "written line by line during the scan" },
  },
  {
    fmt: "JSON",
    ext: "json",
    note: { ru: "полный объект на каждый адрес — для кода и API", en: "a full object per address — for code and APIs" },
  },
  {
    fmt: "CSV",
    ext: "csv",
    note: { ru: "столбцы для Excel и Google Таблиц", en: "columns for Excel and Google Sheets" },
  },
  {
    fmt: "HTML",
    ext: "html",
    note: {
      ru: "самодостаточный отчёт: открыл в браузере — сортируется по столбцам",
      en: "a self-contained report: open it in a browser and sort by columns",
    },
  },
];

const ui = {
  pick: { ru: "Адрес из логов SSH/RDP-брутфорса:", en: "An address from SSH/RDP brute-force logs:" },
  pickHint: { ru: "выберите любой", en: "pick any" },
  trace: { ru: "Проследить", en: "Trace" },
  subject: { ru: "адрес", en: "subject" },
  idle: { ru: "не собрано", en: "not assembled" },
  threat: { ru: "Уровень угрозы", en: "Threat level" },
  srcCap: { ru: "Шесть источников — нажмите, чтобы узнать, что даёт каждый:", en: "Six sources — tap to see what each one returns:" },
  exportCap: { ru: "Сохранить досье", en: "Save the dossier" },
  exportSub: {
    ru: "Один и тот же результат в любом формате — для глаз, таблиц или браузера.",
    en: "The same result in any format — for the eye, spreadsheets, or a browser.",
  },
  under: { ru: "Под капотом", en: "Under the hood" },
  underTeaser: { ru: "приватность и масштаб", en: "privacy & scale" },
  underIntro: {
    ru: "Два механизма, которые делают .след рабочим инструментом, а не игрушкой.",
    en: "Two mechanisms that make .след a real tool, not a toy.",
  },
  // прокси
  proxyTitle: { ru: "Скрытно — через прокси", en: "Stealth — via proxy" },
  proxyDesc: {
    ru: "Как .след ходит к источникам и почему реальный IP не утекает, даже когда прокси сломан.",
    en: "How .след reaches the sources and why the real IP never leaks, even when the proxy breaks.",
  },
  direct: { ru: "Прямо", en: "Direct" },
  proxied: { ru: "Через прокси", en: "Via proxy" },
  pool: { ru: "пул: HTTP · SOCKS4 · SOCKS5 · креды скрыты", en: "pool: HTTP · SOCKS4 · SOCKS5 · creds masked" },
  breakProxy: { ru: "Сломать прокси", en: "Break proxy" },
  httpGroup: { ru: "HTTP-источники (через прокси)", en: "HTTP sources (via proxy)" },
  dnsGroup: { ru: "DNS и RDAP (всегда напрямую)", en: "DNS & RDAP (always direct)" },
  // скан списком
  bulkTitle: { ru: "Скан целым списком", en: "Scan a whole list" },
  bulkDesc: {
    ru: "Как из тысяч строк в логе за один проход всплывают самые опасные адреса.",
    en: "How a single pass over thousands of log lines surfaces the most dangerous addresses.",
  },
  bulkRun: { ru: "Прогнать список", en: "Run the list" },
  bulkColIp: { ru: "адрес", en: "address" },
  bulkColCc: { ru: "страна", en: "country" },
  bulkColThreat: { ru: "уровень угрозы", en: "threat level" },
};

// HTTP-источники (идут через прокси) и прямые — для прокси-демо.
const httpVias = ["ip-api", "AbuseIPDB", "bgpview"];
const dnsVias = ["Team Cymru", "RDAP", "reverse DNS", "Spamhaus"];
---

<section
  class="td"
  id="trace-dossier"
  data-td
  aria-label={t({ ru: "Досье на IP-адрес — DotTraceIP", en: "IP dossier — DotTraceIP" })}
>
  <p class="td__intro">{t(intro)}</p>

  <!-- ===================== ВЫБОР АДРЕСА ===================== -->
  <div class="td__pick">
    <span class="td__pick-cap">
      {t(ui.pick)} <span class="td__pick-hint">{t(ui.pickHint)}</span>
    </span>
    <div class="td__chips" role="group" aria-label={t(ui.pick)}>
      {
        dossiers.map((d, i) => (
          <button
            class={`td__chip${i === 0 ? " is-on" : ""}`}
            type="button"
            data-td-chip={i}
            data-ip={d.ip}
            data-cc={d.cc}
            data-country={t(d.country)}
            data-city={t(d.city)}
            data-asn={d.asn}
            data-op={t(d.operator)}
            data-net={d.network}
            data-host={d.host}
            data-abuse={d.abuse}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <span class="mono">{d.ip}</span>
          </button>
        ))
      }
    </div>
  </div>

  <!-- ===================== СЦЕНА: ИСТОЧНИКИ + ДОСЬЕ ===================== -->
  <div class="td__stage" data-state="idle">
    <!-- левая колонка источников -->
    <div class="td__col td__col--l">
      {
        leftSrc.map((s) => (
          <button
            class="td__src"
            type="button"
            data-td-src={s.id}
            data-fills={s.fills ?? ""}
            data-http={s.http ? "1" : "0"}
            data-silent={s.silent ? "1" : "0"}
            data-hint={t(s.hint)}
            aria-pressed="false"
          >
            <span class="td__src-dot" aria-hidden="true" />
            <span class="td__src-body">
              <span class="td__src-label">{t(s.label)}</span>
              <span class="td__src-via mono">{s.via}</span>
            </span>
            <span class="td__src-state mono" data-td-src-state aria-hidden="true" />
          </button>
        ))
      }
    </div>

    <!-- центральная карточка-досье -->
    <article class="td__card" data-td-card>
      <header class="td__card-head">
        <span class="td__card-sub">{t(ui.subject)}</span>
        <span class="td__card-ip mono" data-td-ip>{dossiers[0]!.ip}</span>
        <span class="td__card-status" data-td-status>{t(ui.idle)}</span>
      </header>

      <dl class="td__fields">
        {
          fields.map((f) => (
            <div class="td__field" data-td-field={f.id}>
              <dt class="td__field-k">{t(f.label)}</dt>
              <dd class="td__field-v" data-td-field-v>
                <span class="td__field-ph" aria-hidden="true">
                  —
                </span>
              </dd>
            </div>
          ))
        }
      </dl>

      <div class="td__threat" data-td-threat data-band="idle">
        <div class="td__threat-top">
          <span class="td__threat-cap">{t(ui.threat)}</span>
          <span class="td__threat-score mono" data-td-score>—</span>
          <span class="td__threat-verdict" data-td-verdict hidden></span>
        </div>
        <div class="td__gauge" aria-hidden="true">
          <span class="td__gauge-fill" data-td-gauge style="--score: 0"></span>
        </div>
      </div>

      <div class="td__card-foot">
        <button class="td__trace" type="button" data-td-trace>
          <span class="td__trace-glyph" aria-hidden="true"></span>
          <span data-td-trace-t>{t(ui.trace)}</span>
        </button>
        <p class="td__note" data-td-note aria-live="polite"></p>
      </div>
    </article>

    <!-- правая колонка источников -->
    <div class="td__col td__col--r">
      {
        rightSrc.map((s) => (
          <button
            class={`td__src${s.silent ? " td__src--silent" : ""}`}
            type="button"
            data-td-src={s.id}
            data-fills={s.fills ?? ""}
            data-http={s.http ? "1" : "0"}
            data-silent={s.silent ? "1" : "0"}
            data-hint={t(s.hint)}
            aria-pressed="false"
          >
            <span class="td__src-dot" aria-hidden="true" />
            <span class="td__src-body">
              <span class="td__src-label">{t(s.label)}</span>
              <span class="td__src-via mono">{s.via}</span>
            </span>
            <span class="td__src-state mono" data-td-src-state aria-hidden="true" />
          </button>
        ))
      }
    </div>
  </div>

  <!-- подсказка по тапнутому источнику -->
  <p class="td__hint" data-td-hint>
    <span class="td__hint-ic" aria-hidden="true">i</span>
    <span class="td__hint-t" data-td-hint-t>{t(ui.srcCap)}</span>
  </p>

  <!-- ===================== ЭКСПОРТ ДОСЬЕ ===================== -->
  <div class="td__export" data-td-export>
    <div class="td__export-head">
      <span class="td__export-cap">{t(ui.exportCap)}</span>
      <span class="td__export-sub">{t(ui.exportSub)}</span>
    </div>
    <div class="td__export-chips" role="group" aria-label={t(ui.exportCap)}>
      {
        exports.map((e, k) => (
          <button
            class={`td__fmt${k === 0 ? " is-on" : ""}`}
            type="button"
            data-td-fmt={e.fmt}
            data-ext={e.ext}
            data-note={t(e.note)}
            aria-pressed={k === 0 ? "true" : "false"}
          >
            <span class="mono">{e.fmt}</span>
          </button>
        ))
      }
    </div>
    <div class="td__file">
      <div class="td__file-bar">
        <span class="td__file-dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="td__file-name mono" data-td-file>results.txt</span>
        <span class="td__file-note" data-td-file-note></span>
      </div>
      <pre class="td__file-body mono" data-td-export-preview aria-live="polite"></pre>
    </div>
  </div>

  <!-- ===================== ПОД КАПОТОМ ===================== -->
  <div class="td__under">
    <button class="td__under-toggle" type="button" data-td-under-toggle aria-expanded="true" aria-controls="td-under">
      <span class="td__under-chevron" aria-hidden="true"></span>
      <span class="td__under-label">{t(ui.under)}</span>
      <span class="td__under-teaser">{t(ui.underTeaser)}</span>
    </button>

    <div class="td__under-box" id="td-under">
      <div class="td__under-inner">
        <p class="td__under-intro">{t(ui.underIntro)}</p>

        <div class="td__panels">
          <!-- ---------- (A) ПРОКСИ-GUARD ---------- -->
          <div class="td__panel td__panel--proxy" data-td-proxy data-mode="direct">
            <div class="td__panel-h">
              <h4 class="td__panel-title">{t(ui.proxyTitle)}</h4>
              <p class="td__panel-desc">{t(ui.proxyDesc)}</p>
            </div>

            <div class="td__seg" role="group" aria-label={t(ui.proxyTitle)}>
              <button class="td__seg-btn is-on" type="button" data-td-mode="direct" aria-pressed="true">
                {t(ui.direct)}
              </button>
              <button class="td__seg-btn" type="button" data-td-mode="proxied" aria-pressed="false">
                {t(ui.proxied)}
              </button>
              <button class="td__break" type="button" data-td-break disabled>
                <span class="td__break-ic" aria-hidden="true">⚡</span>{t(ui.breakProxy)}
              </button>
            </div>
            <span class="td__pool mono" data-td-pool>{t(ui.pool)}</span>

            <div class="td__routes">
              <div class="td__route" data-route="http">
                <span class="td__route-cap">{t(ui.httpGroup)}</span>
                <div class="td__route-pills">
                  {httpVias.map((v) => <span class="td__pill mono" data-td-http-pill>{v}</span>)}
                </div>
              </div>
              <div class="td__route" data-route="dns">
                <span class="td__route-cap">{t(ui.dnsGroup)}</span>
                <div class="td__route-pills">
                  {dnsVias.map((v) => <span class="td__pill td__pill--dns mono">{v}</span>)}
                </div>
              </div>
            </div>

            <div class="td__verdict-box" data-td-proxy-verdict>
              <span class="td__verdict-dot" aria-hidden="true"></span>
              <p class="td__verdict-text" data-td-proxy-note aria-live="polite"></p>
            </div>
          </div>

          <!-- ---------- (B) СКАН СПИСКОМ ---------- -->
          <div class="td__panel td__panel--bulk" data-td-bulk>
            <div class="td__panel-h">
              <h4 class="td__panel-title">{t(ui.bulkTitle)}</h4>
              <p class="td__panel-desc">{t(ui.bulkDesc)}</p>
            </div>

            <div class="td__bulk-controls">
              <button class="td__bulk-run" type="button" data-td-bulk-run>{t(ui.bulkRun)}</button>
              <span class="td__sem mono" data-td-sem aria-hidden="true"></span>
            </div>

            <div class="td__bulk-table">
              <div class="td__bulk-head" aria-hidden="true">
                <span>{t(ui.bulkColIp)}</span>
                <span>{t(ui.bulkColCc)}</span>
                <span class="td__bulk-head-threat">{t(ui.bulkColThreat)}</span>
              </div>
              <ul class="td__bulk-list" data-td-bulk-list>
                {
                  [...dossiers]
                    .sort((a, b) => b.abuse - a.abuse)
                    .map((d, i) => (
                      <li class="td__bulk-row is-in" data-td-bulk-row={i} style={`--i:${i}`}>
                        <span class="td__bulk-ip mono">{d.ip}</span>
                        <span class="td__bulk-cc mono">{d.cc}</span>
                        <span class="td__bulk-bar" aria-hidden="true">
                          <span
                            class="td__bulk-fill"
                            style={`--score:${d.abuse / 100}`}
                            data-band={d.abuse >= 80 ? "high" : d.abuse >= 40 ? "mid" : "low"}
                          />
                        </span>
                        <span class="td__bulk-num mono">{d.abuse}</span>
                      </li>
                    ))
                }
              </ul>
            </div>
            <p class="td__panel-note" data-td-bulk-note aria-live="polite"></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .td {
    --td-accent: var(--project-accent);
    --td-line: color-mix(in srgb, var(--td-accent) 42%, transparent);
    --td-soft: color-mix(in srgb, var(--td-accent) 14%, transparent);
    --td-faint: color-mix(in srgb, var(--td-accent) 8%, transparent);
    --td-glow: color-mix(in srgb, var(--td-accent) 20%, transparent);
    --td-err: var(--state-error);
    --td-warn: var(--state-warn);
    --td-ok: var(--state-ok);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .td__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 70ch;
  }

  /* ---------- выбор адреса ---------- */
  .td__pick {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .td__pick-cap {
    font-size: var(--fs-13);
    color: var(--text-secondary);
  }
  .td__pick-hint {
    color: var(--text-muted);
    font-size: var(--fs-12);
  }
  .td__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .td__chip {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__chip:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }
  .td__chip:active {
    transform: scale(0.97);
  }
  .td__chip:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__chip.is-on {
    color: var(--text);
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  .td__chip .mono {
    font-size: var(--fs-13);
  }

  /* ---------- сцена ---------- */
  .td__stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-3);
    align-items: start;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 120% at 50% 0%, var(--td-glow), transparent 62%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }

  /* На мобиле колонки «растворяются» — их ноды попадают в общую 2-колоночную
     сетку сцены, а карточка идёт первой (order). */
  .td__col {
    display: contents;
  }
  .td__card {
    order: -1;
    grid-column: 1 / -1;
  }

  /* ---------- источник-нода ---------- */
  .td__src {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-3);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    text-align: left;
    cursor: pointer;
    opacity: 0.62;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .td__src:hover {
    border-color: var(--border-hover);
    opacity: 1;
  }
  .td__src:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  /* нода «отчиталась» */
  .td__src.is-on {
    opacity: 1;
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  /* короткий импульс к карточке при отчёте */
  .td.is-inview .td__src.is-report {
    animation: td-report 720ms var(--ease-soft);
  }
  @keyframes td-report {
    40% {
      transform: translateY(-3px) scale(1.02);
    }
  }
  /* молчащая нода (Spamhaus) */
  .td__src.is-silent-on {
    opacity: 0.6;
    border-color: color-mix(in srgb, var(--td-err) 40%, transparent);
    background: transparent;
  }

  .td__src-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--text-faint);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring),
      box-shadow var(--dur-med) var(--ease-standard);
  }
  .td__src.is-on .td__src-dot {
    background: var(--td-accent);
    transform: scale(1.25);
    box-shadow: 0 0 0 4px var(--td-faint);
  }
  .td__src.is-silent-on .td__src-dot {
    background: transparent;
    border: 1.5px solid var(--td-err);
    transform: none;
  }
  .td__src-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .td__src-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-14);
    color: var(--text);
  }
  .td__src-via {
    font-size: var(--fs-11);
    color: var(--text-muted);
    letter-spacing: var(--ls-snug);
    overflow-wrap: anywhere;
  }
  .td__src-state {
    justify-self: end;
    font-size: var(--fs-11);
    color: var(--td-accent);
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .td__src.is-on .td__src-state,
  .td__src.is-silent-on .td__src-state {
    opacity: 1;
  }
  .td__src.is-silent-on .td__src-state {
    color: var(--td-warn);
  }
  /* прокси-режим blocked: HTTP-ноды гаснут */
  .td__stage[data-mode="blocked"] .td__src[data-http="1"] {
    opacity: 0.4;
    border-color: color-mix(in srgb, var(--td-err) 30%, transparent);
  }

  /* ---------- карточка-досье ---------- */
  .td__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding: var(--sp-5);
    border: var(--bw-med) solid var(--td-line);
    border-radius: var(--r-md);
    background:
      radial-gradient(140% 90% at 50% 0%, var(--td-faint), transparent 70%), var(--bg-deep);
    box-shadow: var(--shadow-3);
    overflow: hidden;
  }
  /* тонкий «скан»-блик во время трассировки */
  .td__card::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--td-accent), transparent);
    opacity: 0;
    transform: translateY(0);
  }
  .td.is-inview .td__stage[data-state="tracing"] .td__card::after {
    animation: td-scan 1.7s var(--ease-standard) infinite;
  }
  @keyframes td-scan {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    18% {
      opacity: 0.7;
    }
    100% {
      opacity: 0;
      transform: translateY(280px);
    }
  }

  .td__card-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--sp-1) var(--sp-3);
    padding-bottom: var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
  }
  .td__card-sub {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    font-size: var(--fs-10);
  }
  .td__card-ip {
    font-size: var(--fs-24);
    font-weight: var(--fw-semibold);
    color: var(--text);
    letter-spacing: var(--ls-tight);
  }
  .td__card-status {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 3px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    white-space: nowrap;
  }
  .td__card-status.is-scan {
    color: var(--td-accent);
    border-color: var(--td-line);
  }
  .td__card-status.is-done {
    color: var(--td-accent);
    border-color: var(--td-line);
    background: var(--td-faint);
  }

  .td__fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
    margin: 0;
  }
  .td__field {
    display: grid;
    grid-template-columns: minmax(80px, auto) minmax(0, 1fr);
    align-items: baseline;
    gap: var(--sp-3);
  }
  .td__field-k {
    font-size: var(--fs-11);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .td__field-v {
    margin: 0;
    min-width: 0;
    font-size: var(--fs-15);
    color: var(--text-faint);
    overflow-wrap: anywhere;
    transition: color var(--dur-med) var(--ease-standard);
  }
  .td__field.is-filled .td__field-v {
    color: var(--text);
  }
  .td__field.is-filled .td__field-ph {
    display: none;
  }
  /* код страны как мини-бейдж */
  .td__cc {
    display: inline-block;
    margin-right: var(--sp-2);
    padding: 1px var(--sp-2);
    border: var(--bw-thin) solid var(--td-line);
    border-radius: var(--r-xs);
    background: var(--td-faint);
    font-family: var(--font-stack-display);
    font-size: var(--fs-11);
    font-weight: var(--fw-semibold);
    color: var(--td-accent);
    letter-spacing: var(--ls-wide);
  }
  .td__asn {
    color: var(--text-secondary);
  }

  /* ---------- индикатор угрозы ---------- */
  .td__threat {
    --bandc: var(--text-faint);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
  }
  .td__threat[data-band="high"] {
    --bandc: var(--td-err);
    border-color: color-mix(in srgb, var(--td-err) 38%, transparent);
  }
  .td__threat[data-band="mid"] {
    --bandc: var(--td-warn);
    border-color: color-mix(in srgb, var(--td-warn) 34%, transparent);
  }
  .td__threat[data-band="low"] {
    --bandc: var(--td-warn);
  }
  .td__threat[data-band="clean"] {
    --bandc: var(--td-ok);
  }
  .td__threat-top {
    display: flex;
    align-items: center;
    gap: var(--sp-2) var(--sp-3);
  }
  .td__threat-cap {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .td__threat-score {
    margin-left: auto;
    font-size: var(--fs-20);
    font-weight: var(--fw-bold);
    color: var(--bandc);
    font-variant-numeric: tabular-nums;
  }
  .td__threat-verdict {
    font-size: var(--fs-12);
    font-weight: var(--fw-semibold);
    color: var(--bandc);
    padding: 3px var(--sp-3);
    border: var(--bw-thin) solid color-mix(in srgb, var(--bandc) 46%, transparent);
    border-radius: var(--r-pill);
    background: color-mix(in srgb, var(--bandc) 12%, transparent);
    white-space: nowrap;
  }
  .td__threat-verdict[hidden] {
    display: none;
  }
  .td__gauge {
    height: 10px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .td__gauge-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--bandc);
    transform: scaleX(var(--score, 0));
    transform-origin: left center;
    transition: transform 1.1s var(--ease-soft);
  }

  /* ---------- футер карточки ---------- */
  .td__card-foot {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .td__trace {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-5);
    border: var(--bw-thin) solid var(--td-line);
    border-radius: var(--r-pill);
    background: var(--td-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-15);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__trace:hover {
    border-color: var(--td-accent);
    background: color-mix(in srgb, var(--td-accent) 20%, transparent);
  }
  .td__trace:active {
    transform: scale(0.96);
  }
  .td__trace:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__trace:disabled {
    cursor: progress;
  }
  .td__trace-glyph {
    width: 0;
    height: 0;
    flex: none;
    border-style: solid;
    border-width: 5px 0 5px 9px;
    border-color: transparent transparent transparent currentColor;
  }
  .td__stage[data-state="tracing"] .td__trace-glyph {
    width: 11px;
    height: 11px;
    border: var(--bw-med) solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
  }
  .td.is-inview .td__stage[data-state="tracing"] .td__trace-glyph {
    animation: td-spin 720ms linear infinite;
  }
  @keyframes td-spin {
    to {
      transform: rotate(360deg);
    }
  }
  .td__note {
    flex: 1 1 220px;
    min-width: 0;
    font-size: var(--fs-13);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
  }

  /* ---------- подсказка по источнику ---------- */
  .td__hint {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-2);
    font-size: var(--fs-13);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
  }
  .td__hint-ic {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    border-radius: 50%;
    border: var(--bw-thin) solid var(--td-line);
    color: var(--td-accent);
    font-family: var(--font-stack-display);
    font-size: var(--fs-11);
    font-style: italic;
    font-weight: var(--fw-semibold);
  }

  /* ---------- экспорт ---------- */
  .td__export {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .td__export-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .td__export-cap {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-16);
    color: var(--text);
  }
  .td__export-sub {
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .td__export-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .td__fmt {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__fmt:hover {
    border-color: var(--border-hover);
  }
  .td__fmt:active {
    transform: scale(0.96);
  }
  .td__fmt:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__fmt.is-on {
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  .td__fmt .mono {
    font-size: var(--fs-13);
    color: var(--text);
    letter-spacing: var(--ls-wide);
  }
  /* файл-отчёт */
  .td__file {
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--bg-deep);
  }
  .td__file-bar {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
    background: color-mix(in srgb, var(--surface-2) 70%, transparent);
  }
  .td__file-dots {
    display: inline-flex;
    gap: 5px;
    flex: none;
  }
  .td__file-dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--surface-3);
    border: var(--bw-thin) solid var(--border);
  }
  .td__file-dots i:first-child {
    background: var(--td-faint);
    border-color: var(--td-line);
  }
  .td__file-name {
    font-size: var(--fs-12);
    color: var(--td-accent);
    flex: none;
  }
  .td__file-note {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    text-align: right;
    overflow-wrap: anywhere;
  }
  .td__file-body {
    margin: 0;
    padding: var(--sp-4);
    font-size: var(--fs-12);
    line-height: 1.7;
    color: var(--text-secondary);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    min-height: 7em;
  }
  .td__file-body :global(.td-k) {
    color: var(--text-muted);
  }
  .td__file-body :global(.td-v) {
    color: var(--text);
  }
  .td__file-body :global(.td-accent) {
    color: var(--td-accent);
  }

  /* ---------- под капотом ---------- */
  .td__under {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding-top: var(--sp-2);
    border-top: var(--bw-thin) solid var(--border);
  }
  .td__under-toggle {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-15);
    font-weight: var(--fw-semibold);
  }
  .td__under-toggle:hover .td__under-label {
    color: var(--td-accent);
  }
  .td__under-toggle:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
    border-radius: var(--r-xs);
  }
  .td__under-label {
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .td__under-teaser {
    font-family: var(--font-stack-body);
    font-weight: var(--fw-regular);
    font-size: var(--fs-12);
    color: var(--text-muted);
    padding-left: var(--sp-2);
    border-left: var(--bw-thin) solid var(--border);
  }
  .td__under-chevron {
    position: relative;
    flex: none;
    width: 11px;
    height: 11px;
    color: var(--td-accent);
  }
  .td__under-chevron::before,
  .td__under-chevron::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 11px;
    height: 1.5px;
    border-radius: 1px;
    background: currentColor;
    transform: translateY(-50%);
  }
  .td__under-chevron::after {
    transform: translateY(-50%) rotate(90deg);
  }
  .td__under-toggle[aria-expanded="true"] .td__under-chevron::after {
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .td__under-chevron::after {
      transition: opacity var(--dur-fast) var(--ease-standard);
    }
  }
