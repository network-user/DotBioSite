---
/**
 * TraceScan.astro — сигнатурная визуализация .след (DotTraceIP).
 *
 * Концепт: ДОСЬЕ НА АДРЕС. Голый IP из логов брутфорса превращается в живую
 * карточку-досье. Посетитель выбирает адрес, жмёт «Проследить» — и шесть
 * источников опрашиваются параллельно, сходясь в одну карточку: страна,
 * оператор/ASN, сеть, имя хоста и крупный индикатор угрозы с вердиктом.
 * Один источник (Spamhaus) отвечает таймаутом, но досье всё равно собирается —
 * это и есть asyncio.gather(return_exceptions=True) на простом языке.
 *
 * Главный экран намеренно чистый: одно понятное действие. Движок (скан списком)
 * и прокси-guard вынесены в опциональный блок «Под капотом», экспорт — в слим-
 * ряд под карточкой. Так обычный человек сразу понимает суть, а интересующийся
 * докапывается до механики.
 *
 * Движение: только transform/opacity, конечные CSS-переходы. Постоянного rAF
 * нет — анимация ведётся одним setTimeout-конвейером later(), который чистится
 * офскрин / на скрытой вкладке / при pagehide. Всё гейтится IntersectionObserver
 * (.td.is-inview). prefers-reduced-motion → финальный статичный кадр, интеракции
 * работают.
 *
 * Факты сверены по репозиторию DotTraceIP:
 *  - 6 источников на IP через asyncio.gather: ip-api (geo+ASN), Team Cymru DNS →
 *    bgpview HTTP (BGP-префикс/ASN), RDAP (CIDR владельца), reverse DNS (PTR),
 *    AbuseIPDB (репутация), Spamhaus DNSBL. Сбой одного → дефолты empty_info.
 *  - семафор ограничивает конкурентность по IP; as_completed + Rich Live.
 *  - прокси HTTP/SOCKS4/SOCKS5, ротация пула, маскировка кредов; guard: если
 *    коннектор не собрался — HTTP-источники не уходят в direct, реальный IP не
 *    утекает (идут только DNS/RDAP в thread-pool).
 *  - экспорт TXT (построчно в скане) + JSON/CSV/HTML (самодостаточный, сортируемый).
 *  - 64 теста pytest-asyncio + ruff + mypy в CI.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Выберите IP из логов брутфорса и нажмите «Проследить». Шесть источников опрашиваются параллельно и собирают из голого адреса досье: страна, оператор, сеть, имя хоста и уровень угрозы. Если один источник молчит, досье всё равно собирается.",
  en: "Pick an IP from the brute-force logs and hit “Trace”. Six sources are queried in parallel and turn a bare address into a dossier: country, operator, network, hostname, and a threat level. If one source goes silent, the dossier still assembles.",
};

// --- Адреса-«улики»: реальные по форме IP из логов SSH/RDP-брутфорса. ---
// Поля локализованы на build-time; band угрозы считается в скрипте по abuse.
type Dossier = {
  ip: string;
  cc: string;
  country: Bi;
  city: Bi;
  asn: string;
  operator: Bi;
  network: string;
  host: string;
  abuse: number;
};
const dossiers: Dossier[] = [
  {
    ip: "185.220.101.4",
    cc: "DE",
    country: { ru: "Германия", en: "Germany" },
    city: { ru: "Франкфурт", en: "Frankfurt" },
    asn: "AS205100",
    operator: { ru: "Tor-сеть · выходной узел", en: "Tor network · exit node" },
    network: "185.220.100.0/22",
    host: "tor-exit.relay",
    abuse: 100,
  },
  {
    ip: "45.155.205.233",
    cc: "RU",
    country: { ru: "Россия", en: "Russia" },
    city: { ru: "Москва", en: "Moscow" },
    asn: "AS49505",
    operator: { ru: "облачный хостинг", en: "cloud hosting" },
    network: "45.155.204.0/23",
    host: "—",
    abuse: 92,
  },
  {
    ip: "193.32.162.7",
    cc: "NL",
    country: { ru: "Нидерланды", en: "Netherlands" },
    city: { ru: "Амстердам", en: "Amsterdam" },
    asn: "AS209605",
    operator: { ru: "хостинг / VPS", en: "hosting / VPS" },
    network: "193.32.162.0/24",
    host: "scan-07.probe",
    abuse: 64,
  },
  {
    ip: "104.244.76.13",
    cc: "US",
    country: { ru: "США", en: "USA" },
    city: { ru: "Лас-Вегас", en: "Las Vegas" },
    asn: "AS53667",
    operator: { ru: "VPS-провайдер", en: "VPS provider" },
    network: "104.244.76.0/24",
    host: "tor.exit.us",
    abuse: 31,
  },
  {
    ip: "5.188.206.18",
    cc: "SC",
    country: { ru: "Сейшелы", en: "Seychelles" },
    city: { ru: "—", en: "—" },
    asn: "AS35048",
    operator: { ru: "офшорный хостинг", en: "offshore hosting" },
    network: "5.188.206.0/23",
    host: "—",
    abuse: 8,
  },
];

// --- Шесть источников-нод. side: колонка; fills: какое поле карточки заполняет
//     (null = «молчит», демонстрирует отказоустойчивость). http: идёт через прокси. ---
type Src = {
  id: string;
  side: "l" | "r";
  label: Bi;
  via: string;
  fills: string | null;
  http: boolean;
  silent?: boolean;
  hint: Bi;
};
const sources: Src[] = [
  {
    id: "geo",
    side: "l",
    label: { ru: "Геолокация", en: "Geolocation" },
    via: "ip-api",
    fills: "country",
    http: true,
    hint: {
      ru: "Страна, город и интернет-провайдер. HTTP-запрос к ip-api.",
      en: "Country, city, and ISP. An HTTP request to ip-api.",
    },
  },
  {
    id: "asn",
    side: "l",
    label: { ru: "Сеть и ASN", en: "Network & ASN" },
    via: "Team Cymru → bgpview",
    fills: "operator",
    http: true,
    hint: {
      ru: "Номер и имя автономной системы плюс BGP-префикс. Сначала по DNS (Team Cymru), если молчит — по HTTP (bgpview).",
      en: "AS number and name plus the BGP prefix. DNS first (Team Cymru), HTTP fallback (bgpview).",
    },
  },
  {
    id: "owner",
    side: "l",
    label: { ru: "Владелец сети", en: "Network owner" },
    via: "RDAP",
    fills: "network",
    http: false,
    hint: {
      ru: "Диапазон сети владельца (CIDR) из официальных регистраторов через RDAP.",
      en: "The owner's network range (CIDR) from official registries via RDAP.",
    },
  },
  {
    id: "host",
    side: "r",
    label: { ru: "Имя хоста", en: "Hostname" },
    via: "reverse DNS",
    fills: "host",
    http: false,
    hint: {
      ru: "Обратный DNS: PTR-запись, какое имя стоит за адресом.",
      en: "Reverse DNS: the PTR record — the name behind the address.",
    },
  },
  {
    id: "rep",
    side: "r",
    label: { ru: "Репутация", en: "Reputation" },
    via: "AbuseIPDB",
    fills: "threat",
    http: true,
    hint: {
      ru: "Оценка опасности и число жалоб из AbuseIPDB (нужен бесплатный ключ).",
      en: "An abuse score and report count from AbuseIPDB (a free key is needed).",
    },
  },
  {
    id: "dnsbl",
    side: "r",
    label: { ru: "Чёрные списки", en: "Blocklists" },
    via: "Spamhaus DNSBL",
    fills: null,
    http: false,
    silent: true,
    hint: {
      ru: "Spamhaus DNSBL: в спам- и ботнет-списках ли адрес. В демо отвечает таймаутом, и досье всё равно собирается.",
      en: "Spamhaus DNSBL: is the address in spam/botnet lists? It times out in the demo, and the dossier still assembles.",
    },
  },
];
const leftSrc = sources.filter((s) => s.side === "l");
const rightSrc = sources.filter((s) => s.side === "r");

// Поля карточки в порядке заполнения.
const fields: { id: string; label: Bi }[] = [
  { id: "country", label: { ru: "Страна", en: "Country" } },
  { id: "operator", label: { ru: "Оператор", en: "Operator" } },
  { id: "network", label: { ru: "Сеть", en: "Network" } },
  { id: "host", label: { ru: "Имя хоста", en: "Hostname" } },
];

// Экспорт: 4 формата.
const exports: { fmt: string; note: Bi }[] = [
  { fmt: "TXT", note: { ru: "построчно во время скана", en: "line by line during the scan" } },
  { fmt: "JSON", note: { ru: "полный объект на адрес", en: "full object per address" } },
  { fmt: "CSV", note: { ru: "столбцы для таблиц", en: "columns for spreadsheets" } },
  {
    fmt: "HTML",
    note: { ru: "самодостаточный отчёт, сортируется по столбцам", en: "self-contained report, sortable" },
  },
];

const ui = {
  pick: { ru: "Адрес из логов SSH/RDP-брутфорса:", en: "An address from SSH/RDP brute-force logs:" },
  trace: { ru: "Проследить", en: "Trace" },
  subject: { ru: "субъект", en: "subject" },
  idle: { ru: "не собрано", en: "not assembled" },
  threat: { ru: "Уровень угрозы", en: "Threat level" },
  exportCap: { ru: "Сохранить досье", en: "Save the dossier" },
  under: { ru: "Под капотом", en: "Under the hood" },
  // прокси
  proxyTitle: { ru: "Скрытно: через прокси", en: "Stealth: via proxy" },
  direct: { ru: "Прямо", en: "Direct" },
  proxied: { ru: "Через прокси", en: "Via proxy" },
  pool: { ru: "пул: HTTP · SOCKS4 · SOCKS5 · креды скрыты", en: "pool: HTTP · SOCKS4 · SOCKS5 · creds masked" },
  breakProxy: { ru: "Сломать прокси", en: "Break proxy" },
  httpGroup: { ru: "HTTP-источники", en: "HTTP sources" },
  dnsGroup: { ru: "DNS и RDAP", en: "DNS & RDAP" },
  // скан списком
  bulkTitle: { ru: "Скан списком", en: "List scan" },
  bulkRun: { ru: "Прогнать список", en: "Run the list" },
};

// HTTP-источники (идут через прокси) и прямые — для прокси-демо.
const httpVias = ["ip-api", "AbuseIPDB", "bgpview"];
const dnsVias = ["Team Cymru", "RDAP", "reverse DNS", "Spamhaus"];
---

<section class="td" data-td aria-label={t({ ru: "Досье на IP-адрес — DotTraceIP", en: "IP dossier — DotTraceIP" })}>
  <p class="td__intro">{t(intro)}</p>

  <!-- ===================== ВЫБОР АДРЕСА ===================== -->
  <div class="td__pick">
    <span class="td__pick-cap caption">{t(ui.pick)}</span>
    <div class="td__chips" role="group" aria-label={t(ui.pick)}>
      {
        dossiers.map((d, i) => (
          <button
            class={`td__chip${i === 0 ? " is-on" : ""}`}
            type="button"
            data-td-chip={i}
            data-ip={d.ip}
            data-cc={d.cc}
            data-country={t(d.country)}
            data-city={t(d.city)}
            data-asn={d.asn}
            data-op={t(d.operator)}
            data-net={d.network}
            data-host={d.host}
            data-abuse={d.abuse}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <span class="mono">{d.ip}</span>
          </button>
        ))
      }
    </div>
  </div>

  <!-- ===================== СЦЕНА: ИСТОЧНИКИ + ДОСЬЕ ===================== -->
  <div class="td__stage" data-state="idle">
    <!-- левая колонка источников -->
    <div class="td__col td__col--l">
      {
        leftSrc.map((s) => (
          <button
            class="td__src"
            type="button"
            data-td-src={s.id}
            data-fills={s.fills ?? ""}
            data-http={s.http ? "1" : "0"}
            data-silent={s.silent ? "1" : "0"}
            data-hint={t(s.hint)}
            aria-pressed="false"
          >
            <span class="td__src-dot" aria-hidden="true" />
            <span class="td__src-body">
              <span class="td__src-label">{t(s.label)}</span>
              <span class="td__src-via mono">{s.via}</span>
            </span>
            <span class="td__src-state mono" data-td-src-state aria-hidden="true" />
          </button>
        ))
      }
    </div>

    <!-- центральная карточка-досье -->
    <article class="td__card" data-td-card>
      <header class="td__card-head">
        <span class="td__card-sub caption">{t(ui.subject)}</span>
        <span class="td__card-ip mono" data-td-ip>{dossiers[0]!.ip}</span>
        <span class="td__card-status" data-td-status>{t(ui.idle)}</span>
      </header>

      <dl class="td__fields">
        {
          fields.map((f) => (
            <div class="td__field" data-td-field={f.id}>
              <dt class="td__field-k">{t(f.label)}</dt>
              <dd class="td__field-v" data-td-field-v>
                <span class="td__field-ph" aria-hidden="true">
                  —
                </span>
              </dd>
            </div>
          ))
        }
      </dl>

      <div class="td__threat" data-td-threat data-band="idle">
        <div class="td__threat-top">
          <span class="td__threat-cap caption">{t(ui.threat)}</span>
          <span class="td__threat-score mono" data-td-score>—</span>
          <span class="td__threat-verdict" data-td-verdict hidden></span>
        </div>
        <div class="td__gauge" aria-hidden="true">
          <span class="td__gauge-fill" data-td-gauge style="--score: 0"></span>
        </div>
      </div>

      <div class="td__card-foot">
        <button class="td__trace" type="button" data-td-trace>
          <span class="td__trace-glyph" aria-hidden="true"></span>
          <span data-td-trace-t>{t(ui.trace)}</span>
        </button>
        <p class="td__note" data-td-note aria-live="polite"></p>
      </div>
    </article>

    <!-- правая колонка источников -->
    <div class="td__col td__col--r">
      {
        rightSrc.map((s) => (
          <button
            class={`td__src${s.silent ? " td__src--silent" : ""}`}
            type="button"
            data-td-src={s.id}
            data-fills={s.fills ?? ""}
            data-http={s.http ? "1" : "0"}
            data-silent={s.silent ? "1" : "0"}
            data-hint={t(s.hint)}
            aria-pressed="false"
          >
            <span class="td__src-dot" aria-hidden="true" />
            <span class="td__src-body">
              <span class="td__src-label">{t(s.label)}</span>
              <span class="td__src-via mono">{s.via}</span>
            </span>
            <span class="td__src-state mono" data-td-src-state aria-hidden="true" />
          </button>
        ))
      }
    </div>
  </div>

  <!-- подсказка по тапнутому источнику -->
  <p class="td__hint" data-td-hint aria-live="polite"></p>

  <!-- ===================== ЭКСПОРТ ДОСЬЕ ===================== -->
  <div class="td__export" data-td-export>
    <span class="td__export-cap caption">{t(ui.exportCap)}</span>
    <div class="td__export-chips" role="group" aria-label={t(ui.exportCap)}>
      {
        exports.map((e, k) => (
          <button
            class={`td__fmt${k === 0 ? " is-on" : ""}`}
            type="button"
            data-td-fmt={e.fmt}
            data-note={t(e.note)}
            aria-pressed={k === 0 ? "true" : "false"}
          >
            <span class="mono">{e.fmt}</span>
          </button>
        ))
      }
    </div>
    <pre class="td__export-preview mono" data-td-export-preview aria-live="polite"></pre>
  </div>

  <!-- ===================== ПОД КАПОТОМ ===================== -->
  <div class="td__under">
    <button class="td__under-toggle" type="button" data-td-under-toggle aria-expanded="true" aria-controls="td-under">
      <span class="td__under-chevron" aria-hidden="true"></span>
      <span>{t(ui.under)}</span>
    </button>

    <div class="td__under-box" id="td-under">
      <div class="td__under-inner">
        <!-- ---------- (A) ПРОКСИ-GUARD ---------- -->
        <div class="td__panel" data-td-proxy data-mode="direct">
          <h4 class="td__panel-title">{t(ui.proxyTitle)}</h4>
          <div class="td__seg" role="group" aria-label={t(ui.proxyTitle)}>
            <button class="td__seg-btn is-on" type="button" data-td-mode="direct" aria-pressed="true">
              {t(ui.direct)}
            </button>
            <button class="td__seg-btn" type="button" data-td-mode="proxied" aria-pressed="false">
              {t(ui.proxied)}
            </button>
            <button class="td__break" type="button" data-td-break disabled>{t(ui.breakProxy)}</button>
          </div>
          <span class="td__pool mono" data-td-pool aria-hidden="true">{t(ui.pool)}</span>

          <div class="td__routes">
            <div class="td__route" data-route="http">
              <span class="td__route-cap caption">{t(ui.httpGroup)}</span>
              <div class="td__route-pills">
                {httpVias.map((v) => <span class="td__pill mono" data-td-http-pill>{v}</span>)}
              </div>
            </div>
            <div class="td__route" data-route="dns">
              <span class="td__route-cap caption">{t(ui.dnsGroup)}</span>
              <div class="td__route-pills">
                {dnsVias.map((v) => <span class="td__pill td__pill--dns mono">{v}</span>)}
              </div>
            </div>
          </div>

          <p class="td__panel-note" data-td-proxy-note aria-live="polite"></p>
        </div>

        <!-- ---------- (B) СКАН СПИСКОМ ---------- -->
        <div class="td__panel" data-td-bulk>
          <h4 class="td__panel-title">{t(ui.bulkTitle)}</h4>
          <div class="td__bulk-controls">
            <button class="td__bulk-run" type="button" data-td-bulk-run>{t(ui.bulkRun)}</button>
            <span class="td__sem mono" data-td-sem aria-hidden="true"></span>
          </div>
          <ul class="td__bulk-list" data-td-bulk-list>
            {
              [...dossiers]
                .sort((a, b) => b.abuse - a.abuse)
                .map((d, i) => (
                  <li class="td__bulk-row" data-td-bulk-row={i} style={`--i:${i}`}>
                    <span class="td__bulk-ip mono">{d.ip}</span>
                    <span class="td__bulk-cc mono">{d.cc}</span>
                    <span class="td__bulk-bar" aria-hidden="true">
                      <span class="td__bulk-fill" style={`--score:${d.abuse / 100}`} data-abuse={d.abuse} />
                    </span>
                    <span class="td__bulk-num mono">{d.abuse}</span>
                  </li>
                ))
            }
          </ul>
          <p class="td__panel-note" data-td-bulk-note aria-live="polite"></p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .td {
    --td-accent: var(--project-accent);
    --td-line: color-mix(in srgb, var(--td-accent) 38%, transparent);
    --td-soft: color-mix(in srgb, var(--td-accent) 13%, transparent);
    --td-faint: color-mix(in srgb, var(--td-accent) 8%, transparent);
    --td-glow: color-mix(in srgb, var(--td-accent) 18%, transparent);
    --td-err: var(--state-error);
    --td-warn: var(--state-warn);
    --td-ok: var(--state-ok);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .td__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 68ch;
  }

  /* ---------- выбор адреса ---------- */
  .td__pick {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .td__pick-cap {
    color: var(--text-muted);
  }
  .td__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .td__chip {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__chip:hover {
    border-color: var(--border-hover);
  }
  .td__chip:active {
    transform: scale(0.97);
  }
  .td__chip:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__chip.is-on {
    color: var(--text);
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  .td__chip .mono {
    font-size: var(--fs-13);
  }

  /* ---------- сцена ---------- */
  .td__stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-3);
    align-items: start;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 120% at 50% 0%, var(--td-glow), transparent 60%),
      var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
  }

  /* На мобиле колонки «растворяются» — их ноды попадают в общую 2-колоночную
     сетку сцены, а карточка идёт первой (order). */
  .td__col {
    display: contents;
  }
  .td__card {
    order: -1;
    grid-column: 1 / -1;
  }

  /* ---------- источник-нода ---------- */
  .td__src {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-2);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    text-align: left;
    cursor: pointer;
    opacity: 0.55;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .td__src:hover {
    border-color: var(--border-hover);
    opacity: 0.95;
  }
  .td__src:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  /* нода «отчиталась» */
  .td__src.is-on {
    opacity: 1;
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  /* короткий импульс к карточке при отчёте */
  .td.is-inview .td__src.is-report {
    animation: td-report var(--dur-slow) var(--ease-soft);
  }
  @keyframes td-report {
    40% {
      transform: translateY(-2px) scale(1.015);
    }
  }
  /* молчащая нода (Spamhaus) */
  .td__src.is-silent-on {
    opacity: 0.5;
    border-color: color-mix(in srgb, var(--td-err) 36%, transparent);
    background: transparent;
  }

  .td__src-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--text-faint);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .td__src.is-on .td__src-dot {
    background: var(--td-accent);
    transform: scale(1.2);
  }
  .td__src.is-silent-on .td__src-dot {
    background: transparent;
    border: 1.5px solid var(--td-err);
    transform: none;
  }
  .td__src-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .td__src-label {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-13);
    color: var(--text);
  }
  .td__src-via {
    font-size: var(--fs-10);
    color: var(--text-faint);
    letter-spacing: var(--ls-wide);
    overflow-wrap: anywhere;
  }
  .td__src-state {
    justify-self: end;
    font-size: var(--fs-10);
    color: var(--td-accent);
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .td__src.is-on .td__src-state,
  .td__src.is-silent-on .td__src-state {
    opacity: 1;
  }
  .td__src.is-silent-on .td__src-state {
    color: var(--td-warn);
  }
  /* прокси-режим: HTTP-ноды помечены, в blocked — гаснут */
  .td__stage[data-mode="blocked"] .td__src[data-http="1"] {
    opacity: 0.4;
    border-color: color-mix(in srgb, var(--td-err) 30%, transparent);
  }

  /* ---------- карточка-досье ---------- */
  .td__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--td-line);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    overflow: hidden;
  }
  /* тонкий «скан»-блик во время трассировки */
  .td__card::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--td-accent), transparent);
    opacity: 0;
    transform: translateY(0);
  }
  .td.is-inview .td__stage[data-state="tracing"] .td__card::after {
    animation: td-scan 1.1s var(--ease-standard) infinite;
  }
  @keyframes td-scan {
    0% {
      opacity: 0;
      transform: translateY(0);
    }
    20% {
      opacity: 0.8;
    }
    100% {
      opacity: 0;
      transform: translateY(220px);
    }
  }

  .td__card-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--sp-1) var(--sp-3);
    padding-bottom: var(--sp-3);
    border-bottom: var(--bw-thin) solid var(--border);
  }
  .td__card-sub {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    font-size: var(--fs-10);
  }
  .td__card-ip {
    font-size: var(--fs-22);
    font-weight: var(--fw-semibold);
    color: var(--text);
    letter-spacing: var(--ls-tight);
  }
  .td__card-status {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    white-space: nowrap;
  }
  .td__card-status.is-done {
    color: var(--td-accent);
    border-color: var(--td-line);
  }

  .td__fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2);
    margin: 0;
  }
  .td__field {
    display: grid;
    grid-template-columns: minmax(72px, auto) minmax(0, 1fr);
    align-items: baseline;
    gap: var(--sp-3);
  }
  .td__field-k {
    font-size: var(--fs-11);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .td__field-v {
    margin: 0;
    min-width: 0;
    font-size: var(--fs-14);
    color: var(--text-faint);
    overflow-wrap: anywhere;
    transition: color var(--dur-med) var(--ease-standard);
  }
  .td__field.is-filled .td__field-v {
    color: var(--text);
  }
  .td__field.is-filled .td__field-ph {
    display: none;
  }
  /* код страны как мини-бейдж */
  .td__cc {
    display: inline-block;
    margin-right: var(--sp-2);
    padding: 0 var(--sp-1);
    border: var(--bw-thin) solid var(--td-line);
    border-radius: var(--r-xs);
    font-family: var(--font-stack-display);
    font-size: var(--fs-11);
    font-weight: var(--fw-semibold);
    color: var(--td-accent);
    letter-spacing: var(--ls-wide);
  }
  .td__asn {
    color: var(--text-secondary);
  }

  /* ---------- индикатор угрозы ---------- */
  .td__threat {
    --bandc: var(--text-faint);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: color-mix(in srgb, var(--surface) 40%, transparent);
  }
  .td__threat[data-band="high"] {
    --bandc: var(--td-err);
  }
  .td__threat[data-band="mid"] {
    --bandc: var(--td-warn);
  }
  .td__threat[data-band="low"] {
    --bandc: var(--td-warn);
  }
  .td__threat[data-band="clean"] {
    --bandc: var(--td-ok);
  }
  .td__threat-top {
    display: flex;
    align-items: center;
    gap: var(--sp-2) var(--sp-3);
  }
  .td__threat-cap {
    color: var(--text-muted);
  }
  .td__threat-score {
    margin-left: auto;
    font-size: var(--fs-18);
    font-weight: var(--fw-semibold);
    color: var(--bandc);
    font-variant-numeric: tabular-nums;
  }
  .td__threat-verdict {
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    color: var(--bandc);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid color-mix(in srgb, var(--bandc) 42%, transparent);
    border-radius: var(--r-pill);
    white-space: nowrap;
  }
  .td__threat-verdict[hidden] {
    display: none;
  }
  .td__gauge {
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .td__gauge-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--bandc);
    transform: scaleX(var(--score, 0));
    transform-origin: left center;
    transition: transform var(--dur-slower) var(--ease-soft);
  }

  /* ---------- футер карточки ---------- */
  .td__card-foot {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }
  .td__trace {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-5);
    border: var(--bw-thin) solid var(--td-line);
    border-radius: var(--r-pill);
    background: var(--td-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__trace:hover {
    border-color: var(--td-accent);
  }
  .td__trace:active {
    transform: scale(0.96);
  }
  .td__trace:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__trace:disabled {
    cursor: progress;
  }
  .td__trace-glyph {
    width: 0;
    height: 0;
    flex: none;
    border-style: solid;
    border-width: 5px 0 5px 9px;
    border-color: transparent transparent transparent currentColor;
  }
  .td__stage[data-state="tracing"] .td__trace-glyph {
    width: 11px;
    height: 11px;
    border: var(--bw-med) solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
  }
  .td.is-inview .td__stage[data-state="tracing"] .td__trace-glyph {
    animation: td-spin 700ms linear infinite;
  }
  @keyframes td-spin {
    to {
      transform: rotate(360deg);
    }
  }
  .td__note {
    flex: 1 1 200px;
    min-width: 0;
    font-size: var(--fs-12);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
  }

  /* ---------- подсказка по источнику ---------- */
  .td__hint {
    min-height: 1.4em;
    font-size: var(--fs-13);
    color: var(--text-muted);
    line-height: var(--lh-snug);
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .td__hint.is-on {
    opacity: 1;
  }

  /* ---------- экспорт ---------- */
  .td__export {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .td__export-cap {
    color: var(--text-muted);
  }
  .td__export-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .td__fmt {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__fmt:hover {
    border-color: var(--border-hover);
  }
  .td__fmt:active {
    transform: scale(0.96);
  }
  .td__fmt:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__fmt.is-on {
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  .td__fmt .mono {
    font-size: var(--fs-12);
    color: var(--text);
    letter-spacing: var(--ls-wide);
  }
  .td__export-preview {
    margin: 0;
    min-height: 2.4em;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    font-size: var(--fs-11);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  /* ---------- под капотом ---------- */
  .td__under {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .td__under-toggle {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-12);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .td__under-toggle:hover {
    color: var(--text);
  }
  .td__under-toggle:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
    border-radius: var(--r-xs);
  }
  .td__under-chevron {
    position: relative;
    flex: none;
    width: 10px;
    height: 10px;
  }
  .td__under-chevron::before,
  .td__under-chevron::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 10px;
    height: 1.5px;
    border-radius: 1px;
    background: currentColor;
    transform: translateY(-50%);
  }
  .td__under-chevron::after {
    transform: translateY(-50%) rotate(90deg);
  }
  .td__under-toggle[aria-expanded="true"] .td__under-chevron::after {
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .td__under-chevron::after {
      transition: opacity var(--dur-fast) var(--ease-standard);
    }
  }
  .td__under-box {
    display: grid;
    grid-template-rows: 1fr;
  }
  .td__under-inner {
    min-height: 0;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-3);
  }
  .td.is-enhanced .td__under-box {
    grid-template-rows: 0fr;
  }
  .td.is-enhanced.is-under-open .td__under-box {
    grid-template-rows: 1fr;
  }
  @media (prefers-reduced-motion: no-preference) {
    .td__under-box {
      transition: grid-template-rows var(--dur-med) var(--ease-standard);
    }
  }

  .td__panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    min-width: 0;
  }
  .td__panel-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-15);
    color: var(--text);
  }
  .td__panel-note {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
    overflow-wrap: anywhere;
  }

  /* прокси-сегмент */
  .td__seg {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .td__seg-btn {
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .td__seg-btn:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }
  .td__seg-btn.is-on {
    color: var(--text);
    border-color: var(--td-line);
    background: var(--td-soft);
  }
  .td__break {
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard);
  }
  .td__break:hover:not(:disabled) {
    color: var(--text);
    border-color: color-mix(in srgb, var(--td-err) 42%, transparent);
  }
  .td__break:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .td__pool {
    font-size: var(--fs-11);
    color: var(--text-faint);
    letter-spacing: var(--ls-wide);
    opacity: 0.4;
    transition: opacity var(--dur-med) var(--ease-standard);
    overflow-wrap: anywhere;
  }
  .td__proxy[data-mode="proxied"] .td__pool,
  .td__proxy[data-mode="blocked"] .td__pool {
    opacity: 1;
  }
  .td__routes {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .td__route {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .td__route-cap {
    color: var(--text-muted);
    font-size: var(--fs-10);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }
  .td__route-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
  }
  .td__pill {
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    transition:
      color var(--dur-med) var(--ease-standard),
      border-color var(--dur-med) var(--ease-standard),
      opacity var(--dur-med) var(--ease-standard);
  }
  .td__pill--dns {
    color: var(--text-secondary);
  }
  /* proxied: HTTP-пилюли подсвечены акцентом */
  .td__proxy[data-mode="proxied"] .td__pill[data-td-http-pill] {
    color: var(--td-accent);
    border-color: var(--td-line);
  }
  /* blocked: HTTP заблокированы, DNS идут */
  .td__proxy[data-mode="blocked"] .td__pill[data-td-http-pill] {
    color: var(--td-err);
    border-color: color-mix(in srgb, var(--td-err) 42%, transparent);
    opacity: 0.6;
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--td-err) 60%, transparent);
  }

  /* скан списком */
  .td__bulk-controls {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }
  .td__bulk-run {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--td-line);
    border-radius: var(--r-pill);
    background: var(--td-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .td__bulk-run:hover {
    border-color: var(--td-accent);
  }
  .td__bulk-run:active {
    transform: scale(0.96);
  }
  .td__bulk-run:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .td__sem {
    font-size: var(--fs-11);
    color: var(--td-accent);
  }
  .td__bulk-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .td__bulk-row {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) auto minmax(60px, 1.2fr) auto;
    align-items: center;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface-2);
    opacity: 0;
    transform: translate3d(-8px, 0, 0);
  }
  .td__bulk-row.is-in {
    opacity: 1;
    transform: none;
    transition:
      opacity var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-soft);
  }
  .td__bulk-ip {
    font-size: var(--fs-12);
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .td__bulk-cc {
    font-size: var(--fs-11);
    color: var(--td-accent);
  }
  .td__bulk-bar {
    height: 6px;
    border-radius: var(--r-pill);
    background: var(--surface);
    border: var(--bw-thin) solid var(--border);
    overflow: hidden;
  }
  .td__bulk-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--td-warn);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-slow) var(--ease-soft);
  }
  .td__bulk-row.is-in .td__bulk-fill {
    transform: scaleX(var(--score, 0));
  }
  .td__bulk-fill[data-abuse="100"],
  .td__bulk-fill[data-abuse="92"] {
    background: var(--td-err);
  }
  .td__bulk-num {
    font-size: var(--fs-12);
    color: var(--text);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  /* ====================== Появление сцены ====================== */
  .td.is-inview .td__src {
    animation: td-rise var(--dur-slow) var(--ease-soft) both;
  }
  .td.is-inview .td__col--l .td__src {
    animation-delay: calc(var(--i, 0) * 1ms);
  }
  @keyframes td-rise {
    from {
      opacity: 0;
      transform: translate3d(0, 8px, 0);
    }
  }

  /* ====================== Адаптив ====================== */
  @media (min-width: 760px) {
    .td__stage {
      grid-template-columns: minmax(0, 1fr) minmax(300px, 1.55fr) minmax(0, 1fr);
      gap: var(--sp-4);
      align-items: center;
      padding: var(--sp-5);
    }
    .td__col {
      display: flex;
      flex-direction: column;
      gap: var(--sp-3);
      min-width: 0;
    }
    .td__card {
      order: 0;
      grid-column: auto;
    }
  }

  @media (max-width: 759px) {
    /* карточка во всю ширину, ноды — 2 колонки под ней */
    .td__bulk-row {
      grid-template-columns: minmax(0, 1.4fr) auto minmax(48px, 1fr) auto;
    }
  }

  @media (max-width: 600px) {
    .td__under-inner {
      grid-template-columns: 1fr;
    }
  }

  /* ====================== prefers-reduced-motion ====================== */
  @media (prefers-reduced-motion: reduce) {
    .td.is-inview .td__src,
    .td__src.is-report {
      animation: none;
    }
    .td__card::after {
      animation: none !important;
    }
    .td__gauge-fill,
    .td__bulk-fill,
    .td__bulk-row {
      transition: none;
    }
  }
</style>

<script>
  // Оркестратор досье .след. Без степпера и без постоянного rAF: трассировка и
  // скан списком ведутся одним setTimeout-конвейером later(), который чистится
  // офскрин / на скрытой вкладке / при pagehide. Индикатор угрозы — CSS-переход
  // (composited). Всё гейтится IntersectionObserver. prefers-reduced-motion —
  // финальный статичный кадр, интеракции работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-td]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = document.documentElement.dataset.locale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    const stage = root.querySelector<HTMLElement>(".td__stage");
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-chip]"));
    const srcEls = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-src]"));
    const ipEl = root.querySelector<HTMLElement>("[data-td-ip]");
    const statusEl = root.querySelector<HTMLElement>("[data-td-status]");
    const fieldEls = Array.from(root.querySelectorAll<HTMLElement>("[data-td-field]"));
    const threatEl = root.querySelector<HTMLElement>("[data-td-threat]");
    const scoreEl = root.querySelector<HTMLElement>("[data-td-score]");
    const verdictEl = root.querySelector<HTMLElement>("[data-td-verdict]");
    const gaugeEl = root.querySelector<HTMLElement>("[data-td-gauge]");
    const traceBtn = root.querySelector<HTMLButtonElement>("[data-td-trace]");
    const traceT = root.querySelector<HTMLElement>("[data-td-trace-t]");
    const noteEl = root.querySelector<HTMLElement>("[data-td-note]");
    const hintEl = root.querySelector<HTMLElement>("[data-td-hint]");

    if (!stage || !ipEl) return;

    type Dos = {
      ip: string;
      cc: string;
      country: string;
      city: string;
      asn: string;
      op: string;
      net: string;
      host: string;
      abuse: number;
    };
    const read = (c: HTMLElement): Dos => ({
      ip: c.dataset.ip ?? "",
      cc: c.dataset.cc ?? "",
      country: c.dataset.country ?? "",
      city: c.dataset.city ?? "",
      asn: c.dataset.asn ?? "",
      op: c.dataset.op ?? "",
      net: c.dataset.net ?? "",
      host: c.dataset.host ?? "",
      abuse: Number(c.dataset.abuse) || 0,
    });

    let current: Dos = read(chips[0] ?? document.createElement("div"));

    // ---- инфраструктура таймеров ----
    let inview = false;
    let tracing = false;
    const timers: number[] = [];
    const clearTimers = (): void => {
      while (timers.length) {
        const id = timers.pop();
        if (id !== undefined) window.clearTimeout(id);
      }
    };
    const later = (fn: () => void, ms: number): void => {
      const id = window.setTimeout(() => {
        const i = timers.indexOf(id);
        if (i >= 0) timers.splice(i, 1);
        fn();
      }, ms);
      timers.push(id);
    };
    const D = (ms: number): number => (reduced ? 0 : ms);

    // ---- угроза → band/вердикт ----
    const band = (abuse: number): { band: string; verdict: string } => {
      if (abuse >= 80) return { band: "high", verdict: tr("опасный", "high risk") };
      if (abuse >= 40) return { band: "mid", verdict: tr("подозрительный", "suspicious") };
      if (abuse >= 10) return { band: "low", verdict: tr("замечен", "flagged") };
      return { band: "clean", verdict: tr("низкий риск", "low risk") };
    };

    // ---- значение поля карточки (country с бейджем cc, operator с ASN) ----
    const fieldValue = (id: string, d: Dos): string => {
      if (id === "country") {
        const city = d.city && d.city !== "—" ? ` · ${d.city}` : "";
        return `<span class="td__cc">${d.cc}</span>${d.country}${city}`;
      }
      if (id === "operator") return `<span class="td__asn">${d.asn}</span> · ${d.op}`;
      if (id === "network") return d.net;
      if (id === "host") return d.host && d.host !== "—" ? d.host : tr("нет PTR-записи", "no PTR record");
      return "";
    };

    const setField = (id: string, on: boolean): void => {
      const el = fieldEls.find((f) => f.dataset.tdField === id);
      if (!el) return;
      const v = el.querySelector<HTMLElement>("[data-td-field-v]");
      el.classList.toggle("is-filled", on);
      if (v) {
        if (on) v.innerHTML = fieldValue(id, current);
        else v.innerHTML = '<span class="td__field-ph" aria-hidden="true">—</span>';
      }
    };

    const setThreat = (on: boolean): void => {
      if (!threatEl || !scoreEl || !verdictEl || !gaugeEl) return;
      if (on) {
        const b = band(current.abuse);
        threatEl.dataset.band = b.band;
        scoreEl.textContent = String(current.abuse);
        verdictEl.textContent = b.verdict;
        verdictEl.hidden = false;
        gaugeEl.style.setProperty("--score", (current.abuse / 100).toFixed(2));
      } else {
        threatEl.dataset.band = "idle";
        scoreEl.textContent = "—";
        verdictEl.hidden = true;
        gaugeEl.style.setProperty("--score", "0");
      }
    };

    const lightSrc = (id: string, state: "off" | "on" | "silent"): void => {
      const el = srcEls.find((s) => s.dataset.tdSrc === id);
      if (!el) return;
      el.classList.toggle("is-on", state === "on");
      el.classList.toggle("is-silent-on", state === "silent");
      el.setAttribute("aria-pressed", state === "off" ? "false" : "true");
      if (!reduced && state !== "off") {
        el.classList.remove("is-report");
        void el.offsetWidth;
        el.classList.add("is-report");
      }
      const st = el.querySelector<HTMLElement>("[data-td-src-state]");
      if (st) st.textContent = state === "silent" ? tr("таймаут", "timeout") : state === "on" ? "ok" : "";
    };

    const resetCard = (): void => {
      ipEl.textContent = current.ip;
      if (statusEl) {
        statusEl.textContent = tr("не собрано", "not assembled");
        statusEl.classList.remove("is-done");
      }
      fieldEls.forEach((f) => setField(f.dataset.tdField ?? "", false));
      setThreat(false);
      srcEls.forEach((s) => lightSrc(s.dataset.tdSrc ?? "", "off"));
      if (noteEl) noteEl.textContent = "";
    };

    const setTraceUI = (state: "idle" | "running"): void => {
      stage.dataset.state = state === "running" ? "tracing" : "idle";
      tracing = state === "running";
      if (traceT) traceT.textContent = state === "running" ? tr("Слежу…", "Tracing…") : tr("Проследить заново", "Trace again");
      if (traceBtn) traceBtn.disabled = state === "running";
    };

    // порядок отчёта источников (последний — молчащий Spamhaus)
    const order = ["geo", "asn", "owner", "host", "rep", "dnsbl"];
    const fillOf: Record<string, string | null> = {
      geo: "country",
      asn: "operator",
      owner: "network",
      host: "host",
      rep: "threat",
      dnsbl: null,
    };

    const runTrace = (): void => {
      clearTimers();
      resetCard();
      setTraceUI("running");

      const blocked = stage.dataset.mode === "blocked";
      let ms = 0;
      let answered = 0;

      order.forEach((id) => {
        const silent = id === "dnsbl";
        // в blocked-режиме HTTP-источники не отвечают (guard приватности)
        const isHttp = srcEls.find((s) => s.dataset.tdSrc === id)?.dataset.http === "1";
        ms += silent ? 620 : 220;
        later(() => {
          if (silent) {
            lightSrc(id, "silent");
            return;
          }
          if (blocked && isHttp) {
            lightSrc(id, "silent");
            return;
          }
          lightSrc(id, "on");
          const f = fillOf[id];
          if (f === "threat") setThreat(true);
          else if (f) setField(f, true);
          answered += 1;
        }, D(ms));
      });

      later(() => {
        setTraceUI("idle");
        if (statusEl) {
          statusEl.textContent = tr(`${answered}/6 источников`, `${answered}/6 sources`);
          statusEl.classList.add("is-done");
        }
        if (noteEl) {
          noteEl.textContent = blocked
            ? tr(
                "Прокси-guard: HTTP-источники не ушли в direct — досье собрано только из DNS и RDAP, реальный IP не утёк.",
                "Proxy guard: HTTP sources didn't fall back to direct — the dossier came from DNS and RDAP only, the real IP never leaked.",
              )
            : tr(
                "Готово: ответили 5 из 6. Spamhaus молчит, но через asyncio.gather(return_exceptions=True) это значение, а не падение — досье собрано.",
                "Done: 5 of 6 answered. Spamhaus is silent, but via asyncio.gather(return_exceptions=True) that's a value, not a crash — the dossier is assembled.",
              );
        }
      }, D(ms + 320));
    };

    // мгновенное финальное состояние (reduced / офскрин-старт)
    const fillInstant = (): void => {
      clearTimers();
      ipEl.textContent = current.ip;
      const blocked = stage.dataset.mode === "blocked";
      let answered = 0;
      order.forEach((id) => {
        const isHttp = srcEls.find((s) => s.dataset.tdSrc === id)?.dataset.http === "1";
        if (id === "dnsbl" || (blocked && isHttp)) {
          lightSrc(id, "silent");
          return;
        }
        lightSrc(id, "on");
        const f = fillOf[id];
        if (f === "threat") setThreat(true);
        else if (f) setField(f, true);
        answered += 1;
      });
      if (statusEl) {
        statusEl.textContent = tr(`${answered}/6 источников`, `${answered}/6 sources`);
        statusEl.classList.add("is-done");
      }
      setTraceUI("idle");
    };

    traceBtn?.addEventListener("click", runTrace);

    // ---- выбор адреса ----
    const selectChip = (i: number, trace: boolean): void => {
      const c = chips[i];
      if (!c) return;
      chips.forEach((x, k) => {
        const on = k === i;
        x.classList.toggle("is-on", on);
        x.setAttribute("aria-pressed", on ? "true" : "false");
      });
      current = read(c);
      resetCard();
      updateExport();
      if (trace && inview) {
        if (reduced) fillInstant();
        else runTrace();
      }
    };
    chips.forEach((c, i) => c.addEventListener("click", () => selectChip(i, true)));

    // ---- тап по источнику: подсказка ----
    srcEls.forEach((s) => {
      s.addEventListener("click", () => {
        const text = s.dataset.hint ?? "";
        if (!hintEl) return;
        const same = hintEl.textContent === text && hintEl.classList.contains("is-on");
        if (same) {
          hintEl.classList.remove("is-on");
        } else {
          hintEl.textContent = text;
          hintEl.classList.add("is-on");
        }
      });
    });

    // ---- экспорт ----
    const fmtChips = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-fmt]"));
    const exportPre = root.querySelector<HTMLElement>("[data-td-export-preview]");
    const asnNum = (asn: string): string => asn.replace(/\D/g, "");
    const buildPreview = (fmt: string, d: Dos): string => {
      const host = d.host && d.host !== "—" ? d.host : "";
      if (fmt === "TXT") return `${d.ip}   ${d.cc}  ${d.asn}  ${d.net}  abuse=${d.abuse}  host=${host || "-"}`;
      if (fmt === "JSON")
        return `{\n  "ip": "${d.ip}",\n  "country": "${d.cc}",\n  "asn": ${asnNum(d.asn)},\n  "network": "${d.net}",\n  "abuse": ${d.abuse}\n}`;
      if (fmt === "CSV") return `ip,country,asn,network,abuse,host\n${d.ip},${d.cc},${asnNum(d.asn)},${d.net},${d.abuse},${host}`;
      return `<tr data-ip="${d.ip}">\n  <td>${d.ip}</td><td>${d.cc}</td><td>${d.asn}</td>\n  <td>${d.net}</td><td>${d.abuse}</td>\n</tr>  ${tr("<!-- сортируется по клику на столбец -->", "<!-- sortable on column click -->")}`;
    };
    let curFmt = "TXT";
    const updateExport = (): void => {
      if (!exportPre) return;
      const note = fmtChips.find((c) => c.dataset.tdFmt === curFmt)?.dataset.note ?? "";
      exportPre.textContent = `# ${curFmt} — ${note}\n${buildPreview(curFmt, current)}`;
    };
    fmtChips.forEach((c) => {
      c.addEventListener("click", () => {
        curFmt = c.dataset.tdFmt ?? "TXT";
        fmtChips.forEach((x) => {
          const on = x === c;
          x.classList.toggle("is-on", on);
          x.setAttribute("aria-pressed", on ? "true" : "false");
        });
        updateExport();
      });
    });
    updateExport();

    // ---- под капотом: раскрытие ----
    root.classList.add("is-enhanced");
    const underToggle = root.querySelector<HTMLButtonElement>("[data-td-under-toggle]");
    let underOpen = false;
    const syncUnder = (): void => {
      root.classList.toggle("is-under-open", underOpen);
      underToggle?.setAttribute("aria-expanded", underOpen ? "true" : "false");
    };
    underToggle?.addEventListener("click", () => {
      underOpen = !underOpen;
      syncUnder();
    });
    syncUnder();

    // ---- прокси-guard ----
    const proxyPanel = root.querySelector<HTMLElement>("[data-td-proxy]");
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-td-mode]"));
    const breakBtn = root.querySelector<HTMLButtonElement>("[data-td-break]");
    const proxyNote = root.querySelector<HTMLElement>("[data-td-proxy-note]");

    const setMode = (mode: "direct" | "proxied" | "blocked"): void => {
      stage.dataset.mode = mode;
      if (proxyPanel) proxyPanel.dataset.mode = mode;
      modeBtns.forEach((b) => {
        const on = b.dataset.tdMode === mode || (mode === "blocked" && b.dataset.tdMode === "proxied");
        b.classList.toggle("is-on", on);
        b.setAttribute("aria-pressed", on ? "true" : "false");
      });
      if (breakBtn) breakBtn.disabled = mode === "direct";
      if (proxyNote) {
        proxyNote.textContent =
          mode === "direct"
            ? tr("Прямое соединение: реальный IP виден источникам.", "Direct connection: the real IP is visible to the sources.")
            : mode === "proxied"
              ? tr(
                  "Запросы идут через пул HTTP/SOCKS, креды замаскированы. Реальный IP скрыт.",
                  "Requests go through an HTTP/SOCKS pool, credentials masked. The real IP is hidden.",
                )
              : tr(
                  "Коннектор не собрался. HTTP-источники не уходят в прямое соединение — реальный IP не утёк.",
                  "The connector failed to build. HTTP sources don't fall back to direct — the real IP never leaked.",
                );
      }
    };
    modeBtns.forEach((b) => {
      const mode = b.dataset.tdMode as "direct" | "proxied";
      b.addEventListener("click", () => setMode(mode));
    });
    breakBtn?.addEventListener("click", () => {
      if (stage.dataset.mode !== "direct") setMode("blocked");
    });
    setMode("direct");

    // ---- скан списком ----
    const bulkRun = root.querySelector<HTMLButtonElement>("[data-td-bulk-run]");
    const bulkRows = Array.from(root.querySelectorAll<HTMLElement>("[data-td-bulk-row]"));
    const bulkSem = root.querySelector<HTMLElement>("[data-td-sem]");
    const bulkNote = root.querySelector<HTMLElement>("[data-td-bulk-note]");
    const SEM = 3;

    const runBulk = (): void => {
      clearTimers();
      bulkRows.forEach((r) => r.classList.remove("is-in"));
      if (bulkNote) bulkNote.textContent = "";
      if (bulkSem) bulkSem.textContent = tr(`семафор: до ${SEM} одновременно`, `semaphore: up to ${SEM} at once`);
      bulkRows.forEach((r, i) => {
        later(() => r.classList.add("is-in"), D(260) * (i + 1));
      });
      later(
        () => {
          if (bulkNote)
            bulkNote.textContent = tr(
              "asyncio.gather опрашивает 6 источников на адрес, семафор держит нагрузку. Сбой источника не рушит скан — из логов сразу видно худших нарушителей. Отсортировано по уровню угрозы.",
              "asyncio.gather queries 6 sources per address, the semaphore caps the load. A failing source never breaks the scan — the worst offenders surface straight from the logs. Sorted by threat level.",
            );
        },
        D(260) * (bulkRows.length + 1),
      );
    };
    const bulkInstant = (): void => {
      bulkRows.forEach((r) => r.classList.add("is-in"));
    };
    bulkRun?.addEventListener("click", runBulk);

    // ---- IntersectionObserver-гейтинг ----
    const stopAll = (): void => {
      inview = false;
      clearTimers();
      root.classList.remove("is-inview");
    };

    const onEnter = (): void => {
      // автозапуск трассировки при первом показе
      if (reduced) {
        fillInstant();
        bulkInstant();
      } else if (!tracing) {
        runTrace();
      }
    };

    if (typeof IntersectionObserver === "undefined") {
      inview = true;
      root.classList.add("is-inview");
      onEnter();
    } else {
      let entered = false;
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            inview = e.isIntersecting;
            root.classList.toggle("is-inview", inview);
            if (!inview) {
              clearTimers();
            } else if (!entered) {
              entered = true;
              onEnter();
            }
          }
        },
        { threshold: 0.2 },
      );
      io.observe(root);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
