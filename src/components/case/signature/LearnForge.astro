/* ── Акт 1: терминал + промпт агенту ─────────────────────────────────── */
const termLines: { text: string; kind: string }[] = [
  { text: "git clone …/dotlearn.git", kind: "cmd" },
  { text: "pnpm install", kind: "cmd" },
  { text: "pnpm dev:web", kind: "cmd" },
  { text: "VITE ready · http://localhost:5173", kind: "ok" },
];
const agentPrompt: Bi = {
  ru: "Используй lesson-forge: добавь тему по SQL JOIN для новичка",
  en: "Use lesson-forge: add a beginner topic on SQL JOIN",
};

/* ── Акт 2: план программы + файлы темы ──────────────────────────────── */
const planConcepts: Bi[] = [
  { ru: "SELECT и фильтрация", en: "SELECT and filtering" },
  { ru: "ORDER BY и LIMIT", en: "ORDER BY and LIMIT" },
  { ru: "Агрегация: COUNT, SUM, AVG", en: "Aggregation: COUNT, SUM, AVG" },
  { ru: "JOIN-ы", en: "JOINs" },
  { ru: "GROUP BY и HAVING", en: "GROUP BY and HAVING" },
