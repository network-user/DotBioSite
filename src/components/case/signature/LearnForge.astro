  }

  /* стадии форджа: свёрнуты до forging */
  .lf-forge__stage {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    opacity: 0.35;
    transition: opacity var(--dur-med) var(--ease-standard);
  }

  .lf-forge__stage[data-on="true"] {
    opacity: 1;
  }

  .lf-forge__stage-cap {
    color: var(--text-muted);
  }

  /* список файлов */
  .lf-forge__files {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .lf-forge__file {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    padding: 6px var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
  }

  .lf-forge__file[data-file="0"] {
    border-color: var(--lf-line);
  }

  /* появление файлов по одному (классы вешает скрипт) */
  .lf-forge__stage[data-on="true"] .lf-forge__file {
    opacity: 0;
  }

  .lf.is-inview .lf-forge__stage[data-on="true"] .lf-forge__file.is-show {
    animation: lf-slide var(--dur-slow) var(--ease-soft) both;
  }

  /* без js-классов (reduced/no-io) файлы видимы */
  .lf-forge__stage[data-on="true"] .lf-forge__file.is-show {
    opacity: 1;
  }

  @keyframes lf-slide {
    from {
      opacity: 0;
      transform: translate3d(-10px, 0, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .lf-forge__file-dot {
    flex: none;
    align-self: center;
    width: 6px;
    height: 6px;
    border-radius: 2px;
    background: var(--lf-accent);
  }

  .lf-forge__file-name {
    font-size: var(--fs-13);
    color: var(--text);
    word-break: break-word;
  }

  .lf-forge__file-kind {
    margin-left: auto;
    font-size: var(--fs-11);
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Zod-схема */
  .lf-forge__schema {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    font-size: var(--fs-12);
    color: var(--text-secondary);
    overflow-x: auto;
  }

  .lf-forge__sline {
    white-space: pre;
  }

  .lf-forge__sline--head {
    color: var(--text);
  }

  .lf-forge__sline em {
    font-style: normal;
    color: var(--lf-accent);
  }

  .lf-forge__sline--infer {
    margin-top: 3px;
    color: var(--text-muted);
  }

  /* лишняя строка скрыта в pass, видна в fail */
  .lf-forge__sline--bad {
    display: none;
    color: var(--lf-err);
  }

  .lf-forge__sline--bad em {
    color: var(--lf-err);
  }

  .lf-forge__schema[data-state="fail"] .lf-forge__sline--bad {
    display: block;
  }

  /* gate */
  .lf-forge__gate {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    align-self: flex-start;
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-pill);
    background: var(--lf-soft);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text);
    transition:
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard);
  }

  .lf-forge__gate-icon {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--lf-accent);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      border-radius var(--dur-med) var(--ease-standard);
  }

  .lf-forge__gate[data-state="fail"] {
    border-color: color-mix(in srgb, var(--lf-err) 55%, transparent);
    background: var(--lf-err-soft);
  }

  .lf-forge__gate[data-state="fail"] .lf-forge__gate-icon {
    background: var(--lf-err);
    border-radius: 1px;
  }

  .lf.is-inview .lf-forge__gate[data-state="fail"].is-shake {
    animation: lf-shake var(--dur-slow) var(--ease-standard);
  }

  @keyframes lf-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  .lf-forge__toggle {
    align-self: flex-start;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-12);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .lf-forge__toggle:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  .lf-forge__toggle[aria-pressed="true"] {
    color: var(--text);
    border-color: color-mix(in srgb, var(--lf-err) 50%, transparent);
  }

  .lf-forge__toggle:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  /* пайп → PR */
  .lf-forge__pipe {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .lf-forge__pipe-step {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-13);
    color: var(--text-secondary);
  }

  .lf-forge__pipe-dot {
    flex: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: var(--bw-thin) solid var(--lf-line);
    background:
      linear-gradient(45deg, transparent 42%, var(--lf-accent) 42% 58%, transparent 58%),
      linear-gradient(-45deg, transparent 46%, var(--lf-accent) 46% 54%, transparent 54%);
  }

  .lf-forge__pr {
    display: inline-flex;
    align-self: flex-start;
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-sm);
    background: var(--surface);
  }

  .lf-forge__pr-state {
    font-size: var(--fs-13);
    font-weight: var(--fw-semibold);
    color: var(--lf-accent);
  }

  /* footer / BYOK */
  .lf-forge__foot {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-top: auto;
    padding-top: var(--sp-3);
    border-top: var(--bw-thin) solid var(--border);
  }

  .lf-forge__byok {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    align-self: flex-start;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .lf-forge__byok:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  .lf-forge__byok[aria-expanded="true"] {
    color: var(--text);
    border-color: var(--lf-line);
  }

  .lf-forge__byok:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .lf-forge__byok-key {
    flex: none;
    width: 12px;
    height: 7px;
    border: var(--bw-thin) solid var(--lf-accent);
    border-radius: var(--r-pill);
  }

  .lf-forge__byok-note {
    margin: 0;
    font-size: var(--fs-12);
    color: var(--text);
  }

  .lf-forge__byok-note[hidden] {
    display: none;
  }

  .lf-forge__stack {
    color: var(--text-faint);
  }

  /* ════════════════ Responsive ════════════════ */
  @media (max-width: 760px) {
    .lf__bench {
