    min-width: 100%;
    font-family: var(--font-stack-mono);
  }

  .lf-ide__table :global(th),
  .lf-ide__table :global(td) {
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    font-size: var(--fs-13);
    text-align: left;
    white-space: nowrap;
  }

  .lf-ide__table :global(th) {
    color: var(--lf-accent);
    background: var(--surface);
    font-weight: var(--fw-semibold);
  }

  .lf-ide__table :global(td) {
    color: var(--text);
  }

  /* строка-аномалия неверного варианта подсвечивается */
  .lf-ide__table :global(tr[data-bad="1"] td) {
    color: var(--lf-err);
    background: var(--lf-err-soft);
  }

  /* стаггер появления строк результата */
  .lf.is-inview .lf-ide__table :global(tr.is-row) {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
    animation-delay: calc(var(--ri, 0) * 90ms);
