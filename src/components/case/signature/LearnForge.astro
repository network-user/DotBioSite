---
/**
 * LearnForge.astro — сигнатурная визуализация .учёба (DotLearn).
 *
 * ПОЛНЫЙ РЕБИЛД (был отклонён нумерованный «степпер»). Теперь это ОДНА цельная
 * сцена-верстак: мини-IDE урока слева и ИИ-«кузница» (forge) справа. Метафора
 * взята из самой природы продукта — тема в .учёба это типобезопасный МОДУЛЬ-КОД
 * (theory.mdx + exercises.yaml), а не строка в БД; код реально исполняется в
 * браузере (sql.js / Pyodide в Web Worker); общий Zod-контракт валидирует форму.
 *
 * Что можно «потрогать» (живой верстак, не слайды):
 *  ЛЕВО — редактор урока:
 *   · вкладка рантайма SQL (sql.js) ↔ Python (Pyodide), оба «в Web Worker»;
 *   · 2-3 варианта запроса/решения (один верный, остальные — нет);
 *   · кнопка Run → мок-движок «исполняет» и рисует РЕЗУЛЬТАТ-ТАБЛИЦУ
 *     (верный вариант = совпало с gold, неверный = расхождение).
 *  ПРАВО — рейка ИИ-кузницы (forge):
 *   · чип-промпт «add a topic on SQL JOIN» + кнопка Forge → модуль темы
 *     собирается по файлам (topics/sql-joins/ → theory.mdx + exercises.yaml);
 *   · Zod-гейт контракта: тогл «лишнее поле» → REJECT (красный) / PASS (акцент),
 *     одна схема на web И api, типы через z.infer;
 *   · после PASS gold-решение «прогоняется в песочнице» и открывается PR;
 *   · чип BYOK: ключи к ИИ остаются в браузере.
 *
 * Бюджет анимации (строго): анимируются ТОЛЬКО transform и opacity. Постоянного
 * rAF нет — автосборка форджа ведётся цепочкой setTimeout, которые ЧИСТЯТСЯ за
 * экраном. Всё движение под классом .is-inview (IntersectionObserver на корне) и
 * гасится за экраном, на скрытой вкладке (visibilitychange) и на pagehide.
 * prefers-reduced-motion → финальный читаемый статичный кадр; все кнопки/тоглы
 * работают. Любая «infinite»-анимация скоупится под .lf.is-inview.
 *
 * Факты сверены по репозиторию DotLearn (точно):
 *  · тема = типобезопасный модуль-код: theory.mdx + exercises.yaml;
 *  · Zod-контракт в packages/contracts, общий для web+api, типы через z.infer;
 *  · sql.js + Pyodide исполняются в Web Workers;
 *  · 6 типов упражнений; 22 темы в каталоге;
 *  · local-first через import.meta.glob (бэкенд не требуется);
 *  · BYOK: OpenAI / Anthropic / Ollama / OpenRouter;
 *  · прогресс — ts-fsrs + IndexedDB.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi) => b[locale];

const intro: Bi = {
  ru: "Не слайды, а живой верстак урока .учёба: слева — мини-IDE, где код реально «исполняется» в браузере, справа — ИИ-кузница, что собирает новую тему как типобезопасный модуль и прогоняет её через общий Zod-контракт. Тыкайте: переключайте рантайм, меняйте вариант запроса, жмите Run и Forge.",
  en: "Not slides but a live lesson workbench from .учёба: a mini-IDE on the left where code really “runs” in the browser, and an AI forge on the right that assembles a new topic as a type-safe module and pushes it through one shared Zod contract. Poke it: switch runtime, change the query variant, hit Run and Forge.",
};

/* ── ЛЕВО: рантаймы редактора (вкладки) ───────────────────────────────── */
const runtimes: { id: string; lang: string; engine: Bi }[] = [
  { id: "sql", lang: "sql.js", engine: { ru: "SQLite в WASM", en: "SQLite in WASM" } },
  { id: "py", lang: "Pyodide", engine: { ru: "Python в WASM", en: "Python in WASM" } },
];

/* Варианты решения: 0 — верный (совпадёт с gold), 1/2 — нет. */
type Variant = {
  label: Bi;
  ok: boolean;
  /* строки кода редактора (faux line numbers) */
  sql: string[];
  py: string[];
  /* мок-результат прогона: колонки + строки */
  cols: string[];
  rows: string[][];
  note: Bi;
};

const variants: Variant[] = [
  {
    label: { ru: "INNER JOIN", en: "INNER JOIN" },
    ok: true,
    sql: [
      "SELECT o.id, u.name",
      "FROM orders o",
      "JOIN users u ON u.id = o.user_id",
      "ORDER BY o.id;",
    ],
    py: [
      "rows = sql(db, '''",
      "  SELECT o.id, u.name FROM orders o",
      "  JOIN users u ON u.id = o.user_id''')",
      "print(rows)",
    ],
    cols: ["id", "name"],
    rows: [
      ["1001", "nova"],
      ["1002", "mira"],
      ["1003", "keto"],
    ],
    note: { ru: "совпало с gold-решением", en: "matches the gold solution" },
  },
  {
    label: { ru: "LEFT JOIN", en: "LEFT JOIN" },
    ok: false,
    sql: [
      "SELECT o.id, u.name",
      "FROM orders o",
      "LEFT JOIN users u ON u.id = o.user_id",
      "ORDER BY o.id;",
    ],
    py: [
      "rows = sql(db, '''",
      "  SELECT o.id, u.name FROM orders o",
      "  LEFT JOIN users u ON u.id = o.user_id''')",
      "print(rows)",
    ],
    cols: ["id", "name"],
    rows: [
      ["1001", "nova"],
      ["1002", "mira"],
      ["1003", "keto"],
      ["1004", "NULL"],
    ],
    note: { ru: "лишняя строка NULL — расходится с gold", en: "extra NULL row — differs from gold" },
  },
  {
    label: { ru: "CROSS JOIN", en: "CROSS JOIN" },
    ok: false,
    sql: [
      "SELECT o.id, u.name",
      "FROM orders o",
      "CROSS JOIN users u",
      "ORDER BY o.id;",
    ],
    py: [
      "rows = sql(db, '''",
      "  SELECT o.id, u.name",
      "  FROM orders o CROSS JOIN users u''')",
      "print(rows)",
    ],
    cols: ["id", "name"],
    rows: [
      ["1001", "nova"],
      ["1001", "mira"],
      ["1001", "keto"],
      ["…", "9 rows"],
    ],
    note: { ru: "декартово произведение — не то", en: "cartesian product — not it" },
  },
];

/* ── ПРАВО: файлы, которые кузница собирает по одному ──────────────────── */
const forgeFiles: { name: string; kind: Bi }[] = [
  { name: "topics/sql-joins/", kind: { ru: "папка модуля", en: "module folder" } },
  { name: "theory.mdx", kind: { ru: "теория в MDX", en: "theory in MDX" } },
  { name: "exercises.yaml", kind: { ru: "задачи в YAML", en: "exercises in YAML" } },
];

/* Поля Zod-контракта манифеста темы. */
const schemaFields: { key: string; type: string }[] = [
  { key: "slug", type: "z.string()" },
  { key: "title", type: "z.string()" },
  { key: "theory", type: "z.string()" },
  { key: "exercises", type: "z.array(Exercise)" },
];

/* Первый (верный) вариант — заполняет редактор и таблицу по умолчанию. */
const firstVariant = variants[0];
const initialCode = (firstVariant?.sql ?? []).join("\n");

const ui = {
  run: { ru: "Запустить", en: "Run" },
  forge: { ru: "Сковать тему", en: "Forge topic" },
  reset: { ru: "Сброс", en: "Reset" },
  badField: { ru: "Внедрить лишнее поле", en: "Inject extra field" },
  fixField: { ru: "Убрать поле", en: "Remove field" },
  worker: { ru: "в Web Worker", en: "in a Web Worker" },
  editorTitle: { ru: "exercise.sql · урок SQL JOIN", en: "exercise.sql · SQL JOIN lesson" },
  forgeTitle: { ru: "ИИ-кузница темы", en: "Topic AI forge" },
  variantsLabel: { ru: "Вариант решения", en: "Solution variant" },
  runtimeLabel: { ru: "Рантайм", en: "Runtime" },
};
---

<section
  class="lf"
  data-lf
  data-lf-locale={locale}
  aria-label={t({ ru: "Верстак урока DotLearn", en: "DotLearn lesson workbench" })}
>
  <p class="lf__intro">{t(intro)}</p>

  <!-- statline: живые факты экосистемы -->
  <ul class="lf__statline" role="list" aria-hidden="true">
    <li class="lf__stat"><b>22</b> {t({ ru: "темы", en: "topics" })}</li>
    <li class="lf__stat"><b>6</b> {t({ ru: "типов упражнений", en: "exercise types" })}</li>
    <li class="lf__stat"><b>2</b> {t({ ru: "рантайма в WASM", en: "WASM runtimes" })}</li>
    <li class="lf__stat lf__stat--local">{t({ ru: "local-first · import.meta.glob", en: "local-first · import.meta.glob" })}</li>
  </ul>

  <div class="lf__bench">
    <!-- ═══════════ ЛЕВО: мини-IDE урока ═══════════ -->
    <div class="lf-ide" data-lf-ide>
      <header class="lf-ide__bar">
        <span class="lf-ide__dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="lf-ide__file mono" data-lf-file>{t(ui.editorTitle)}</span>
      </header>

      <!-- вкладки рантайма: sql.js ↔ Pyodide -->
      <div
        class="lf-ide__runtimes"
        role="tablist"
        aria-label={t(ui.runtimeLabel)}
      >
        {
          runtimes.map((r, k) => (
            <button
              class="lf-ide__runtime"
              type="button"
              role="tab"
              id={`lf-rt-${k}`}
              data-lf-runtime={k}
              aria-selected={k === 0 ? "true" : "false"}
              tabindex={k === 0 ? 0 : -1}
            >
              <span class="lf-ide__runtime-lang mono">{r.lang}</span>
              <span class="lf-ide__runtime-engine">{t(r.engine)}</span>
            </button>
          ))
        }
        <span class="lf-ide__worker caption" aria-hidden="true">{t(ui.worker)}</span>
      </div>

      <!-- редактор: faux line numbers + код активного варианта -->
      <div class="lf-ide__editor" data-lf-editor>
        <pre class="lf-ide__gutter mono" aria-hidden="true"><span>1</span><span>2</span><span>3</span><span>4</span></pre>
        <pre class="lf-ide__code mono" data-lf-code aria-live="polite"><code>{initialCode}</code></pre>
      </div>

      <!-- селектор варианта решения -->
      <div class="lf-ide__variants" role="radiogroup" aria-label={t(ui.variantsLabel)}>
        {
          variants.map((v, k) => (
            <button
              class="lf-ide__variant"
              type="button"
              role="radio"
              data-lf-variant={k}
              data-ok={v.ok ? "1" : "0"}
              aria-checked={k === 0 ? "true" : "false"}
              tabindex={k === 0 ? 0 : -1}
            >
              {t(v.label)}
            </button>
          ))
        }
      </div>

      <!-- кнопка Run + панель результата -->
      <div class="lf-ide__run">
        <button class="lf-ide__runbtn" type="button" data-lf-run>
          <span class="lf-ide__runbtn-glyph" aria-hidden="true"></span>
          <span>{t(ui.run)}</span>
        </button>
        <span class="lf-ide__status mono" data-lf-runstatus role="status" aria-live="polite">
          {t({ ru: "готово к запуску", en: "ready to run" })}
        </span>
      </div>

      <div class="lf-ide__result" data-lf-result data-state="idle">
        <div class="lf-ide__result-head">
          <span class="lf-ide__result-cap caption">{t({ ru: "результат прогона", en: "run output" })}</span>
          <span class="lf-ide__verdict mono" data-lf-verdict></span>
        </div>
        <div class="lf-ide__table-wrap">
          <table class="lf-ide__table" data-lf-table>
            <thead data-lf-thead></thead>
            <tbody data-lf-tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══════════ ПРАВО: рейка ИИ-кузницы ═══════════ -->
    <aside class="lf-forge" data-lf-forge aria-label={t(ui.forgeTitle)}>
      <header class="lf-forge__head">
        <span class="lf-forge__spark" aria-hidden="true"></span>
        <span class="lf-forge__title">{t(ui.forgeTitle)}</span>
      </header>

      <!-- промпт-чип + Forge -->
      <div class="lf-forge__prompt">
        <span class="lf-forge__chip mono">
          <span class="lf-forge__chip-sigil" aria-hidden="true">/</span>add a topic on SQL JOIN
        </span>
        <button class="lf-forge__btn" type="button" data-lf-forge-btn>
          <span class="lf-forge__btn-glyph" aria-hidden="true"></span>
          <span data-lf-forge-label>{t(ui.forge)}</span>
        </button>
      </div>

      <!-- 1. сборка файлов модуля по одному -->
      <div class="lf-forge__stage" data-lf-stage="files" data-on="false">
        <span class="lf-forge__stage-cap caption">{t({ ru: "1 · тема собирается как код", en: "1 · topic assembles as code" })}</span>
        <ul class="lf-forge__files" role="list">
          {
            forgeFiles.map((f, k) => (
              <li class="lf-forge__file" data-file={k} style={`--i:${k}`}>
                <span class="lf-forge__file-dot" aria-hidden="true"></span>
                <span class="lf-forge__file-name mono">{f.name}</span>
                <span class="lf-forge__file-kind">{t(f.kind)}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- 2. Zod-гейт контракта -->
      <div class="lf-forge__stage" data-lf-stage="zod" data-on="false">
        <span class="lf-forge__stage-cap caption">
          {t({ ru: "2 · общий Zod-контракт (web + api)", en: "2 · shared Zod contract (web + api)" })}
        </span>
        <div class="lf-forge__schema mono" data-state="pass" data-lf-schema aria-hidden="true">
          <span class="lf-forge__sline lf-forge__sline--head">topicSchema = z.object(&#123;</span>
          {
            schemaFields.map((f) => (
              <span class="lf-forge__sline">{"  "}{f.key}: <em>{f.type}</em>,</span>
            ))
          }
          <span class="lf-forge__sline lf-forge__sline--bad" data-lf-badline>{"  "}_inject: <em>z.any()</em>,</span>
          <span class="lf-forge__sline lf-forge__sline--head">&#125;)</span>
          <span class="lf-forge__sline lf-forge__sline--infer">type Topic = z.infer&lt;typeof topicSchema&gt;</span>
        </div>
        <div class="lf-forge__gate" data-lf-gate data-state="pass" role="status" aria-live="polite">
          <span class="lf-forge__gate-icon" aria-hidden="true"></span>
          <span class="lf-forge__gate-text" data-lf-gatetext>{t({ ru: "PASS · форма валидна для web и api", en: "PASS · shape valid for web and api" })}</span>
        </div>
        <button class="lf-forge__toggle" type="button" data-lf-badfield aria-pressed="false">
          {t(ui.badField)}
        </button>
      </div>

      <!-- 3. прогон в песочнице → PR -->
      <div class="lf-forge__stage" data-lf-stage="pr" data-on="false">
        <span class="lf-forge__stage-cap caption">{t({ ru: "3 · gold-прогон → pull request", en: "3 · gold run → pull request" })}</span>
        <ul class="lf-forge__pipe" role="list">
          <li class="lf-forge__pipe-step" data-pipe="0">
            <span class="lf-forge__pipe-dot" aria-hidden="true"></span>
            {t({ ru: "gold-решение прогнано в песочнице", en: "gold solution ran in the sandbox" })}
          </li>
          <li class="lf-forge__pipe-step" data-pipe="1">
            <span class="lf-forge__pipe-dot" aria-hidden="true"></span>
            <span class="mono">topic/sql-joins → main</span>
          </li>
        </ul>
        <div class="lf-forge__pr mono" data-lf-pr>
          <span class="lf-forge__pr-state">PR #142 · open</span>
        </div>
      </div>

      <!-- BYOK + стек -->
      <footer class="lf-forge__foot">
        <button class="lf-forge__byok" type="button" data-lf-byok aria-expanded="false">
          <span class="lf-forge__byok-key" aria-hidden="true"></span>
          <span>{t({ ru: "BYOK · ключи в браузере", en: "BYOK · keys in the browser" })}</span>
        </button>
        <p class="lf-forge__byok-note mono" data-lf-byok-note hidden>
          OpenAI · Anthropic · Ollama · OpenRouter
        </p>
        <span class="lf-forge__stack caption">ts-fsrs · IndexedDB</span>
      </footer>
    </aside>
  </div>
</section>

<style>
  .lf {
    --lf-accent: var(--project-accent);
    --lf-line: color-mix(in srgb, var(--lf-accent) 38%, transparent);
    --lf-glow: color-mix(in srgb, var(--lf-accent) 16%, transparent);
    --lf-soft: color-mix(in srgb, var(--lf-accent) 12%, transparent);
    --lf-faint: color-mix(in srgb, var(--lf-accent) 6%, transparent);
    --lf-err: color-mix(in srgb, var(--state-error) 70%, var(--text-muted));
    --lf-err-soft: color-mix(in srgb, var(--lf-err) 13%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .lf__intro {
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 70ch;
  }

  /* ── statline ── */
  .lf__statline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
  }

  .lf__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    font-size: var(--fs-12);
    color: var(--text-muted);
    font-family: var(--font-stack-mono);
  }

  .lf__stat b {
    font-size: var(--fs-15);
    font-weight: var(--fw-bold);
    color: var(--lf-accent);
  }

  .lf__stat--local {
    color: var(--text-muted);
  }

  /* ── верстак: два столбца ── */
  .lf__bench {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: var(--sp-4);
    align-items: start;
  }

  /* ════════════════ ЛЕВО: мини-IDE ════════════════ */
  .lf-ide {
    display: flex;
    flex-direction: column;
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 80% at 0% 0%, var(--lf-glow), transparent 52%),
      var(--bg-elevated);
    overflow: hidden;
  }

  .lf-ide__bar {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    border-bottom: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }

  .lf-ide__dots {
    display: inline-flex;
    gap: 6px;
  }

  .lf-ide__dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--surface-3);
  }

  .lf-ide__file {
    font-size: var(--fs-12);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* вкладки рантайма */
  .lf-ide__runtimes {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4) 0;
  }

  .lf-ide__runtime {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm) var(--r-sm) 0 0;
    border-bottom: 0;
    background: transparent;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .lf-ide__runtime:hover {
    border-color: var(--border-hover);
  }

  .lf-ide__runtime[aria-selected="true"] {
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }

  .lf-ide__runtime:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .lf-ide__runtime-lang {
    font-size: var(--fs-13);
    color: var(--text);
  }

  .lf-ide__runtime[aria-selected="true"] .lf-ide__runtime-lang {
    color: var(--lf-accent);
  }

  .lf-ide__runtime-engine {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }

  .lf-ide__worker {
    margin-left: auto;
    color: var(--text-muted);
  }

  /* редактор: gutter + код */
  .lf-ide__editor {
    display: flex;
    gap: var(--sp-3);
    margin: 0 var(--sp-4);
    padding: var(--sp-3);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: 0 var(--r-sm) var(--r-sm) var(--r-sm);
    background: var(--bg-deep);
    overflow-x: auto;
  }

  .lf-ide__gutter {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding-right: var(--sp-3);
    border-right: var(--bw-thin) solid var(--border);
    font-size: var(--fs-13);
    line-height: 1.7;
    color: var(--text-faint);
    user-select: none;
    text-align: right;
  }

  .lf-ide__code {
    margin: 0;
    font-size: var(--fs-13);
    line-height: 1.7;
    color: var(--text-secondary);
    white-space: pre;
    tab-size: 2;
  }

  .lf-ide__code code {
    color: inherit;
  }

  /* появление кода при смене варианта/рантайма */
  .lf.is-inview .lf-ide__code.is-swap {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
  }

  @keyframes lf-fade {
    from {
      opacity: 0;
      transform: translate3d(0, 5px, 0);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* селектор варианта */
  .lf-ide__variants {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    padding: var(--sp-4) var(--sp-4) 0;
  }

  .lf-ide__variant {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }

  .lf-ide__variant:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  .lf-ide__variant[aria-checked="true"] {
    color: var(--text);
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }

  .lf-ide__variant:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  /* run row */
  .lf-ide__run {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4);
  }

  .lf-ide__runbtn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-pill);
    background: var(--lf-soft);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-semibold);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-spring);
  }

  .lf-ide__runbtn:hover {
    border-color: var(--lf-accent);
  }

  .lf-ide__runbtn:active {
    transform: scale(0.96);
  }

  .lf-ide__runbtn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .lf-ide__runbtn-glyph {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 5px 0 5px 9px;
    border-color: transparent transparent transparent var(--lf-accent);
  }

  /* во время «прогона» глиф пульсирует масштабом (только в кадре) */
  .lf-ide[data-busy="true"] .lf-ide__runbtn-glyph {
    border-color: transparent transparent transparent var(--text-muted);
  }

  .lf.is-inview .lf-ide[data-busy="true"] .lf-ide__runbtn-glyph {
    animation: lf-pulse 600ms var(--ease-standard) infinite;
  }

  @keyframes lf-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.6); opacity: 0.5; }
  }

  .lf-ide__status {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  /* результат */
  .lf-ide__result {
    border-top: var(--bw-thin) solid var(--border);
    padding: var(--sp-4);
    background: var(--bg-deep);
  }

  .lf-ide__result[data-state="idle"] .lf-ide__table-wrap {
    opacity: 0.32;
  }

  .lf-ide__result-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .lf-ide__result-cap {
    color: var(--text-muted);
  }

  .lf-ide__verdict {
    font-size: var(--fs-12);
    font-weight: var(--fw-semibold);
    color: var(--text-muted);
    text-align: right;
    transition: color var(--dur-med) var(--ease-standard);
  }

  .lf-ide__result[data-state="ok"] .lf-ide__verdict {
    color: var(--lf-accent);
  }

  .lf-ide__result[data-state="bad"] .lf-ide__verdict {
