];
const forgeFiles: { name: string; kind: Bi }[] = [
  { name: "manifest.json", kind: { ru: "структурный контракт темы", en: "topic structural contract" } },
  { name: "theory/04-joins.ru.mdx", kind: { ru: "теория-лонгрид с визуализацией", en: "longread theory with a viz" } },
  { name: "exercises/04-joins.ru.yaml", kind: { ru: "задачи с gold-решением", en: "exercises with a gold solution" } },
