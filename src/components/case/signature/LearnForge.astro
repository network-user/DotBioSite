  label: Bi;
  code: string[];
  rows: string[][];
  note: Bi;
};
const sqlVariants: SqlVariant[] = [
  {
    ok: true,
    label: { ru: "LEFT JOIN", en: "LEFT JOIN" },
    code: [
      "SELECT a.name, b.title",
      "FROM author a",
