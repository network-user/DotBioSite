    ],
    rows: [
      ["Ada", "Analytical engine"],
      ["Linus", "Kernel notes"],
    ],
    note: { ru: "Grace без книги потерялась — не то", en: "Grace with no book is lost — not it" },
  },
];
const pyCases: { call: string; expect: string }[] = [
  { call: "Vector(3, 4).length()", expect: "5.0" },
  { call: "Vector(0, 0).length()", expect: "0.0" },
  { call: "Vector(1, 1).length()", expect: "1.4142" },
];

/* ── Акт 5: теория-виз + проверочный вопрос ──────────────────────────── */
const vizChips: Bi[] = [
  { ru: "JOIN", en: "JOIN" },
  { ru: "хеш-таблица", en: "hash table" },
  { ru: "attention", en: "attention" },
  { ru: "градиентный спуск", en: "gradient descent" },
  { ru: "токенизация", en: "tokenization" },
];
const quizPrompt: Bi = {
  ru: "Какие утверждения об INNER JOIN и LEFT JOIN верны?",
  en: "Which statements about INNER JOIN and LEFT JOIN are true?",
};
const quizChoices: { id: string; text: Bi; correct: boolean }[] = [
  { id: "a", text: { ru: "INNER JOIN оставляет только строки с совпадением с обеих сторон.", en: "INNER JOIN keeps only rows matched on both sides." }, correct: true },
  { id: "b", text: { ru: "LEFT JOIN сохраняет каждую строку правой таблицы.", en: "LEFT JOIN keeps every row of the right table." }, correct: false },
  { id: "c", text: { ru: "LEFT JOIN заполняет отсутствующие колонки справа значением NULL.", en: "LEFT JOIN fills missing right-side columns with NULL." }, correct: true },
  { id: "d", text: { ru: "Только INNER JOIN использует условие ON.", en: "Only INNER JOIN uses the ON condition." }, correct: false },
];
const quizExplain: Bi = {
  ru: "INNER отбрасывает несовпадения; LEFT сохраняет левую сторону и заполняет NULL справа. ON используют оба JOIN-а.",
  en: "INNER drops non-matches; LEFT keeps the left side and fills NULL on the right. Both JOINs use ON.",
};

/* ── Акт 6: heatmap + стрик + карточка FSRS ──────────────────────────── */
/* детерминированная (build-time) тепловая карта 7×14, без Math.random */
const HM_COLS = 14;
const HM_ROWS = 7;
const heatmap: number[] = Array.from({ length: HM_COLS * HM_ROWS }, (_, i) => {
  const col = Math.floor(i / HM_ROWS);
  const row = i % HM_ROWS;
  const wave = (col * 5 + row * 3 + ((col * row) % 7)) % 11;
  if (col > HM_COLS - 3 && row > 4) return 0; /* «будущее» пусто */
  return wave > 8 ? 4 : wave > 6 ? 3 : wave > 4 ? 2 : wave > 2 ? 1 : 0;
});
const flashcard = {
  front: { ru: "Что станет с автором без книги при LEFT JOIN?", en: "What happens to an author with no book under LEFT JOIN?" } as Bi,
  back: { ru: "Строка автора останется, колонки книги будут NULL.", en: "The author row stays; the book columns become NULL." } as Bi,
};
const fsrsRatings: { key: string; label: Bi; due: Bi; tone: string }[] = [
  { key: "again", label: { ru: "Снова", en: "Again" }, due: { ru: "<10 мин", en: "<10 min" }, tone: "err" },
  { key: "hard", label: { ru: "Трудно", en: "Hard" }, due: { ru: "1 дн", en: "1 d" }, tone: "warn" },
  { key: "good", label: { ru: "Хорошо", en: "Good" }, due: { ru: "4 дн", en: "4 d" }, tone: "accent" },
  { key: "easy", label: { ru: "Легко", en: "Easy" }, due: { ru: "9 дн", en: "9 d" }, tone: "ok" },
];

/* ── Акт 7: содержимое экспорта ──────────────────────────────────────── */
const exportRows: Bi[] = [
  { ru: "прогресс и попытки", en: "progress and attempts" },
  { ru: "повторения карточек (FSRS)", en: "flashcard reviews (FSRS)" },
  { ru: "заметки и закладки", en: "notes and bookmarks" },
  { ru: "выделения и достижения", en: "highlights and achievements" },
];

/* ── Строки для скрипта (единый источник, без дублей в JS) ────────────── */
const sx = {
  runAgent: { ru: "Запустить агента", en: "Run the agent" },
  agentBusy: { ru: "lesson-forge активируется…", en: "lesson-forge activating…" },
  agentDone: { ru: "скилл активирован — куёт тему", en: "skill activated — forging" },
  approve: { ru: "Утвердить план", en: "Approve the plan" },
  forge: { ru: "Сковать тему", en: "Forge the topic" },
  forging: { ru: "Куётся…", en: "Forging…" },
  forged: { ru: "тема собрана", en: "topic assembled" },
  planWait: { ru: "план ждёт твоего «ок»", en: "plan awaits your OK" },
  inject: { ru: "Внедрить лишнее поле", en: "Inject an extra field" },
  fix: { ru: "Убрать поле", en: "Remove the field" },
  pass: { ru: "PASS · форма валидна для web и api", en: "PASS · valid for web and api" },
  reject: { ru: "REJECT · ZodError: unrecognized key — отклонено web И api", en: "REJECT · ZodError: unrecognized key — rejected by web AND api" },
  validate: { ru: "pnpm validate · gold-SQL прогнан в sql.js ✓", en: "pnpm validate · gold SQL ran in sql.js ✓" },
  run: { ru: "Запустить", en: "Run" },
