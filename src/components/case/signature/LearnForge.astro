  }

  /* промпт-чип + кнопка */
  .lf-forge__prompt {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .lf-forge__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: var(--sp-2) var(--sp-3);
