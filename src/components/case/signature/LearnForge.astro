  check: { ru: "Проверить", en: "Check" },
  quizRight: { ru: "верно — a и c", en: "correct — a and c" },
  quizWrong: { ru: "не совсем — верны a и c", en: "not quite — a and c are right" },
  flip: { ru: "Перевернуть карточку", en: "Flip the card" },
  nextDue: { ru: "следующий показ через", en: "next review in" },
  exportBtn: { ru: "Экспорт", en: "Export" },
  importBtn: { ru: "Импорт", en: "Import" },
  exported: { ru: "выгружен один JSON", en: "one JSON exported" },
  imported: { ru: "Импортировано записей: 1 248", en: "Imported records: 1,248" },
  prev: { ru: "Назад", en: "Back" },
  next: { ru: "Далее", en: "Next" },
  step: { ru: "Шаг", en: "Step" },
};
const sBundle = Object.fromEntries(Object.entries(sx).map(([k, v]) => [k, t(v)]));
sBundle.locale = locale;
---

<section
  class="lf"
  data-lf
  data-lf-bundle={JSON.stringify(sBundle)}
  aria-label={t({ ru: "Как живёт DotLearn — интерактивная история", en: "How DotLearn lives — an interactive story" })}
>
  <p class="lf__intro">{t(intro)}</p>

  <ul class="lf__stats" role="list">
    {
      stats.map((s) => (
        <li class:list={["lf__stat", s.plain && "lf__stat--plain"]}>
          {s.v && <b>{s.v}</b>}
          <span>{t(s.label)}</span>
        </li>
      ))
    }
  </ul>

  <!-- ░░░░░ горизонтальный маршрут: станции + прогресс-линия ░░░░░ -->
  <nav class="lf__journey" aria-label={t({ ru: "Шаги истории", en: "Story steps" })}>
    <ol class="lf__spine" role="tablist">
      {
        acts.map((a, i) => (
          <li class="lf__station">
            <button
              class="lf__st"
              type="button"
              role="tab"
              id={`lf-tab-${a.id}`}
              aria-controls={`lf-panel-${a.id}`}
              aria-selected={i === 0 ? "true" : "false"}
              tabindex={i === 0 ? 0 : -1}
              data-lf-tab={a.id}
              data-i={i}
            >
              <span class="lf__st-node" aria-hidden="true">
                <span class="lf__st-num">{i + 1}</span>
                <span class="lf__st-check" />
              </span>
              <span class="lf__st-label">{t(a.eyebrow)}</span>
            </button>
          </li>
        ))
      }
    </ol>
  </nav>

  <!-- ░░░░░ stage активного акта ░░░░░ -->
  <div class="lf__stage">
    {
      acts.map((a, i) => (
        <section
          class:list={["lf-act", i === 0 && "is-active"]}
          id={`lf-panel-${a.id}`}
          role="tabpanel"
          aria-labelledby={`lf-tab-${a.id}`}
          data-lf-panel={a.id}
          hidden={i !== 0}
        >
          <header class="lf-act__head">
            <span class="lf-act__eyebrow">
              <span class="lf-act__eyebrow-n">{`0${i + 1}`}</span>
              {t(a.eyebrow)}
            </span>
            <h3 class="lf-act__title">{t(a.title)}</h3>
            <p class="lf-act__lede">{t(a.lede)}</p>
          </header>

          <div class="lf-act__body">
            {/* ═════════ Акт 1: clone ═════════ */}
            {a.id === "clone" && (
              <div class="lf-clone">
                <div class="lf-term" data-lf-term aria-hidden="true">
                  <div class="lf-term__bar"><i /><i /><i /></div>
                  <div class="lf-term__body mono">
                    {termLines.map((l, k) => (
                      <div class:list={["lf-term__line", `lf-term__line--${l.kind}`]} data-term={k}>
                        {l.kind === "cmd" && <span class="lf-term__sigil">$</span>}
                        <span class="lf-term__cmd">{l.text}</span>
                      </div>
                    ))}
                  </div>
                </div>
                <div class="lf-ask">
                  <span class="lf-ask__cap caption">
                    {t({ ru: "в редакторе (Cursor / Claude Code):", en: "in your editor (Cursor / Claude Code):" })}
                  </span>
                  <div class="lf-ask__bubble">
                    <span class="lf-ask__sigil mono" aria-hidden="true">/</span>
                    <span class="lf-ask__text">{t(agentPrompt)}</span>
                  </div>
                  <div class="lf-act__run">
                    <button class="lf-btn lf-btn--accent" type="button" data-lf-clone-run>
                      <span class="lf-btn__glyph lf-btn__glyph--play" aria-hidden="true" />
                      <span data-lf-clone-label>{t(sx.runAgent)}</span>
                    </button>
                    <span class="lf-status mono" data-lf-clone-status role="status" aria-live="polite" />
                  </div>
                </div>
              </div>
            )}

            {/* ═════════ Акт 2: forge ═════════ */}
            {a.id === "forge" && (
              <div class="lf-forge">
                <div class="lf-plan" data-lf-plan>
                  <span class="lf-plan__cap caption">
                    {t({ ru: "план программы · 6 концептов", en: "curriculum plan · 6 concepts" })}
                  </span>
                  <ol class="lf-plan__list">
                    {planConcepts.map((c, k) => (
                      <li class="lf-plan__item" data-plan={k}>
                        <span class="lf-plan__dot" aria-hidden="true" />
                        {t(c)}
                      </li>
                    ))}
                  </ol>
                </div>
                <div class="lf-files" data-lf-files>
                  <span class="lf-files__cap caption">topics/sql-joins/</span>
                  <ul class="lf-files__list" role="list">
                    {forgeFiles.map((f, k) => (
                      <li class="lf-file" data-file={k}>
                        <span class="lf-file__dot" aria-hidden="true" />
                        <span class="lf-file__name mono">{f.name}</span>
                        <span class="lf-file__kind">{t(f.kind)}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="lf-act__run">
                  <button class="lf-btn lf-btn--accent" type="button" data-lf-forge-run>
                    <span class="lf-btn__glyph lf-btn__glyph--spark" aria-hidden="true" />
                    <span data-lf-forge-label>{t(sx.approve)}</span>
                  </button>
                  <span class="lf-status mono" data-lf-forge-status role="status" aria-live="polite">
                    {t(sx.planWait)}
                  </span>
                </div>
              </div>
            )}

            {/* ═════════ Акт 3: contract ═════════ */}
            {a.id === "contract" && (
              <div class="lf-contract">
                <div class="lf-schema mono" data-lf-schema data-state="pass" aria-hidden="true">
                  <span class="lf-schema__line lf-schema__line--head">topicSchema = z.object(&#123;</span>
                  {schemaFields.map((f) => (
                    <span class="lf-schema__line">{"  "}{f.key}: <em>{f.type}</em>,</span>
                  ))}
                  <span class="lf-schema__line lf-schema__line--bad" data-lf-badline>{"  "}_inject: <em>z.any()</em>,</span>
                  <span class="lf-schema__line lf-schema__line--head">&#125;).strict()</span>
                  <span class="lf-schema__line lf-schema__line--infer">type Topic = z.infer&lt;typeof topicSchema&gt;</span>
                </div>
                <div class="lf-gate__wrap">
                  <div class="lf-gate" data-lf-gate data-state="pass" role="status" aria-live="polite">
                    <span class="lf-gate__icon" aria-hidden="true" />
                    <span class="lf-gate__text" data-lf-gate-text>{t(sx.pass)}</span>
                  </div>
                  <span class="lf-validate mono">{t(sx.validate)}</span>
                </div>
                <button class="lf-toggle" type="button" data-lf-inject aria-pressed="false">
                  {t(sx.inject)}
                </button>
              </div>
            )}

            {/* ═════════ Акт 4: solve ═════════ */}
            {a.id === "solve" && (
              <div class="lf-ide" data-lf-ide>
                <div class="lf-ide__tabs" role="tablist" aria-label={t({ ru: "Рантайм", en: "Runtime" })}>
                  <button class="lf-ide__tab" type="button" role="tab" data-lf-rt="sql" aria-selected="true" tabindex="0">
                    <span class="mono">sql.js</span>
                    <span class="lf-ide__tab-sub">{t({ ru: "SQLite в WASM", en: "SQLite in WASM" })}</span>
                  </button>
                  <button class="lf-ide__tab" type="button" role="tab" data-lf-rt="py" aria-selected="false" tabindex="-1">
                    <span class="mono">Pyodide</span>
                    <span class="lf-ide__tab-sub">{t({ ru: "Python в WASM", en: "Python in WASM" })}</span>
                  </button>
                  <span class="lf-ide__worker caption">{t({ ru: "в Web Worker", en: "in a Web Worker" })}</span>
                </div>

                <div class="lf-ide__editor">
                  <pre class="lf-ide__code mono" data-lf-code aria-live="polite"><code>{sqlVariants[0]!.code.join("\n")}</code></pre>
                </div>

                <div class="lf-ide__variants" data-lf-variants role="radiogroup" aria-label={t({ ru: "Вариант решения", en: "Solution variant" })}>
                  {sqlVariants.map((v, k) => (
                    <button class="lf-chip" type="button" role="radio" data-lf-variant={k} aria-checked={k === 0 ? "true" : "false"} tabindex={k === 0 ? 0 : -1}>
                      {t(v.label)}
                    </button>
                  ))}
                </div>

                <div class="lf-act__run">
                  <button class="lf-btn lf-btn--accent" type="button" data-lf-run>
                    <span class="lf-btn__glyph lf-btn__glyph--play" aria-hidden="true" />
                    <span>{t(sx.run)}</span>
                  </button>
                  <span class="lf-status mono" data-lf-run-status role="status" aria-live="polite">{t(sx.ready)}</span>
                </div>

                <div class="lf-ide__out" data-lf-out data-kind="sql" data-state="idle">
                  <div class="lf-ide__out-head">
                    <span class="caption">{t({ ru: "результат прогона", en: "run output" })}</span>
                    <span class="lf-ide__verdict mono" data-lf-verdict />
                  </div>
                  <div class="lf-ide__table-wrap" data-lf-sqlout>
                    <table class="lf-ide__table"><thead data-lf-thead /><tbody data-lf-tbody /></table>
                  </div>
                  <ul class="lf-ide__cases" data-lf-pyout hidden>
                    {pyCases.map((c, k) => (
                      <li class="lf-ide__case" data-case={k}>
                        <span class="lf-ide__case-mark" aria-hidden="true" />
                        <span class="mono">{c.call}</span>
                        <span class="lf-ide__case-eq mono">→ {c.expect}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}

            {/* ═════════ Акт 5: theory ═════════ */}
            {a.id === "theory" && (
              <div class="lf-theory">
                <ul class="lf-theory__chips" data-lf-viz role="list" aria-label={t({ ru: "Визуализации в теории", en: "Theory visualizations" })}>
                  {vizChips.map((c, k) => (
                    <li class="lf-vchip" data-viz={k}>{t(c)}</li>
                  ))}
                </ul>
                <div class="lf-quiz" data-lf-quiz>
                  <span class="lf-quiz__cap caption">{t({ ru: "проверочный вопрос · theory-quiz", en: "check question · theory-quiz" })}</span>
                  <p class="lf-quiz__prompt">{t(quizPrompt)}</p>
                  <ul class="lf-quiz__choices" role="list">
                    {quizChoices.map((c) => (
                      <li>
                        <button class="lf-quiz__choice" type="button" data-lf-choice={c.id} data-correct={c.correct ? "1" : "0"} aria-pressed="false">
                          <span class="lf-quiz__mark" aria-hidden="true">{c.id}</span>
                          <span>{t(c.text)}</span>
                        </button>
                      </li>
                    ))}
                  </ul>
                  <div class="lf-act__run">
                    <button class="lf-btn lf-btn--accent" type="button" data-lf-quiz-check>{t(sx.check)}</button>
                    <span class="lf-status mono" data-lf-quiz-status role="status" aria-live="polite" />
                  </div>
                  <p class="lf-quiz__explain" data-lf-quiz-explain hidden>{t(quizExplain)}</p>
                </div>
              </div>
            )}

            {/* ═════════ Акт 6: habit ═════════ */}
            {a.id === "habit" && (
              <div class="lf-habit">
                <div class="lf-streak">
                  <div class="lf-streak__head">
                    <span class="lf-streak__num" data-lf-streak>0</span>
                    <span class="lf-streak__cap">{t({ ru: "стрик · подряд идущих дней", en: "streak · consecutive days" })}</span>
                  </div>
                  <div class="lf-heat" data-lf-heat aria-hidden="true" style={`--cols:${HM_COLS}`}>
                    {heatmap.map((lvl, k) => (
                      <span class="lf-heat__cell" data-lvl={lvl} data-k={k} />
                    ))}
                  </div>
                  <span class="lf-heat__cap caption">{t({ ru: "тепловая карта активности · IndexedDB", en: "activity heatmap · IndexedDB" })}</span>
                </div>

                <div class="lf-card" data-lf-card>
                  <span class="lf-card__cap caption">{t({ ru: "интервальное повторение · FSRS", en: "spaced repetition · FSRS" })}</span>
                  <button class="lf-card__flip" type="button" data-lf-flip aria-label={t(sx.flip)}>
                    <span class="lf-card__inner" data-lf-card-inner>
                      <span class="lf-card__face lf-card__face--front">{t(flashcard.front)}</span>
                      <span class="lf-card__face lf-card__face--back">{t(flashcard.back)}</span>
                    </span>
                  </button>
                  <div class="lf-card__ratings" data-lf-ratings data-armed="false">
                    {fsrsRatings.map((r) => (
                      <button class="lf-rate" type="button" data-lf-rate={r.key} data-tone={r.tone}>
                        <span class="lf-rate__label">{t(r.label)}</span>
                        <span class="lf-rate__due mono">{t(r.due)}</span>
                      </button>
                    ))}
                  </div>
                  <span class="lf-status mono" data-lf-card-status role="status" aria-live="polite" />
                </div>
              </div>
            )}

            {/* ═════════ Акт 7: export ═════════ */}
            {a.id === "export" && (
              <div class="lf-export">
                <div class="lf-export__file" data-lf-file-card data-on="false">
                  <span class="lf-export__name mono">dotlearn-progress-2026-06-30.json</span>
                  <ul class="lf-export__rows" role="list">
                    {exportRows.map((r, k) => (
                      <li class="lf-export__row" data-row={k}>
                        <span class="lf-export__check" aria-hidden="true" />
                        {t(r)}
                      </li>
                    ))}
                  </ul>
                  <span class="lf-export__foot caption">version 4 · app: "dotlearn" · {t({ ru: "без аккаунта", en: "no account" })}</span>
                </div>
                <div class="lf-export__controls">
                  <button class="lf-btn lf-btn--accent" type="button" data-lf-export>
                    <span class="lf-btn__glyph lf-btn__glyph--down" aria-hidden="true" />
                    <span>{t(sx.exportBtn)}</span>
                  </button>
                  <button class="lf-btn" type="button" data-lf-import>
                    <span class="lf-btn__glyph lf-btn__glyph--up" aria-hidden="true" />
                    <span>{t(sx.importBtn)}</span>
                  </button>
                  <span class="lf-status mono" data-lf-export-status role="status" aria-live="polite" />
                </div>
              </div>
            )}
          </div>
        </section>
      ))
    }

    <!-- пейджер -->
    <footer class="lf__pager">
      <button class="lf__pager-btn" type="button" data-lf-prev aria-label={t(sx.prev)}>
        <span aria-hidden="true">←</span>
        <span class="lf__pager-word">{t(sx.prev)}</span>
      </button>
      <span class="lf__pager-step mono" data-lf-step>{`01 / 0${acts.length}`}</span>
      <button class="lf__pager-btn lf__pager-btn--next" type="button" data-lf-next aria-label={t(sx.next)}>
        <span class="lf__pager-word">{t(sx.next)}</span>
        <span aria-hidden="true">→</span>
      </button>
    </footer>
  </div>
</section>

<style>
  .lf {
    --lf-accent: var(--project-accent, var(--accent-learn));
    --lf-line: color-mix(in srgb, var(--lf-accent) 40%, transparent);
    --lf-glow: color-mix(in srgb, var(--lf-accent) 16%, transparent);
    --lf-soft: color-mix(in srgb, var(--lf-accent) 13%, transparent);
    --lf-faint: color-mix(in srgb, var(--lf-accent) 7%, transparent);
    --lf-err: color-mix(in srgb, var(--state-error) 72%, var(--text-muted));
    --lf-err-soft: color-mix(in srgb, var(--lf-err) 14%, transparent);
    --lf-warn: color-mix(in srgb, var(--state-warn) 72%, var(--text-muted));
    --lf-ok: color-mix(in srgb, var(--state-ok, var(--lf-accent)) 72%, var(--text-muted));
    --lf-frac: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .lf__intro {
    font-size: var(--fs-17);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 74ch;
    margin: 0;
  }

  /* ── statline ── */
  .lf__stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
  }
  .lf__stat {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .lf__stat b {
    font-size: var(--fs-22);
    font-weight: var(--fw-bold);
    color: var(--lf-accent);
    line-height: 1;
  }
  .lf__stat--plain {
    color: var(--text-faint);
  }

  /* ═══════════ горизонтальный маршрут ═══════════ */
  .lf__journey {
    width: 100%;
    min-width: 0;
  }
  .lf__spine {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    position: relative;
  }
  /* трек-линия и заливка прогресса — на высоте центра узла */
  .lf__spine::before,
  .lf__spine::after {
    content: "";
    position: absolute;
    top: 23px;
    height: 2px;
    left: calc(100% / 14);
    right: calc(100% / 14);
    border-radius: 2px;
  }
  .lf__spine::before {
    background: var(--border);
  }
  .lf__spine::after {
    right: auto;
    width: calc((100% - 100% / 7) * var(--lf-frac));
    background: var(--lf-accent);
    transition: width var(--dur-slow) var(--ease-soft);
  }
  .lf__station {
    min-width: 0;
  }
  .lf__st {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    width: 100%;
    padding: 0 var(--sp-1) var(--sp-1);
    border: 0;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    text-align: center;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .lf__st:hover {
    color: var(--text-secondary);
  }
  .lf__st-node {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border: var(--bw-med) solid var(--border);
    border-radius: 50%;
    background: var(--bg-elevated);
    transition:
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .lf__st-num {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-16);
    font-weight: var(--fw-semibold);
    color: var(--text-muted);
    transition: opacity var(--dur-fast) var(--ease-standard);
  }
  /* галочка для пройденных */
  .lf__st-check {
    position: absolute;
    width: 16px;
    height: 9px;
    border-left: var(--bw-thick) solid var(--lf-accent);
    border-bottom: var(--bw-thick) solid var(--lf-accent);
    transform: rotate(-45deg) translateY(-1px) scale(0.6);
    opacity: 0;
    transition:
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-med) var(--ease-spring);
  }
  .lf__st-label {
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    line-height: var(--lh-snug);
    max-width: 14ch;
  }
  /* пройденная станция: контур + галочка, цифра скрыта */
  .lf__st[data-done="true"] .lf__st-node {
    border-color: var(--lf-line);
    background: var(--bg-elevated);
  }
  .lf__st[data-done="true"] .lf__st-num {
    opacity: 0;
  }
  .lf__st[data-done="true"] .lf__st-check {
    opacity: 1;
    transform: rotate(-45deg) translateY(-1px) scale(1);
  }
  /* активная станция: залитый акцентом узел — однозначно доминирует */
  .lf__st[aria-selected="true"] {
    color: var(--text);
  }
  .lf__st[aria-selected="true"] .lf__st-label {
    font-weight: var(--fw-semibold);
  }
  .lf__st[aria-selected="true"] .lf__st-node {
    border-color: var(--lf-accent);
    background: var(--lf-accent);
    transform: scale(1.18);
    box-shadow: 0 0 0 5px var(--lf-faint);
  }
  .lf__st[aria-selected="true"] .lf__st-num {
    color: var(--bg-deep);
  }
  .lf__st:focus-visible {
    outline: none;
  }
  .lf__st:focus-visible .lf__st-node {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
  }

  /* ═══════════ stage ═══════════ */
  .lf__stage {
    display: flex;
    flex-direction: column;
    min-width: 0;
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-xl);
    background:
      radial-gradient(130% 90% at 100% 0%, var(--lf-glow), transparent 58%),
      var(--bg-elevated);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }
  .lf-act {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    padding: var(--sp-7) var(--sp-7) var(--sp-6);
  }
  .lf-act[hidden] {
    display: none;
  }
  .lf.is-inview .lf-act.is-active {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
  }

  .lf-act__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .lf-act__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--lf-accent);
  }
  .lf-act__eyebrow-n {
    color: var(--text-faint);
  }
  .lf-act__title {
    margin: 0;
    font-family: var(--font-stack-display);
    font-size: clamp(var(--fs-22), 2.6vw, var(--fs-32));
    font-weight: var(--fw-semibold);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--text);
  }
  .lf-act__lede {
    margin: 0;
    font-size: var(--fs-17);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 66ch;
  }
  .lf-act__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .lf-act__run {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-4);
  }

  /* ── общие: кнопки / чипы / статус ── */
  .lf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-3) var(--sp-5);
    border: var(--bw-thin) solid var(--border-hover);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text);
    font-family: var(--font-stack-display);
    font-size: var(--fs-15);
    font-weight: var(--fw-semibold);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-spring);
  }
  .lf-btn--accent {
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }
  .lf-btn:hover {
    border-color: var(--lf-accent);
  }
  .lf-btn:active {
    transform: scale(0.96);
  }
  .lf-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .lf-btn__glyph {
    flex: none;
  }
  .lf-btn__glyph--play {
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 6px 0 6px 10px;
    border-color: transparent transparent transparent var(--lf-accent);
  }
  .lf-btn__glyph--spark {
    width: 13px;
    height: 13px;
    background:
      linear-gradient(to bottom, var(--lf-accent) 0 100%) center / 2px 13px no-repeat,
      linear-gradient(to right, var(--lf-accent) 0 100%) center / 13px 2px no-repeat;
  }
  .lf-btn__glyph--down,
  .lf-btn__glyph--up {
    width: 11px;
    height: 11px;
    border-right: 2px solid var(--lf-accent);
    border-bottom: 2px solid var(--lf-accent);
  }
  .lf-btn__glyph--down {
    transform: rotate(45deg) translate(-1px, -1px);
  }
  .lf-btn__glyph--up {
    transform: rotate(-135deg) translate(-1px, -1px);
  }

  .lf-chip {
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    color: var(--text-secondary);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .lf-chip:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .lf-chip[aria-checked="true"] {
    color: var(--text);
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }
  .lf-chip:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  .lf-status {
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .lf-status[data-tone="ok"] {
    color: var(--lf-accent);
  }
  .lf-status[data-tone="bad"] {
    color: var(--lf-err);
  }

  .lf-toggle {
    align-self: flex-start;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .lf-toggle:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .lf-toggle[aria-pressed="true"] {
    color: var(--text);
    border-color: color-mix(in srgb, var(--lf-err) 50%, transparent);
  }
  .lf-toggle:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }

  @keyframes lf-fade {
    from { opacity: 0; transform: translate3d(0, 8px, 0); }
    to { opacity: 1; transform: none; }
  }
  @keyframes lf-slide {
    from { opacity: 0; transform: translate3d(-12px, 0, 0); }
    to { opacity: 1; transform: none; }
  }
  @keyframes lf-pop {
    0% { opacity: 0; transform: scale(0.8); }
    60% { transform: scale(1.05); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* ════════ Акт 1: clone ════════ */
  .lf-clone {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: var(--sp-5);
    align-items: start;
  }
  .lf-term {
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    overflow: hidden;
  }
  .lf-term__bar {
    display: flex;
    gap: 7px;
    padding: var(--sp-3) var(--sp-4);
    border-bottom: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }
  .lf-term__bar i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--surface-3);
  }
  .lf-term__body {
    display: flex;
    flex-direction: column;
    padding: var(--sp-4);
    font-size: var(--fs-14);
    line-height: 1.5;
  }
  .lf-term__line {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    padding: 3px 0;
    white-space: nowrap;
    opacity: 0;
  }
  .lf-term__line.is-show {
    opacity: 1;
  }
  .lf.is-inview .lf-term__line.is-show {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
  }
  .lf-term__sigil {
    flex: none;
    color: var(--lf-accent);
  }
  .lf-term__cmd {
    min-width: 0;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lf-term__line--ok .lf-term__cmd {
    color: var(--lf-accent);
  }
  .lf-ask {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .lf-ask__cap {
    color: var(--text-muted);
  }
  .lf-ask__bubble {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-sm) var(--r-md) var(--r-md) var(--r-md);
    background: var(--lf-faint);
    color: var(--text);
    font-size: var(--fs-15);
    line-height: var(--lh-snug);
  }
  .lf-ask__sigil {
    flex: none;
    font-weight: var(--fw-bold);
    color: var(--lf-accent);
  }

  /* ════════ Акт 2: forge ════════ */
  .lf-forge {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: var(--sp-4);
    align-items: start;
  }
  .lf-plan,
  .lf-files {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
  }
  .lf-plan {
    transition:
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard);
  }
  .lf-plan[data-state="approved"] {
    border-color: var(--lf-line);
    background: var(--lf-faint);
  }
  .lf-plan__cap,
  .lf-files__cap {
    color: var(--text-muted);
  }
  .lf-files__cap {
    font-family: var(--font-stack-mono);
  }
  .lf-plan__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .lf-plan__item {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-14);
    color: var(--text-secondary);
  }
  .lf-plan__item[data-plan="3"] {
    color: var(--text);
    font-weight: var(--fw-semibold);
  }
  .lf-plan__dot {
    flex: none;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lf-accent);
    opacity: 0.5;
  }
  .lf-plan__item[data-plan="3"] .lf-plan__dot {
    opacity: 1;
  }
  .lf-files__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .lf-file {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    opacity: 0;
  }
  .lf-file.is-show {
    opacity: 1;
  }
  .lf.is-inview .lf-file.is-show {
    animation: lf-slide var(--dur-slow) var(--ease-soft) both;
  }
  .lf-file__dot {
    flex: none;
    align-self: center;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--lf-accent);
  }
  .lf-file__name {
    font-size: var(--fs-13);
    color: var(--text);
    word-break: break-word;
  }
  .lf-file__kind {
    margin-left: auto;
    font-size: var(--fs-12);
    color: var(--text-muted);
    text-align: right;
  }

  /* ════════ Акт 3: contract ════════ */
  .lf-contract {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .lf-schema {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    font-size: var(--fs-13);
    line-height: 1.5;
    color: var(--text-secondary);
    overflow-x: auto;
  }
  .lf-schema__line {
    white-space: pre;
  }
  .lf-schema__line--head {
    color: var(--text);
  }
  .lf-schema__line em {
    font-style: normal;
    color: var(--lf-accent);
  }
  .lf-schema__line--infer {
    margin-top: 4px;
    color: var(--text-muted);
  }
  .lf-schema__line--bad {
    display: none;
    color: var(--lf-err);
  }
  .lf-schema__line--bad em {
    color: var(--lf-err);
  }
  .lf-schema[data-state="fail"] .lf-schema__line--bad {
    display: block;
  }
  .lf-gate__wrap {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-4);
  }
  .lf-gate {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-pill);
    background: var(--lf-soft);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text);
    transition:
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard);
  }
  .lf-gate__icon {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--lf-accent);
    transition:
      background-color var(--dur-med) var(--ease-standard),
      border-radius var(--dur-med) var(--ease-standard);
  }
  .lf-gate[data-state="fail"] {
    border-color: color-mix(in srgb, var(--lf-err) 55%, transparent);
    background: var(--lf-err-soft);
  }
  .lf-gate[data-state="fail"] .lf-gate__icon {
    background: var(--lf-err);
    border-radius: 1px;
  }
  .lf.is-inview .lf-gate[data-state="fail"].is-shake {
    animation: lf-shake var(--dur-slow) var(--ease-standard);
  }
  @keyframes lf-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }
  .lf-validate {
    font-size: var(--fs-13);
    color: var(--text-muted);
  }

  /* ════════ Акт 4: solve ════════ */
  .lf-ide {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    padding: var(--sp-4);
    background: var(--surface);
  }
  .lf-ide__tabs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .lf-ide__tab {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: transparent;
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .lf-ide__tab[aria-selected="true"] {
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }
  .lf-ide__tab[aria-selected="true"] .mono {
    color: var(--lf-accent);
  }
  .lf-ide__tab .mono {
    font-size: var(--fs-14);
    color: var(--text);
  }
  .lf-ide__tab-sub {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .lf-ide__tab:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .lf-ide__worker {
    margin-left: auto;
    color: var(--text-muted);
  }
  .lf-ide__editor {
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    overflow-x: auto;
  }
  .lf-ide__code {
    margin: 0;
    font-size: var(--fs-14);
    line-height: 1.75;
    color: var(--text-secondary);
    white-space: pre;
    tab-size: 2;
  }
  .lf.is-inview .lf-ide__code.is-swap {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
  }
  .lf-ide__variants {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .lf-ide__variants[hidden] {
    display: none;
  }
  .lf-ide__out {
    border-top: var(--bw-thin) solid var(--border);
    padding-top: var(--sp-4);
  }
  .lf-ide__out[data-state="idle"] .lf-ide__table-wrap,
  .lf-ide__out[data-state="idle"] .lf-ide__cases {
    opacity: 0.32;
  }
  .lf-ide__out-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }
  .lf-ide__out-head .caption {
    color: var(--text-muted);
  }
  .lf-ide__verdict {
    font-size: var(--fs-13);
    font-weight: var(--fw-semibold);
    color: var(--text-muted);
    transition: color var(--dur-med) var(--ease-standard);
  }
  .lf-ide__out[data-state="ok"] .lf-ide__verdict {
    color: var(--lf-accent);
  }
  .lf-ide__out[data-state="bad"] .lf-ide__verdict {
    color: var(--lf-err);
  }
  .lf-ide__table-wrap {
    overflow-x: auto;
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .lf-ide__table {
    border-collapse: collapse;
    width: max-content;
    min-width: 100%;
    font-family: var(--font-stack-mono);
  }
  .lf-ide__table :global(th),
  .lf-ide__table :global(td) {
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    font-size: var(--fs-14);
    text-align: left;
    white-space: nowrap;
  }
  .lf-ide__table :global(th) {
    color: var(--lf-accent);
    background: var(--surface);
    font-weight: var(--fw-semibold);
  }
  .lf-ide__table :global(td) {
    color: var(--text);
  }
  .lf-ide__table :global(td.is-null) {
    color: var(--text-faint);
  }
  .lf-ide__table :global(tr[data-bad="1"] td) {
    color: var(--lf-err);
    background: var(--lf-err-soft);
  }
  .lf.is-inview .lf-ide__table :global(tr.is-row) {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
    animation-delay: calc(var(--ri, 0) * 80ms);
  }
  .lf-ide__cases {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .lf-ide__cases[hidden] {
    display: none;
  }
  .lf-ide__case {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    font-size: var(--fs-13);
    color: var(--text-secondary);
  }
  .lf-ide__case-mark {
    flex: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: var(--bw-thin) solid var(--border);
  }
  .lf-ide__case.is-pass .lf-ide__case-mark {
    border-color: var(--lf-line);
    background:
      linear-gradient(45deg, transparent 44%, var(--lf-accent) 44% 56%, transparent 56%),
      linear-gradient(-45deg, transparent 48%, var(--lf-accent) 48% 52%, transparent 52%);
  }
  .lf.is-inview .lf-ide__case.is-pass {
    animation: lf-pop var(--dur-med) var(--ease-spring) both;
    animation-delay: calc(var(--ci, 0) * 110ms);
  }
  .lf-ide__case-eq {
    margin-left: auto;
    color: var(--lf-accent);
  }

  /* ════════ Акт 5: theory ════════ */
  .lf-theory {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .lf-theory__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .lf-vchip {
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--surface);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .lf-vchip.is-lit {
    color: var(--lf-accent);
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }
  .lf.is-inview .lf-vchip.is-lit {
    animation: lf-pop var(--dur-med) var(--ease-spring) both;
  }
  .lf-quiz {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: var(--surface);
  }
  .lf-quiz__cap {
    color: var(--text-muted);
  }
  .lf-quiz__prompt {
    margin: 0;
    font-size: var(--fs-17);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-snug);
    color: var(--text);
  }
  .lf-quiz__choices {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .lf-quiz__choice {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--sp-3) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-deep);
    color: var(--text-secondary);
    text-align: left;
    font-size: var(--fs-14);
    line-height: var(--lh-snug);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .lf-quiz__choice:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }
  .lf-quiz__choice[aria-pressed="true"] {
    color: var(--text);
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }
  .lf-quiz__choice:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .lf-quiz__mark {
    flex: none;
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .lf-quiz__choice[aria-pressed="true"] .lf-quiz__mark {
    color: var(--lf-accent);
    border-color: var(--lf-line);
  }
  .lf-quiz[data-checked="true"] .lf-quiz__choice[data-correct="1"] {
    border-color: var(--lf-line);
    background: var(--lf-soft);
    color: var(--text);
  }
  .lf-quiz[data-checked="true"] .lf-quiz__choice[data-correct="1"] .lf-quiz__mark {
    color: var(--lf-accent);
    border-color: var(--lf-line);
    background: var(--lf-soft);
  }
  .lf-quiz[data-checked="true"] .lf-quiz__choice[aria-pressed="true"][data-correct="0"] {
    border-color: color-mix(in srgb, var(--lf-err) 50%, transparent);
    background: var(--lf-err-soft);
    color: var(--lf-err);
  }
  .lf-quiz[data-checked="true"] .lf-quiz__choice[aria-pressed="true"][data-correct="0"] .lf-quiz__mark {
    color: var(--lf-err);
    border-color: color-mix(in srgb, var(--lf-err) 50%, transparent);
  }
  .lf-quiz__explain {
    margin: 0;
    padding: var(--sp-3) var(--sp-4);
    border-left: 3px solid var(--lf-line);
    font-size: var(--fs-14);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
  }
  .lf-quiz__explain[hidden] {
    display: none;
  }
  .lf.is-inview .lf-quiz__explain {
    animation: lf-fade var(--dur-med) var(--ease-soft) both;
  }

  /* ════════ Акт 6: habit ════════ */
  .lf-habit {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: var(--sp-4);
    align-items: start;
  }
  .lf-streak {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: var(--surface);
  }
  .lf-streak__head {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
  }
  .lf-streak__num {
    font-family: var(--font-stack-display);
    font-size: var(--fs-40);
    font-weight: var(--fw-bold);
    color: var(--lf-accent);
    line-height: 1;
  }
  .lf-streak__cap {
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .lf-heat {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    grid-auto-rows: 1fr;
    gap: 4px;
  }
  .lf-heat__cell {
    aspect-ratio: 1;
    border-radius: 2px;
    background: var(--surface-3);
    opacity: 0;
    transform: scale(0.6);
  }
  .lf-heat__cell[data-lvl="1"] { background: color-mix(in srgb, var(--lf-accent) 24%, var(--surface-3)); }
  .lf-heat__cell[data-lvl="2"] { background: color-mix(in srgb, var(--lf-accent) 46%, var(--surface-3)); }
  .lf-heat__cell[data-lvl="3"] { background: color-mix(in srgb, var(--lf-accent) 70%, var(--surface-3)); }
  .lf-heat__cell[data-lvl="4"] { background: var(--lf-accent); }
  .lf-heat__cell.is-on {
    opacity: 1;
    transform: scale(1);
  }
  .lf.is-inview .lf-heat__cell.is-on {
    transition:
      opacity var(--dur-med) var(--ease-soft),
      transform var(--dur-med) var(--ease-spring);
    transition-delay: calc(var(--ci, 0) * 6ms);
  }
  .lf-heat__cap {
    color: var(--text-faint);
  }
  .lf-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background:
      radial-gradient(130% 90% at 0% 0%, var(--lf-glow), transparent 62%),
      var(--surface);
  }
  .lf-card__cap {
    color: var(--text-muted);
  }
  .lf-card__flip {
    display: block;
    width: 100%;
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
    perspective: 1000px;
  }
  .lf-card__flip:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 3px;
    border-radius: var(--r-sm);
  }
  .lf-card__inner {
    position: relative;
    display: block;
    min-height: 104px;
    transform-style: preserve-3d;
    transition: transform var(--dur-slow) var(--ease-spring);
  }
  .lf-card[data-flipped="true"] .lf-card__inner {
    transform: rotateY(180deg);
  }
  .lf-card__face {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--lf-line);
    border-radius: var(--r-md);
    background: var(--bg-deep);
    text-align: center;
    font-size: var(--fs-15);
    line-height: var(--lh-snug);
    color: var(--text);
    backface-visibility: hidden;
  }
  .lf-card__face--back {
    transform: rotateY(180deg);
    color: var(--lf-accent);
  }
  .lf-card__ratings {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-2);
  }
  .lf-card__ratings[data-armed="false"] {
    opacity: 0.4;
    pointer-events: none;
  }
  .lf-rate {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-height: var(--tap-min);
    padding: var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-spring);
  }
  .lf-rate:active {
    transform: scale(0.94);
  }
  .lf-rate:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .lf-rate__label {
    font-family: var(--font-stack-display);
    font-size: var(--fs-13);
    font-weight: var(--fw-semibold);
    color: var(--text);
  }
  .lf-rate__due {
    font-size: var(--fs-11);
    color: var(--text-muted);
  }
  .lf-rate[data-tone="err"]:hover { border-color: color-mix(in srgb, var(--lf-err) 50%, transparent); }
  .lf-rate[data-tone="warn"]:hover { border-color: color-mix(in srgb, var(--lf-warn) 50%, transparent); }
  .lf-rate[data-tone="accent"]:hover { border-color: var(--lf-line); }
  .lf-rate[data-tone="ok"]:hover { border-color: color-mix(in srgb, var(--lf-ok) 50%, transparent); }

  /* ════════ Акт 7: export ════════ */
  .lf-export {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
    gap: var(--sp-4);
    align-items: start;
  }
  .lf-export__file {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: var(--bg-deep);
    opacity: 0.4;
    transform: translate3d(0, 8px, 0);
    transition:
      opacity var(--dur-med) var(--ease-soft),
      transform var(--dur-med) var(--ease-spring),
      border-color var(--dur-med) var(--ease-standard);
  }
  .lf-export__file[data-on="true"] {
    opacity: 1;
    transform: none;
    border-color: var(--lf-line);
  }
  .lf-export__name {
    font-size: var(--fs-13);
    color: var(--lf-accent);
    word-break: break-all;
  }
  .lf-export__rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .lf-export__row {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-14);
    color: var(--text-secondary);
  }
  .lf-export__file[data-on="true"] .lf-export__row {
    opacity: 0;
  }
  .lf.is-inview .lf-export__file[data-on="true"] .lf-export__row {
    animation: lf-slide var(--dur-med) var(--ease-soft) both;
    animation-delay: calc(var(--ri, 0) * 90ms);
  }
  .lf-export__check {
    flex: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: var(--bw-thin) solid var(--lf-line);
    background:
      linear-gradient(45deg, transparent 44%, var(--lf-accent) 44% 56%, transparent 56%),
      linear-gradient(-45deg, transparent 48%, var(--lf-accent) 48% 52%, transparent 52%);
  }
  .lf-export__foot {
    color: var(--text-faint);
    font-family: var(--font-stack-mono);
  }
  .lf-export__controls {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: stretch;
  }
  .lf-export__controls .lf-btn {
    justify-content: flex-start;
  }

  /* ── пейджер ── */
  .lf__pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-7);
    border-top: var(--bw-thin) solid var(--border);
    background: var(--surface);
  }
  .lf__pager-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    background: var(--bg-elevated);
    color: var(--text-secondary);
    font-family: var(--font-stack-display);
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-spring);
  }
  .lf__pager-btn:hover {
    color: var(--text);
    border-color: var(--lf-accent);
  }
  .lf__pager-btn:active {
    transform: scale(0.96);
  }
  .lf__pager-btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .lf__pager-btn[disabled] {
    opacity: 0.32;
    pointer-events: none;
  }
  .lf__pager-step {
    font-size: var(--fs-14);
    font-weight: var(--fw-semibold);
    color: var(--lf-accent);
    letter-spacing: var(--ls-wide);
  }

  /* ════════ Responsive ════════ */
  @media (max-width: 880px) {
    .lf-clone,
    .lf-forge,
    .lf-habit,
    .lf-export {
      grid-template-columns: 1fr;
    }
    .lf-act {
      padding: var(--sp-6) var(--sp-5) var(--sp-5);
    }
    /* маршрут: горизонтальная лента со скроллом */
    .lf__spine {
      grid-auto-flow: column;
      grid-auto-columns: minmax(96px, 1fr);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: var(--sp-1);
    }
    .lf__spine::-webkit-scrollbar {
      display: none;
    }
    .lf__spine::before,
    .lf__spine::after {
      display: none;
    }
    .lf__st-label {
      font-size: var(--fs-12);
    }
  }

  @media (max-width: 560px) {
    .lf-act {
      padding: var(--sp-5) var(--sp-4) var(--sp-4);
    }
    .lf-act__run .lf-btn {
      flex: 1 1 100%;
    }
    .lf__pager {
      padding: var(--sp-3) var(--sp-4);
    }
    .lf__pager-word {
      display: none;
    }
    .lf-card__ratings {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ════════ Reduced motion: статичный читаемый кадр ════════ */
  @media (prefers-reduced-motion: reduce) {
    .lf-act.is-active,
    .lf-term__line.is-show,
    .lf-file.is-show,
    .lf-ide__code.is-swap,
    .lf-ide__table tr.is-row,
    .lf-ide__case.is-pass,
    .lf-vchip.is-lit,
    .lf-quiz__explain,
    .lf-heat__cell.is-on,
    .lf-export__file[data-on="true"] .lf-export__row,
    .lf-gate.is-shake {
      animation: none !important;
    }
    .lf-card__inner,
    .lf-heat__cell.is-on,
    .lf__spine::after {
      transition: none !important;
    }
  }
</style>

<script>
  /* LearnForge — история-навигатор «маршрут продукта» (.учёба).
   *
   * Движение: только transform/opacity. Постоянного rAF нет — демо ведётся
   * через setTimeout (массив timers), которые чистятся за экраном / на скрытой
   * вкладке / на pagehide. Класс .is-inview на корне включает CSS-анимации.
   * prefers-reduced-motion → собранный читаемый кадр; интерактив жив. */
  (() => {
    const root = document.querySelector<HTMLElement>("[data-lf]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let S: Record<string, string> = {};
    try {
      S = JSON.parse(root.dataset.lfBundle ?? "{}");
    } catch {
      S = {};
    }
    const s = (k: string): string => S[k] ?? "";

    const timers: number[] = [];
    const after = (ms: number, fn: () => void): void => {
      timers.push(window.setTimeout(fn, reduced ? 0 : ms));
    };
    const clearTimers = (): void => {
      for (const id of timers.splice(0)) window.clearTimeout(id);
    };

    /* ── навигатор: станции + панели + пейджер ── */
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-tab]"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-lf-panel]"));
    const stepEl = root.querySelector<HTMLElement>("[data-lf-step]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-lf-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-lf-next]");
    const ids = tabs.map((t) => t.dataset.lfTab ?? "");
    const n = panels.length;
    let current = 0;
    const played = new Set<string>();

    const pad2 = (x: number): string => (x < 10 ? `0${x}` : String(x));

    const select = (i: number, focus = false): void => {
      current = Math.max(0, Math.min(n - 1, i));
      tabs.forEach((t, k) => {
        const on = k === current;
        t.setAttribute("aria-selected", on ? "true" : "false");
        t.tabIndex = on ? 0 : -1;
        if (k < current) t.dataset.done = "true";
        else delete t.dataset.done;
      });
      panels.forEach((p, k) => {
        const on = k === current;
        p.classList.toggle("is-active", on);
        p.hidden = !on;
      });
      root.style.setProperty("--lf-frac", n > 1 ? String(current / (n - 1)) : "0");
      if (stepEl) stepEl.textContent = `${pad2(current + 1)} / ${pad2(n)}`;
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === n - 1;
      if (focus) tabs[current]?.focus();
      clearTimers();
      if (root.classList.contains("is-inview")) play(ids[current] ?? "");
    };

    tabs.forEach((t, k) => {
      t.addEventListener("click", () => select(k));
      t.addEventListener("keydown", (e: KeyboardEvent) => {
        let m = -1;
        if (e.key === "ArrowRight" || e.key === "ArrowDown") m = (k + 1) % tabs.length;
        else if (e.key === "ArrowLeft" || e.key === "ArrowUp") m = (k - 1 + tabs.length) % tabs.length;
        else if (e.key === "Home") m = 0;
        else if (e.key === "End") m = tabs.length - 1;
        if (m < 0) return;
        e.preventDefault();
        select(m, true);
      });
    });
    prevBtn?.addEventListener("click", () => select(current - 1));
    nextBtn?.addEventListener("click", () => select(current + 1));

    /* ════════ Акт 1: clone ════════ */
    const cloneRun = root.querySelector<HTMLButtonElement>("[data-lf-clone-run]");
    const cloneLabel = root.querySelector<HTMLElement>("[data-lf-clone-label]");
    const cloneStatus = root.querySelector<HTMLElement>("[data-lf-clone-status]");
    const termLineEls = Array.from(root.querySelectorAll<HTMLElement>("[data-term]"));
    const playClone = (): void => {
      termLineEls.forEach((l) => l.classList.remove("is-show"));
      if (cloneStatus) {
        cloneStatus.textContent = "";
        cloneStatus.removeAttribute("data-tone");
      }
      termLineEls.forEach((l, i) => after(300 * (i + 1), () => l.classList.add("is-show")));
    };
    cloneRun?.addEventListener("click", () => {
      clearTimers();
      playClone();
      if (cloneLabel) cloneLabel.textContent = s("agentBusy");
      if (cloneStatus) {
        cloneStatus.textContent = s("agentBusy");
        cloneStatus.removeAttribute("data-tone");
      }
      after(300 * (termLineEls.length + 1) + 200, () => {
        if (cloneLabel) cloneLabel.textContent = s("runAgent");
        if (cloneStatus) {
          cloneStatus.textContent = s("agentDone");
          cloneStatus.setAttribute("data-tone", "ok");
        }
      });
    });

    /* ════════ Акт 2: forge ════════ */
    const planEl = root.querySelector<HTMLElement>("[data-lf-plan]");
    const forgeRun = root.querySelector<HTMLButtonElement>("[data-lf-forge-run]");
    const forgeLabel = root.querySelector<HTMLElement>("[data-lf-forge-label]");
    const forgeStatus = root.querySelector<HTMLElement>("[data-lf-forge-status]");
    const fileEls = Array.from(root.querySelectorAll<HTMLElement>("[data-file]"));
    let forging = false;
    const playForge = (): void => {
      forging = true;
      fileEls.forEach((f) => f.classList.remove("is-show"));
      planEl?.setAttribute("data-state", "approved");
      if (forgeLabel) forgeLabel.textContent = s("forging");
      if (forgeStatus) {
        forgeStatus.textContent = s("forging");
        forgeStatus.removeAttribute("data-tone");
      }
      const step = 300;
      fileEls.forEach((f, i) => after(step * (i + 1), () => f.classList.add("is-show")));
      after(step * (fileEls.length + 1) + 200, () => {
        forging = false;
        if (forgeLabel) forgeLabel.textContent = s("forge");
        if (forgeStatus) {
          forgeStatus.textContent = s("forged");
          forgeStatus.setAttribute("data-tone", "ok");
        }
      });
    };
    forgeRun?.addEventListener("click", () => {
      if (forging) return;
      clearTimers();
      playForge();
    });

    /* ════════ Акт 3: contract ════════ */
    const schemaEl = root.querySelector<HTMLElement>("[data-lf-schema]");
    const gateEl = root.querySelector<HTMLElement>("[data-lf-gate]");
    const gateText = root.querySelector<HTMLElement>("[data-lf-gate-text]");
    const injectBtn = root.querySelector<HTMLButtonElement>("[data-lf-inject]");
    let injected = false;
    const renderGate = (shake = false): void => {
      schemaEl?.setAttribute("data-state", injected ? "fail" : "pass");
      gateEl?.setAttribute("data-state", injected ? "fail" : "pass");
      if (gateText) gateText.textContent = injected ? s("reject") : s("pass");
      if (injectBtn) {
        injectBtn.setAttribute("aria-pressed", injected ? "true" : "false");
        injectBtn.textContent = injected ? s("fix") : s("inject");
      }
      if (injected && shake && !reduced && gateEl) {
        gateEl.classList.remove("is-shake");
        void gateEl.offsetWidth;
        gateEl.classList.add("is-shake");
      }
    };
    injectBtn?.addEventListener("click", () => {
      injected = !injected;
      renderGate(true);
    });

    /* ════════ Акт 4: solve ════════ */
    const ide = root.querySelector<HTMLElement>("[data-lf-ide]");
    const rtTabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-rt]"));
    const codeEl = root.querySelector<HTMLElement>("[data-lf-code]");
    const variantsWrap = root.querySelector<HTMLElement>("[data-lf-variants]");
    const variantBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-variant]"));
    const runBtn = root.querySelector<HTMLButtonElement>("[data-lf-run]");
    const runStatus = root.querySelector<HTMLElement>("[data-lf-run-status]");
    const out = root.querySelector<HTMLElement>("[data-lf-out]");
    const sqlOut = root.querySelector<HTMLElement>("[data-lf-sqlout]");
    const pyOut = root.querySelector<HTMLElement>("[data-lf-pyout]");
    const theadEl = root.querySelector<HTMLElement>("[data-lf-thead]");
    const tbodyEl = root.querySelector<HTMLElement>("[data-lf-tbody]");
    const verdictEl = root.querySelector<HTMLElement>("[data-lf-verdict]");
    const caseEls = Array.from(root.querySelectorAll<HTMLElement>("[data-case]"));

    const sqlVariants = [
      {
        ok: true,
        code: "SELECT a.name, b.title\nFROM author a\nLEFT JOIN book b ON b.author_id = a.id\nORDER BY a.name, b.title;",
        rows: [["Ada", "Analytical engine"], ["Grace", "NULL"], ["Linus", "Kernel notes"]],
      },
      {
        ok: false,
        code: "SELECT a.name, b.title\nFROM author a\nJOIN book b ON b.author_id = a.id\nORDER BY a.name;",
        rows: [["Ada", "Analytical engine"], ["Linus", "Kernel notes"]],
      },
    ];
    const pyCode =
      "class Vector:\n    def __init__(self, x, y):\n        self.x, self.y = x, y\n    def length(self):\n        return (self.x**2 + self.y**2) ** 0.5";
    const sqlCols = ["name", "title"];
    let runtime: "sql" | "py" = "sql";
    let variant = 0;

    const swapCode = (): void => {
      if (!codeEl) return;
      codeEl.textContent = runtime === "sql" ? (sqlVariants[variant]?.code ?? "") : pyCode;
      if (!reduced) {
        codeEl.classList.remove("is-swap");
        void codeEl.offsetWidth;
        codeEl.classList.add("is-swap");
      }
    };
    const resetOut = (): void => {
      out?.setAttribute("data-state", "idle");
      out?.setAttribute("data-kind", runtime);
      if (sqlOut) sqlOut.hidden = runtime !== "sql";
      if (pyOut) pyOut.hidden = runtime !== "py";
      if (variantsWrap) variantsWrap.hidden = runtime !== "sql";
      if (theadEl) theadEl.replaceChildren();
      if (tbodyEl) tbodyEl.replaceChildren();
      caseEls.forEach((c) => c.classList.remove("is-pass"));
      if (verdictEl) verdictEl.textContent = "";
      if (runStatus) {
        runStatus.textContent = s("ready");
        runStatus.removeAttribute("data-tone");
      }
      ide?.setAttribute("data-busy", "false");
    };
    const renderSql = (): void => {
      const v = sqlVariants[variant];
      if (!v || !theadEl || !tbodyEl) return;
      const hr = document.createElement("tr");
      for (const c of sqlCols) {
        const th = document.createElement("th");
        th.scope = "col";
        th.textContent = c;
        hr.appendChild(th);
      }
      theadEl.replaceChildren(hr);
      const frag = document.createDocumentFragment();
      v.rows.forEach((row, ri) => {
        const tr = document.createElement("tr");
        tr.className = "is-row";
        tr.style.setProperty("--ri", String(ri));
        for (const cell of row) {
          const td = document.createElement("td");
          td.textContent = cell;
          if (cell === "NULL") td.classList.add("is-null");
          tr.appendChild(td);
        }
        frag.appendChild(tr);
      });
      tbodyEl.replaceChildren(frag);
      out?.setAttribute("data-state", v.ok ? "ok" : "bad");
      if (verdictEl) verdictEl.textContent = v.ok ? s("okGold") : s("badGold");
    };
    const renderPy = (): void => {
      caseEls.forEach((c, i) => {
        c.classList.remove("is-pass");
        c.style.setProperty("--ci", String(i));
      });
      caseEls.forEach((c, i) => after(120 * (i + 1), () => c.classList.add("is-pass")));
      out?.setAttribute("data-state", "ok");
      if (verdictEl) verdictEl.textContent = s("casesPass");
    };
    const run = (): void => {
      clearTimers();
      ide?.setAttribute("data-busy", "true");
      const eng = runtime === "sql" ? "sql.js" : "Pyodide";
      if (runStatus) {
        runStatus.textContent = `${eng}: ${s("running")}`;
        runStatus.removeAttribute("data-tone");
      }
      out?.setAttribute("data-state", "idle");
      if (theadEl) theadEl.replaceChildren();
      if (tbodyEl) tbodyEl.replaceChildren();
      caseEls.forEach((c) => c.classList.remove("is-pass"));
      after(520, () => {
        ide?.setAttribute("data-busy", "false");
        if (runtime === "sql") renderSql();
        else renderPy();
        if (runStatus) {
          const okTone = runtime === "py" || sqlVariants[variant]?.ok;
          runStatus.textContent = `${eng} ✓`;
          runStatus.setAttribute("data-tone", okTone ? "ok" : "bad");
        }
      });
    };
    const selectRt = (k: number): void => {
      runtime = k === 1 ? "py" : "sql";
      rtTabs.forEach((b, i) => {
        b.setAttribute("aria-selected", i === k ? "true" : "false");
        b.tabIndex = i === k ? 0 : -1;
      });
      variant = 0;
      variantBtns.forEach((b, i) => {
        b.setAttribute("aria-checked", i === 0 ? "true" : "false");
        b.tabIndex = i === 0 ? 0 : -1;
      });
      swapCode();
      resetOut();
    };
    const selectVariant = (k: number): void => {
      variant = k;
      variantBtns.forEach((b, i) => {
        b.setAttribute("aria-checked", i === k ? "true" : "false");
        b.tabIndex = i === k ? 0 : -1;
      });
      swapCode();
      resetOut();
    };
    rtTabs.forEach((b, k) => b.addEventListener("click", () => selectRt(k)));
    variantBtns.forEach((b, k) => b.addEventListener("click", () => selectVariant(k)));
    runBtn?.addEventListener("click", run);

    /* ════════ Акт 5: theory ════════ */
    const vizEls = Array.from(root.querySelectorAll<HTMLElement>("[data-viz]"));
    const quizEl = root.querySelector<HTMLElement>("[data-lf-quiz]");
    const choiceBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-choice]"));
    const quizCheck = root.querySelector<HTMLButtonElement>("[data-lf-quiz-check]");
    const quizStatus = root.querySelector<HTMLElement>("[data-lf-quiz-status]");
    const quizExplain = root.querySelector<HTMLElement>("[data-lf-quiz-explain]");
    choiceBtns.forEach((b) => {
      b.addEventListener("click", () => {
        if (quizEl?.dataset.checked === "true") return;
        const on = b.getAttribute("aria-pressed") === "true";
        b.setAttribute("aria-pressed", on ? "false" : "true");
      });
    });
    quizCheck?.addEventListener("click", () => {
      quizEl?.setAttribute("data-checked", "true");
      let ok = true;
      choiceBtns.forEach((b) => {
        const picked = b.getAttribute("aria-pressed") === "true";
        const correct = b.dataset.correct === "1";
        if (picked !== correct) ok = false;
      });
      if (quizStatus) {
        quizStatus.textContent = ok ? s("quizRight") : s("quizWrong");
        quizStatus.setAttribute("data-tone", ok ? "ok" : "bad");
      }
      if (quizExplain) quizExplain.hidden = false;
    });
    const playTheory = (): void => {
      vizEls.forEach((v) => v.classList.remove("is-lit"));
      vizEls.forEach((v, i) => after(140 * (i + 1), () => v.classList.add("is-lit")));
    };

    /* ════════ Акт 6: habit ════════ */
    const streakNum = root.querySelector<HTMLElement>("[data-lf-streak]");
    const heatCells = Array.from(root.querySelectorAll<HTMLElement>("[data-lf-heat] .lf-heat__cell"));
    const cardEl = root.querySelector<HTMLElement>("[data-lf-card]");
    const flipBtn = root.querySelector<HTMLButtonElement>("[data-lf-flip]");
    const ratingsWrap = root.querySelector<HTMLElement>("[data-lf-ratings]");
    const rateBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-rate]"));
    const cardStatus = root.querySelector<HTMLElement>("[data-lf-card-status]");
    const TARGET_STREAK = 23;
    heatCells.forEach((c, i) => c.style.setProperty("--ci", String(i)));
    flipBtn?.addEventListener("click", () => {
      const flipped = cardEl?.dataset.flipped === "true";
      cardEl?.setAttribute("data-flipped", flipped ? "false" : "true");
      if (!flipped) ratingsWrap?.setAttribute("data-armed", "true");
    });
    rateBtns.forEach((b) => {
      b.addEventListener("click", () => {
        const due = b.querySelector(".lf-rate__due")?.textContent ?? "";
        if (cardStatus) {
          cardStatus.textContent = `${s("nextDue")} ${due}`;
          cardStatus.setAttribute("data-tone", "ok");
        }
        cardEl?.setAttribute("data-flipped", "false");
        ratingsWrap?.setAttribute("data-armed", "false");
      });
    });
    const playHabit = (): void => {
      heatCells.forEach((c) => c.classList.remove("is-on"));
      if (reduced) {
        heatCells.forEach((c) => c.classList.add("is-on"));
        if (streakNum) streakNum.textContent = String(TARGET_STREAK);
        return;
      }
      heatCells.forEach((c) => c.classList.add("is-on"));
      let v = 0;
      const tick = (): void => {
        v += 1;
        if (streakNum) streakNum.textContent = String(v);
        if (v < TARGET_STREAK) after(34, tick);
      };
      after(120, tick);
    };

    /* ════════ Акт 7: export ════════ */
    const fileCard = root.querySelector<HTMLElement>("[data-lf-file-card]");
    const exportBtn = root.querySelector<HTMLButtonElement>("[data-lf-export]");
    const importBtn = root.querySelector<HTMLButtonElement>("[data-lf-import]");
    const exportStatus = root.querySelector<HTMLElement>("[data-lf-export-status]");
    const playExport = (): void => {
      fileCard?.setAttribute("data-on", "true");
    };
    exportBtn?.addEventListener("click", () => {
      clearTimers();
      fileCard?.setAttribute("data-on", "false");
      void fileCard?.offsetWidth;
      after(40, () => fileCard?.setAttribute("data-on", "true"));
      if (exportStatus) {
        exportStatus.textContent = s("exported");
        exportStatus.setAttribute("data-tone", "ok");
      }
    });
    importBtn?.addEventListener("click", () => {
      fileCard?.setAttribute("data-on", "true");
      if (exportStatus) {
        exportStatus.textContent = s("imported");
        exportStatus.setAttribute("data-tone", "ok");
      }
    });

    /* ── автопроигрыш активной сцены (один раз на акт) ── */
    const play = (id: string): void => {
      if (!id) return;
      if (id === "contract") {
        renderGate(false);
        return;
      }
      if (id === "solve") {
        if (!played.has(id)) {
          played.add(id);
          after(260, run);
        }
        return;
      }
      if (played.has(id)) return;
      played.add(id);
      if (id === "clone") after(260, playClone);
      else if (id === "forge") after(260, playForge);
      else if (id === "theory") after(200, playTheory);
      else if (id === "habit") after(200, playHabit);
      else if (id === "export") after(300, playExport);
    };

    /* ── начальное состояние ── */
    selectRt(0);
    renderGate(false);
    select(0);

    /* reduced / нет IO: собранный кадр */
    if (reduced || !("IntersectionObserver" in window)) {
      root.classList.add("is-inview");
      termLineEls.forEach((l) => l.classList.add("is-show"));
      planEl?.setAttribute("data-state", "approved");
      fileEls.forEach((f) => f.classList.add("is-show"));
      vizEls.forEach((v) => v.classList.add("is-lit"));
      heatCells.forEach((c) => c.classList.add("is-on"));
      if (streakNum) streakNum.textContent = String(23);
      fileCard?.setAttribute("data-on", "true");
      renderSql();
      if (runStatus) {
        runStatus.textContent = "sql.js ✓";
        runStatus.setAttribute("data-tone", "ok");
      }
      return;
    }

    /* ── IntersectionObserver: гейтит всё движение ── */
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            root.classList.add("is-inview");
            play(ids[current] ?? "");
          } else {
            root.classList.remove("is-inview");
            clearTimers();
            ide?.setAttribute("data-busy", "false");
          }
        }
      },
      { threshold: 0.15 },
    );
    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        clearTimers();
        ide?.setAttribute("data-busy", "false");
      }
    });
    window.addEventListener(
      "pagehide",
      () => {
        clearTimers();
        root.classList.remove("is-inview");
        io.disconnect();
      },
      { once: true },
    );
  })();
</script>
