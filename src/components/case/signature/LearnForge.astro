      en: "SQL via sql.js, Python via Pyodide — both in a Web Worker, no server. Write a solution, hit Run, and see the result at once: a table or a test run.",
    },
  },
  {
    id: "theory",
    eyebrow: { ru: "Интерактивная теория", en: "Interactive theory" },
    title: { ru: "Не стена текста, а живые схемы", en: "Not a wall of text, but live diagrams" },
    lede: {
      ru: "В теорию встроены 40+ визуализаций — от JOIN и хеш-таблиц до attention и градиентного спуска. И проверочные вопросы прямо по ходу чтения.",
      en: "Theory embeds 40+ visualizations — from JOINs and hash tables to attention and gradient descent. Plus quick check questions as you read.",
    },
  },
  {
    id: "habit",
    eyebrow: { ru: "Привычка и карточки", en: "Habit and flashcards" },
