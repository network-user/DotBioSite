];

/* ── Акт 3: Zod-контракт ─────────────────────────────────────────────── */
const schemaFields: { key: string; type: string }[] = [
  { key: "slug", type: "z.string().regex(SLUG)" },
  { key: "title", type: "z.string().min(3)" },
  { key: "runtime", type: "z.enum(['sql.js','pyodide',…])" },
  { key: "difficulty", type: "z.enum(['beginner',…])" },
  { key: "concepts", type: "z.array(Concept).min(1)" },
  { key: "author", type: "{ kind:'agent', model }" },
];

/* ── Акт 4: упражнения двух рантаймов ────────────────────────────────── */
type SqlVariant = {
