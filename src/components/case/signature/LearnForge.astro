---
/**
 * LearnForge.astro — сигнатурная визуализация .учёба (DotLearn).
 *
 * ФОРМА — «МАРШРУТ ПРОДУКТА» (сознательно НЕ shell-селектор .звук): сверху
 * горизонтальная прогресс-линия из 7 станций (линия заливается до текущего
 * шага), снизу — один крупный stage активного акта. Пользователь идёт по пути
 * продукта стрелками ←/→ или клавишами; активная сцена сама проигрывает демо.
 * Цель — чтобы человек, мало знакомый с программированием, протыкал интерактив
 * и понял продукт целиком: от `git clone` до экспорта прогресса.
 *
 * Акты (опираются на реальные артефакты репозитория DotLearn):
 *  1 · Клонируй и попроси — `git clone … && pnpm dev:web`, словами просишь агента.
 *  2 · Кузница кует урок — lesson-forge: план → manifest → theory.mdx + yaml + flashcards.
 *  3 · Контракт проверяет форму — общий Zod (`topic.schema.ts`, .strict()), web+api.
 *  4 · Решаешь в браузере — sql.js (JOIN author/book) и Pyodide (Vector.length) в Worker.
 *  5 · Интерактивная теория — 40+ живых визуализаций + theory-quiz по ходу чтения.
 *  6 · Привычка и карточки — стрик + GitHub-heatmap (IndexedDB), FSRS-карточка.
 *  7 · Унеси с собой — экспорт/импорт всего прогресса одним JSON (version 4).
 *
 * Бюджет анимации (строго): анимируются ТОЛЬКО transform и opacity. Постоянного
 * rAF нет — демо ведётся цепочками setTimeout (массив timers), которые ЧИСТЯТСЯ
 * за экраном / на скрытой вкладке (visibilitychange) / на pagehide. Всё движение
 * под классом .is-inview (IntersectionObserver на корне) и гасится вне кадра.
 * prefers-reduced-motion → финальный читаемый кадр; все кнопки/тоглы работают.
 *
 * Факты сверены по репозиторию (точно): 34 темы; 7 типов упражнений; рантаймы
 * sql.js / Pyodide / JS / git в Web Workers; Zod-контракт общий для web+api;
 * lesson-forge — офлайн-скилл, РАНТАЙМ-AI НЕТ; прогресс/heatmap/стрик —
 * Dexie/IndexedDB; карточки — ts-fsrs; экспорт прогресса — version 4.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const intro: Bi = {
  ru: "Не слайды, а сквозной путь продукта: клонируешь репозиторий, просишь ИИ-агента собрать тему, смотришь как урок рождается из файлов, решаешь код прямо в браузере и копишь прогресс. Иди по шагам стрелками ←/→ — каждая сцена показывает себя сама.",
  en: "Not slides but the product end to end: you clone the repo, ask an AI agent to forge a topic, watch a lesson born from files, solve code right in the browser and build up progress. Step through with ←/→ — each scene plays itself.",
};

