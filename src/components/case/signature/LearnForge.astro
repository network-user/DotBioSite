    .lf-ide__runtimes,
    .lf-ide__variants,
    .lf-ide__run,
    .lf-ide__result {
      padding-left: var(--sp-3);
      padding-right: var(--sp-3);
    }
  }

  /* ════════════════ Reduced motion: статичный читаемый кадр ════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .lf-ide__code.is-swap,
    .lf-ide__table tr.is-row,
    .lf-forge__file.is-show,
    .lf-forge__gate.is-shake,
    .lf-ide[data-busy="true"] .lf-ide__runbtn-glyph,
    .lf-forge[data-forging="true"] .lf-forge__spark {
      animation: none !important;
    }
    .lf-forge__stage {
      opacity: 1;
    }
    .lf-forge__stage[data-on="true"] .lf-forge__file,
    .lf-forge__file.is-show {
      opacity: 1;
    }
    .lf-ide__result[data-state="idle"] .lf-ide__table-wrap {
      opacity: 1;
    }
  }
</style>

<script>
  /* LearnForge — мини-IDE урока + ИИ-кузница. Один цельный верстак.
   *
   * Движение: только transform/opacity. Постоянного rAF нет — автосборка
   * форджа ведётся через setTimeout (массив timers), которые чистятся за
   * экраном / на скрытой вкладке / на pagehide. Класс .is-inview на корне
   * включает CSS-анимации; вне кадра «infinite»-анимации (spark, pulse) не
   * крутятся, потому что их селекторы скоупятся под .lf.is-inview.
   * prefers-reduced-motion → собранный читаемый кадр, тоглы/кнопки работают. */
  (() => {
    const root = document.querySelector<HTMLElement>("[data-lf]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isEn = root.dataset.lfLocale === "en";
    const tr = (ru: string, en: string): string => (isEn ? en : ru);

    /* ── данные вариантов (зеркало серверного const) ── */
    type Row = string[];
    type VariantData = {
      ok: boolean;
      sql: string[];
      py: string[];
      cols: string[];
      rows: Row[];
      note: string;
    };
    const variants: VariantData[] = [
      {
        ok: true,
        sql: [
          "SELECT o.id, u.name",
          "FROM orders o",
          "JOIN users u ON u.id = o.user_id",
          "ORDER BY o.id;",
        ],
        py: [
          "rows = sql(db, '''",
          "  SELECT o.id, u.name FROM orders o",
          "  JOIN users u ON u.id = o.user_id''')",
          "print(rows)",
        ],
        cols: ["id", "name"],
        rows: [
          ["1001", "nova"],
          ["1002", "mira"],
          ["1003", "keto"],
        ],
        note: tr("совпало с gold-решением", "matches the gold solution"),
      },
      {
        ok: false,
        sql: [
          "SELECT o.id, u.name",
          "FROM orders o",
          "LEFT JOIN users u ON u.id = o.user_id",
          "ORDER BY o.id;",
        ],
        py: [
          "rows = sql(db, '''",
          "  SELECT o.id, u.name FROM orders o",
          "  LEFT JOIN users u ON u.id = o.user_id''')",
          "print(rows)",
        ],
        cols: ["id", "name"],
        rows: [
          ["1001", "nova"],
          ["1002", "mira"],
          ["1003", "keto"],
          ["1004", "NULL"],
        ],
        note: tr("лишняя строка NULL — расходится с gold", "extra NULL row — differs from gold"),
      },
      {
        ok: false,
        sql: [
          "SELECT o.id, u.name",
          "FROM orders o",
          "CROSS JOIN users u",
          "ORDER BY o.id;",
        ],
        py: [
          "rows = sql(db, '''",
          "  SELECT o.id, u.name",
          "  FROM orders o CROSS JOIN users u''')",
          "print(rows)",
        ],
        cols: ["id", "name"],
        rows: [
          ["1001", "nova"],
          ["1001", "mira"],
          ["1001", "keto"],
          ["…", "9 rows"],
        ],
        note: tr("декартово произведение — не то", "cartesian product — not it"),
      },
    ];

    /* ── общий таймер-менеджер ── */
    const timers: number[] = [];
    const after = (ms: number, fn: () => void): void => {
      timers.push(window.setTimeout(fn, ms));
    };
    const clearTimers = (): void => {
      for (const id of timers.splice(0)) window.clearTimeout(id);
    };

    /* ───────────────── ЛЕВО: мини-IDE ───────────────── */
    const ide = root.querySelector<HTMLElement>("[data-lf-ide]");
    const codeEl = root.querySelector<HTMLElement>("[data-lf-code]");
    const runtimeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-runtime]"));
    const variantBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-lf-variant]"));
    const runBtn = root.querySelector<HTMLButtonElement>("[data-lf-run]");
    const runStatus = root.querySelector<HTMLElement>("[data-lf-runstatus]");
    const result = root.querySelector<HTMLElement>("[data-lf-result]");
    const theadEl = root.querySelector<HTMLElement>("[data-lf-thead]");
    const tbodyEl = root.querySelector<HTMLElement>("[data-lf-tbody]");
    const verdictEl = root.querySelector<HTMLElement>("[data-lf-verdict]");

    let runtime = 0; /* 0 = sql.js, 1 = Pyodide */
    let variant = 0;

    const swapCode = (): void => {
      if (!codeEl) return;
      const v = variants[variant];
      if (!v) return;
      const lines = runtime === 0 ? v.sql : v.py;
      codeEl.textContent = lines.join("\n");
      if (!reduced) {
        codeEl.classList.remove("is-swap");
        void codeEl.offsetWidth;
        codeEl.classList.add("is-swap");
      }
    };

    const resetResult = (): void => {
      if (theadEl) theadEl.replaceChildren();
      if (tbodyEl) tbodyEl.replaceChildren();
      if (result) result.setAttribute("data-state", "idle");
      if (verdictEl) verdictEl.textContent = "";
      if (runStatus) runStatus.textContent = tr("готово к запуску", "ready to run");
      ide?.setAttribute("data-busy", "false");
    };

    const renderTable = (): void => {
      const v = variants[variant];
      if (!v || !theadEl || !tbodyEl) return;
      const hr = document.createElement("tr");
      for (const c of v.cols) {
        const th = document.createElement("th");
        th.scope = "col";
        th.textContent = c;
        hr.appendChild(th);
      }
      theadEl.replaceChildren(hr);

      const body = document.createDocumentFragment();
      v.rows.forEach((row, ri) => {
        const trEl = document.createElement("tr");
        trEl.className = "is-row";
        trEl.style.setProperty("--ri", String(ri));
        /* пометить аномальную строку неверного варианта */
        const isExtra = !v.ok && ri >= 3;
        if (isExtra) trEl.dataset.bad = "1";
        for (const cell of row) {
          const td = document.createElement("td");
          td.textContent = cell;
          trEl.appendChild(td);
        }
        body.appendChild(trEl);
      });
      tbodyEl.replaceChildren(body);

      if (result) result.setAttribute("data-state", v.ok ? "ok" : "bad");
      if (verdictEl) {
        verdictEl.textContent = v.ok
          ? tr("✓ совпало с gold", "✓ matches gold")
          : tr("✗ расходится с gold", "✗ differs from gold");
      }
    };

    const run = (): void => {
      const v = variants[variant];
      if (!v) return;
      ide?.setAttribute("data-busy", "true");
      const eng = runtime === 0 ? "sql.js" : "Pyodide";
      if (runStatus) {
        runStatus.textContent = tr(
          `${eng}: исполняю в Web Worker…`,
          `${eng}: executing in a Web Worker…`,
        );
      }
      if (theadEl) theadEl.replaceChildren();
      if (tbodyEl) tbodyEl.replaceChildren();
      if (result) result.setAttribute("data-state", "idle");
      if (verdictEl) verdictEl.textContent = "";

      const delay = reduced ? 0 : 520;
      after(delay, () => {
        ide?.setAttribute("data-busy", "false");
        renderTable();
        if (runStatus) {
          runStatus.textContent = `${eng} · ${v.note}`;
        }
      });
    };

    const selectRuntime = (k: number): void => {
      runtime = k;
      runtimeBtns.forEach((b, i) => {
        b.setAttribute("aria-selected", i === k ? "true" : "false");
        b.tabIndex = i === k ? 0 : -1;
      });
      swapCode();
      resetResult();
    };

    const selectVariant = (k: number): void => {
      variant = k;
      variantBtns.forEach((b, i) => {
        b.setAttribute("aria-checked", i === k ? "true" : "false");
        b.tabIndex = i === k ? 0 : -1;
      });
      swapCode();
      resetResult();
    };

    runtimeBtns.forEach((b, k) => b.addEventListener("click", () => selectRuntime(k)));
    variantBtns.forEach((b, k) => b.addEventListener("click", () => selectVariant(k)));
    runBtn?.addEventListener("click", run);

    /* клавиатура для радиогрупп (стрелки) */
    const wireArrows = (
      list: HTMLButtonElement[],
      pick: (k: number) => void,
      getIdx: () => number,
    ): void => {
      list.forEach((b) => {
        b.addEventListener("keydown", (e: KeyboardEvent) => {
          if (e.key !== "ArrowRight" && e.key !== "ArrowLeft") return;
          e.preventDefault();
          const n = list.length;
          const cur = getIdx();
          const next = e.key === "ArrowRight" ? (cur + 1) % n : (cur - 1 + n) % n;
          pick(next);
          list[next]?.focus();
        });
      });
    };
    wireArrows(runtimeBtns, selectRuntime, () => runtime);
    wireArrows(variantBtns, selectVariant, () => variant);

    /* ───────────────── ПРАВО: кузница ───────────────── */
    const forge = root.querySelector<HTMLElement>("[data-lf-forge]");
    const forgeBtn = root.querySelector<HTMLButtonElement>("[data-lf-forge-btn]");
    const forgeLabel = root.querySelector<HTMLElement>("[data-lf-forge-label]");
    const fileEls = Array.from(root.querySelectorAll<HTMLElement>(".lf-forge__file"));
    const stageEls = Array.from(root.querySelectorAll<HTMLElement>("[data-lf-stage]"));
    const schemaEl = root.querySelector<HTMLElement>("[data-lf-schema]");
    const gateEl = root.querySelector<HTMLElement>("[data-lf-gate]");
    const gateText = root.querySelector<HTMLElement>("[data-lf-gatetext]");
    const badFieldBtn = root.querySelector<HTMLButtonElement>("[data-lf-badfield]");

    const stage = (name: string): HTMLElement | undefined =>
      stageEls.find((s) => s.dataset.lfStage === name);

    const setStageOn = (name: string, on: boolean): void => {
      stage(name)?.setAttribute("data-on", on ? "true" : "false");
    };

    let badField = false;

    const renderGate = (): void => {
      const failed = badField;
      schemaEl?.setAttribute("data-state", failed ? "fail" : "pass");
      gateEl?.setAttribute("data-state", failed ? "fail" : "pass");
      if (gateText) {
        gateText.textContent = failed
          ? tr("REJECT · ZodError: unrecognized key — отклонено web И api", "REJECT · ZodError: unrecognized key — rejected by web AND api")
          : tr("PASS · форма валидна для web и api", "PASS · shape valid for web and api");
      }
      if (badFieldBtn) {
        badFieldBtn.setAttribute("aria-pressed", failed ? "true" : "false");
        badFieldBtn.textContent = failed
          ? tr("Убрать поле", "Remove field")
          : tr("Внедрить лишнее поле", "Inject extra field");
      }
      if (failed && !reduced && gateEl) {
        gateEl.classList.remove("is-shake");
        void gateEl.offsetWidth;
        gateEl.classList.add("is-shake");
      }
    };

    /* собрать форж: файлы по одному → стадии включаются */
    let forging = false;
    const forgeTopic = (): void => {
      clearTimers();
      forging = true;
      forge?.setAttribute("data-forging", "true");
      if (forgeLabel) forgeLabel.textContent = tr("Куётся…", "Forging…");

      /* сброс */
      fileEls.forEach((f) => f.classList.remove("is-show"));
      setStageOn("files", true);
      setStageOn("zod", false);
      setStageOn("pr", false);

      const stepMs = reduced ? 0 : 260;
      fileEls.forEach((f, i) => {
        after(stepMs * (i + 1), () => f.classList.add("is-show"));
      });
      after(stepMs * (fileEls.length + 1), () => {
        setStageOn("zod", true);
        renderGate();
      });
      after(stepMs * (fileEls.length + 2), () => setStageOn("pr", true));
      after(stepMs * (fileEls.length + 3) + 200, () => {
        forging = false;
        forge?.setAttribute("data-forging", "false");
        if (forgeLabel) forgeLabel.textContent = tr("Сковать заново", "Forge again");
      });
    };

    forgeBtn?.addEventListener("click", () => {
      if (forging) return;
      forgeTopic();
    });

    badFieldBtn?.addEventListener("click", () => {
      badField = !badField;
      renderGate();
    });

    /* BYOK */
    const byokBtn = root.querySelector<HTMLButtonElement>("[data-lf-byok]");
    const byokNote = root.querySelector<HTMLElement>("[data-lf-byok-note]");
    byokBtn?.addEventListener("click", () => {
      const open = byokBtn.getAttribute("aria-expanded") === "true";
      byokBtn.setAttribute("aria-expanded", open ? "false" : "true");
      if (byokNote) byokNote.hidden = open;
    });

    /* ── начальное состояние ── */
    selectRuntime(0);
    selectVariant(0);
    renderGate();

    /* reduced / нет IO: собранный читаемый кадр без движения */
    if (reduced || !("IntersectionObserver" in window)) {
      fileEls.forEach((f) => f.classList.add("is-show"));
      setStageOn("files", true);
      setStageOn("zod", true);
      setStageOn("pr", true);
      renderTable(); /* показать результат верного варианта */
      if (runStatus && variants[0]) {
        runStatus.textContent = `sql.js · ${variants[0].note}`;
      }
      return;
    }

    /* ── IntersectionObserver: гейтит всё движение ── */
    let armed = false;
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            root.classList.add("is-inview");
            if (!armed) {
              armed = true;
              after(360, () => forgeTopic()); /* авто-проигрыш сборки один раз */
            }
          } else {
            root.classList.remove("is-inview");
            clearTimers();
            forge?.setAttribute("data-forging", "false");
            ide?.setAttribute("data-busy", "false");
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        clearTimers();
        forge?.setAttribute("data-forging", "false");
        ide?.setAttribute("data-busy", "false");
      }
    });

    window.addEventListener(
      "pagehide",
      () => {
        clearTimers();
        root.classList.remove("is-inview");
        io.disconnect();
      },
      { once: true },
    );
  })();
</script>
