</style>

<script>
  // Оркестратор «Дорожки дня» (.счёт). Одна нисходящая дорожка, ровно одна активная
  // зона, результат-чип физически съезжает в табло и становится строкой. Состояние:
  // idle → configured → solving → solved → landed → counted; активная зона и подсказка
  // — чистая функция состояния.
  //
  // Движение — только transform/opacity. Автопрогон и пульс — цепочки setTimeout
  // (later()), чистятся за экраном / на скрытой вкладке / на pagehide. Всё под
  // IntersectionObserver (.is-inview). При prefers-reduced-motion — финальный читаемый
  // кадр, все тапы/переключения/сортировка работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-dl]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    type OpInfo = { glyph: string; name: string };
    type LvInfo = { name: string; dot: string; count: number; choices: number; weight: number };
    type ModeInfo = { label: string; why: string; unit: string };
    type PData = {
      id: string;
      name: string;
      you: boolean;
      streak: number;
      solved: number;
      accuracy: number;
      weighted: number;
    };
    type Bundle = {
      ops: Record<string, OpInfo>;
      levels: Record<string, LvInfo>;
      modes: Record<string, ModeInfo>;
      players: PData[];
      txt: Record<string, string>;
      hints: Record<string, string>;
      start: { op: string; level: string };
    };

    const fallback: Bundle = {
      ops: {},
      levels: {},
      modes: {},
      players: [],
      txt: {},
      hints: {},
      start: { op: "mul", level: "medium" },
    };
    let data: Bundle = fallback;
    try {
      if (root.dataset.bundle) data = JSON.parse(root.dataset.bundle) as Bundle;
    } catch {
      data = fallback;
    }
    const txt = (k: string): string => data.txt[k] ?? "";

    // --- Управление таймерами (без вечного rAF) ---
    const timers: number[] = [];
    const clearTimers = (): void => {
      timers.forEach((id) => window.clearTimeout(id));
      timers.length = 0;
    };
    const later = (ms: number, fn: () => void): void => {
      const id = window.setTimeout(fn, reduced ? 0 : ms);
      timers.push(id);
    };

    // ===================================================================
    // ГЕНЕРАТОР ЗАДАЧ — настоящая арифметика под операцию и уровень.
    // (зеркалит ProblemGenerator × DIFFICULTY_CONFIG/OPERATION_RANGES, упрощённо
    // до устно-решаемых чисел; ответ всегда целое.)
    // ===================================================================
    type LevelKey = "easy" | "medium" | "hard";

    // Детерминированный PRNG (mulberry32) — стабильные наборы без Math.random.
    const mkRng = (seed: number): (() => number) => {
      let s = seed >>> 0;
      return (): number => {
        s = (s + 0x6d2b79f5) | 0;
        let x = Math.imul(s ^ (s >>> 15), 1 | s);
        x = (x + Math.imul(x ^ (x >>> 7), 61 | x)) ^ x;
        return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
      };
    };
    const between = (rng: () => number, lo: number, hi: number): number =>
      lo + Math.floor(rng() * (hi - lo + 1));

    const SUP: Record<string, string> = { "2": "²", "3": "³" };

    type Problem = { expr: string; answer: number; rem: number | null };

    // Диапазоны операндов на (операция, уровень). Источник правды для config-readout.
    const RANGES = {
      add: { easy: [2, 20], medium: [10, 100], hard: [100, 999] },
      sub: { easy: [2, 20], medium: [10, 100], hard: [100, 999] },
      mul: { easy: [2, 9], medium: [3, 12], hard: [4, 19] },
      div: { easy: [2, 9], medium: [3, 12], hard: [4, 19] },
      rem: { easy: 9, medium: 15, hard: 25 },
      pow: { easy: [2, 9, [2]], medium: [2, 13, [2, 3]], hard: [2, 15, [2, 3]] },
      root: { easy: 12, medium: 16, hard: 24 },
    } as const;

    const genProblem = (op: string, level: LevelKey, rng: () => number): Problem => {
      switch (op) {
        case "add": {
          const [lo, hi] = RANGES.add[level];
          const a = between(rng, lo, hi);
          const b = between(rng, lo, hi);
          return { expr: `${a} + ${b}`, answer: a + b, rem: null };
        }
        case "sub": {
          const [lo, hi] = RANGES.sub[level];
          let a = between(rng, lo, hi);
          let b = between(rng, lo, hi);
          if (a < b) [a, b] = [b, a];
          return { expr: `${a} − ${b}`, answer: a - b, rem: null };
        }
        case "mul": {
          const [lo, hi] = RANGES.mul[level];
          const a = between(rng, lo, hi);
          const b = between(rng, lo, hi);
          return { expr: `${a} × ${b}`, answer: a * b, rem: null };
        }
        case "div": {
          const [lo, hi] = RANGES.div[level];
          const b = between(rng, lo, hi);
          const q = between(rng, lo, hi);
          return { expr: `${b * q} ÷ ${b}`, answer: q, rem: null };
        }
        case "rem": {
          const dmax = RANGES.rem[level];
          const b = between(rng, 3, dmax);
          const q = between(rng, 2, level === "easy" ? 9 : 12);
          const rem = between(rng, 1, b - 1);
          return { expr: `${b * q + rem} ÷ ${b}`, answer: q, rem };
        }
        case "pow": {
          const [blo, bhi, exps] = RANGES.pow[level];
          const exp = exps[Math.floor(rng() * exps.length)] ?? 2;
          // для куба ограничим основание, чтобы число оставалось читаемым
          const base = exp === 3 ? between(rng, 2, Math.min(bhi as number, 9)) : between(rng, blo as number, bhi as number);
          return { expr: `${base}${SUP[String(exp)] ?? ""}`, answer: base ** exp, rem: null };
        }
        case "root": {
          const rmax = RANGES.root[level];
          const r = between(rng, 2, rmax);
          return { expr: `√${r * r}`, answer: r, rem: null };
        }
        default: {
          const a = between(rng, 2, 20);
          const b = between(rng, 2, 20);
          return { expr: `${a} + ${b}`, answer: a + b, rem: null };
        }
      }
    };

    // Варианты: верный + правдоподобные «соседи». Кол-во = choices уровня.
    const genChoices = (
      p: Problem,
      want: number,
      rng: () => number,
    ): { label: string; correct: boolean }[] => {
      const used = new Set<number>([p.answer]);
      const out: { label: string; correct: boolean }[] = [{ label: String(p.answer), correct: true }];
      let guard = 0;
      while (out.length < want && guard < 80) {
        guard += 1;
        const delta = (1 + Math.floor(rng() * 4)) * (rng() < 0.5 ? 1 : -1);
        const v = p.answer + delta;
        if (v < 0 || used.has(v)) continue;
        used.add(v);
        out.push({ label: String(v), correct: false });
      }
      // запасной проход по смещению, если соседей не хватило
      let off = 1;
      while (out.length < want && off < 50) {
        for (const sign of [1, -1]) {
          const v = p.answer + sign * off;
          if (v < 0 || used.has(v)) continue;
          used.add(v);
          out.push({ label: String(v), correct: false });
          if (out.length >= want) break;
        }
        off += 1;
      }
      // детерминированная тасовка
      for (let i = out.length - 1; i > 0; i -= 1) {
        const j = Math.floor(rng() * (i + 1));
        const a = out[i];
        const b = out[j];
        if (a && b) {
          out[i] = b;
          out[j] = a;
        }
      }
      return out;
    };

    // Человеческая строка диапазона под config-readout.
    const rangePhrase = (op: string, level: LevelKey): string => {
      const up = txt("upToWord");
      if (op === "add" || op === "sub") {
        const [lo, hi] = op === "add" ? RANGES.add[level] : RANGES.sub[level];
        return `${txt("numbersWord")} ${lo}–${hi}`;
      }
      if (op === "mul") {
        const [lo, hi] = RANGES.mul[level];
        return `${txt("factorsWord")} ${lo}–${hi}`;
      }
      if (op === "div") {
        const [, hi] = RANGES.div[level];
        return `${txt("divisorWord")} ${up} ${hi}`;
      }
      if (op === "rem") {
        return `${txt("divisorWord")} ${up} ${RANGES.rem[level]}`;
      }
      if (op === "pow") {
        const [, bhi, exps] = RANGES.pow[level];
        return `${txt("baseWord")} ${up} ${bhi}, ${txt("powerWord")} ${exps.join("/")}`;
      }
      if (op === "root") {
        return `${txt("rootWord")} ${RANGES.root[level]}`;
      }
      return "";
    };

    // ===================================================================
    // DOM
    // ===================================================================
    const zones = new Map<string, HTMLElement>();
    root.querySelectorAll<HTMLElement>("[data-zone]").forEach((z) => zones.set(z.dataset.zone ?? "", z));
    const ZONE_ORDER = ["setup", "solve", "board", "streak"];

    const hintEl = root.querySelector<HTMLElement>("[data-hint]");
    const opBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-op]"));
    const levelBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-level]"));
    const configEl = root.querySelector<HTMLElement>("[data-config]");
    const counterEl = root.querySelector<HTMLElement>("[data-counter]");
    const pipsEl = root.querySelector<HTMLElement>("[data-pips]");
    const exprEl = root.querySelector<HTMLElement>("[data-expr]");
    const phEl = root.querySelector<HTMLElement>("[data-ph]");
    const remTagEl = root.querySelector<HTMLElement>("[data-rem-tag]");
    const choiceBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-choice]"));
    const feedbackEl = root.querySelector<HTMLElement>("[data-feedback]");
    const pointsEl = root.querySelector<HTMLElement>("[data-points]");
    const pointsWhyEl = root.querySelector<HTMLElement>("[data-points-why]");
    const autoBtn = root.querySelector<HTMLButtonElement>("[data-autoplay]");
    const resetBtn = root.querySelector<HTMLButtonElement>("[data-reset]");
    const retryEl = root.querySelector<HTMLElement>("[data-retry]");
    const chipEl = root.querySelector<HTMLElement>("[data-chip]");
    const chipLabelEl = root.querySelector<HTMLElement>("[data-chip-label]");
    const chipSlotEl = root.querySelector<HTMLElement>("[data-chip-slot]");
    const loopEl = root.querySelector<HTMLElement>("[data-loop]");

    // ===================================================================
    // СОСТОЯНИЕ
    // ===================================================================
    type State = "idle" | "configured" | "solving" | "solved" | "landed" | "counted";
    let state: State = "idle";
    let curOp = data.start.op;
    let curLevel = (data.start.level as LevelKey) || "medium";
    let problems: Problem[] = [];
    let choiceSets: { label: string; correct: boolean }[][] = [];
    let qIndex = 0;
    let correctCount = 0;
    let triedCount = 0;
    let pointsTotal = 0;
    let answered = false;
    let setSolved = false;
    let autoRunning = false;
    let handing = false; // идёт съезд чипа — глушим повторные тапы
    let inview = false;

    const lvInfo = (): LvInfo => data.levels[curLevel] ?? { name: "", dot: "", count: 7, choices: 3, weight: 2 };

    // Активная зона + пройденные зоны как функция состояния.
    const zoneForState = (): string => {
      if (state === "idle") return "setup";
      if (state === "configured" || state === "solving" || state === "solved") return "solve";
      if (state === "landed") return "board";
      return "streak";
    };
    const applyZones = (): void => {
      const active = zoneForState();
      const ai = ZONE_ORDER.indexOf(active);
      ZONE_ORDER.forEach((id, i) => {
        const z = zones.get(id);
        if (!z) return;
        z.classList.toggle("is-active", i === ai);
        z.classList.toggle("is-done", i < ai);
      });
    };

    const setHint = (key: string): void => {
      if (!hintEl) return;
      const txtv = data.hints[key] ?? "";
      if (hintEl.textContent === txtv) return;
      hintEl.textContent = txtv;
      if (!reduced && inview) {
        hintEl.classList.remove("dl__hint-swap");
        void hintEl.offsetWidth;
        hintEl.classList.add("dl__hint-swap");
      }
    };

    // Пульс-подсказка на следующий шаг (самогаснущий, transform).
    const pulse = (el: Element | null): void => {
      if (!el || reduced || !inview) return;
      el.classList.remove("dl__pulse");
      void (el as HTMLElement).offsetWidth;
      el.classList.add("dl__pulse");
    };

    const setState = (s: State): void => {
      state = s;
      applyZones();
    };

    // ===================================================================
    // ЗОНА 1 — НАСТРОЙКА
    // ===================================================================
    const renderConfig = (): void => {
      const lv = lvInfo();
      if (configEl) {
        configEl.textContent = `${lv.dot} ${lv.name} · ${lv.count} ${txt("examplesWord")} · ${lv.choices} ${txt("variantsWord")} · ${rangePhrase(curOp, curLevel)}`;
      }
      if (pointsWhyEl) pointsWhyEl.textContent = `${txt("pointsHint")} +${lv.weight}`;
    };

    // ===================================================================
    // ЗОНА 2 — РЕШИ
    // ===================================================================
    const buildSet = (): void => {
      const lv = lvInfo();
      const n = lv.count || 5;
      const want = lv.choices || 3;
      const seed = (curOp.charCodeAt(0) || 1) * 131 + curLevel.length * 977 + n * 17 + want * 7;
      const rng = mkRng(seed);
      problems = [];
      choiceSets = [];
      for (let i = 0; i < n; i += 1) {
        const p = genProblem(curOp, curLevel, rng);
        problems.push(p);
        choiceSets.push(genChoices(p, want, rng));
      }
    };

    const renderPips = (): void => {
      if (!pipsEl) return;
      pipsEl.textContent = "";
      problems.forEach(() => {
        const dot = document.createElement("span");
        dot.className = "dl__pip";
        pipsEl.append(dot);
      });
    };

    const markPip = (i: number, ok: boolean): void => {
      const dot = pipsEl?.children[i] as HTMLElement | undefined;
      if (!dot) return;
      dot.classList.remove("is-cur");
      dot.classList.add(ok ? "is-ok" : "is-miss");
    };
    const markCur = (): void => {
      Array.from(pipsEl?.children ?? []).forEach((d, i) =>
        (d as HTMLElement).classList.toggle("is-cur", i === qIndex),
      );
    };

    const setCounter = (): void => {
      const n = problems.length || 1;
      if (counterEl && !setSolved) {
        counterEl.textContent = `${txt("problemOf")} ${Math.min(qIndex + 1, n)} ${txt("setOf")} ${n}`;
      }
    };

    const renderQuestion = (): void => {
      const p = problems[qIndex];
      const choices = choiceSets[qIndex];
      answered = false;
      if (phEl) phEl.textContent = "?";
      if (exprEl) {
        exprEl.textContent = p ? p.expr : "—";
        if (!reduced && inview) {
          exprEl.classList.remove("dl__expr-swap");
          void exprEl.offsetWidth;
          exprEl.classList.add("dl__expr-swap");
        }
      }
      if (remTagEl) remTagEl.hidden = !(p && p.rem !== null);
      choiceBtns.forEach((btn, i) => {
        const c = choices?.[i];
        const valEl = btn.querySelector<HTMLElement>("[data-val]");
        const markEl = btn.querySelector<HTMLElement>("[data-mark]");
        btn.classList.remove("is-correct", "is-wrong", "is-faded", "dl__shake");
        btn.disabled = false;
        if (markEl) markEl.textContent = "";
        if (c) {
          btn.hidden = false;
          if (valEl) valEl.textContent = c.label;
          btn.dataset.correct = c.correct ? "1" : "0";
        } else {
          btn.hidden = true;
        }
      });
      if (feedbackEl) {
        feedbackEl.textContent = txt("pickAnswer");
        feedbackEl.classList.remove("is-good");
      }
      setCounter();
      markCur();
    };

    const bumpPoints = (): void => {
      if (!pointsEl) return;
      pointsEl.textContent = `+${pointsTotal}`;
      if (!reduced && inview) {
        pointsEl.classList.remove("dl__bump");
        void pointsEl.offsetWidth;
        pointsEl.classList.add("dl__bump");
      }
    };

    const answer = (choiceIdx: number, auto: boolean): void => {
      if (answered || setSolved || handing) return;
      const p = problems[qIndex];
      const choices = choiceSets[qIndex];
      const picked = choices?.[choiceIdx];
      if (!picked || !p) return;
      answered = true;
      triedCount += 1;
      if (state === "configured") setState("solving");
      const isRight = picked.correct;
      const weight = lvInfo().weight || 1;
      if (isRight) {
        correctCount += 1;
        pointsTotal += weight;
        bumpPoints();
      }

      choiceBtns.forEach((btn, i) => {
        const c = choices?.[i];
        if (!c) return;
        btn.disabled = true;
        const m = btn.querySelector<HTMLElement>("[data-mark]");
        if (c.correct) {
          btn.classList.add("is-correct");
          if (m) m.textContent = "✓";
        } else if (i === choiceIdx) {
          btn.classList.add("is-wrong");
          if (m) m.textContent = "✕";
          if (!reduced && inview) {
            btn.classList.remove("dl__shake");
            void btn.offsetWidth;
            btn.classList.add("dl__shake");
          }
        } else {
          btn.classList.add("is-faded");
        }
      });

      // показать верный (для остатка — «q ост. r»)
      if (phEl) {
        phEl.textContent = p.rem !== null ? `${p.answer} ${txt("remShort")} ${p.rem}` : String(p.answer);
      }
      markPip(qIndex, isRight);

      if (feedbackEl) {
        if (!isRight) {
          feedbackEl.textContent = `${data.hints.wrong ?? ""} ${txt("correctIs")} ${p.answer}${p.rem !== null ? ` ${txt("remShort")} ${p.rem}` : ""}`;
          feedbackEl.classList.remove("is-good");
        } else if (p.rem !== null) {
          feedbackEl.textContent = txt("remGloss");
          feedbackEl.classList.add("is-good");
        } else {
          feedbackEl.textContent = `${correctCount} / ${triedCount} ${txt("chipSolved")}`;
          feedbackEl.classList.add("is-good");
        }
      }
      if (retryEl && triedCount - correctCount > 0) retryEl.hidden = false;

      if (!auto) {
        if (!isRight) setHint("wrong");
        // после двух решённых вручную — намекнуть на «Прогон»
        if (triedCount >= 2 && qIndex + 1 < problems.length) {
          setHint("auto");
          pulse(autoBtn);
        }
      }

      const advance = (): void => {
        if (qIndex + 1 < problems.length) {
          qIndex += 1;
          renderQuestion();
          if (autoRunning) scheduleAuto();
        } else {
          finishSet();
        }
      };
      later(auto ? 720 : 620, advance);
    };

    const scheduleAuto = (): void => {
      if (!autoRunning || reduced) return;
      later(820, () => {
        if (!autoRunning || answered || setSolved) return;
        const choices = choiceSets[qIndex] ?? [];
        const rightIdx = choices.findIndex((c) => c.correct);
        // изредка мажет, чтобы точность была < 100%
        const miss = (qIndex + 1) % 4 === 0 && choices.length > 1;
        let pick = rightIdx;
        if (miss) {
          const wrongIdx = choices.findIndex((c) => !c.correct);
          pick = wrongIdx >= 0 ? wrongIdx : rightIdx;
        }
        answer(pick >= 0 ? pick : 0, true);
      });
    };

    const startSet = (autoMode: boolean): void => {
      clearTimers();
      buildSet();
      qIndex = 0;
      correctCount = 0;
      triedCount = 0;
      pointsTotal = 0;
      setSolved = false;
      answered = false;
      autoRunning = autoMode && !reduced;
      handing = false;
      if (pointsEl) pointsEl.textContent = "+0";
      if (retryEl) retryEl.hidden = true;
      if (chipEl) {
        chipEl.hidden = true;
        chipEl.style.transform = "";
        chipEl.classList.remove("dl__chip-travel");
      }
      renderPips();
      renderQuestion();
      if (state === "landed" || state === "counted" || state === "solved") setState("configured");
      if (autoMode && !reduced) scheduleAuto();
    };

    const finishSet = (): void => {
      setSolved = true;
      autoRunning = false;
      qIndex = problems.length;
      setCounter();
      if (counterEl) counterEl.textContent = `${correctCount}/${problems.length}`;
      setState("solved");
      setHint("solved");
      // собрать чип
      const acc = triedCount > 0 ? Math.round((correctCount / triedCount) * 100) : 100;
      if (chipLabelEl) chipLabelEl.textContent = `${correctCount}/${problems.length} · ${acc}% · +${pointsTotal} ${txt("points")}`;
      if (chipEl) chipEl.hidden = false;
      pulse(chipEl);
      // через паузу — съезд в табло
      later(900, () => handoff());
    };

    // ===================================================================
    // ПЕРЕДАЧА — чип съезжает в табло и становится строкой «ты».
    // ===================================================================
    const flashElbow = (toZone: string): void => {
      const z = zones.get(toZone === "board" ? "solve" : "board");
      const el = z?.querySelector<HTMLElement>(`[data-elbow="${toZone}"]`);
      if (!el) return;
      el.classList.add("is-flash");
    };

    const setChipLabel = (s: string): void => {
      if (!chipLabelEl) return;
      chipLabelEl.textContent = s;
      if (!reduced && inview) {
        chipLabelEl.classList.remove("dl__chip-swap");
        void chipLabelEl.offsetWidth;
        chipLabelEl.classList.add("dl__chip-swap");
      }
    };

    const handoff = (): void => {
      // обновить живые значения «тебя» до посадки. Идемпотентно: считаем от seed-
      // значений (me.*), а не накоплением — повторный прогон сходится к seed+последний
      // набор, а не раздувается. Точность — реальная доля верных по объёму попыток.
      const me = data.players.find((p) => p.you);
      if (me) {
        const l = live[me.id];
        if (l) {
          l.solved = me.solved + correctCount;
          l.weighted = me.weighted + pointsTotal;
          l.accuracy = Math.round((me.accuracy * me.solved + correctCount * 100) / (me.solved + triedCount));
        }
      }
      flashElbow("board");

      const finishLanding = (): void => {
        if (chipEl) {
          chipEl.hidden = true;
          chipEl.style.transform = "";
          chipEl.classList.remove("dl__chip-travel");
        }
        setState("landed");
        setHint("landed");
        setMode(curMode, true);
        const meRow = me ? rowEls.find((el) => el.dataset.row === me.id) : null;
        if (meRow && !reduced && inview) {
          meRow.classList.remove("is-land");
          void meRow.offsetWidth;
          meRow.classList.add("is-land");
        }
        // после паузы — намёк на чтение срезов
        later(1400, () => {
          if (state === "landed") setHint("cuts");
        });
        handing = false;
      };

      // FLIP-съезд чипа в слот табло; фолбэк — просто появление строки.
      if (reduced || !inview || !chipEl || !chipSlotEl) {
        finishLanding();
        return;
      }
      handing = true;
      const from = chipEl.getBoundingClientRect();
      const to = chipSlotEl.getBoundingClientRect();
      if (from.width === 0 || to.width === 0) {
        finishLanding();
        return;
      }
      const dx = to.left - from.left;
      const dy = to.top - from.top;
      setChipLabel(`+${pointsTotal} ${txt("points")} ${txt("chipToBoard")}`);
      requestAnimationFrame(() => {
        chipEl.classList.add("dl__chip-travel");
        chipEl.style.transform = `translate(${Math.round(dx)}px, ${Math.round(dy)}px)`;
      });
      later(360, () => setChipLabel(txt("chipPlace")));
      later(760, () => {
        setChipLabel(txt("chipLanded"));
        finishLanding();
      });
    };

    // ===================================================================
    // ЗОНА 3 — ТАБЛО (4 среза, FLIP-перестановка)
    // ===================================================================
    const board = root.querySelector<HTMLElement>("[data-board]");
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));
    const whyEl = root.querySelector<HTMLElement>("[data-why]");
    const rowEls = Array.from(root.querySelectorAll<HTMLElement>("[data-row]"));
    let curMode = "streak";
    const medals = ["①", "②", "③"];

    const live: Record<string, { solved: number; accuracy: number; weighted: number }> = {};
    data.players.forEach((p) => {
      live[p.id] = { solved: p.solved, accuracy: p.accuracy, weighted: p.weighted };
    });

    const valueOf = (p: PData, key: string): number => {
      const l = live[p.id] ?? { solved: p.solved, accuracy: p.accuracy, weighted: p.weighted };
      if (key === "streak") return p.streak;
      if (key === "solved") return l.solved;
      if (key === "accuracy") return l.accuracy;
      return l.weighted;
    };

    const rankFor = (key: string): { id: string; val: number; rank: number }[] => {
      const arr = data.players.map((p) => ({ id: p.id, val: valueOf(p, key) }));
      arr.sort((a, b) => b.val - a.val);
      return arr.map((r, i) => ({ id: r.id, val: r.val, rank: i + 1 }));
    };

    const setMode = (key: string, animate: boolean): void => {
      curMode = key;
      modeBtns.forEach((b) => {
        const on = b.dataset.mode === key;
        b.classList.toggle("is-on", on);
        b.setAttribute("aria-selected", on ? "true" : "false");
      });
      if (whyEl) whyEl.textContent = data.modes[key]?.why ?? "";

      const ranked = rankFor(key);
      const unit = data.modes[key]?.unit ?? "";

      const first = new Map<string, number>();
      if (animate && !reduced && inview) {
        rowEls.forEach((row) => first.set(row.dataset.row ?? "", row.getBoundingClientRect().top));
      }

      ranked.forEach((r) => {
        const row = rowEls.find((el) => el.dataset.row === r.id);
        if (!row) return;
        row.style.order = String(r.rank);
        const placeEl = row.querySelector<HTMLElement>("[data-place]");
        if (placeEl) placeEl.textContent = String(r.rank);
        const medalEl = row.querySelector<HTMLElement>("[data-medal]");
        if (medalEl) medalEl.textContent = r.rank <= 3 ? (medals[r.rank - 1] ?? "") : "";
        const valEl = row.querySelector<HTMLElement>("[data-pval]");
        if (valEl) valEl.textContent = String(r.val);
        const unitEl = row.querySelector<HTMLElement>("[data-unit]");
        if (unitEl) unitEl.textContent = unit;
        row.classList.toggle("is-lead", r.rank === 1);
      });

      if (!animate || reduced || !inview) {
        rowEls.forEach((row) => row.style.setProperty("--flip", "0"));
        return;
      }

      board?.classList.remove("is-flip");
      rowEls.forEach((row) => {
        const id = row.dataset.row ?? "";
        const before = first.get(id) ?? 0;
        const afterTop = row.getBoundingClientRect().top;
        row.style.setProperty("--flip", String(Math.round(before - afterTop)));
      });
      requestAnimationFrame(() => {
        board?.classList.add("is-flip");
        rowEls.forEach((row) => row.style.setProperty("--flip", "0"));
      });
    };

    modeBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.dataset.mode;
        if (!key || key === curMode) return;
        if (state === "landed" || state === "counted") setHint("cuts");
        setMode(key, true);
      });
    });

    // ===================================================================
    // ЗОНА 4 — СЕРИЯ ДНЕЙ
    // ===================================================================
    const dayBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-day]"));
    const nowEl = root.querySelector<HTMLElement>("[data-now]");
    const countBtn = root.querySelector<HTMLButtonElement>("[data-count]");
    const dayOn: boolean[] = dayBtns.map((b) => b.classList.contains("is-on"));

    const currentStreak = (): number => {
      let run = 0;
      for (let i = dayOn.length - 1; i >= 0; i -= 1) {
        if (dayOn[i]) run += 1;
        else break;
      }
      return run;
    };

    const renderDays = (): void => {
      const run = currentStreak();
      const runFrom = dayOn.length - run;
      dayBtns.forEach((btn, i) => {
        const on = dayOn[i] === true;
        btn.classList.toggle("is-on", on);
        btn.classList.toggle("is-run", on && i >= runFrom);
        btn.setAttribute("aria-pressed", on ? "true" : "false");
        const mark = btn.querySelector<HTMLElement>(".dl__day-mark");
        if (mark) mark.textContent = on ? "✓" : "";
      });
      if (nowEl) {
        nowEl.textContent = "";
        nowEl.append(`${txt("nowStreak")}: `);
        const b = document.createElement("b");
        b.textContent = String(run);
        nowEl.append(b, ` ${txt("dayUnit")}`);
      }
    };

    dayBtns.forEach((btn, i) => {
      btn.addEventListener("click", () => {
        dayOn[i] = !dayOn[i];
        renderDays();
        if (state === "counted" || state === "landed") setHint("counted");
      });
    });

    // Засчитать день: зажечь «сегодня», прокрутить серию, открыть петлю-возврат.
    const countDay = (): void => {
      const last = dayOn.length - 1;
      if (correctCount <= 0) return;
      flashElbow("streak");
      if (!dayOn[last]) {
        dayOn[last] = true;
        renderDays();
        const cell = dayBtns[last];
        if (cell && !reduced && inview) {
          cell.classList.remove("dl__day-pop");
          void cell.offsetWidth;
          cell.classList.add("dl__day-pop");
        }
      }
      setState("counted");
      setHint("counted");
      if (loopEl) loopEl.classList.add("is-on");
    };

    countBtn?.addEventListener("click", countDay);

    // ===================================================================
    // ОБРАБОТЧИКИ НАСТРОЙКИ
    // ===================================================================
    opBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.op;
        if (!id) return;
        const changed = id !== curOp;
        curOp = id;
        opBtns.forEach((b) => {
          const on = b === btn;
          b.classList.toggle("is-on", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        renderConfig();
        if (state === "idle") {
          setHint("op");
          pulse(root.querySelector("[data-levels]"));
        }
        if (changed) startSet(false);
      });
    });

    levelBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.level as LevelKey | undefined;
        if (!id) return;
        const changed = id !== curLevel;
        curLevel = id;
        levelBtns.forEach((b) => {
          const on = b === btn;
          b.classList.toggle("is-on", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        renderConfig();
        if (state === "idle" || state === "configured") {
          setState("configured");
          setHint("config");
          pulse(root.querySelector("[data-choices]"));
        }
        if (changed) startSet(false);
      });
    });

    choiceBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.choice ?? "-1");
        autoRunning = false;
        answer(idx, false);
      });
    });

    autoBtn?.addEventListener("click", () => {
      if (state === "idle") setState("configured");
      startSet(true);
    });
    resetBtn?.addEventListener("click", () => {
      autoRunning = false;
      if (loopEl) loopEl.classList.remove("is-on");
      root.querySelectorAll(".dl__elbow.is-flash").forEach((e) => e.classList.remove("is-flash"));
      data.players.forEach((p) => {
        live[p.id] = { solved: p.solved, accuracy: p.accuracy, weighted: p.weighted };
      });
      startSet(false);
      setState("idle");
      setHint("idle");
      setMode(curMode, false);
    });

    // ===================================================================
    // СТАРТ + IntersectionObserver-гейтинг
    // ===================================================================
    renderConfig();
    startSet(false);
    setState("idle");
    setMode("streak", false);
    renderDays();
    applyZones();

    if (reduced || !("IntersectionObserver" in window)) {
      // финальный читаемый кадр без движения
      inview = true;
      root.classList.add("is-inview");
      ZONE_ORDER.forEach((id) => zones.get(id)?.classList.add("is-active"));
      return;
    }

    let pulsedOnce = false;
    const stopAll = (): void => {
      inview = false;
      autoRunning = false;
      clearTimers();
      root.classList.remove("is-inview");
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          inview = e.isIntersecting;
          root.classList.toggle("is-inview", inview);
          if (inview && !pulsedOnce) {
            pulsedOnce = true;
            pulse(root.querySelector("[data-ops]"));
          }
          if (!inview) {
            autoRunning = false;
            clearTimers();
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
