---
/**
 * MathDaily.astro — сигнатурная визуализация .счёт (DotMath).
 *
 * Метафора: ТРЕНАЖЁР, в который посетитель реально играет ~20 секунд, а потом
 * видит себя на ЖИВОМ табло. Это не степпер: нет вкладок шагов и нет «Шаг N из M».
 * Один связный пульт: слева играешь (выбор операции и уровня → набор реальных
 * примеров с тапаемыми вариантами ответа), справа смотришь, как твой результат
 * падает в табло и переранжируется четырьмя срезами; снизу — серия дней.
 *
 * Что можно потыкать:
 *   1) Выбрать 1 из 7 операций (+, −, ×, ÷, ÷ с остатком, степени, корни) и 1 из 3
 *      уровней. Уровень меняет диапазон чисел и размер набора (лёгкий 5 / средний 7 /
 *      сложный 10) — ровно как DIFFICULTY_CONFIG.
 *   2) Прорешать набор: примеры считаются НАСТОЯЩИМ арифметическим значением в JS
 *      (14 × 7 = 98), даются 3–4 варианта, тап отмечает верно/неверно на месте.
 *   3) Табло с 4 срезами (StatsService.get_top_users_by_streak / _by_solved /
 *      _by_accuracy / _by_weighted_score). Переключение среза ФИЗИЧЕСКИ переставляет
 *      строки (FLIP на transform), меняет значения и подписи 1/2/3 мест; в каждом
 *      срезе свой лидер. Взвешенные очки: easy/medium/hard = 1/2/3.
 *   4) Серия дней: 7 ячеек. День хотя бы с одним верным ответом даёт +1; тап
 *      выключает день (пропуск) и обнуляет серию от разрыва; несколько подходов
 *      за день её не двигают.
 *
 * Перф-бюджет: анимируем ТОЛЬКО transform/opacity (FLIP строк, scaleX полос, fade
 * отметок). Ни width/height, ни box-shadow/filter/backdrop-filter в движении.
 * Постоянного rAF нет: автопрогон набора ведёт цепочка setTimeout, которая чистится
 * за экраном / на скрытой вкладке / на pagehide. Всё движение под IntersectionObserver
 * (класс .is-inview). При prefers-reduced-motion — финальное читаемое состояние без
 * движения, а все тапы/переключения/сортировка продолжают работать.
 *
 * Факты (как в репо, без выдумок): ProblemGenerator, DIFFICULTY_CONFIG,
 * StatsService.get_top_users_by_*; aiogram 3, PostgreSQL + asyncpg, Redis FSM,
 * APScheduler в одном процессе; ~9k строк; RU/EN.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const ui = {
  eyebrow: { ru: "Тренажёр устного счёта · поиграй", en: "Mental-math trainer · play it" },
  intro: {
    ru: "Выбери, что тренировать, прорешай набор — примеры настоящие, считаются на лету. Твой результат тут же падает в живое табло, которое можно прочитать четырьмя срезами, и в серию дней. Всё кликается.",
    en: "Pick what to train, solve a set — the problems are real and computed live. Your result drops straight into a live leaderboard you can read four ways, and into a day streak. Everything is clickable.",
  },
  facts: {
    ru: "ProblemGenerator · DIFFICULTY_CONFIG · aiogram 3 · PostgreSQL + asyncpg · Redis FSM · APScheduler в процессе · ~9k строк · RU/EN",
    en: "ProblemGenerator · DIFFICULTY_CONFIG · aiogram 3 · PostgreSQL + asyncpg · Redis FSM · in-process APScheduler · ~9k lines · RU/EN",
  },

  // --- Тренажёр ---
  trainerTitle: { ru: "Тренажёр", en: "Trainer" },
  opsLabel: { ru: "Операция", en: "Operation" },
  levelLabel: { ru: "Уровень", en: "Level" },
  rangeWord: { ru: "диапазон", en: "range" },
  setOf: { ru: "из", en: "of" },
  autoplay: { ru: "Прогон", en: "Auto" },
  reset: { ru: "Заново", en: "Reset" },
  pickAnswer: { ru: "выбери ответ", en: "pick an answer" },
  yourScore: { ru: "верно", en: "correct" },
  attempts: { ru: "попыток", en: "attempts" },
  done: { ru: "набор пройден", en: "set complete" },
  problemOf: { ru: "пример", en: "problem" },
  landed: {
    ru: "результат ушёл в табло и засчитал день",
    en: "result sent to the board, the day is counted",
  },

  // --- Табло ---
  boardTitle: { ru: "Живое табло", en: "Live leaderboard" },
  you: { ru: "ты", en: "you" },
  mStreak: { ru: "стрик", en: "streak" },
  mStreakWhy: {
    ru: "кто занимается без пропусков дольше всех",
    en: "who practised the longest without skipping",
  },
  mSolved: { ru: "решено", en: "solved" },
  mSolvedWhy: { ru: "общий объём верных ответов", en: "raw volume of correct answers" },
  mAccuracy: { ru: "точность", en: "accuracy" },
  mAccuracyWhy: { ru: "верных из всех попыток, в %", en: "correct out of all attempts, %" },
  mWeighted: { ru: "очки", en: "points" },
  mWeightedWhy: {
    ru: "сложное дороже: лёгкое 1 · среднее 2 · сложное 3",
    en: "harder counts more: easy 1 · medium 2 · hard 3",
  },

  // --- Серия дней ---
  streakTitle: { ru: "Серия дней", en: "Day streak" },
  last7: { ru: "Последние 7 дней", en: "Last 7 days" },
  today: { ru: "сегодня", en: "today" },
  legOn: { ru: "день с верным ответом", en: "day with a correct answer" },
  legGap: { ru: "пропуск обнуляет серию", en: "a skip resets the streak" },
  legSess: {
    ru: "второй подход за день не двигает серию",
    en: "a 2nd session that day does nothing",
  },
  nowStreak: { ru: "текущая серия", en: "current streak" },
  dayUnit: { ru: "дн.", en: "d." },
};

// --- 7 операций (TrainingMode / ProblemGenerator) ---
type OpId = "add" | "sub" | "mul" | "div" | "rem" | "pow" | "root";
type Op = { id: OpId; glyph: string; name: Bi };
const operations: Op[] = [
  { id: "add", glyph: "+", name: { ru: "сложение", en: "addition" } },
  { id: "sub", glyph: "−", name: { ru: "вычитание", en: "subtraction" } },
  { id: "mul", glyph: "×", name: { ru: "умножение", en: "multiplication" } },
  { id: "div", glyph: "÷", name: { ru: "деление", en: "division" } },
  { id: "rem", glyph: "÷ᵣ", name: { ru: "с остатком", en: "remainder" } },
  { id: "pow", glyph: "xⁿ", name: { ru: "степени", en: "powers" } },
  { id: "root", glyph: "√", name: { ru: "корни", en: "roots" } },
];

// --- DIFFICULTY_CONFIG: уровень → диапазон чисел, размер набора, вес очков ---
type LvId = "easy" | "medium" | "hard";
type Level = { id: LvId; name: Bi; range: string; count: number; weight: number };
const levels: Level[] = [
  { id: "easy", name: { ru: "лёгкий", en: "easy" }, range: "2–20", count: 5, weight: 1 },
  { id: "medium", name: { ru: "средний", en: "medium" }, range: "10–99", count: 7, weight: 2 },
  { id: "hard", name: { ru: "сложный", en: "hard" }, range: "12–400", count: 10, weight: 3 },
];

// --- Срезы табло (StatsService.get_top_users_by_*) ---
type Mode = { key: string; label: Bi; why: Bi; unit: Bi };
const boardModes: Mode[] = [
  { key: "streak", label: ui.mStreak, why: ui.mStreakWhy, unit: { ru: " дн.", en: " d." } },
  { key: "solved", label: ui.mSolved, why: ui.mSolvedWhy, unit: { ru: "", en: "" } },
  { key: "accuracy", label: ui.mAccuracy, why: ui.mAccuracyWhy, unit: { ru: "%", en: "%" } },
  { key: "weighted", label: ui.mWeighted, why: ui.mWeightedWhy, unit: { ru: "", en: "" } },
];

// --- Игроки. Лидер в каждом срезе РАЗНЫЙ: streak→A, solved→B, accuracy→C, weighted→A. ---
type Player = {
  id: string;
  name: Bi;
  you?: boolean;
  streak: number;
  solved: number;
  accuracy: number;
  weighted: number;
};
const players: Player[] = [
  {
    id: "A",
    name: { ru: "Аня", en: "Anya" },
    streak: 41,
    solved: 980,
    accuracy: 92,
    weighted: 2410,
  },
  {
    id: "B",
    name: { ru: "Борис", en: "Boris" },
    streak: 33,
    solved: 1510,
    accuracy: 90,
    weighted: 2180,
  },
  {
    id: "C",
    name: { ru: "Вера", en: "Vera" },
    streak: 28,
    solved: 870,
    accuracy: 97,
    weighted: 1640,
  },
  { id: "you", name: ui.you, you: true, streak: 4, solved: 1190, accuracy: 94, weighted: 1980 },
];

// Серия дней: ✓✓×(пропуск)✓✓✓✓ → стартовая текущая серия 4.
const initialDays = [true, true, false, true, true, true, true];

// --- Стартовый выбор: умножение · средний ---
const startOp: OpId = "mul";
const startLevel: LvId = "medium";

// Бандл для скрипта (единый источник правды, без дублей строк в JS).
const bundle = {
  ops: Object.fromEntries(operations.map((o) => [o.id, { glyph: o.glyph, name: t(o.name) }])),
  levels: Object.fromEntries(
    levels.map((l) => [
      l.id,
      { name: t(l.name), range: l.range, count: l.count, weight: l.weight },
    ]),
  ),
  modes: Object.fromEntries(boardModes.map((m) => [m.key, { why: t(m.why), unit: t(m.unit) }])),
  players: players.map((p) => ({
    id: p.id,
    name: t(p.name),
    you: Boolean(p.you),
    streak: p.streak,
    solved: p.solved,
    accuracy: p.accuracy,
    weighted: p.weighted,
  })),
  txt: {
    rangeWord: t(ui.rangeWord),
    setOf: t(ui.setOf),
    pickAnswer: t(ui.pickAnswer),
    yourScore: t(ui.yourScore),
    attempts: t(ui.attempts),
    done: t(ui.done),
    problemOf: t(ui.problemOf),
    landed: t(ui.landed),
    you: t(ui.you),
    nowStreak: t(ui.nowStreak),
    dayUnit: t(ui.dayUnit),
  },
  start: { op: startOp, level: startLevel },
};
---

<section class="sd" data-sd data-bundle={JSON.stringify(bundle)} aria-label={t(ui.eyebrow)}>
  <header class="sd__head">
    <p class="sd__eyebrow">{t(ui.eyebrow)}</p>
    <p class="sd__intro">{t(ui.intro)}</p>
  </header>

  <div class="sd__grid">
    <!-- ============================ ТРЕНАЖЁР ============================ -->
    <div class="sd__console" data-trainer>
      <div class="sd__console-head">
        <span class="sd__chip" aria-hidden="true">.счёт</span>
        <h3 class="sd__panel-title">{t(ui.trainerTitle)}</h3>
      </div>

      <span class="sd__label">{t(ui.opsLabel)}</span>
      <div class="sd__ops" role="group" aria-label={t(ui.opsLabel)} data-ops>
        {
          operations.map((op) => (
            <button
              type="button"
              class:list={["sd__op", { "is-on": op.id === startOp }]}
              data-op={op.id}
              aria-pressed={op.id === startOp ? "true" : "false"}
            >
              <span class="sd__glyph" aria-hidden="true">
                {op.glyph}
              </span>
              <span class="sd__op-name">{t(op.name)}</span>
            </button>
          ))
        }
      </div>

      <span class="sd__label">{t(ui.levelLabel)}</span>
      <div class="sd__levels" role="group" aria-label={t(ui.levelLabel)} data-levels>
        {
          levels.map((lv) => (
            <button
              type="button"
              class:list={["sd__level", { "is-on": lv.id === startLevel }]}
              data-level={lv.id}
              aria-pressed={lv.id === startLevel ? "true" : "false"}
            >
              <span class="sd__level-name">{t(lv.name)}</span>
              <span class="sd__level-meta" aria-hidden="true">
                {t(ui.rangeWord)} {lv.range} · {lv.count}
              </span>
            </button>
          ))
        }
      </div>

      <!-- Игровое поле: один пример + варианты ответа -->
      <div class="sd__play" data-play>
        <div class="sd__play-top">
          <span class="sd__counter" data-counter aria-live="polite">
            {t(ui.problemOf)} 1 {t(ui.setOf)}
            {levels[1]?.count ?? 7}
          </span>
          <span class="sd__track" aria-hidden="true">
            <span class="sd__track-fill" data-track style="--p:0;"></span>
          </span>
        </div>

        <div class="sd__question" data-question>
          <span class="sd__expr" data-expr>—</span>
          <span class="sd__eq" aria-hidden="true">=</span>
          <span class="sd__ph" data-ph aria-hidden="true">?</span>
        </div>

        <div class="sd__choices" role="group" aria-label={t(ui.pickAnswer)} data-choices>
          {
            [0, 1, 2, 3].map((k) => (
              <button type="button" class="sd__choice" data-choice={k} hidden={k === 3}>
                <span class="sd__choice-val" data-val>
                  —
                </span>
                <span class="sd__choice-mark" aria-hidden="true" data-mark />
              </button>
            ))
          }
        </div>

        <p class="sd__hint" data-hint aria-live="polite">{t(ui.pickAnswer)}</p>
      </div>

      <div class="sd__console-foot">
        <div class="sd__score" aria-live="polite">
          <b data-correct>0</b>
          <span class="sd__score-sep">/</span>
          <span data-tried>0</span>
          <span class="sd__score-lbl">{t(ui.yourScore)} · {t(ui.attempts)}</span>
        </div>
        <div class="sd__ctl">
          <button type="button" class="sd__btn sd__btn--accent" data-autoplay
            >{t(ui.autoplay)}</button
          >
          <button type="button" class="sd__btn sd__btn--ghost" data-reset>{t(ui.reset)}</button>
        </div>
      </div>
    </div>

    <!-- ============================ ТАБЛО ============================ -->
    <div class="sd__console" data-board-wrap>
      <div class="sd__console-head">
        <span class="sd__chip" aria-hidden="true">top</span>
        <h3 class="sd__panel-title">{t(ui.boardTitle)}</h3>
      </div>

      <div class="sd__modes" role="tablist" aria-label={t(ui.boardTitle)} data-modes>
        {
          boardModes.map((m, i) => (
            <button
              type="button"
              class:list={["sd__mode", { "is-on": i === 0 }]}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              data-mode={m.key}
            >
              {t(m.label)}
            </button>
          ))
        }
      </div>

      <p class="sd__why" data-why aria-live="polite">{t(ui.mStreakWhy)}</p>

      <ol class="sd__board" data-board>
        {
          players.map((p) => (
            <li class:list={["sd__row", { "is-you": p.you }]} data-row={p.id} style="--flip:0;">
              <span class="sd__place" data-place aria-hidden="true">
                1
              </span>
              <span class="sd__medal" aria-hidden="true" data-medal />
              <span class="sd__pname">{t(p.name)}</span>
              <span class="sd__bar" aria-hidden="true">
                <span class="sd__bar-fill" data-fill style="--w:1;" />
              </span>
              <span class="sd__pval">
                <b data-pval>0</b>
                <span class="sd__pval-unit" data-unit />
              </span>
            </li>
          ))
        }
      </ol>
    </div>

    <!-- ============================ СЕРИЯ ДНЕЙ ============================ -->
    <div class="sd__console sd__console--wide" data-streak-wrap>
      <div class="sd__console-head">
        <span class="sd__chip" aria-hidden="true">streak</span>
        <h3 class="sd__panel-title">{t(ui.streakTitle)}</h3>
        <span class="sd__last7">{t(ui.last7)}</span>
      </div>

      <div class="sd__days" role="group" aria-label={t(ui.last7)} data-days>
        {
          initialDays.map((on, i) => (
            <button
              type="button"
              class:list={["sd__day", { "is-on": on }]}
              style={`--i:${i};`}
              data-day={i}
              aria-pressed={on ? "true" : "false"}
              aria-label={`${t(ui.last7)} · ${i + 1}`}
            >
              <span class="sd__day-num" aria-hidden="true">
                {i + 1}
              </span>
              <span class="sd__day-mark" aria-hidden="true" />
              {i === initialDays.length - 1 ? (
                <span class="sd__day-today" aria-hidden="true">
                  {t(ui.today)}
                </span>
              ) : null}
            </button>
          ))
        }
      </div>

      <div class="sd__streak-foot">
        <ul class="sd__legend" role="list">
          <li class="sd__leg sd__leg--on">
            <span class="sd__leg-sw" aria-hidden="true"></span>
            {t(ui.legOn)}
          </li>
          <li class="sd__leg sd__leg--gap">
            <span class="sd__leg-sw" aria-hidden="true"></span>
            {t(ui.legGap)}
          </li>
          <li class="sd__leg sd__leg--sess">{t(ui.legSess)}</li>
        </ul>
        <p class="sd__now" data-now aria-live="polite">
          {t(ui.nowStreak)}: <b>4</b>
          {t(ui.dayUnit)}
        </p>
      </div>
    </div>
  </div>

  <p class="sd__facts">{t(ui.facts)}</p>
</section>

<style>
  .sd {
    --a: var(--project-accent);
    --a-line: color-mix(in srgb, var(--a) 36%, transparent);
    --a-soft: color-mix(in srgb, var(--a) 12%, transparent);
    --a-faint: color-mix(in srgb, var(--a) 7%, transparent);
    --a-glow: color-mix(in srgb, var(--a) 16%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    container-type: inline-size;
  }

  .sd__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sd__eyebrow {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .sd__intro {
    margin: 0;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 66ch;
  }

  /* ------------------------ Раскладка пульта ------------------------ */
  .sd__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @container (min-width: 720px) {
    .sd__grid {
      grid-template-columns: 1fr 1fr;
    }
    .sd__console--wide {
      grid-column: 1 / -1;
    }
  }

  .sd__console {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-xl);
    background:
      radial-gradient(130% 130% at 0% 0%, var(--a-glow), transparent 52%), var(--glass-tint-frost);
    box-shadow: var(--shadow-2);
    min-width: 0;
  }

  .sd__console-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sd__chip {
    display: inline-flex;
    align-items: center;
    padding: 2px var(--sp-2);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-snug);
    color: var(--a);
    border: var(--bw-thin) solid var(--a-line);
    border-radius: var(--r-pill);
    background: var(--a-faint);
  }
  .sd__panel-title {
    margin: 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-20);
    letter-spacing: var(--ls-tight);
    color: var(--text);
  }
  .sd__last7 {
    margin-left: auto;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  .sd__label {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ------------------------ Операции ------------------------ */
  .sd__ops {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-2);
  }
  @container (min-width: 420px) {
    .sd__ops {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .sd__op {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    cursor: pointer;
    text-align: left;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sd__op:hover {
    border-color: var(--border-hover);
  }
  .sd__op:active {
    transform: scale(0.96);
  }
  .sd__op:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sd__op.is-on {
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 9%, var(--surface));
  }
  .sd__glyph {
    flex: none;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-15);
    color: var(--a);
    border: var(--bw-thin) solid color-mix(in srgb, var(--a) 40%, var(--border));
    border-radius: var(--r-xs);
    background: var(--a-faint);
  }
  .sd__op-name {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sd__op.is-on .sd__op-name {
    color: var(--text);
  }

  /* ------------------------ Уровни ------------------------ */
  .sd__levels {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .sd__level {
    flex: 1;
    min-width: 96px;
    min-height: var(--tap-min);
    display: flex;
    flex-direction: column;
    gap: 2px;
    justify-content: center;
    padding: var(--sp-2) var(--sp-3);
    color: var(--text-muted);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    cursor: pointer;
    text-align: left;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sd__level:hover {
    border-color: var(--border-hover);
  }
  .sd__level:active {
    transform: scale(0.96);
  }
  .sd__level:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sd__level-name {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
  }
  .sd__level-meta {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    color: var(--text-faint);
  }
  .sd__level.is-on {
    color: var(--text);
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 9%, var(--surface));
  }
  .sd__level.is-on .sd__level-meta {
    color: var(--text-muted);
  }

  /* ------------------------ Игровое поле ------------------------ */
  .sd__play {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 130% at 50% 0%, var(--a-soft), transparent 55%), var(--surface);
  }
  .sd__play-top {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }
  .sd__counter {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .sd__track {
    flex: 1;
    height: 4px;
    border-radius: var(--r-pill);
    background: var(--surface-3);
    overflow: hidden;
  }
  .sd__track-fill {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--a-line), var(--a));
    transform: scaleX(var(--p, 0));
    transform-origin: left center;
    transition: transform var(--dur-slow) var(--ease-soft);
  }

  .sd__question {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--sp-3);
    padding: var(--sp-3) 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
  }
  .sd__expr {
    font-size: var(--fs-32);
    color: var(--text);
    font-variant-numeric: tabular-nums;
    overflow-wrap: anywhere;
    text-align: center;
  }
  .sd__eq {
    font-size: var(--fs-24);
    color: var(--text-muted);
  }
  .sd__ph {
    font-size: var(--fs-32);
    color: var(--a);
    min-width: 1.2ch;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .sd__question.is-wrong .sd__ph {
    color: var(--text-secondary);
  }

  .sd__choices {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-2);
  }
  @container (min-width: 420px) {
    .sd__choices {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .sd__choice {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--tap-min);
    padding: var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-elevated);
    cursor: pointer;
    font-family: var(--font-stack-mono);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sd__choice[hidden] {
    display: none;
  }
  .sd__choice:hover:not(:disabled) {
    border-color: var(--border-hover);
  }
  .sd__choice:active:not(:disabled) {
    transform: scale(0.95);
  }
  .sd__choice:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sd__choice:disabled {
    cursor: default;
  }
  .sd__choice-val {
    font-size: var(--fs-17);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .sd__choice-mark {
    position: absolute;
    top: 3px;
    right: 5px;
    font-size: var(--fs-11);
    line-height: 1;
    opacity: 0;
    transform: scale(0.4);
    transition:
      opacity var(--dur-fast) var(--ease-soft),
      transform var(--dur-fast) var(--ease-spring);
  }
  .sd__choice.is-correct {
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 14%, var(--bg-elevated));
  }
  .sd__choice.is-correct .sd__choice-mark {
    color: var(--a);
    opacity: 1;
    transform: none;
  }
  .sd__choice.is-wrong {
    border-color: color-mix(in srgb, var(--state-warn) 32%, var(--border));
    opacity: 0.72;
  }
  .sd__choice.is-wrong .sd__choice-mark {
    color: var(--text-muted);
    opacity: 1;
    transform: none;
  }
  .sd__choice.is-faded {
    opacity: 0.4;
  }

  .sd__hint {
    margin: 0;
    font-size: var(--fs-13);
    color: var(--text-muted);
    min-height: 1.4em;
  }
  .sd__hint.is-good {
    color: color-mix(in srgb, var(--a) 70%, var(--text-secondary));
  }

  .sd__console-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .sd__score {
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-1);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-16);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .sd__score b {
    color: var(--a);
    font-weight: var(--fw-semibold);
  }
  .sd__score-sep {
    color: var(--text-faint);
  }
  .sd__score-lbl {
    font-size: var(--fs-11);
    color: var(--text-muted);
    margin-left: var(--sp-1);
  }
  .sd__ctl {
    display: flex;
    gap: var(--sp-2);
  }
  .sd__btn {
    min-height: 38px;
    padding: var(--sp-1) var(--sp-4);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sd__btn:active {
    transform: scale(0.96);
  }
  .sd__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sd__btn--accent {
    color: var(--text);
    background: color-mix(in srgb, var(--a) 14%, var(--surface));
    border: var(--bw-thin) solid var(--a-line);
  }
  .sd__btn--accent:hover {
    border-color: var(--a);
  }
  .sd__btn--ghost {
    color: var(--text-muted);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
  }
  .sd__btn--ghost:hover {
    color: var(--text-secondary);
    border-color: var(--border-hover);
  }

  /* ------------------------ Табло ------------------------ */
  .sd__modes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .sd__mode {
    min-height: 34px;
    padding: var(--sp-1) var(--sp-3);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }
  .sd__mode:hover {
    color: var(--text-secondary);
  }
  .sd__mode.is-on {
    color: var(--text);
    border-color: var(--a-line);
    background: var(--a-faint);
  }
  .sd__mode:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sd__why {
    margin: 0;
    font-size: var(--fs-13);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    min-height: 2.4em;
  }

  .sd__board {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .sd__row {
    display: grid;
    grid-template-columns: 20px 14px minmax(48px, auto) 1fr auto;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2);
    border: var(--bw-thin) solid transparent;
    border-radius: var(--r-sm);
    background: var(--surface);
    /* FLIP: скрипт задаёт стартовый сдвиг через --flip (px), CSS гасит до 0. */
    transform: translateY(calc(var(--flip, 0) * 1px));
  }
  .sd__board.is-flip .sd__row {
    transition: transform var(--dur-slower) var(--ease-soft);
  }
  .sd__row.is-you {
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 7%, var(--surface));
  }
  .sd__place {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .sd__row.is-lead .sd__place {
    color: var(--a);
    font-weight: var(--fw-semibold);
  }
  .sd__medal {
    width: 14px;
    text-align: center;
    font-size: var(--fs-13);
    line-height: 1;
  }
  .sd__pname {
    font-size: var(--fs-14);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sd__row.is-you .sd__pname {
    color: var(--a);
    font-weight: var(--fw-medium);
  }
  .sd__bar {
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface-3);
    overflow: hidden;
  }
  .sd__bar-fill {
    display: block;
    height: 100%;
    width: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--a-line), var(--a));
    transform-origin: left center;
    transform: scaleX(var(--w, 1));
    transition: transform var(--dur-slower) var(--ease-soft);
  }
  .sd__pval {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
    font-family: var(--font-stack-mono);
    font-variant-numeric: tabular-nums;
    justify-self: end;
  }
  .sd__pval b {
    font-size: var(--fs-15);
    color: var(--text);
    font-weight: var(--fw-semibold);
  }
  .sd__pval-unit {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }

  /* «ты» падает в табло после игры — мягкий импульс (transform-only) */
  .sd__row.is-land {
    animation: sd-land var(--dur-slower) var(--ease-spring);
  }
  @keyframes sd-land {
    0% {
      transform: translateY(calc(var(--flip, 0) * 1px)) scale(1.04);
    }
    100% {
      transform: translateY(calc(var(--flip, 0) * 1px)) scale(1);
    }
  }

  /* ------------------------ Серия дней ------------------------ */
  .sd__days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--sp-2);
    margin-bottom: var(--sp-3);
  }
  .sd__day {
    position: relative;
    min-height: var(--tap-min);
    display: grid;
    place-items: center;
    border-radius: var(--r-sm);
    background: var(--surface);
    border: var(--bw-thin) dashed var(--border-hover);
    cursor: pointer;
    transition:
      border-color var(--dur-med) var(--ease-standard),
      background-color var(--dur-med) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .sd__day:hover {
    border-color: var(--border-strong);
  }
  .sd__day:active {
    transform: scale(0.94);
  }
  .sd__day:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .sd__day-num {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-faint);
  }
  .sd__day-mark {
    position: absolute;
    top: 3px;
    right: 5px;
    font-size: var(--fs-11);
    line-height: 1;
    color: var(--a);
    opacity: 0;
    transform: scale(0.4);
    transition:
      opacity var(--dur-fast) var(--ease-soft),
      transform var(--dur-fast) var(--ease-spring);
  }
  .sd__day-today {
    position: absolute;
    bottom: -16px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-10);
    color: var(--text-faint);
    white-space: nowrap;
  }
  .sd__day.is-on {
    background: color-mix(in srgb, var(--a) 20%, var(--surface));
    border-style: solid;
    border-color: var(--a-line);
  }
  .sd__day.is-on .sd__day-num {
    color: var(--text);
  }
  .sd__day.is-on .sd__day-mark {
    opacity: 1;
    transform: none;
  }
  /* дни внутри текущей серии (хвост из ON) — ярче */
  .sd__day.is-run {
    background: color-mix(in srgb, var(--a) 32%, var(--surface));
    border-color: var(--a);
  }

  .sd__streak-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-top: var(--sp-3);
  }
  .sd__legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .sd__leg {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-13);
    color: var(--text-secondary);
  }
  .sd__leg-sw {
    width: 14px;
    height: 14px;
    border-radius: var(--r-xs);
    flex: none;
  }
  .sd__leg--on .sd__leg-sw {
    background: color-mix(in srgb, var(--a) 20%, var(--surface));
    border: var(--bw-thin) solid var(--a-line);
  }
  .sd__leg--gap .sd__leg-sw {
    background: var(--surface);
    border: var(--bw-thin) dashed var(--border-hover);
  }
  .sd__leg--sess {
    color: var(--text-muted);
  }
  .sd__now {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .sd__now b {
    color: var(--a);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-17);
  }

  .sd__facts {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    line-height: var(--lh-normal);
    color: var(--text-faint);
    overflow-wrap: anywhere;
  }

  /* ------------------------ Появление строк (только в кадре) ------------------------ */
  @media (prefers-reduced-motion: no-preference) {
    .sd.is-inview .sd__row {
      animation: sd-rise var(--dur-slow) var(--ease-soft) both;
      animation-delay: calc(var(--ri, 0) * 70ms);
    }
  }
  @keyframes sd-rise {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(calc(var(--flip, 0) * 1px));
    }
  }

  /* ------------------------ Мобайл (≤719px) ------------------------ */
  /*
   * Все правки только в этом блоке — десктопная раскладка (≥720px) не тронута.
   * Брейкпоинт совпадает с переходом грида: container < 720px = 1 колонка.
   */
  @container (max-width: 719px) {
    /* Консоль: меньше внутренних отступов, чтобы контент не давил в стены */
    .sd__console {
      padding: var(--sp-4) var(--sp-3);
      gap: var(--sp-2);
    }

    /* Операции: 2 колонки (уже по умолчанию), но тап-таргет явно ≥44px */
    .sd__op {
      min-height: 44px;
      padding: var(--sp-2) var(--sp-2);
    }

    /* Уровни: растягиваем на всю ширину, по одному в строку чтобы метаинфо не обрезалась */
    .sd__levels {
      flex-direction: column;
    }
    .sd__level {
      flex: none;
      width: 100%;
      min-width: 0;
      min-height: 44px;
      padding: var(--sp-2) var(--sp-3);
    }

    /* Игровое поле: чуть меньше gap */
    .sd__play {
      padding: var(--sp-3);
      gap: var(--sp-2);
    }

    /* Выражение: крупный, читаемый */
    .sd__expr {
      font-size: var(--fs-28);
    }
    .sd__ph {
      font-size: var(--fs-28);
    }

    /* Варианты ответа: 2 колонки, тап-таргет ≥44px, шрифт крупнее */
    .sd__choices {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sp-2);
    }
    .sd__choice {
      min-height: 44px;
      padding: var(--sp-2) var(--sp-1);
    }
    .sd__choice-val {
      font-size: var(--fs-18, var(--fs-17));
    }

    /* Футер тренажёра: счёт и кнопки переносятся */
    .sd__console-foot {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-2);
    }
    .sd__ctl {
      width: 100%;
    }

    /* Кнопки Прогон/Заново: тап-таргет 44px, тянутся на ширину */
    .sd__btn {
      min-height: 44px;
      flex: 1;
      padding: var(--sp-2) var(--sp-3);
    }

    /* Срезы табло: кнопки тянутся равномерно */
    .sd__modes {
      gap: var(--sp-1);
    }
    .sd__mode {
      min-height: 44px;
      flex: 1;
      text-align: center;
    }

    /* Строка табло: убираем бар (мало места), чуть компактнее */
    .sd__row {
      grid-template-columns: 18px 14px 1fr auto;
      padding: var(--sp-1) var(--sp-2);
    }
    .sd__bar {
      display: none;
    }

    /* Серия дней: 7 ячеек на узком — минимальный gap */
    .sd__days {
      gap: var(--sp-1);
    }
    .sd__day {
      min-height: 44px;
    }

    /* «Сегодня»-подпись под ячейкой: немного поднять, чтобы не обрезалась */
    .sd__day-today {
      font-size: 9px;
      bottom: -14px;
    }

    /* Легенда серии: колонкой, чтобы не давила по ширине */
    .sd__streak-foot {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--sp-2);
      margin-top: var(--sp-2);
    }
    .sd__legend {
      flex-direction: column;
      gap: var(--sp-1);
    }
    .sd__leg {
      font-size: var(--fs-12);
    }

    /* Intro: убираем max-width, пусть занимает всю ширину */
    .sd__intro {
      max-width: 100%;
      font-size: var(--fs-14, var(--fs-16));
    }
  }

  /* Совсем узко (≤380px): ещё плотнее */
  @container (max-width: 380px) {
    .sd__days {
      gap: var(--sp-1);
    }
    .sd__console {
      padding: var(--sp-3) var(--sp-2);
    }
    .sd__modes {
      flex-wrap: wrap;
    }
    .sd__mode {
      flex: none;
      min-height: 44px;
      padding: var(--sp-1) var(--sp-2);
      font-size: var(--fs-12);
    }
  }

  /* ------------------------ reduced-motion: статичное читаемое состояние ------------------------ */
  @media (prefers-reduced-motion: reduce) {
    .sd__board.is-flip .sd__row,
    .sd__row {
      transition: none;
      animation: none;
    }
    .sd__track-fill,
    .sd__bar-fill {
      transition: none;
    }
    .sd__choice-mark,
    .sd__day-mark {
      transition: none;
    }
    .sd__row.is-land {
      animation: none;
    }
  }
</style>

<script>
  // Оркестратор тренажёра .счёт. Один пульт: играешь слева, смотришь табло справа,
  // держишь серию снизу. Нет постоянного rAF и нет нумерованного степпера.
  //
  // Движение — только transform/opacity: FLIP строк табло, scaleX полос и прогресса,
  // fade отметок. Автопрогон набора ведёт цепочка setTimeout, которая чистится за
  // экраном / на скрытой вкладке / на pagehide. Всё под IntersectionObserver
  // (класс .is-inview). При prefers-reduced-motion — финальное читаемое состояние,
  // все тапы/переключения/сортировка работают.
  (() => {
    const root = document.querySelector<HTMLElement>("[data-sd]");
    if (!root) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    type OpInfo = { glyph: string; name: string };
    type LvInfo = { name: string; range: string; count: number; weight: number };
    type ModeInfo = { why: string; unit: string };
    type PData = {
      id: string;
      name: string;
      you: boolean;
      streak: number;
      solved: number;
      accuracy: number;
      weighted: number;
    };
    type Bundle = {
      ops: Record<string, OpInfo>;
      levels: Record<string, LvInfo>;
      modes: Record<string, ModeInfo>;
      players: PData[];
      txt: Record<string, string>;
      start: { op: string; level: string };
    };

    const fallback: Bundle = {
      ops: {},
      levels: {},
      modes: {},
      players: [],
      txt: {},
      start: { op: "mul", level: "medium" },
    };
    let data: Bundle = fallback;
    try {
      if (root.dataset.bundle) data = JSON.parse(root.dataset.bundle) as Bundle;
    } catch {
      data = fallback;
    }
    const txt = (k: string): string => data.txt[k] ?? "";

    // ===================================================================
    // ГЕНЕРАТОР ЗАДАЧ — настоящая арифметика под операцию и уровень.
    // ===================================================================
    type LevelKey = "easy" | "medium" | "hard";
    const ranges: Record<LevelKey, { lo: number; hi: number }> = {
      easy: { lo: 2, hi: 20 },
      medium: { lo: 10, hi: 99 },
      hard: { lo: 12, hi: 400 },
    };

    // Детерминированный PRNG (mulberry32) — стабильные наборы без Math.random в цикле.
    const mkRng = (seed: number): (() => number) => {
      let s = seed >>> 0;
      return (): number => {
        s = (s + 0x6d2b79f5) | 0;
        let x = Math.imul(s ^ (s >>> 15), 1 | s);
        x = (x + Math.imul(x ^ (x >>> 7), 61 | x)) ^ x;
        return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
      };
    };
    const between = (rng: () => number, lo: number, hi: number): number =>
      lo + Math.floor(rng() * (hi - lo + 1));

    type Problem = { expr: string; answer: number; ansLabel: string };

    const genProblem = (op: string, level: LevelKey, rng: () => number): Problem => {
      const r = ranges[level];
      const small =
        level === "easy"
          ? { lo: 2, hi: 9 }
          : level === "medium"
            ? { lo: 3, hi: 12 }
            : { lo: 6, hi: 19 };
      switch (op) {
        case "add": {
          const a = between(rng, r.lo, r.hi);
          const b = between(rng, r.lo, r.hi);
          return { expr: `${a} + ${b}`, answer: a + b, ansLabel: String(a + b) };
        }
        case "sub": {
          const a = between(rng, r.lo, r.hi);
          const b = between(rng, r.lo, a);
          return { expr: `${a} − ${b}`, answer: a - b, ansLabel: String(a - b) };
        }
        case "mul": {
          const a = between(rng, small.lo, small.hi);
          const b = between(rng, small.lo, small.hi);
          return { expr: `${a} × ${b}`, answer: a * b, ansLabel: String(a * b) };
        }
        case "div": {
          const b = between(rng, small.lo, small.hi);
          const q = between(rng, small.lo, small.hi);
          const a = b * q;
          return { expr: `${a} ÷ ${b}`, answer: q, ansLabel: String(q) };
        }
        case "rem": {
          const b = between(rng, Math.max(3, small.lo), small.hi);
          const q = between(rng, small.lo, small.hi);
          const rem = between(rng, 1, b - 1);
          const a = b * q + rem;
          // Кодируем ответ как q*100+rem, метка читается «q · rem».
          return { expr: `${a} ÷ ${b}`, answer: q * 100 + rem, ansLabel: `${q} · ${rem}` };
        }
        case "pow": {
          const base = level === "hard" ? between(rng, 2, 13) : between(rng, 2, 9);
          return { expr: `${base}²`, answer: base * base, ansLabel: String(base * base) };
        }
        case "root": {
          const rt = level === "hard" ? between(rng, 4, 20) : between(rng, 2, 12);
          const sq = rt * rt;
          return { expr: `√${sq}`, answer: rt, ansLabel: String(rt) };
        }
        default: {
          const a = between(rng, r.lo, r.hi);
          const b = between(rng, r.lo, r.hi);
          return { expr: `${a} + ${b}`, answer: a + b, ansLabel: String(a + b) };
        }
      }
    };

    // Варианты ответа: верный + 2–3 правдоподобных «соседа».
    const genChoices = (
      p: Problem,
      op: string,
      rng: () => number,
    ): { label: string; correct: boolean }[] => {
      const labels = new Set<string>([p.ansLabel]);
      const out: { label: string; correct: boolean }[] = [{ label: p.ansLabel, correct: true }];
      const wantWrong = op === "mul" || op === "div" || op === "add" || op === "sub" ? 3 : 2;
      let guard = 0;
      while (out.length < wantWrong + 1 && guard < 60) {
        guard += 1;
        let lbl: string;
        if (op === "rem") {
          const q = Math.floor(p.answer / 100);
          const rem = p.answer % 100;
          const dq = Math.max(0, q + (rng() < 0.5 ? 1 : -1) * (1 + Math.floor(rng() * 2)));
          const dr = Math.max(1, rem + (rng() < 0.5 ? 1 : -1));
          lbl = rng() < 0.5 ? `${dq} · ${rem}` : `${q} · ${dr}`;
        } else {
          const delta = (1 + Math.floor(rng() * 4)) * (rng() < 0.5 ? 1 : -1);
          const v = p.answer + delta;
          if (v < 0 || v === p.answer) continue;
          lbl = String(v);
        }
        if (labels.has(lbl)) continue;
        labels.add(lbl);
        out.push({ label: lbl, correct: false });
      }
      // Перемешать детерминированно.
      for (let i = out.length - 1; i > 0; i -= 1) {
        const j = Math.floor(rng() * (i + 1));
        const a = out[i];
        const b = out[j];
        if (a && b) {
          out[i] = b;
          out[j] = a;
        }
      }
      return out;
    };

    // ===================================================================
    // СОСТОЯНИЕ ТРЕНАЖЁРА
    // ===================================================================
    let curOp = data.start.op;
    let curLevel = (data.start.level as LevelKey) || "medium";
    let problems: Problem[] = [];
    let choiceSets: { label: string; correct: boolean }[][] = [];
    let qIndex = 0;
    let correctCount = 0;
    let triedCount = 0;
    let answered = false; // на текущий вопрос уже ответили
    let setSolved = false; // весь набор пройден
    let autoRunning = false;
    let inview = false;
    const timers: number[] = [];

    const clearTimers = (): void => {
      timers.forEach((id) => window.clearTimeout(id));
      timers.length = 0;
    };
    const after = (ms: number, fn: () => void): void => {
      const id = window.setTimeout(fn, ms);
      timers.push(id);
    };

    // --- DOM-узлы тренажёра ---
    const opBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-op]"));
    const levelBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-level]"));
    const exprEl = root.querySelector<HTMLElement>("[data-expr]");
    const phEl = root.querySelector<HTMLElement>("[data-ph]");
    const questionEl = root.querySelector<HTMLElement>("[data-question]");
    const choiceBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-choice]"));
    const counterEl = root.querySelector<HTMLElement>("[data-counter]");
    const trackEl = root.querySelector<HTMLElement>("[data-track]");
    const hintEl = root.querySelector<HTMLElement>("[data-hint]");
    const correctEl = root.querySelector<HTMLElement>("[data-correct]");
    const triedEl = root.querySelector<HTMLElement>("[data-tried]");
    const autoBtn = root.querySelector<HTMLButtonElement>("[data-autoplay]");
    const resetBtn = root.querySelector<HTMLButtonElement>("[data-reset]");

    const lvInfo = (): LvInfo =>
      data.levels[curLevel] ?? { name: "", range: "", count: 7, weight: 2 };

    const buildSet = (): void => {
      const n = lvInfo().count || 5;
      const seed = (curOp.charCodeAt(0) || 1) * 131 + curLevel.length * 977 + n * 17;
      const rng = mkRng(seed);
      problems = [];
      choiceSets = [];
      for (let i = 0; i < n; i += 1) {
        const p = genProblem(curOp, curLevel, rng);
        problems.push(p);
        choiceSets.push(genChoices(p, curOp, rng));
      }
    };

    const setProgress = (): void => {
      const n = problems.length || 1;
      if (trackEl) trackEl.style.setProperty("--p", String(Math.min(1, qIndex / n)));
      if (counterEl && !setSolved) {
        counterEl.textContent = `${txt("problemOf")} ${Math.min(qIndex + 1, n)} ${txt("setOf")} ${n}`;
      }
      if (correctEl) correctEl.textContent = String(correctCount);
      if (triedEl) triedEl.textContent = String(triedCount);
    };

    const renderQuestion = (): void => {
      const p = problems[qIndex];
      const choices = choiceSets[qIndex];
      answered = false;
      questionEl?.classList.remove("is-wrong");
      if (phEl) phEl.textContent = "?";
      if (exprEl) exprEl.textContent = p ? p.expr : "—";
      choiceBtns.forEach((btn, i) => {
        const c = choices?.[i];
        const valEl = btn.querySelector<HTMLElement>("[data-val]");
        const markEl = btn.querySelector<HTMLElement>("[data-mark]");
        btn.classList.remove("is-correct", "is-wrong", "is-faded");
        btn.disabled = false;
        if (markEl) markEl.textContent = "";
        if (c) {
          btn.hidden = false;
          if (valEl) valEl.textContent = c.label;
          btn.dataset.correct = c.correct ? "1" : "0";
        } else {
          btn.hidden = true;
        }
      });
      if (hintEl) {
        hintEl.textContent = txt("pickAnswer");
        hintEl.classList.remove("is-good");
      }
      setProgress();
    };

    // Засчитать ответ: tap по варианту (или авто-выбор в прогоне).
    const answer = (choiceIdx: number, auto: boolean): void => {
      if (answered || setSolved) return;
      const choices = choiceSets[qIndex];
      const picked = choices?.[choiceIdx];
      if (!picked) return;
      answered = true;
      triedCount += 1;
      const isRight = picked.correct;
      if (isRight) correctCount += 1;

      choiceBtns.forEach((btn, i) => {
        const c = choices?.[i];
        if (!c) return;
        btn.disabled = true;
        const m = btn.querySelector<HTMLElement>("[data-mark]");
        if (c.correct) {
          btn.classList.add("is-correct");
          if (m) m.textContent = "✓";
        } else if (i === choiceIdx) {
          btn.classList.add("is-wrong");
          if (m) m.textContent = "✕";
        } else {
          btn.classList.add("is-faded");
        }
      });

      const correctChoice = choices?.find((c) => c.correct);
      if (phEl && correctChoice) phEl.textContent = correctChoice.label;
      questionEl?.classList.toggle("is-wrong", !isRight);
      if (hintEl) {
        hintEl.textContent = `${correctCount} / ${triedCount} ${txt("yourScore")}`;
        hintEl.classList.add("is-good");
      }
      if (correctEl) correctEl.textContent = String(correctCount);
      if (triedEl) triedEl.textContent = String(triedCount);

      const advance = (): void => {
        if (qIndex + 1 < problems.length) {
          qIndex += 1;
          renderQuestion();
          if (autoRunning) scheduleAuto();
        } else {
          finishSet();
        }
      };
      after(reduced ? 0 : auto ? 760 : 600, advance);
    };

    const finishSet = (): void => {
      setSolved = true;
      autoRunning = false;
      qIndex = problems.length;
      setProgress();
      if (counterEl) counterEl.textContent = txt("done");
      if (hintEl) {
        hintEl.textContent = txt("landed");
        hintEl.classList.add("is-good");
      }
      landResult();
    };

    const startSet = (autoMode: boolean): void => {
      clearTimers();
      buildSet();
      qIndex = 0;
      correctCount = 0;
      triedCount = 0;
      setSolved = false;
      answered = false;
      autoRunning = autoMode;
      renderQuestion();
      if (autoMode) scheduleAuto();
    };

    // --- Автопрогон: цепочка setTimeout, чистится за кадром ---
    const scheduleAuto = (): void => {
      if (!autoRunning || reduced) return;
      after(900, () => {
        if (!autoRunning || answered || setSolved) return;
        // Авто чаще выбирает верный, иногда мажет — чтобы accuracy была < 100%.
        const choices = choiceSets[qIndex] ?? [];
        const rightIdx = choices.findIndex((c) => c.correct);
        const miss = (qIndex + 1) % 4 === 0 && choices.length > 1;
        let pick = rightIdx;
        if (miss) {
          const wrongIdx = choices.findIndex((c) => !c.correct);
          pick = wrongIdx >= 0 ? wrongIdx : rightIdx;
        }
        answer(pick >= 0 ? pick : 0, true);
      });
    };

    // Выбор операции / уровня — пересобирает набор.
    opBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.op;
        if (!id || id === curOp) return;
        curOp = id;
        opBtns.forEach((b) => {
          const on = b === btn;
          b.classList.toggle("is-on", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        startSet(false);
      });
    });
    levelBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.level as LevelKey | undefined;
        if (!id || id === curLevel) return;
        curLevel = id;
        levelBtns.forEach((b) => {
          const on = b === btn;
          b.classList.toggle("is-on", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        startSet(false);
      });
    });

    choiceBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.choice ?? "-1");
        autoRunning = false;
        answer(idx, false);
      });
    });

    autoBtn?.addEventListener("click", () => startSet(!reduced));
    resetBtn?.addEventListener("click", () => {
      autoRunning = false;
      startSet(false);
    });

    // ===================================================================
    // ТАБЛО — четыре среза, FLIP-перестановка строк.
    // ===================================================================
    const board = root.querySelector<HTMLElement>("[data-board]");
    const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-mode]"));
    const whyEl = root.querySelector<HTMLElement>("[data-why]");
    const rowEls = Array.from(root.querySelectorAll<HTMLElement>("[data-row]"));
    let curMode = "streak";
    const medals = ["①", "②", "③"];

    // Живые значения «тебя» — стартовые, оживают после игры.
    const live: Record<string, { solved: number; accuracy: number; weighted: number }> = {};
    data.players.forEach((p) => {
      live[p.id] = { solved: p.solved, accuracy: p.accuracy, weighted: p.weighted };
    });

    const valueOf = (p: PData, key: string): number => {
      const l = live[p.id] ?? { solved: p.solved, accuracy: p.accuracy, weighted: p.weighted };
      if (key === "streak") return p.streak;
      if (key === "solved") return l.solved;
      if (key === "accuracy") return l.accuracy;
      return l.weighted;
    };

    // Ранжируем игроков по выбранному срезу → порядок id и значения.
    const rankFor = (key: string): { id: string; val: number; rank: number }[] => {
      const arr = data.players.map((p) => ({ id: p.id, val: valueOf(p, key) }));
      arr.sort((a, b) => b.val - a.val);
      return arr.map((r, i) => ({ id: r.id, val: r.val, rank: i + 1 }));
    };

    // Установить срез: посчитать ранги, FLIP-переставить строки (только transform).
    const setMode = (key: string, animate: boolean): void => {
      curMode = key;
      modeBtns.forEach((b) => {
        const on = b.dataset.mode === key;
        b.classList.toggle("is-on", on);
        b.setAttribute("aria-selected", on ? "true" : "false");
      });
      if (whyEl) whyEl.textContent = data.modes[key]?.why ?? "";

      const ranked = rankFor(key);
      const maxVal = Math.max(1, ...ranked.map((r) => r.val));
      const unit = data.modes[key]?.unit ?? "";

      // FIRST: текущие top-позиции строк (только если двигаем).
      const first = new Map<string, number>();
      if (animate && !reduced && inview) {
        rowEls.forEach((row) => first.set(row.dataset.row ?? "", row.getBoundingClientRect().top));
      }

      // Применяем новый порядок (order) + значения + классы лидера.
      ranked.forEach((r) => {
        const row = rowEls.find((el) => el.dataset.row === r.id);
        if (!row) return;
        row.style.order = String(r.rank);
        const placeEl = row.querySelector<HTMLElement>("[data-place]");
        if (placeEl) placeEl.textContent = String(r.rank);
        const medalEl = row.querySelector<HTMLElement>("[data-medal]");
        if (medalEl) medalEl.textContent = r.rank <= 3 ? (medals[r.rank - 1] ?? "") : "";
        const valEl = row.querySelector<HTMLElement>("[data-pval]");
        if (valEl) valEl.textContent = String(r.val);
        const unitEl = row.querySelector<HTMLElement>("[data-unit]");
        if (unitEl) unitEl.textContent = unit;
        const fillEl = row.querySelector<HTMLElement>("[data-fill]");
        if (fillEl) fillEl.style.setProperty("--w", (r.val / maxVal).toFixed(3));
        row.classList.toggle("is-lead", r.rank === 1);
      });

      if (!animate || reduced || !inview) {
        rowEls.forEach((row) => row.style.setProperty("--flip", "0"));
        return;
      }

      // LAST + INVERT: после смены order считаем новый top, ставим обратный сдвиг.
      board?.classList.remove("is-flip");
      rowEls.forEach((row) => {
        const id = row.dataset.row ?? "";
        const before = first.get(id) ?? 0;
        const afterTop = row.getBoundingClientRect().top;
        row.style.setProperty("--flip", String(Math.round(before - afterTop)));
      });
      // PLAY: на следующем кадре включаем переход и гасим сдвиг до 0.
      requestAnimationFrame(() => {
        board?.classList.add("is-flip");
        rowEls.forEach((row) => row.style.setProperty("--flip", "0"));
      });
    };

    modeBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.dataset.mode;
        if (!key || key === curMode) return;
        setMode(key, true);
      });
    });

    // Результат набора падает в табло: пересчитываем живые значения «тебя».
    const landResult = (): void => {
      const me = data.players.find((p) => p.you);
      if (!me) return;
      const w = lvInfo().weight || 1;
      const l = live[me.id];
      if (l) {
        l.solved += correctCount;
        l.weighted += correctCount * w;
        const sessAcc = triedCount > 0 ? Math.round((correctCount / triedCount) * 100) : l.accuracy;
        l.accuracy = Math.round((l.accuracy + sessAcc) / 2);
      }
      setMode(curMode, true);
      const meRow = rowEls.find((el) => el.dataset.row === me.id);
      if (meRow && !reduced && inview) {
        meRow.classList.remove("is-land");
        void meRow.offsetWidth;
        meRow.classList.add("is-land");
      }
      countTodayFromSession();
    };

    // ===================================================================
    // СЕРИЯ ДНЕЙ
    // ===================================================================
    const dayBtns = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-day]"));
    const nowEl = root.querySelector<HTMLElement>("[data-now]");
    const dayOn: boolean[] = dayBtns.map((b) => b.classList.contains("is-on"));

    // Текущая серия = длина непрерывного хвоста ON, идущего к «сегодня» (последний).
    const currentStreak = (): number => {
      let run = 0;
      for (let i = dayOn.length - 1; i >= 0; i -= 1) {
        if (dayOn[i]) run += 1;
        else break;
      }
      return run;
    };

    const renderDays = (): void => {
      const run = currentStreak();
      const runFrom = dayOn.length - run;
      dayBtns.forEach((btn, i) => {
        const on = dayOn[i] === true;
        btn.classList.toggle("is-on", on);
        btn.classList.toggle("is-run", on && i >= runFrom);
        btn.setAttribute("aria-pressed", on ? "true" : "false");
        const mark = btn.querySelector<HTMLElement>(".sd__day-mark");
        if (mark) mark.textContent = on ? "✓" : "";
      });
      if (nowEl) {
        nowEl.textContent = "";
        nowEl.append(`${txt("nowStreak")}: `);
        const b = document.createElement("b");
        b.textContent = String(run);
        nowEl.append(b, ` ${txt("dayUnit")}`);
      }
    };

    dayBtns.forEach((btn, i) => {
      btn.addEventListener("click", () => {
        dayOn[i] = !dayOn[i];
        renderDays();
      });
    });

    // Прохождение набора засчитывает «сегодня» (последний день). Несколько подходов
    // за день не двигают серию: повторное засчитывание ничего не меняет.
    const countTodayFromSession = (): void => {
      if (correctCount <= 0) return;
      const last = dayOn.length - 1;
      if (!dayOn[last]) {
        dayOn[last] = true;
        renderDays();
      }
    };

    // ===================================================================
    // СТАРТ + IntersectionObserver-гейтинг
    // ===================================================================
    rowEls.forEach((row, i) => row.style.setProperty("--ri", String(i)));
    startSet(false);
    setMode("streak", false);
    renderDays();

    if (reduced || !("IntersectionObserver" in window)) {
      inview = true;
      root.classList.add("is-inview");
      setMode("streak", false);
      return;
    }

    const stopAll = (): void => {
      inview = false;
      autoRunning = false;
      clearTimers();
      root.classList.remove("is-inview");
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          inview = e.isIntersecting;
          root.classList.toggle("is-inview", inview);
          if (!inview) {
            autoRunning = false;
            clearTimers();
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(root);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAll();
    });
    window.addEventListener("pagehide", stopAll);
  })();
</script>
