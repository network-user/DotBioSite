  .md__glyph {
    flex: none;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-16);
    color: var(--project-accent);
    border: var(--bw-thin) solid color-mix(in oklab, var(--project-accent) 40%, var(--border));
    border-radius: var(--r-xs);
    background: color-mix(in oklab, var(--project-accent) 8%, transparent);
  }
  .md__op-label {
    font-size: var(--fs-13);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .md__op.is-picked .md__op-label { color: var(--text); }

  .md__levels {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-top: var(--sp-1);
  }
  .md__level-row {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .md__level {
    flex: 1;
    min-width: 92px;
    text-align: center;
    padding: var(--sp-2) var(--sp-2);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
  }
  .md__level.is-picked {
    color: var(--text);
    border-color: color-mix(in oklab, var(--project-accent) 60%, var(--border));
    background: color-mix(in oklab, var(--project-accent) 9%, var(--surface));
  }
  .md__pick {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: color-mix(in oklab, var(--project-accent) 70%, var(--text-secondary));
  }

  /* ---------- Шаг 2 · набор ---------- */
  .md__set-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
  }
  .md__set-count {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .md__set {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  @container (min-width: 520px) {
    .md__set { grid-template-columns: 1fr 1fr; }
  }
  .md__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    font-family: var(--font-stack-mono);
