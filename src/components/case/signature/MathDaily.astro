  .md__expr {
    font-size: var(--fs-15);
    color: var(--text);
  }
  .md__mark {
    flex: none;
    font-size: var(--fs-15);
  }
  .md__row.is-correct {
    border-color: color-mix(in oklab, var(--project-accent) 32%, var(--border));
  }
  .md__row.is-correct .md__mark { color: var(--project-accent); }
  .md__row.is-wrong .md__mark { color: var(--text-muted); }
  .md__set-foot {
    margin: 0;
    font-size: var(--fs-14);
    color: var(--text-secondary);
  }

  /* ---------- Шаг 3 · рейтинг ---------- */
  .md__modes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .md__mode {
    min-height: 34px;
    padding: var(--sp-1) var(--sp-3);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .md__mode:hover { color: var(--text-secondary); }
  .md__mode.is-active {
    color: var(--text);
    border-color: color-mix(in oklab, var(--project-accent) 55%, var(--border));
  }
  .md__mode:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .md__mode-why {
    margin: 0;
    font-size: var(--fs-14);
    line-height: var(--lh-snug);
    color: var(--text-secondary);
    min-height: 2.4em;
  }

  .md__board {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .md__brow {
    display: grid;
    grid-template-columns: 24px minmax(54px, auto) 1fr auto auto;
    align-items: center;
    gap: var(--sp-2);
    transition: opacity var(--dur-med) var(--ease-standard);
  }
  .md__place {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    color: var(--text-muted);
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .md__brow:first-child .md__place { color: var(--project-accent); }
  .md__name {
    font-size: var(--fs-14);
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .md__bar {
    height: 8px;
    border-radius: var(--r-pill);
    background: var(--surface-3);
    overflow: hidden;
  }
  .md__bar-fill {
    display: block;
    height: 100%;
    width: 100%;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      color-mix(in oklab, var(--project-accent) 65%, transparent),
      var(--project-accent)
    );
    transform-origin: left center;
    /* Длина полосы через scaleX (--w 0..1), а не width — анимируем только transform. */
    transform: scaleX(var(--w, 1));
    transition: transform var(--dur-slower) var(--ease-soft);
  }
  .md__val {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-15);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .md__unit {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .md__hint {
    margin: 0;
    font-size: var(--fs-13);
    color: var(--text-muted);
  }

  /* ---------- Шаг 4 · серия дней ---------- */
  .md__days {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .md__day {
    position: relative;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: var(--r-sm);
    background: var(--surface-3);
    border: var(--bw-thin) solid var(--border);
  }
  .md__day-num {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    color: var(--text-muted);
  }
  .md__day.is-on {
    background: color-mix(in oklab, var(--project-accent) 22%, var(--surface));
    border-color: color-mix(in oklab, var(--project-accent) 60%, var(--border));
  }
  .md__day.is-on .md__day-num { color: var(--text); }
  .md__day.is-gap {
    background: var(--surface);
    border-style: dashed;
    border-color: var(--border-hover);
  }
  .md__day.is-gap .md__day-num { color: var(--text-faint); }

  .md__legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .md__leg {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-13);
    color: var(--text-secondary);
  }
  .md__leg-swatch {
    width: 14px;
    height: 14px;
    border-radius: var(--r-xs);
    flex: none;
  }
  .md__leg--on .md__leg-swatch {
    background: color-mix(in oklab, var(--project-accent) 22%, var(--surface));
    border: var(--bw-thin) solid color-mix(in oklab, var(--project-accent) 60%, var(--border));
  }
  .md__leg--gap .md__leg-swatch {
    background: var(--surface);
    border: var(--bw-thin) dashed var(--border-hover);
  }
  .md__now {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    color: color-mix(in oklab, var(--project-accent) 70%, var(--text-secondary));
  }

  /* ---------- Объяснение шага ---------- */
  .md__explain {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding-top: var(--sp-3);
    border-top: var(--bw-thin) solid var(--border);
  }
  .md__title {
    margin: 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-20);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    color: var(--text);
  }
  .md__body {
    margin: 0;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 64ch;
  }

  /* мягкая смена текста при переключении шага */
  .md__explain[data-swap="true"] .md__title,
  .md__explain[data-swap="true"] .md__body {
    opacity: 0;
    transform: translateY(4px);
  }
  .md__title,
  .md__body {
    transition:
      opacity var(--dur-med) var(--ease-soft),
      transform var(--dur-med) var(--ease-soft);
  }

  /* ---------- Управление ---------- */
  .md__controls {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .md__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: 40px;
    padding: var(--sp-2) var(--sp-4);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    color: var(--text-secondary);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard);
  }
  .md__btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }
  .md__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .md__btn:disabled {
    opacity: 0.4;
    cursor: default;
  }
  .md__btn--replay {
    margin-left: auto;
    color: var(--text-muted);
  }

  .md__progress {
    flex: 1;
    min-width: 80px;
    height: 3px;
    border-radius: var(--r-pill);
    background: var(--surface-3);
    overflow: hidden;
  }
  .md__progress-fill {
    display: block;
    height: 100%;
    width: 0%;
    border-radius: inherit;
    background: color-mix(in oklab, var(--project-accent) 80%, transparent);
    transform-origin: left center;
  }
  /* Авто-таймер шага: плавное заполнение, только когда видно и играет */
  .md.is-inview[data-playing="true"] .md__progress-fill[data-anim="true"] {
    animation: md-progress var(--md-step-ms, 4600ms) linear forwards;
  }
  @keyframes md-progress {
    from { transform: scaleX(0); width: 100%; }
    to { transform: scaleX(1); width: 100%; }
  }

  /* ---------- Появление активной панели (только в кадре) ---------- */
  @media (prefers-reduced-motion: no-preference) {
    .md.is-inview .md__step[data-active="true"] .md__op,
    .md.is-inview .md__step[data-active="true"] .md__row,
    .md.is-inview .md__step[data-active="true"] .md__day,
    .md.is-inview .md__step[data-active="true"] .md__brow {
      opacity: 0;
      animation: md-in var(--dur-slow) var(--ease-soft) forwards;
      animation-delay: calc(var(--i, 0) * 70ms + 90ms);
    }
  }
  @keyframes md-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---------- Мобайл ---------- */
  @container (max-width: 460px) {
    .md__brow {
      grid-template-columns: 22px 1fr auto auto;
    }
    .md__bar { display: none; }
  }

  /* ---------- coarse pointer: без параллакса ---------- */
  @media (pointer: coarse) {
    .md__field { transform: none; }
  }

  /* ---------- reduced-motion: финальное читаемое состояние, без движения ---------- */
  @media (prefers-reduced-motion: reduce) {
    .md__field { transform: none; transition: none; }
    .md__stage { min-height: 0; }
    .md__step {
      position: relative;
      opacity: 1;
      transform: none;
      visibility: visible;
      pointer-events: auto;
      margin-bottom: var(--sp-4);
    }
    .md__step[data-active="false"] { display: block; }
    .md__bar-fill { transition: none; }
    .md__progress-fill { display: none; }
    .md__title,
    .md__body { transition: none; }
  }
</style>

<script>
  // Самодостаточный пошаговый «проигрыватель». Дискретные шаги; никакого rAF
  // и собственных слушателей на document для параллакса. Всё движение —
  // transform/opacity. Авто-проигрывание медленное (~4.6с), пауза на hover и
  // за экраном; таймеры чистятся при скрытии и на pagehide.
  (() => {
    const roots = document.querySelectorAll<HTMLElement>("[data-md]");
    const STEP_MS = 4600;

    roots.forEach((root) => {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const lang = document.documentElement.lang === "en" ? "en" : "ru";

      const steps = Array.from(root.querySelectorAll<HTMLElement>(".md__step"));
      const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>(".md__tab"));
      const explain = root.querySelector<HTMLElement>("[data-explain]");
      const titleEl = root.querySelector<HTMLElement>("[data-title]");
      const textEl = root.querySelector<HTMLElement>("[data-text]");
      const curEl = root.querySelector<HTMLElement>("[data-cur]");
      const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]");
      const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]");
      const replayBtn = root.querySelector<HTMLButtonElement>("[data-replay]");
      const progress = root.querySelector<HTMLElement>("[data-progress]");

      if (!steps.length) return;

      // Тексты шагов и объяснения срезов — из data-* (единый источник из .astro).
      const stepCopy = (JSON.parse(root.dataset.copy || "[]") as
        | { title: string; body: string }[]) ?? [];
      const whyText = (JSON.parse(root.dataset.modewhy || "{}") as
        Record<string, string>) ?? {};

      let idx = 0;
      let playing = !reduce;
      let timer = 0;
      const timers: number[] = [];

      const clearTimers = () => {
        timers.forEach((id) => window.clearTimeout(id));
        timers.length = 0;
        if (timer) {
          window.clearTimeout(timer);
          timer = 0;
        }
      };

      // ---- Рейтинг (шаг 3): переключение срезов ----
      const board = root.querySelector<HTMLElement>("[data-board]");
      const modeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>(".md__mode"));
      const whyEl = root.querySelector<HTMLElement>("[data-why]");

      function applyMode(mode: string) {
        if (!board) return;
        const rows = Array.from(board.querySelectorAll<HTMLElement>(".md__brow"));
        // нормируем длину полос по значению в текущем срезе
        let max = 0;
        rows.forEach((r) => {
          const v = Number(r.dataset["v" + cap(mode)] || 0);
          if (v > max) max = v;
        });
        rows.forEach((r) => {
          const rank = Number(r.dataset["rank" + cap(mode)] || 1);
          const v = Number(r.dataset["v" + cap(mode)] || 0);
          r.style.order = String(rank);
          const place = r.querySelector<HTMLElement>("[data-place]");
          if (place) place.textContent = String(rank);
          const valEl = r.querySelector<HTMLElement>("[data-val]");
          if (valEl) valEl.textContent = String(v);
          const fill = r.querySelector<HTMLElement>("[data-fill]");
          // длина полосы как доля 0..1 от максимума в текущем срезе (scaleX)
          if (fill) fill.style.setProperty("--w", max ? (v / max).toFixed(3) : "0");
          const unitEl = r.querySelector<HTMLElement>("[data-unit]");
          if (unitEl) unitEl.textContent = UNITS[mode]?.[lang] ?? "";
        });
        modeBtns.forEach((b) => {
          const on = b.dataset.mode === mode;
          b.classList.toggle("is-active", on);
          b.setAttribute("aria-selected", on ? "true" : "false");
        });
        if (whyEl && whyText[mode]) whyEl.textContent = whyText[mode];
      }

      const UNITS: Record<string, { ru: string; en: string }> = {
        streak: { ru: " дн.", en: " d." },
        solved: { ru: "", en: "" },
        accuracy: { ru: "%", en: "%" },
        weighted: { ru: "", en: "" },
      };
      const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

      modeBtns.forEach((b) => {
        b.addEventListener("click", () => {
          applyMode(b.dataset.mode || "streak");
          // ручное взаимодействие со срезами не должно «перебрасывать» шаг —
          // просто сбрасываем авто-таймер текущего шага
          restartAuto();
        });
      });

      // ---- Переключение шага ----
      function show(n: number, viaAuto = false) {
        idx = (n + steps.length) % steps.length;

        steps.forEach((s, i) =>
          s.setAttribute("data-active", i === idx ? "true" : "false"),
        );
        tabs.forEach((tb, i) => {
          const on = i === idx;
          tb.classList.toggle("is-active", on);
          tb.setAttribute("aria-selected", on ? "true" : "false");
        });
        if (curEl) curEl.textContent = String(idx + 1);

        // мягкая подмена текста объяснения
        const entry = stepCopy[idx];
        if (explain && titleEl && textEl && entry) {
          explain.setAttribute("data-swap", "true");
          window.setTimeout(() => {
            titleEl.textContent = entry.title;
            textEl.textContent = entry.body;
            explain.removeAttribute("data-swap");
          }, reduce ? 0 : 160);
        }

        if (prevBtn) prevBtn.disabled = idx === 0;

        // на шаге 3 при входе ставим срез «стрик» по умолчанию
        if (idx === 2) applyMode("streak");

        // перезапустить покадровое появление активной панели
        if (!reduce) reflowStepIn();

        // Ручной переход — заново заводим авто-таймер. Авто-переход управляется
        // из scheduleNext (он сам заведёт прогресс-полосу), здесь ничего не делаем.
        if (!viaAuto) restartAuto();
      }

      function reflowStepIn() {
        const active = steps[idx];
        if (!active) return;
        // снять/вернуть .is-inview-зависимую анимацию через короткий тогл класса
        active
          .querySelectorAll<HTMLElement>(".md__op, .md__row, .md__day, .md__brow")
          .forEach((el) => {
            el.style.animation = "none";
            void el.offsetWidth;
            el.style.animation = "";
          });
      }

      // ---- Авто-таймер шага + прогресс-полоса ----
      function armProgress() {
        if (!progress || reduce || !playing) return;
        // рестартуем CSS-анимацию полосы: снять data-anim, сделать reflow, вернуть
        progress.removeAttribute("data-anim");
        progress.style.animation = "none";
        void progress.offsetWidth;
        progress.style.animation = "";
        progress.setAttribute("data-anim", "true");
      }

      function clearProgress() {
        if (!progress) return;
        progress.removeAttribute("data-anim");
      }

      function scheduleNext() {
        if (reduce || !playing) return;
        clearTimers();
        armProgress();
        timer = window.setTimeout(() => {
          show(idx + 1, true);
          scheduleNext();
        }, STEP_MS);
        timers.push(timer);
      }

      function restartAuto() {
        clearTimers();
        clearProgress();
        if (playing && !reduce) scheduleNext();
      }

      // ---- Управление ----
      tabs.forEach((tb) =>
        tb.addEventListener("click", () => {
          show(Number(tb.dataset.go || 0));
        }),
      );
      prevBtn?.addEventListener("click", () => show(idx - 1));
      nextBtn?.addEventListener("click", () => show(idx + 1));
      replayBtn?.addEventListener("click", () => {
        playing = !reduce;
        root.setAttribute("data-playing", playing ? "true" : "false");
        show(0);
      });

      // пауза авто-проигрывания на hover/focus, продолжение при уходе
      const pause = () => {
        playing = false;
        root.setAttribute("data-playing", "false");
        clearTimers();
        clearProgress();
      };
      const resume = () => {
        // не возобновляем за экраном и при reduced-motion
        if (reduce || !root.classList.contains("is-inview")) return;
        playing = true;
        root.setAttribute("data-playing", "true");
        scheduleNext();
      };
      root.addEventListener("mouseenter", pause);
      root.addEventListener("mouseleave", resume);
      root.addEventListener("focusin", pause);
      root.addEventListener("focusout", (e) => {
        if (!root.contains(e.relatedTarget as Node)) resume();
      });

      // ---- Видимость: играть только в кадре ----
      let everInview = false;
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              root.classList.add("is-inview");
              if (!everInview) {
                everInview = true;
                if (!reduce) reflowStepIn();
              }
              playing = !reduce;
              root.setAttribute("data-playing", playing ? "true" : "false");
              scheduleNext();
            } else {
              root.classList.remove("is-inview");
              playing = false;
              root.setAttribute("data-playing", "false");
              clearTimers();
              clearProgress();
            }
          }
        },
        { threshold: 0.3 },
      );
      io.observe(root);

      window.addEventListener(
        "pagehide",
        () => {
          clearTimers();
          io.disconnect();
        },
        { once: true },
      );

      // старт: длительность авто-шага → в CSS-var, чтобы полоса и таймер совпадали
      root.style.setProperty("--md-step-ms", `${STEP_MS}ms`);
      root.setAttribute("data-playing", reduce ? "false" : "true");
      if (prevBtn) prevBtn.disabled = true;
    });
  })();
</script>
