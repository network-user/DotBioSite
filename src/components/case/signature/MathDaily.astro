---
/**
 * MathDaily.astro — сигнатурная визуализация .счёт (DotMath): «Дорожка дня».
 *
 * Метафора: ОДНА нисходящая дорожка, по которой идёт твой результат. Сверху вниз
 * читается причинная петля проекта: Настройка → Реши → Табло → Серия. В каждый
 * момент подсвечена РОВНО ОДНА зона (остальные приглушены прозрачностью) — поэтому
 * глаз всегда знает, куда смотреть. Когда набор пройден, твой результат не «появляется»
 * в табло новой строкой, а ФИЗИЧЕСКИ съезжает по дорожке вниз и СТАНОВИТСЯ твоей
 * строкой; по пути его подпись меняется (+N очк. → ↑ место → +1 день). Так связь
 * «решил → очки → рейтинг → серия» видно буквально, а не подразумевается.
 *
 * Что можно потыкать:
 *   1) Выбрать 1 из 7 операций (+, −, ×, ÷, ÷ с остатком, степени, корни) и 1 из 3
 *      уровней. Уровень меняет диапазон чисел, размер набора (5/7/10) и число
 *      вариантов (2/3/4) — как DIFFICULTY_CONFIG. Под выбором — живой config-readout.
 *   2) Решить набор: примеры считаются НАСТОЯЩИМ арифметическим значением в JS
 *      (14 × 7 = 98). «С остатком» теперь честное «47 ÷ 9 = 5 ост. 2»: в ответе целое
 *      частное, остаток показывается отдельной подписью (а не кодом «q · rem»).
 *      Счётчик очков набегает по весу уровня (1/2/3) — вес видно ДО того, как табло
 *      назовёт срез «Очки».
 *   3) Табло с 4 срезами (StatsService.get_top_users_by_streak / _by_solved /
 *      _by_accuracy / _by_weighted). У срезов человеческие имена и одна строка-смысл.
 *      В каждом срезе свой лидер; твоя строка стоит на разном месте.
 *   4) Серия дней: 7 ячеек. День хотя бы с одним верным даёт +1; тап выключает день
 *      (пропуск) и обнуляет серию от разрыва; второй подход за день её не двигает.
 *
 * Перф-бюджет: анимируем ТОЛЬКО transform/opacity (съезд чипа — FLIP-translate, смена
 * активной зоны и стрелок-связок — opacity, перестановка строк — FLIP). Ни width/height,
 * ни box-shadow/filter/backdrop-filter в движении. Постоянного rAF нет: автопрогон и
 * пульс-подсказка — цепочки setTimeout (later()), чистятся за экраном / на скрытой
 * вкладке / на pagehide. Всё движение под IntersectionObserver (.is-inview).
 * prefers-reduced-motion → финальный читаемый кадр (чип уже стал строкой табло, день
 * засчитан, серия +1), а все тапы/переключения/сортировка продолжают работать.
 *
 * Факты (как в репо, без выдумок): ProblemGenerator, DIFFICULTY_CONFIG, OPERATION_RANGES,
 * StatsService.get_top_users_by_* + DIFFICULTY_WEIGHTS {easy:1, medium:2, hard:3};
 * aiogram 3.15, PostgreSQL + asyncpg, Redis FSM (AOF), APScheduler в одном процессе;
 * ~9k строк; RU/EN; общий челлендж дня и перерешивание ошибок.
 */
import type { Locale } from "../../../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

type Bi = { ru: string; en: string };
const t = (b: Bi): string => b[locale];

const ui = {
  eyebrow: { ru: "Тренажёр устного счёта · пройди дорожку", en: "Mental-math trainer · walk the lane" },
  intro: {
    ru: "Один пример проходит весь движок проекта. Выбери, что тренировать, реши набор — и смотри, как твой результат сам спускается в очки, рейтинг и серию дней. Всё кликается, в каждый момент подсвечено то, что делать дальше.",
    en: "One problem walks the whole engine. Pick what to train, solve a set — and watch your result descend on its own into points, the leaderboard, and your day streak. Everything is clickable; the next step is always lit.",
  },
  facts: {
    ru: "ProblemGenerator · DIFFICULTY_CONFIG · StatsService — 4 среза · веса 1·2·3 · челлендж дня · aiogram 3 · PostgreSQL + asyncpg · Redis FSM · APScheduler · ~9k строк · RU/EN",
    en: "ProblemGenerator · DIFFICULTY_CONFIG · StatsService — 4 cuts · weights 1·2·3 · daily challenge · aiogram 3 · PostgreSQL + asyncpg · Redis FSM · APScheduler · ~9k lines · RU/EN",
  },

  // --- Зоны ---
  z1: { ru: "Настройка", en: "Set up" },
  z1cap: { ru: "что тренируем", en: "what to train" },
  z2: { ru: "Реши", en: "Solve" },
  z3: { ru: "Табло", en: "Board" },
  z3cap: { ru: "один результат — четыре среза", en: "one result — four cuts" },
  z4: { ru: "Серия дней", en: "Day streak" },
  z4cap: { ru: "последние 7 дней", en: "last 7 days" },

  opsLabel: { ru: "Операция", en: "Operation" },
  levelLabel: { ru: "Уровень", en: "Level" },

  // config-readout «слова»
  examplesWord: { ru: "примеров", en: "problems" },
  variantsWord: { ru: "варианта", en: "choices" },
  numbersWord: { ru: "числа", en: "numbers" },
  upToWord: { ru: "до", en: "up to" },
  factorsWord: { ru: "множители", en: "factors" },
  dividendWord: { ru: "делимое", en: "dividend" },
  divisorWord: { ru: "делитель", en: "divisor" },
  baseWord: { ru: "основание", en: "base" },
  powerWord: { ru: "степень", en: "power" },
  rootWord: { ru: "корни до", en: "roots up to" },

  // решалка
  problemOf: { ru: "пример", en: "problem" },
  setOf: { ru: "из", en: "of" },
  pickAnswer: { ru: "посчитай в уме и выбери ответ", en: "do it in your head and pick the answer" },
  withRemainder: { ru: "с остатком", en: "with remainder" },
  remShort: { ru: "ост.", en: "r" },
  correctIs: { ru: "верный ответ:", en: "correct answer:" },
  remGloss: {
    ru: "в ответе — целое от деления; остаток показан отдельно",
    en: "the answer is the whole quotient; the remainder is shown separately",
  },
  points: { ru: "очк.", en: "pts" },
  pointsHint: {
    ru: "сложное дороже: верный на этом уровне даёт",
    en: "harder counts more: a correct answer here is worth",
  },
  autoplay: { ru: "Прогнать набор", en: "Auto-run set" },
  reset: { ru: "Заново", en: "Reset" },
  retryNote: {
    ru: "промахи копятся: «перерешать ошибки» собрал бы новый набор только из них",
    en: "misses pile up: “retry mistakes” would build a fresh set from those only",
  },

  // результат-чип
  chipSolved: { ru: "верных", en: "correct" },
  chipToBoard: { ru: "→ в табло", en: "→ to board" },
  chipPlace: { ru: "↑ место", en: "↑ rank" },
  chipLanded: { ru: "встал в табло", en: "in the board" },

  // связки между зонами
  elbowToBoard: { ru: "результат → табло", en: "result → board" },
  elbowToStreak: { ru: "+1 день →", en: "+1 day →" },
  loopBack: { ru: "и завтра заново", en: "and tomorrow again" },

  // табло
  you: { ru: "ты", en: "you" },
  mStreak: { ru: "Дни подряд", en: "Days in a row" },
  mStreakWhy: { ru: "самая длинная серия без пропусков", en: "longest no-skip run" },
  mSolved: { ru: "Решено", en: "Solved" },
  mSolvedWhy: { ru: "сколько верных ответов всего", en: "total correct answers" },
  mAccuracy: { ru: "Точность", en: "Accuracy" },
  mAccuracyWhy: { ru: "доля верных из всех попыток, %", en: "share of correct out of all attempts, %" },
  mWeighted: { ru: "Очки", en: "Points" },
  mWeightedWhy: {
    ru: "сложное дороже: лёгкое ×1 · среднее ×2 · сложное ×3",
    en: "harder counts more: easy ×1 · medium ×2 · hard ×3",
  },

  // серия
  today: { ru: "сегодня", en: "today" },
  dayWord: { ru: "день", en: "day" },
  countDay: { ru: "Засчитать день", en: "Count the day" },
  legOn: { ru: "день с верным ответом", en: "day with a correct answer" },
  legGap: { ru: "пропуск обнуляет серию", en: "a skip resets the streak" },
  legSess: { ru: "второй подход за день ничего не меняет", en: "a 2nd session that day does nothing" },
  nowStreak: { ru: "текущая серия", en: "current streak" },
  dayUnit: { ru: "дн.", en: "d." },

  // подсказки-ведение (одна живая строка)
  hIdle: { ru: "Выбери, что тренировать.", en: "Pick what to train." },
  hOp: { ru: "Хорошо — теперь выбери уровень сложности.", en: "Good — now pick a difficulty." },
  hConfig: {
    ru: "Готово. Реши набор — примеры настоящие, считаются на лету.",
    en: "Set. Solve the set — real problems, computed live.",
  },
  hWrong: {
    ru: "Мимо — верный подсвечен. Попытка засчитана, идём дальше.",
    en: "Missed — the right one's highlighted. The attempt counts; moving on.",
  },
  hAuto: { ru: "Дальше можно прогнать набор одной кнопкой.", en: "You can auto-run the rest with one button." },
  hSolved: { ru: "Набор пройден. Смотри, куда уходит результат.", en: "Set complete. Watch where your result goes." },
  hLanded: {
    ru: "Твоя строка встала в табло. Прочитай его четырьмя способами.",
    en: "Your row is in the board. Read it four ways.",
  },
  hCuts: {
    ru: "Один результат — четыре рейтинга. Твоё место в каждом разное.",
    en: "One result, four rankings. Your place differs in each.",
  },
  hCounted: {
    ru: "Один верный за день держит серию, пропуск — обнуляет. И завтра заново — это и есть привычка.",
    en: "One correct a day keeps the streak; a skip resets it. And tomorrow again — that's the habit.",
  },
};

// --- 7 операций (TrainingMode / ProblemGenerator) ---
type OpId = "add" | "sub" | "mul" | "div" | "rem" | "pow" | "root";
type Op = { id: OpId; glyph: string; name: Bi };
const operations: Op[] = [
  { id: "add", glyph: "+", name: { ru: "сложение", en: "addition" } },
  { id: "sub", glyph: "−", name: { ru: "вычитание", en: "subtraction" } },
  { id: "mul", glyph: "×", name: { ru: "умножение", en: "multiplication" } },
  { id: "div", glyph: "÷", name: { ru: "деление", en: "division" } },
  { id: "rem", glyph: "÷·", name: { ru: "с остатком", en: "remainder" } },
  { id: "pow", glyph: "xⁿ", name: { ru: "степени", en: "powers" } },
  { id: "root", glyph: "√", name: { ru: "корни", en: "roots" } },
];

// --- DIFFICULTY_CONFIG: уровень → размер набора, число вариантов, вес очков ---
type LvId = "easy" | "medium" | "hard";
type Level = { id: LvId; name: Bi; dot: string; count: number; choices: number; weight: number };
const levels: Level[] = [
  { id: "easy", name: { ru: "лёгкий", en: "easy" }, dot: "🟢", count: 5, choices: 2, weight: 1 },
  { id: "medium", name: { ru: "средний", en: "medium" }, dot: "🟡", count: 7, choices: 3, weight: 2 },
  { id: "hard", name: { ru: "сложный", en: "hard" }, dot: "🔴", count: 10, choices: 4, weight: 3 },
];

// --- Срезы табло (StatsService.get_top_users_by_*) ---
type Mode = { key: string; label: Bi; why: Bi; unit: Bi };
const boardModes: Mode[] = [
  { key: "streak", label: ui.mStreak, why: ui.mStreakWhy, unit: { ru: " дн.", en: " d." } },
  { key: "solved", label: ui.mSolved, why: ui.mSolvedWhy, unit: { ru: "", en: "" } },
  { key: "accuracy", label: ui.mAccuracy, why: ui.mAccuracyWhy, unit: { ru: "%", en: "%" } },
  { key: "weighted", label: ui.mWeighted, why: ui.mWeightedWhy, unit: { ru: "", en: "" } },
];

// --- Игроки. Лидер в каждом срезе РАЗНЫЙ: streak→A, solved→B, accuracy→C, weighted→ты.
// «Ты» лидируешь по очкам при том, что решено меньше, чем у Бориса, — это и продаёт
// идею взвешенных очков (сложное стоит дороже). ---
type Player = {
  id: string;
  name: Bi;
  you?: boolean;
  streak: number;
  solved: number;
  accuracy: number;
  weighted: number;
};
const players: Player[] = [
  { id: "A", name: { ru: "Аня", en: "Anya" }, streak: 41, solved: 980, accuracy: 92, weighted: 2050 },
  { id: "B", name: { ru: "Борис", en: "Boris" }, streak: 33, solved: 1510, accuracy: 90, weighted: 2180 },
  { id: "C", name: { ru: "Вера", en: "Vera" }, streak: 28, solved: 870, accuracy: 97, weighted: 1640 },
  { id: "you", name: ui.you, you: true, streak: 4, solved: 1190, accuracy: 94, weighted: 2410 },
];

// Серия дней: ✓✓×(пропуск)✓✓✓✓ → стартовая текущая серия 4.
const initialDays = [true, true, false, true, true, true, true];

// Стартовый выбор: умножение · средний (head-solvable по умолчанию).
const startOp: OpId = "mul";
const startLevel: LvId = "medium";

// Бандл для скрипта (единый источник правды строк, без дублей в JS).
const bundle = {
  ops: Object.fromEntries(operations.map((o) => [o.id, { glyph: o.glyph, name: t(o.name) }])),
  levels: Object.fromEntries(
    levels.map((l) => [l.id, { name: t(l.name), dot: l.dot, count: l.count, choices: l.choices, weight: l.weight }]),
  ),
  modes: Object.fromEntries(boardModes.map((m) => [m.key, { label: t(m.label), why: t(m.why), unit: t(m.unit) }])),
  players: players.map((p) => ({
    id: p.id,
    name: t(p.name),
    you: Boolean(p.you),
    streak: p.streak,
    solved: p.solved,
    accuracy: p.accuracy,
    weighted: p.weighted,
  })),
  txt: {
    problemOf: t(ui.problemOf),
    setOf: t(ui.setOf),
    pickAnswer: t(ui.pickAnswer),
    withRemainder: t(ui.withRemainder),
    remShort: t(ui.remShort),
    correctIs: t(ui.correctIs),
    remGloss: t(ui.remGloss),
    points: t(ui.points),
    pointsHint: t(ui.pointsHint),
    you: t(ui.you),
    nowStreak: t(ui.nowStreak),
    dayUnit: t(ui.dayUnit),
    chipSolved: t(ui.chipSolved),
    chipToBoard: t(ui.chipToBoard),
    chipPlace: t(ui.chipPlace),
    chipLanded: t(ui.chipLanded),
    examplesWord: t(ui.examplesWord),
    variantsWord: t(ui.variantsWord),
    numbersWord: t(ui.numbersWord),
    upToWord: t(ui.upToWord),
    factorsWord: t(ui.factorsWord),
    dividendWord: t(ui.dividendWord),
    divisorWord: t(ui.divisorWord),
    baseWord: t(ui.baseWord),
    powerWord: t(ui.powerWord),
    rootWord: t(ui.rootWord),
  },
  hints: {
    idle: t(ui.hIdle),
    op: t(ui.hOp),
    config: t(ui.hConfig),
    wrong: t(ui.hWrong),
    auto: t(ui.hAuto),
    solved: t(ui.hSolved),
    landed: t(ui.hLanded),
    cuts: t(ui.hCuts),
    counted: t(ui.hCounted),
  },
  start: { op: startOp, level: startLevel },
};
---

<section class="dl" data-dl data-bundle={JSON.stringify(bundle)} aria-label={t(ui.eyebrow)}>
  <header class="dl__head">
    <p class="dl__eyebrow">{t(ui.eyebrow)}</p>
    <p class="dl__intro">{t(ui.intro)}</p>
  </header>

  <p class="dl__hint" data-hint aria-live="polite">{t(ui.hIdle)}</p>

  <div class="dl__lane">
    <!-- =================== ЗОНА 1 · НАСТРОЙКА =================== -->
    <section class="dl__zone is-active" data-zone="setup" aria-label={t(ui.z1)}>
      <span class="dl__rail" aria-hidden="true"><span class="dl__node"></span></span>
      <div class="dl__body">
        <div class="dl__zhead">
          <span class="dl__znum" aria-hidden="true">1</span>
          <h3 class="dl__ztitle">{t(ui.z1)}</h3>
          <span class="dl__zcap">{t(ui.z1cap)}</span>
        </div>

        <span class="dl__label">{t(ui.opsLabel)}</span>
        <div class="dl__ops" role="group" aria-label={t(ui.opsLabel)} data-ops>
          {
            operations.map((op) => (
              <button
                type="button"
                class:list={["dl__op", { "is-on": op.id === startOp }]}
                data-op={op.id}
                aria-pressed={op.id === startOp ? "true" : "false"}
              >
                <span class="dl__glyph" aria-hidden="true">{op.glyph}</span>
                <span class="dl__op-name">{t(op.name)}</span>
              </button>
            ))
          }
        </div>

        <span class="dl__label">{t(ui.levelLabel)}</span>
        <div class="dl__levels" role="group" aria-label={t(ui.levelLabel)} data-levels>
          {
            levels.map((lv) => (
              <button
                type="button"
                class:list={["dl__level", { "is-on": lv.id === startLevel }]}
                data-level={lv.id}
                aria-pressed={lv.id === startLevel ? "true" : "false"}
              >
                <span class="dl__level-dot" aria-hidden="true">{lv.dot}</span>
                <span class="dl__level-name">{t(lv.name)}</span>
              </button>
            ))
          }
        </div>

        <p class="dl__config" data-config aria-live="polite"></p>

        <span class="dl__elbow" data-elbow="solve" aria-hidden="true"></span>
      </div>
    </section>

    <!-- =================== ЗОНА 2 · РЕШИ =================== -->
    <section class="dl__zone" data-zone="solve" aria-label={t(ui.z2)}>
      <span class="dl__rail" aria-hidden="true"><span class="dl__node"></span></span>
      <div class="dl__body">
        <div class="dl__zhead">
          <span class="dl__znum" aria-hidden="true">2</span>
          <h3 class="dl__ztitle">{t(ui.z2)}</h3>
          <span class="dl__counter" data-counter aria-live="polite">
            {t(ui.problemOf)} 1 {t(ui.setOf)} {levels[1]?.count ?? 7}
          </span>
        </div>

        <div class="dl__pips" data-pips aria-hidden="true"></div>

        <div class="dl__play" data-play>
          <div class="dl__question" data-question>
            <span class="dl__expr" data-expr>—</span>
            <span class="dl__eq" aria-hidden="true">=</span>
            <span class="dl__ph" data-ph aria-hidden="true">?</span>
            <span class="dl__rem-tag" data-rem-tag hidden>{t(ui.withRemainder)}</span>
          </div>

          <div class="dl__choices" role="group" aria-label={t(ui.pickAnswer)} data-choices>
            {
              [0, 1, 2, 3].map((k) => (
                <button type="button" class="dl__choice" data-choice={k} hidden={k >= 2}>
                  <span class="dl__choice-val" data-val>—</span>
                  <span class="dl__choice-mark" aria-hidden="true" data-mark />
                </button>
              ))
            }
          </div>

          <p class="dl__feedback" data-feedback aria-live="polite">{t(ui.pickAnswer)}</p>
        </div>

        <div class="dl__solvefoot">
          <span class="dl__pointsbox" aria-live="polite">
            <span class="dl__points" data-points>+0</span>
            <span class="dl__points-lbl">{t(ui.points)}</span>
            <span class="dl__points-why" data-points-why></span>
          </span>
          <div class="dl__ctl">
            <button type="button" class="dl__btn dl__btn--accent" data-autoplay>{t(ui.autoplay)}</button>
            <button type="button" class="dl__btn dl__btn--ghost" data-reset>{t(ui.reset)}</button>
          </div>
        </div>

        <p class="dl__retry" data-retry hidden>{t(ui.retryNote)}</p>

        <!-- Результат-чип: рождается тут, съезжает в табло. -->
        <div class="dl__chip" data-chip hidden aria-hidden="true">
          <span class="dl__chip-spark"></span>
          <span class="dl__chip-label" data-chip-label></span>
        </div>

        <span class="dl__elbow" data-elbow="board" aria-hidden="true">
          <span class="dl__elbow-lbl">{t(ui.elbowToBoard)}</span>
        </span>
      </div>
    </section>

    <!-- =================== ЗОНА 3 · ТАБЛО =================== -->
    <section class="dl__zone" data-zone="board" aria-label={t(ui.z3)}>
      <span class="dl__rail" aria-hidden="true"><span class="dl__node"></span></span>
      <div class="dl__body">
        <div class="dl__zhead">
          <span class="dl__znum" aria-hidden="true">3</span>
          <h3 class="dl__ztitle">{t(ui.z3)}</h3>
          <span class="dl__zcap">{t(ui.z3cap)}</span>
          <span class="dl__chip-slot" data-chip-slot aria-hidden="true"></span>
        </div>

        <div class="dl__modes" role="group" aria-label={t(ui.z3)} data-modes>
          {
            boardModes.map((m, i) => (
              <button
                type="button"
                class:list={["dl__mode", { "is-on": i === 0 }]}
                aria-pressed={i === 0 ? "true" : "false"}
                data-mode={m.key}
              >
                {t(m.label)}
              </button>
            ))
          }
        </div>

        <p class="dl__why" data-why aria-live="polite">{t(ui.mStreakWhy)}</p>

        <ol class="dl__board" data-board>
          {
            players.map((p) => (
              <li class:list={["dl__row", { "is-you": p.you }]} data-row={p.id} style="--flip:0;">
                <span class="dl__place" data-place aria-hidden="true">1</span>
                <span class="dl__medal" aria-hidden="true" data-medal />
                <span class="dl__pname">{t(p.name)}</span>
                <span class="dl__pval">
                  <b data-pval>0</b>
                  <span class="dl__pval-unit" data-unit />
                </span>
              </li>
            ))
          }
        </ol>

        <span class="dl__elbow" data-elbow="streak" aria-hidden="true">
          <span class="dl__elbow-lbl">{t(ui.elbowToStreak)}</span>
        </span>
      </div>
    </section>

    <!-- =================== ЗОНА 4 · СЕРИЯ =================== -->
    <section class="dl__zone dl__zone--last" data-zone="streak" aria-label={t(ui.z4)}>
      <span class="dl__rail" aria-hidden="true"><span class="dl__node"></span></span>
      <div class="dl__body">
        <div class="dl__zhead">
          <span class="dl__znum" aria-hidden="true">4</span>
          <h3 class="dl__ztitle">{t(ui.z4)}</h3>
          <span class="dl__zcap">{t(ui.z4cap)}</span>
        </div>

        <div class="dl__days" role="group" aria-label={t(ui.z4cap)} data-days>
          {
            initialDays.map((on, i) => (
              <button
                type="button"
                class:list={["dl__day", { "is-on": on }]}
                data-day={i}
                aria-pressed={on ? "true" : "false"}
                aria-label={
                  i === initialDays.length - 1
                    ? `${t(ui.dayWord)} ${i + 1}, ${t(ui.today)}`
                    : `${t(ui.dayWord)} ${i + 1}`
                }
              >
                <span class="dl__day-num" aria-hidden="true">{i + 1}</span>
                <span class="dl__day-mark" aria-hidden="true" />
                {i === initialDays.length - 1 ? (
                  <span class="dl__day-today" aria-hidden="true">{t(ui.today)}</span>
                ) : null}
              </button>
            ))
          }
        </div>

        <div class="dl__streakfoot">
          <ul class="dl__legend" role="list">
            <li class="dl__leg dl__leg--on"><span class="dl__leg-sw" aria-hidden="true" />{t(ui.legOn)}</li>
            <li class="dl__leg dl__leg--gap"><span class="dl__leg-sw" aria-hidden="true" />{t(ui.legGap)}</li>
            <li class="dl__leg dl__leg--sess">{t(ui.legSess)}</li>
          </ul>
          <div class="dl__streakright">
            <button type="button" class="dl__btn dl__btn--ghost" data-count>{t(ui.countDay)}</button>
            <p class="dl__now" data-now aria-live="polite">{t(ui.nowStreak)}: <b>4</b> {t(ui.dayUnit)}</p>
          </div>
        </div>

        <span class="dl__loop" data-loop aria-hidden="true">
          <span class="dl__loop-lbl">{t(ui.loopBack)}</span>
        </span>
      </div>
    </section>
  </div>

  <p class="dl__facts">{t(ui.facts)}</p>
</section>

<style>
  .dl {
    --a: var(--project-accent);
    --a-line: color-mix(in srgb, var(--a) 36%, transparent);
    --a-soft: color-mix(in srgb, var(--a) 12%, transparent);
    --a-faint: color-mix(in srgb, var(--a) 7%, transparent);
    --a-glow: color-mix(in srgb, var(--a) 16%, transparent);
    --dim: 0.46; /* пол приглушения неактивной зоны — числа остаются читаемы */
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    container-type: inline-size;
  }

  .dl__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .dl__eyebrow {
    margin: 0;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .dl__intro {
    margin: 0;
    font-size: var(--fs-16);
    line-height: var(--lh-normal);
    color: var(--text-secondary);
    max-width: 66ch;
  }

  /* Живая строка-ведение */
  .dl__hint {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: 2.6em;
    padding: var(--sp-2) var(--sp-3);
    border: var(--bw-thin) solid var(--a-line);
    border-radius: var(--r-md);
    background: var(--a-faint);
    color: var(--text);
    font-size: var(--fs-14);
    line-height: var(--lh-snug);
  }
  .dl__hint::before {
    content: "›";
    flex: none;
    font-family: var(--font-stack-mono);
    color: var(--a);
    font-weight: var(--fw-bold);
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__hint-swap {
      animation: dl-fade var(--dur-med) var(--ease-soft);
    }
  }

  /* ----------------------- Дорожка ----------------------- */
  .dl__lane {
    display: flex;
    flex-direction: column;
  }

  .dl__zone {
    display: grid;
    grid-template-columns: 26px 1fr;
    gap: var(--sp-3);
    opacity: var(--dim);
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__zone {
      transition: opacity var(--dur-med) var(--ease-standard);
    }
  }
  .dl__zone.is-active {
    opacity: 1;
  }
  /* Наведение/фокус внутри приглушённой зоны делает её отзывчивой. */
  .dl__zone:not(.is-active):hover,
  .dl__zone:not(.is-active):focus-within {
    opacity: 0.82;
  }

  /* Спина дорожки + узел «где работа сейчас» */
  .dl__rail {
    position: relative;
    display: block;
    width: 26px;
  }
  .dl__rail::before {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-start: 12px;
    width: 2px;
    background: var(--border);
    border-radius: var(--r-pill);
  }
  .dl__zone:first-child .dl__rail::before {
    inset-block-start: 14px;
  }
  .dl__zone--last .dl__rail::before {
    inset-block-end: auto;
    height: 14px;
  }
  .dl__node {
    position: absolute;
    inset-block-start: 6px;
    inset-inline-start: 7px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--border-strong);
    z-index: 1;
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__node {
      transition:
        transform var(--dur-med) var(--ease-spring),
        border-color var(--dur-fast) var(--ease-standard),
        background-color var(--dur-fast) var(--ease-standard);
    }
  }
  .dl__zone.is-active .dl__node {
    background: var(--a);
    border-color: var(--a);
    transform: scale(1.25);
  }
  /* пройденные зоны (выше активной) — узел залит, но не увеличен */
  .dl__zone.is-done .dl__node {
    background: var(--a-line);
    border-color: var(--a-line);
  }
  .dl__zone.is-done .dl__rail::before,
  .dl__zone.is-active .dl__rail::before {
    background: linear-gradient(to bottom, var(--a-line), var(--border));
  }

  .dl__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    min-width: 0;
    padding-block-end: var(--sp-2);
  }

  .dl__zhead {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .dl__znum {
    flex: none;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    color: var(--text-muted);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-xs);
  }
  .dl__zone.is-active .dl__znum {
    color: var(--a);
    border-color: var(--a-line);
    background: var(--a-faint);
  }
  .dl__ztitle {
    margin: 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-18);
    letter-spacing: var(--ls-tight);
    color: var(--text);
  }
  .dl__zcap {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .dl__counter {
    margin-inline-start: auto;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .dl__label {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* --- Операции --- */
  .dl__ops {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-2);
  }
  @container (min-width: 460px) {
    .dl__ops {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .dl__op {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-1) var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    cursor: pointer;
    text-align: left;
    overflow: hidden;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  /* акцент-подчёркивание выбранной операции (scaleX, не width) */
  .dl__op::after {
    content: "";
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    height: 2px;
    background: var(--a);
    transform: scaleX(0);
    transform-origin: left center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__op::after {
      transition: transform var(--dur-med) var(--ease-soft);
    }
  }
  .dl__op:hover {
    border-color: var(--border-hover);
  }
  .dl__op:active {
    transform: scale(0.96);
  }
  .dl__op:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .dl__op.is-on {
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 9%, var(--surface));
  }
  .dl__op.is-on::after {
    transform: scaleX(1);
  }
  .dl__glyph {
    flex: none;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-14);
    color: var(--a);
    border: var(--bw-thin) solid color-mix(in srgb, var(--a) 40%, var(--border));
    border-radius: var(--r-xs);
    background: var(--a-faint);
  }
  .dl__op-name {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dl__op.is-on .dl__op-name {
    color: var(--text);
  }

  /* --- Уровни --- */
  .dl__levels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-2);
  }
  .dl__level {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    min-height: var(--tap-min);
    padding: var(--sp-2) var(--sp-2);
    color: var(--text-muted);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .dl__level:hover {
    border-color: var(--border-hover);
  }
  .dl__level:active {
    transform: scale(0.96);
  }
  .dl__level:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .dl__level-dot {
    font-size: var(--fs-11);
    line-height: 1;
  }
  .dl__level-name {
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
  }
  .dl__level.is-on {
    color: var(--text);
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 9%, var(--surface));
  }

  .dl__config {
    margin: 0;
    min-height: 1.4em;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-12);
    color: var(--text-secondary);
  }

  /* --- Пульс-подсказка следующего шага (transform, самогаснущий) --- */
  @media (prefers-reduced-motion: no-preference) {
    .dl__pulse {
      animation: dl-pulse var(--dur-slow) var(--ease-spring) 2;
    }
  }
  @keyframes dl-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.035);
    }
  }

  /* --- Прогресс-точки набора --- */
  .dl__pips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .dl__pip {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--surface-3);
    border: var(--bw-thin) solid var(--border);
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__pip {
      transition:
        background-color var(--dur-fast) var(--ease-standard),
        border-color var(--dur-fast) var(--ease-standard),
        opacity var(--dur-fast) var(--ease-standard);
    }
  }
  .dl__pip.is-ok {
    background: var(--a);
    border-color: var(--a);
  }
  .dl__pip.is-miss {
    background: var(--surface);
    border-color: color-mix(in srgb, var(--state-warn) 40%, var(--border));
    opacity: 0.85;
  }
  .dl__pip.is-cur {
    border-color: var(--a-line);
  }

  /* --- Игровое поле --- */
  .dl__play {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-4);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-lg);
    background: radial-gradient(120% 130% at 50% 0%, var(--a-soft), transparent 55%), var(--surface);
  }
  .dl__question {
    display: flex;
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    padding: var(--sp-2) 0;
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
  }
  .dl__expr {
    font-size: var(--fs-32);
    color: var(--text);
    font-variant-numeric: tabular-nums;
    overflow-wrap: anywhere;
    text-align: center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__expr.dl__expr-swap {
      animation: dl-fade var(--dur-med) var(--ease-soft);
    }
  }
  .dl__eq {
    font-size: var(--fs-24);
    color: var(--text-muted);
  }
  .dl__ph {
    font-size: var(--fs-32);
    color: var(--a);
    min-width: 1.2ch;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .dl__rem-tag {
    align-self: center;
    font-family: var(--font-stack-mono);
    font-size: var(--fs-11);
    color: var(--text-muted);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
  }
  .dl__rem-tag[hidden] {
    display: none;
  }

  .dl__choices {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-2);
  }
  @container (min-width: 460px) {
    .dl__choices {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .dl__choice {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--tap-min);
    padding: var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-sm);
    background: var(--bg-elevated);
    cursor: pointer;
    font-family: var(--font-stack-mono);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .dl__choice[hidden] {
    display: none;
  }
  .dl__choice:hover:not(:disabled) {
    border-color: var(--border-hover);
  }
  .dl__choice:active:not(:disabled) {
    transform: scale(0.95);
  }
  .dl__choice:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .dl__choice:disabled {
    cursor: default;
  }
  .dl__choice-val {
    font-size: var(--fs-17);
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .dl__choice-mark {
    position: absolute;
    top: 3px;
    right: 5px;
    font-size: var(--fs-11);
    line-height: 1;
    opacity: 0;
    transform: scale(0.4);
    transition:
      opacity var(--dur-fast) var(--ease-soft),
      transform var(--dur-fast) var(--ease-spring);
  }
  .dl__choice.is-correct {
    border-color: var(--a-line);
    background: color-mix(in srgb, var(--a) 14%, var(--bg-elevated));
  }
  .dl__choice.is-correct .dl__choice-mark {
    color: var(--a);
    opacity: 1;
    transform: none;
  }
  .dl__choice.is-wrong {
    border-color: color-mix(in srgb, var(--state-warn) 34%, var(--border));
    opacity: 0.78;
  }
  .dl__choice.is-wrong .dl__choice-mark {
    color: var(--text-muted);
    opacity: 1;
    transform: none;
  }
  .dl__choice.is-faded {
    opacity: 0.4;
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__choice.dl__shake {
      animation: dl-shake 0.32s var(--ease-standard);
    }
  }
  @keyframes dl-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-6px);
    }
    75% {
      transform: translateX(6px);
    }
  }

  .dl__feedback {
    margin: 0;
    font-size: var(--fs-13);
    color: var(--text-muted);
    min-height: 1.4em;
  }
  .dl__feedback.is-good {
    color: color-mix(in srgb, var(--a) 70%, var(--text-secondary));
  }

  .dl__solvefoot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .dl__pointsbox {
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-1);
    font-family: var(--font-stack-mono);
    flex-wrap: wrap;
  }
  .dl__points {
    font-size: var(--fs-20);
    font-weight: var(--fw-semibold);
    color: var(--a);
    font-variant-numeric: tabular-nums;
  }
  @media (prefers-reduced-motion: no-preference) {
    .dl__points.dl__bump {
      animation: dl-bump var(--dur-med) var(--ease-spring);
    }
  }
  @keyframes dl-bump {
    0% {
      transform: translateY(0.18em);
      opacity: 0.5;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }
  .dl__points-lbl {
    font-size: var(--fs-12);
    color: var(--text-muted);
  }
  .dl__points-why {
    font-size: var(--fs-11);
    color: var(--text-faint);
    margin-inline-start: var(--sp-2);
  }
  .dl__ctl {
    display: flex;
    gap: var(--sp-2);
  }
  .dl__btn {
    min-height: 38px;
    padding: var(--sp-1) var(--sp-4);
    font-family: var(--font-stack-mono);
    font-size: var(--fs-13);
    border-radius: var(--r-pill);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }
  .dl__btn:active {
    transform: scale(0.96);
  }
  .dl__btn:focus-visible {
    outline: var(--ring-width) solid var(--ring-focus);
    outline-offset: 2px;
  }
  .dl__btn--accent {
    color: var(--text);
    background: color-mix(in srgb, var(--a) 14%, var(--surface));
    border: var(--bw-thin) solid var(--a-line);
  }
  .dl__btn--accent:hover {
    border-color: var(--a);
  }
  .dl__btn--ghost {
    color: var(--text-muted);
    background: transparent;
    border: var(--bw-thin) solid var(--border);
  }
  .dl__btn--ghost:hover {
    color: var(--text-secondary);
