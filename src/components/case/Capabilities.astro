---
/**
 * Capabilities.astro — сетка карточек с иконкой, заголовком и описанием.
 *
 * Каждая карточка — одна capability проекта. Иконка берётся из общего набора
 * Icon.astro (24×24 stroke). На мобильных — одна колонка, дальше две, потом
 * три при ширине ≥1100.
 */

import type { ProjectCapability } from "../../lib/projects";
import type { Locale } from "../../lib/i18n";
import Icon from "../Icon/Icon.astro";

interface Props {
  items: ReadonlyArray<ProjectCapability>;
  locale: Locale;
  class?: string;
}

const { items, locale, class: className = "" } = Astro.props;
---

<div class:list={["capabilities", className]}>
  {
    items.map((item, i) => (
      <article class="capabilities__card glass glass--hover" data-reveal data-reveal-delay={i * 60}>
        <Icon name={item.icon} size={24} class="capabilities__icon" />
        <h3 class="capabilities__title">{item.title[locale]}</h3>
        <p class="capabilities__desc body-sm">{item.description[locale]}</p>
      </article>
    ))
  }
</div>

<style>
  .capabilities {
    display: grid;
    gap: var(--sp-4);
    grid-template-columns: 1fr;
  }

  .capabilities__card {
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    border-radius: var(--r-lg);
  }

  .capabilities__icon {
    color: var(--text);
  }

  .capabilities__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-18);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-tight);
  }

  .capabilities__desc {
    color: var(--text-secondary);
  }

  @media (min-width: 720px) {
    .capabilities {
      grid-template-columns: repeat(2, 1fr);
    }

    .capabilities__card {
      padding: var(--sp-6);
    }

    .capabilities__title {
      font-size: var(--fs-20);
    }
  }

  @media (min-width: 1100px) {
    .capabilities {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
