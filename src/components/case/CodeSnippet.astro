---
/**
 * CodeSnippet.astro — один реальный фрагмент кода ключевого механизма.
 *
 * Монохромный блок (в духе сайта, без цветной подсветки и без клиентского JS):
 * шапка с путём файла и языком, сам код в <pre>, короткая подпись «что это».
 * Тонкая акцентная полоса слева связывает блок с цветом проекта.
 */

import type { Locale } from "../../lib/i18n";
import type { ProjectCodeSnippet } from "../../lib/projects";

interface Props {
  snippet: ProjectCodeSnippet;
  locale: Locale;
  class?: string;
}

const { snippet, locale, class: className = "" } = Astro.props;
const caption = snippet.caption[locale] ?? snippet.caption.ru;
---

<figure class:list={["code-snippet", "glass", "glass--bordered", className]} data-reveal>
  <figcaption class="code-snippet__head">
    <span class="code-snippet__file mono">{snippet.file}</span>
    <span class="code-snippet__lang mono">{snippet.lang}</span>
  </figcaption>
  <pre class="code-snippet__pre"><code class="code-snippet__code mono">{snippet.code}</code></pre>
  {caption && <p class="code-snippet__caption body-sm">{caption}</p>}
</figure>

<style>
  .code-snippet {
    position: relative;
    margin: 0;
    border-radius: var(--r-lg);
    overflow: hidden;
    isolation: isolate;
  }

  /* Тонкая акцентная полоса слева — мостик к цвету проекта. */
  .code-snippet::before {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    width: 2px;
    background: var(--project-accent);
    opacity: 0.7;
  }

  .code-snippet__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    border-block-end: var(--bw-thin) solid var(--glass-edge);
    background: var(--glass-tint-1);
  }

  .code-snippet__file {
    font-size: var(--fs-12);
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .code-snippet__lang {
    flex: none;
    font-size: var(--fs-11);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    padding: 2px var(--sp-2);
    border: var(--bw-thin) solid var(--border);
    border-radius: var(--r-pill);
  }

  .code-snippet__pre {
    margin: 0;
    padding: var(--sp-4) var(--sp-5);
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    -webkit-overflow-scrolling: touch;
    background: var(--bg-elevated);
  }

  .code-snippet__code {
    display: block;
    font-size: var(--fs-13);
    line-height: var(--lh-relaxed);
    color: var(--text-secondary);
    white-space: pre;
    tab-size: 4;
  }

  .code-snippet__caption {
    margin: 0;
    padding: var(--sp-3) var(--sp-4);
    border-block-start: var(--bw-thin) solid var(--glass-edge);
    color: var(--text-muted);
  }

  @media (min-width: 720px) {
    .code-snippet__pre {
      padding: var(--sp-5) var(--sp-6);
    }

    .code-snippet__code {
      font-size: var(--fs-14);
    }
  }
</style>
