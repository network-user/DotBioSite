---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import {
  type Project,
  projectName,
  projectBrand,
  projectTagline,
  projectDescription,
  repoUrl,
} from "../lib/projects";
import Icon from "./Icon/Icon.astro";
import MeshGradient from "./illustration/MeshGradient.astro";
import DotConstellation from "./react/DotConstellation.island.tsx";
import Architecture from "./diagram/Architecture.astro";
import StackMatrix from "./case/StackMatrix.astro";
import Capabilities from "./case/Capabilities.astro";
import EngineeringCallouts from "./case/EngineeringCallouts.astro";
import CaseTimeline from "./case/CaseTimeline.astro";
import CaseFooterCrossLinks from "./case/CaseFooterCrossLinks.astro";

interface Props {
  project: Project;
  locale: Locale;
}
const { project: p, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const name = projectName(p, locale);
const brand = projectBrand(p, locale);
const tagline = projectTagline(p, locale);
const desc = projectDescription(p, locale);
const backHref = `${prefix}/#projects`;
const primaryRepoUrl = p.repos[0] ? repoUrl(p.repos[0]) : "";

const overviewParas = p.overview ? p.overview[locale] : [desc];

const meshPalette = p.slug === "dotsound" ? "violet" : p.slug === "dotmathbot" ? "cool" : "warm";

const hasMetrics = p.metrics && p.metrics.length > 0;
const hasStackGroups = p.stackGroups && Object.values(p.stackGroups).some((arr) => arr && arr.length > 0);
const hasArchitecture = p.architectureNodes && p.architectureNodes.length > 0;
const hasCapabilities = p.capabilities && p.capabilities.length > 0;
const hasEngineering = p.engineeringChoices && p.engineeringChoices.length > 0;
const hasTimeline = p.timeline && p.timeline.length > 0;
const hasLinks = p.links && Object.keys(p.links).length > 0;
---

<article class="case">
  <section class="case__hero" data-case-hero>
    <MeshGradient palette={meshPalette} intensity="default" />
    <DotConstellation client:idle variant="case" />

    <div class="container case__hero-inner">
      <a href={backHref} class="case__back">
        <Icon name="arrow-right" size={16} class="case__back-arrow" />
        <span>{t("case.back")}</span>
      </a>

      <div class="case__eyebrow" data-reveal>
        <span class="eyebrow">{t(`projects.category.${p.category}`)}</span>
        {p.year && (
          <span class="eyebrow case__eyebrow-divider" aria-hidden="true">·</span>
        )}
        {p.year && <span class="eyebrow tabular">{p.year}</span>}
        <span class="eyebrow case__eyebrow-divider" aria-hidden="true">·</span>
        <span class={`case__status case__status--${p.status}`}>
          <Icon name="dot" size={10} />
          <span>{t(`projects.status.${p.status}`)}</span>
        </span>
      </div>

      <h1
        class="case__brand display-xl"
        data-reveal
        data-reveal-delay="60"
        style={`view-transition-name: project-${p.slug}-brand;`}
      >
        {brand}
      </h1>
      <p class="case__name caption" data-reveal data-reveal-delay="120">{name}</p>
      <p class="case__tagline title" data-reveal data-reveal-delay="180">{tagline}</p>

      {p.repos.length > 0 && (
        <ul class="case__repos-pills" aria-label={t("case.repos")} data-reveal data-reveal-delay="240">
          {p.repos.map((r) => (
            <li class="case__repos-pill">
              <Icon name="code" size={12} />
              <span class="mono">{r.name}</span>
            </li>
          ))}
        </ul>
      )}

      <div class="case__actions" data-reveal data-reveal-delay="300">
        {primaryRepoUrl && (
          <a href={primaryRepoUrl} target="_blank" rel="noopener noreferrer" class="cta cta--primary magnetic">
            <Icon name="github" size={16} />
            <span>{t("case.primaryRepo")}</span>
          </a>
        )}
        {p.links?.domain && (
          <a href={p.links.domain} target="_blank" rel="noopener noreferrer" class="cta cta--ghost magnetic">
            <Icon name="globe" size={16} />
            <span>{t("projects.openSite")}</span>
          </a>
        )}
      </div>
    </div>
  </section>

  <div class="container case__body">
    <!-- 2. Overview -->
    <section class="case__section case__section--narrow" data-reveal>
      <header class="case__h">
        <p class="eyebrow">{t("case.overview")}</p>
      </header>
      {overviewParas.map((para) => <p class="case__lede body">{para}</p>)}
    </section>

    <!-- 3. Metrics -->
    {hasMetrics && (
      <section class="case__section" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.metrics")}</p>
          <p class="case__h-lede subtitle">{t("case.metricsLede")}</p>
        </header>
        <div class="case__metrics">
          {p.metrics!.map((m, i) => (
            <div class="case__metric" data-reveal data-reveal-delay={i * 60}>
              <span class="metric">
                <span>{m.value}</span>
                {m.unit && <span class="metric__unit">{m.unit}</span>}
              </span>
              <span class="metric__label">{m.label[locale]}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- 4. Architecture -->
    {hasArchitecture && (
      <section class="case__section case__section--bleed" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.architecture")}</p>
        </header>
        <div class="case__arch">
          <Architecture
            nodes={p.architectureNodes!}
            edges={p.architectureEdges ?? []}
            clusters={p.clusters ?? []}
            ariaLabel={`${name} — ${t("case.architecture")}`}
          />
        </div>
      </section>
    )}

    <!-- 5. Stack matrix -->
    {hasStackGroups ? (
      <section class="case__section" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.stack")}</p>
        </header>
        <StackMatrix groups={p.stackGroups!} locale={locale} />
      </section>
    ) : (
      <section class="case__section" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.stack")}</p>
        </header>
        <ul class="case__chips">
          {p.stack.map((s) => <li class="case__chip">{s}</li>)}
        </ul>
      </section>
    )}

    <!-- 6. Capabilities -->
    {hasCapabilities && (
      <section class="case__section" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.capabilities")}</p>
          <p class="case__h-lede subtitle">{t("case.capabilitiesLede")}</p>
        </header>
        <Capabilities items={p.capabilities!} locale={locale} />
      </section>
    )}

    <!-- 7. Engineering choices -->
    {hasEngineering && (
      <section class="case__section" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.engineering")}</p>
          <p class="case__h-lede subtitle">{t("case.engineeringLede")}</p>
        </header>
        <EngineeringCallouts items={p.engineeringChoices!} locale={locale} />
      </section>
    )}

    <!-- 8. Project timeline -->
    {hasTimeline && (
      <section class="case__section case__section--narrow" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.timeline")}</p>
          <p class="case__h-lede subtitle">{t("case.timelineLede")}</p>
        </header>
        <CaseTimeline items={p.timeline!} locale={locale} />
      </section>
    )}

    <!-- Repos (always — shows multiple repos for ecosystems) -->
    {p.repos.length > 1 && (
      <section class="case__section" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.repos")}</p>
        </header>
        <ul class="case__repos">
          {p.repos.map((r) => {
            const rUrl = repoUrl(r);
            return (
              <li class="case__repo glass glass--hover">
                <div class="case__repo-head">
                  <Icon name="code" size={18} />
                  <span class="case__repo-name display">{r.name}</span>
                  {r.role && <span class="case__repo-role">{r.role}</span>}
                </div>
                {r.description && (
                  <p class="case__repo-desc body-sm">
                    {r.description[locale] ?? r.description.ru}
                  </p>
                )}
                {rUrl && (
                  <a
                    href={rUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="case__repo-link"
                  >
                    <span class="mono">{rUrl.replace(/^https?:\/\//, "")}</span>
                    <Icon name="external" size={14} />
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {hasLinks && (
      <section class="case__section case__section--narrow" data-reveal>
        <header class="case__h">
          <p class="eyebrow">{t("case.links")}</p>
        </header>
        <ul class="case__links">
          {p.links?.domain && (
            <li>
              <a href={p.links.domain} target="_blank" rel="noopener noreferrer" class="case__link">
                <Icon name="globe" size={16} />
                <span class="mono">{p.links.domain}</span>
              </a>
            </li>
          )}
          {p.links?.docs && (
            <li>
              <a href={p.links.docs} target="_blank" rel="noopener noreferrer" class="case__link">
                <Icon name="code" size={16} />
                <span class="mono">{p.links.docs}</span>
              </a>
            </li>
          )}
          {p.links?.telegram && (
            <li>
              <a href={p.links.telegram} target="_blank" rel="noopener noreferrer" class="case__link">
                <Icon name="telegram" size={16} />
                <span class="mono">{p.links.telegram}</span>
              </a>
            </li>
          )}
        </ul>
      </section>
    )}

    <!-- 9. Cross-links to other projects -->
    <section class="case__section" data-reveal>
      <CaseFooterCrossLinks current={p.slug} locale={locale} />
    </section>
  </div>
</article>

<style>
  .case__hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-11) var(--sp-10);
    isolation: isolate;
  }

  .case__hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .case__back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    padding: var(--sp-2) 0;
    margin-block-end: var(--sp-6);
    width: max-content;
  }

  .case__back-arrow {
    transform: rotate(180deg);
  }

  .case__back:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
    color: var(--text-muted);
  }

  .case__eyebrow-divider {
    color: var(--text-faint);
  }

  .case__status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    text-transform: lowercase;
    letter-spacing: var(--ls-wide);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
  }

  .case__status--active { color: var(--state-ok); }
  .case__status--wip { color: var(--state-warn); }
  .case__status--beta { color: var(--state-info); }
  .case__status--archived { color: var(--text-muted); }

  .case__brand {
    font-size: clamp(64px, 14vw, 180px);
    line-height: var(--lh-display-xl);
    letter-spacing: var(--ls-display-xl);
    margin-block-start: var(--sp-3);
    background: linear-gradient(180deg, var(--text) 0%, var(--text-secondary) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .case__name {
    color: var(--text-secondary);
    margin-block-start: var(--sp-2);
  }

  .case__tagline {
    font-size: clamp(20px, 2.4vw, 32px);
    color: var(--text);
    max-width: 38ch;
    margin-block-start: var(--sp-3);
  }

  .case__repos-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block-start: var(--sp-3);
  }

  .case__repos-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-11);
    background: var(--glass-tint-1);
    backdrop-filter: blur(var(--glass-blur-soft));
    -webkit-backdrop-filter: blur(var(--glass-blur-soft));
  }

  .case__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-block-start: var(--sp-5);
  }

  .case__body {
    padding-block: var(--sp-11) var(--sp-12);
  }

  .case__section {
    margin-block-end: var(--sp-11);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .case__section--narrow {
    max-width: var(--container-narrow);
  }

  .case__section--bleed {
    /* Architecture diagram benefits from a wider canvas. */
    max-width: none;
  }

  .case__h {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .case__h-lede {
    color: var(--text-secondary);
    max-width: 56ch;
  }

  .case__lede {
    color: var(--text-secondary);
    font-size: var(--fs-17);
    max-width: 70ch;
    line-height: var(--lh-normal);
  }

  .case__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-6);
  }

  .case__metric {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .case__arch {
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-xl);
    background:
      radial-gradient(ellipse at 50% 0%, var(--mesh-violet-a), transparent 60%),
      var(--bg-elevated);
    padding: var(--sp-7);
    overflow: hidden;
  }

  .case__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .case__chip {
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
  }

  .case__repos {
    display: grid;
    gap: var(--sp-3);
    grid-template-columns: 1fr;
  }

  .case__repo {
    padding: var(--sp-5) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    border-radius: var(--r-lg);
  }

  .case__repo-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .case__repo-name {
    font-size: var(--fs-22);
    letter-spacing: var(--ls-tight);
  }

  .case__repo-role {
    margin-left: auto;
    font-size: var(--fs-11);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    color: var(--text-muted);
  }

  .case__repo-desc {
    color: var(--text-secondary);
  }

  .case__repo-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    margin-block-start: auto;
  }

  .case__repo-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__links {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .case__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-secondary);
    font-size: var(--fs-14);
  }

  .case__link:hover {
    color: var(--text);
    opacity: 1;
  }

  @media (min-width: 720px) {
    .case__repos {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
