  /* Кнопка-обёртка обложки: весь блок кликабелен */
  .case__cover-btn {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    background: none;
    border: none;
    cursor: zoom-in;
    position: relative;
  }

  .case__hero-cover {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-standard);
