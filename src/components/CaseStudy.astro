  /* Тач-устройства: подсказка лайтбокса говорит про «колесо мыши / drag», но на
     телефоне это неверно. Жесты там очевидны (double-tap: зум, перетаскивание,
     ✕/тап-вне: закрыть), поэтому подсказку скрываем. Закрытие крестиком видно. */
  @media (pointer: coarse) {
    .case-lightbox__hint {
      display: none;
    }
  }
</style>

<script>
  /**
   * Count-up метрик: числовая часть значения набегает 0 → target при первом
   * появлении секции в вьюпорте. Один проход requestAnimationFrame (не бесконечный),
   * затем IntersectionObserver отключается. Префикс/суффикс ("k+", "+", "$") и
   * нечисловые значения ("HLS", "ASR") сохраняются как есть.
   *
   * prefers-reduced-motion → значение остаётся финальным, анимация не стартует.
   * Без JS значение и так в DOM (SSR), поэтому деградация полная.
   */
  /* ===== Лайтбокс обложки ===== */
  (() => {
    const lb = document.getElementById("case-lightbox") as HTMLElement | null;
    const stage = document.getElementById("case-lightbox-stage") as HTMLElement | null;
    const img = document.getElementById("case-lightbox-img") as HTMLImageElement | null;
    const closeBtn = document.getElementById("case-lightbox-close") as HTMLButtonElement | null;
    const backdrop = document.getElementById("case-lightbox-backdrop") as HTMLElement | null;
    if (!lb || !stage || !img || !closeBtn || !backdrop) return;

    let scale = 1,
      tx = 0,
      ty = 0;
    const MIN = 0.5,
      MAX = 6;

    function applyTransform(animated = false) {
      img!.style.transition = animated ? "transform 0.25s ease" : "none";
      img!.style.transform = `translate(${tx}px,${ty}px) scale(${scale})`;
    }

    function reset(animated = true) {
      scale = 1;
      tx = 0;
      ty = 0;
      applyTransform(animated);
    }

    function openLightbox(src: string, title: string) {
      img!.src = src;
      img!.alt = title;
      reset(false);
      img!.style.willChange = "transform";
      lb!.removeAttribute("hidden");
      requestAnimationFrame(() => lb!.setAttribute("data-open", ""));
      document.body.style.overflow = "hidden";
      closeBtn!.focus();
    }

    function closeLightbox() {
      lb!.removeAttribute("data-open");
      document.body.style.overflow = "";
      setTimeout(() => {
        lb!.setAttribute("hidden", "");
        img!.style.willChange = "auto";
      }, 240);
    }

    /* Триггеры открытия */
    document.querySelectorAll<HTMLButtonElement>("[data-lightbox-src]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.dataset.lightboxSrc ?? "";
        const title = btn.dataset.lightboxTitle ?? "";
        if (src) openLightbox(src, title);
      });
    });

    closeBtn.addEventListener("click", closeLightbox);
    backdrop.addEventListener("click", closeLightbox);

    document.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape" && lb!.hasAttribute("data-open")) closeLightbox();
    });

    /* Zoom с колеса (cursor-aware) */
    stage.addEventListener(
      "wheel",
      (e: WheelEvent) => {
        e.preventDefault();
        const factor = e.deltaY < 0 ? 1.12 : 0.88;
        const newScale = Math.max(MIN, Math.min(MAX, scale * factor));
        const rect = stage.getBoundingClientRect();
        const cx = e.clientX - rect.left - rect.width / 2;
        const cy = e.clientY - rect.top - rect.height / 2;
        const ratio = newScale / scale;
        tx = cx + (tx - cx) * ratio;
        ty = cy + (ty - cy) * ratio;
        scale = newScale;
        applyTransform(false);
      },
      { passive: false },
    );

    /* Drag (pan) */
    let dragging = false,
      px = 0,
      py = 0,
      startTx = 0,
      startTy = 0;

    stage.addEventListener("pointerdown", (e: PointerEvent) => {
      if (scale <= 1) return;
      dragging = true;
      px = e.clientX;
      py = e.clientY;
      startTx = tx;
      startTy = ty;
      stage.setPointerCapture(e.pointerId);
    });

    stage.addEventListener("pointermove", (e: PointerEvent) => {
      if (!dragging) return;
      tx = startTx + (e.clientX - px);
      ty = startTy + (e.clientY - py);
      applyTransform(false);
    });

    stage.addEventListener("pointerup", () => {
      dragging = false;
    });

    /* Двойной клик: сброс или zoom x2 */
    stage.addEventListener("dblclick", (e: MouseEvent) => {
      if (scale > 1) {
        reset(true);
      } else {
        const rect = stage.getBoundingClientRect();
        const cx = e.clientX - rect.left - rect.width / 2;
        const cy = e.clientY - rect.top - rect.height / 2;
        const newScale = Math.min(MAX, 2.5);
        const ratio = newScale / scale;
        tx = cx + (tx - cx) * ratio;
        ty = cy + (ty - cy) * ratio;
        scale = newScale;
        applyTransform(true);
      }
    });
  })();

  /* ===== Count-up метрик ===== */
  (() => {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const nodes = Array.from(document.querySelectorAll<HTMLElement>("[data-countup]"));
    if (reduce || nodes.length === 0) return;

    type Target = { node: HTMLElement; prefix: string; suffix: string; to: number };
    const targets: Target[] = [];

    for (const node of nodes) {
      const raw = (node.textContent ?? "").trim();
      // префикс (нецифры) + целое с разделителями тысяч (пробел/запятая) + суффикс.
      // Точка НЕ входит в число, поэтому "127.0.0.1" и "4.5k" не матчатся и
      // остаются как есть; чисто буквенные ("BYOK", "VPS") тоже пропускаются.
      const m = raw.match(/^(\D*?)(\d[\d\s,]*)(\D*)$/);
      if (!m) continue;
      const prefix = m[1] ?? "";
      const digits = (m[2] ?? "").replace(/[\s,]/g, "");
      const suffix = m[3] ?? "";
      const to = Number(digits);
      if (digits.length === 0 || !Number.isFinite(to)) continue;
      targets.push({ node, prefix, suffix, to });
      node.textContent = prefix + "0" + suffix;
    }
    if (targets.length === 0) return;

    const DURATION = 1000;
    const easeOut = (t: number): number => 1 - Math.pow(1 - t, 3);

    let started = false;
    const run = (): void => {
      if (started) return;
      started = true;
      let start: number | undefined;
      const tick = (now: number): void => {
        if (start === undefined) start = now;
        const p = Math.min(1, (now - start) / DURATION);
        const e = easeOut(p);
        for (const it of targets) {
          it.node.textContent = it.prefix + Math.round(it.to * e) + it.suffix;
        }
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const first = targets[0];
    if (!first) return;
    const anchor = first.node.closest(".case__metrics") ?? first.node;
    if (!("IntersectionObserver" in window)) {
      run();
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const en of entries) {
          if (en.isIntersecting) {
            run();
            io.disconnect();
            break;
          }
        }
      },
      { threshold: 0.4 },
    );
    io.observe(anchor);
  })();
</script>
