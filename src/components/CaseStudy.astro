---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import {
  type Project,
  projectName,
  projectBrand,
  projectTagline,
  projectDescription,
  repoUrl,
} from "../lib/projects";
import Icon from "./Icon/Icon.astro";

interface Props {
  project: Project;
  locale: Locale;
}
const { project: p, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const name = projectName(p, locale);
const brand = projectBrand(p, locale);
const tagline = projectTagline(p, locale);
const desc = projectDescription(p, locale);
const backHref = `${prefix}/#projects`;
const primaryRepoUrl = p.repos[0] ? repoUrl(p.repos[0]) : "";
---

<article class="case">
  <div class="container">
    <a href={backHref} class="case__back">
      <Icon name="arrow-right" size={16} class="case__back-arrow" />
      <span>{t("case.back")}</span>
    </a>

    <header class="case__hero" data-reveal>
      <div class="case__meta">
        <span class="caption">{t(`projects.category.${p.category}`)}</span>
        <span class={`case__status case__status--${p.status}`}>
          <Icon name="dot" size={10} />
          <span>{t(`projects.status.${p.status}`)}</span>
        </span>
        {p.year && <span class="caption">{p.year}</span>}
      </div>

      <h1 class="case__brand display">{brand}</h1>
      <p class="case__name caption">{name}</p>
      <p class="case__tagline title">{tagline}</p>

      <div class="case__actions">
        {primaryRepoUrl && (
          <a href={primaryRepoUrl} target="_blank" rel="noopener noreferrer" class="cta cta--primary magnetic">
            <Icon name="github" size={16} />
            <span>{t("projects.viewSource")}</span>
          </a>
        )}
        {p.links?.domain && (
          <a href={p.links.domain} target="_blank" rel="noopener noreferrer" class="cta cta--ghost magnetic">
            <Icon name="globe" size={16} />
            <span>{t("projects.openSite")}</span>
          </a>
        )}
      </div>
    </header>

    <section class="case__section" data-reveal>
      <h2 class="case__h2 title">{t("case.overview")}</h2>
      <p class="case__lede body">{desc}</p>
    </section>

    <section class="case__section" data-reveal>
      <h2 class="case__h2 title">{t("case.stack")}</h2>
      <ul class="case__chips">
        {p.stack.map((s) => (
          <li class="case__chip">{s}</li>
        ))}
      </ul>
    </section>

    <section class="case__section" data-reveal>
      <h2 class="case__h2 title">{t("case.repos")}</h2>
      <ul class="case__repos">
        {p.repos.map((r) => {
          const rUrl = repoUrl(r);
          return (
            <li class="case__repo glass glass--hover">
              <div class="case__repo-head">
                <Icon name="code" size={18} />
                <span class="case__repo-name display">{r.name}</span>
                {r.role && <span class="case__repo-role">{r.role}</span>}
              </div>
              {r.description && (
                <p class="case__repo-desc body-sm">
                  {r.description[locale] ?? r.description.ru}
                </p>
              )}
              {rUrl && (
                <a
                  href={rUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="case__repo-link"
                >
                  <span class="mono">{rUrl.replace(/^https?:\/\//, "")}</span>
                  <Icon name="external" size={14} />
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </section>

    {p.links && (Object.keys(p.links).length > 0) && (
      <section class="case__section" data-reveal>
        <h2 class="case__h2 title">{t("case.links")}</h2>
        <ul class="case__links">
          {p.links.domain && (
            <li>
              <a href={p.links.domain} target="_blank" rel="noopener noreferrer" class="case__link">
                <Icon name="globe" size={16} />
                <span class="mono">{p.links.domain}</span>
              </a>
            </li>
          )}
          {p.links.docs && (
            <li>
              <a href={p.links.docs} target="_blank" rel="noopener noreferrer" class="case__link">
                <Icon name="code" size={16} />
                <span class="mono">{p.links.docs}</span>
              </a>
            </li>
          )}
          {p.links.telegram && (
            <li>
              <a href={p.links.telegram} target="_blank" rel="noopener noreferrer" class="case__link">
                <Icon name="telegram" size={16} />
                <span class="mono">{p.links.telegram}</span>
              </a>
            </li>
          )}
        </ul>
      </section>
    )}
  </div>
</article>

<style>
  .case {
    padding-block: var(--sp-9) var(--sp-12);
  }

  .case__back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    padding: var(--sp-2) 0;
    margin-block-end: var(--sp-7);
  }

  .case__back-arrow {
    transform: rotate(180deg);
  }

  .case__back:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__hero {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-block-end: var(--sp-10);
  }

  .case__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-3);
    color: var(--text-muted);
  }

  .case__status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-11);
    text-transform: lowercase;
    letter-spacing: var(--ls-wide);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
  }

  .case__status--active {
    color: var(--state-ok);
  }
  .case__status--wip {
    color: var(--state-warn);
  }
  .case__status--beta {
    color: var(--state-info);
  }
  .case__status--archived {
    color: var(--text-muted);
  }

  .case__brand {
    font-size: clamp(56px, 11vw, 144px);
    line-height: 0.92;
    margin-block-start: var(--sp-3);
  }

  .case__name {
    color: var(--text-secondary);
  }

  .case__tagline {
    font-size: clamp(20px, 2.4vw, 32px);
    color: var(--text);
    max-width: 38ch;
    margin-block-start: var(--sp-4);
  }

  .case__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-block-start: var(--sp-5);
  }

  .case__section {
    margin-block-end: var(--sp-9);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .case__h2 {
    font-size: clamp(24px, 2vw, 32px);
    color: var(--text);
    letter-spacing: var(--ls-tight);
  }

  .case__lede {
    color: var(--text-secondary);
    font-size: var(--fs-17);
    max-width: 70ch;
    line-height: var(--lh-normal);
  }

  .case__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .case__chip {
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
  }

  .case__repos {
    display: grid;
    gap: var(--sp-3);
    grid-template-columns: 1fr;
  }

  .case__repo {
    padding: var(--sp-5) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    border-radius: var(--r-lg);
  }

  .case__repo-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .case__repo-name {
    font-size: var(--fs-22);
    letter-spacing: var(--ls-tight);
  }

  .case__repo-role {
    margin-left: auto;
    font-size: var(--fs-11);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    color: var(--text-muted);
  }

  .case__repo-desc {
    color: var(--text-secondary);
  }

  .case__repo-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    margin-block-start: auto;
  }

  .case__repo-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__links {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .case__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-secondary);
    font-size: var(--fs-14);
  }

  .case__link:hover {
    color: var(--text);
    opacity: 1;
  }

  @media (min-width: 720px) {
    .case__repos {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
