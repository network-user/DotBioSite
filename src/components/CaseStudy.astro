---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import {
  type Project,
  projectName,
  projectBrand,
  projectCaseTagline,
  projectCaseDescription,
  projectStartDate,
  projectDomainUrl,
  projectTelegramUrl,
  repoUrl,
} from "../lib/projects";
import Icon from "./Icon/Icon.astro";
import ProjectGlyph from "./ProjectGlyph.astro";
import Architecture from "./diagram/Architecture.astro";
import StackMatrix from "./case/StackMatrix.astro";
import StackComposition from "./case/StackComposition.astro";
import Capabilities from "./case/Capabilities.astro";
import CaseTimeline from "./case/CaseTimeline.astro";
import CaseFooterCrossLinks from "./case/CaseFooterCrossLinks.astro";
import ProjectSignature from "./case/signature/ProjectSignature.astro";

interface Props {
  project: Project;
  locale: Locale;
}
const { project: p, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const name = projectName(p, locale);
const brand = projectBrand(p, locale);
const tagline = projectCaseTagline(p, locale);
const desc = projectCaseDescription(p, locale);
const startDate = projectStartDate(p);
const backHref = `${prefix}/#projects`;
const primaryRepoUrl = p.repos[0] ? repoUrl(p.repos[0]) : "";
// DotSound: мультирепо-экосистема (Backend/Bot/ComputeWorker), где "primary"
// неоднозначен, поэтому подпись остаётся родовой; у остальных берём имя репозитория.
const primaryRepoLabel =
  p.slug === "dotsound" ? t("case.primaryRepo") : (p.repos[0]?.name ?? t("case.primaryRepo"));
const domainUrl = projectDomainUrl(p);
const telegramUrl = projectTelegramUrl(p);
const accent = p.accent ?? "var(--accent)";

const overviewParas = p.overview ? p.overview[locale] : [desc];

const hasMetrics = p.metrics && p.metrics.length > 0;
// Если у метрик заданы `span`, секция «масштаб» рендерится фиксированной
// 12-колоночной сеткой с явными ширинами плиток (иначе авто-сетка + лид).
const metricsSpanned = !!(p.metrics && p.metrics.some((m) => typeof m.span === "number"));
const hasStackGroups =
  p.stackGroups && Object.values(p.stackGroups).some((arr) => arr && arr.length > 0);
const hasArchitecture = p.architectureNodes && p.architectureNodes.length > 0;
const hasCapabilities = p.capabilities && p.capabilities.length > 0;
const hasTimeline = p.timeline && p.timeline.length > 0;
const hasLinks = Boolean(domainUrl || telegramUrl || p.links?.docs);

// Сигнатурная визуализация «как это работает»: bespoke-анимация ключевых
// механизмов проекта. Список slug-ов, для которых она есть (см. ProjectSignature).
const SIGNATURE_SLUGS = new Set([
  "dotsound",
  "dotlearn",
  "dotagents",
  "dotworkbot",
  "dotmath",
  "dottraceip",
]);
const hasSignature = SIGNATURE_SLUGS.has(p.slug);

// Лид к секции «Платформа изнутри»: по slug, чтобы вступление совпадало с
// концепцией конкретной сигнатуры. Фолбэк - общий «выбери домен».
const signatureLedes: Record<string, { ru: string; en: string }> = {
  dotlearn: {
    ru: "Семь шагов одной историей: от клонирования репозитория до экспорта прогресса. Иди стрелками ←/→ и смотри, как всё работает изнутри.",
    en: "Seven steps as one story: from cloning the repo to exporting your progress. Step through with ←/→ and watch how it works inside.",
  },
  dottraceip: {
    ru: 'Не список полей, а живое досье на адрес. Выберите IP из списка и нажмите "Проследить" и посмотрите, как всё работает изнутри.',
    en: "Not a list of fields but a live dossier on an address. Pick an IP from the brute-force logs, hit 'Trace', and see how it works inside.",
  },
  dotagents: {
    ru: "Два экрана одной истории: слева в терминале работает Claude Code, справа в Telegram сидишь ты. Агент дошёл до опасной команды и встал; реши за него с телефона и посмотри, как контроль работает изнутри.",
    en: "Two screens, one story: Claude Code runs in the terminal on the left, you sit in Telegram on the right. The agent hit a dangerous command and froze; decide for it from your phone and watch the control loop from the inside.",
  },
  dotworkbot: {
    ru: "Живая kanban-доска биржи смен, а не список полей. Попробуйте её ниже и посмотрите, как всё работает изнутри.",
    en: "A live kanban board for a gig-shift marketplace, not a list of fields. Try it below and see how it works inside.",
  },
};
const signatureLede = (signatureLedes[p.slug] ?? {
  ru: "Интерактивный разбор ключевых механик. Выбери домен, увидишь как всё работает изнутри.",
  en: "An interactive breakdown of the core mechanics. Pick a domain to see how it works inside.",
})[locale];
---

<article class="case" style={`--project-accent: ${accent};`}>
  <section class="case__hero" data-case-hero>
    <div class="case__hero-bg" aria-hidden="true"></div>

    <div class="container case__hero-inner">
      <div class="case__hero-copy">
        <a href={backHref} class="case__back">
          <Icon name="arrow-left" size={16} class="case__back-arrow" />
          <span>{t("case.back")}</span>
        </a>

        <div class="case__eyebrow" data-reveal>
          <span class="eyebrow">{t(`projects.category.${p.category}`)}</span>
          {
            startDate && (
              <span class="eyebrow case__eyebrow-divider" aria-hidden="true">
                ·
              </span>
            )
          }
          {startDate && <span class="eyebrow tabular">{startDate}</span>}
          <span class="eyebrow case__eyebrow-divider" aria-hidden="true">·</span>
          <span class={`case__status case__status--${p.status}`}>
            <Icon name="dot" size={10} />
            <span>{t(`projects.status.${p.status}`)}</span>
          </span>
        </div>

        <div class="case__glyph" data-reveal aria-hidden="true">
          <ProjectGlyph slug={p.slug} breathe />
        </div>
        <div class="case__brand-breathe">
          <h1
            class="case__brand display-xl"
            data-reveal
            data-reveal-delay="60"
            style={`view-transition-name: project-${p.slug}-brand;`}
          >
            {brand}
          </h1>
        </div>
        <p class="case__name caption" data-reveal data-reveal-delay="120">{name}</p>
        <p class="case__tagline title" data-reveal data-reveal-delay="180">{tagline}</p>

        {
          /* Только для мультирепо-экосистем (DotSound): у одного репозитория
             имя уже показано в основной GitHub-кнопке ниже, и пилюля дублировала бы его. */
          p.repos.length > 1 && (
            <ul
              class="case__repos-pills"
              aria-label={t("case.repos")}
              data-reveal
              data-reveal-delay="240"
            >
              {p.repos.map((r) => {
                const rUrl = repoUrl(r);
                return (
                  <li class="case__repos-pill">
                    {rUrl ? (
                      <a
                        href={rUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="case__repos-pill-link"
                        aria-label={`${r.name}: ${t("projects.viewSource")}`}
                        data-umami-event="open-repo"
                        data-umami-event-project={p.slug}
                      >
                        <Icon name="github" size={12} />
                        <span class="mono">{r.name}</span>
                      </a>
                    ) : (
                      <>
                        <Icon name="code" size={12} />
                        <span class="mono">{r.name}</span>
                      </>
                    )}
                  </li>
                );
              })}
            </ul>
          )
        }

        <div class="case__actions" data-reveal data-reveal-delay="300">
          {
            primaryRepoUrl && (
              <a
                href={primaryRepoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="cta cta--primary magnetic"
                data-umami-event="open-repo"
                data-umami-event-project={p.slug}
              >
                <Icon name="github" size={16} />
                <span>{primaryRepoLabel}</span>
              </a>
            )
          }
          {
            domainUrl && (
              <a
                href={domainUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="cta cta--ghost magnetic"
              >
                <Icon name="globe" size={16} />
                <span>{t("projects.openSite")}</span>
              </a>
            )
          }
          {
            telegramUrl && (
              <a
                href={telegramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="cta cta--ghost magnetic"
                data-umami-event="open-bot"
                data-umami-event-project={p.slug}
              >
                <Icon name="telegram" size={16} />
                <span>{t("projects.openBot")}</span>
              </a>
            )
          }
        </div>
      </div>

      {
        p.cover && (
          <figure
            class="case__hero-visual glass glass--bordered"
            data-reveal
            data-reveal-delay="180"
          >
            <button
              class="case__cover-btn"
              data-lightbox-src={p.cover}
              data-lightbox-title={name}
              aria-label={`${name}: открыть обложку`}
              type="button"
            >
              <img
                src={p.cover}
                alt=""
                class="case__hero-cover"
                width="1600"
                height="900"
                decoding="async"
                fetchpriority="high"
              />
              <span class="case__cover-zoom" aria-hidden="true">
                <svg
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                >
                  <circle cx="9" cy="9" r="6" />
                  <path d="M15 15 L19 19" />
                  <path d="M7 9 H11 M9 7 V11" />
                </svg>
              </span>
            </button>
            <span class="case__cover-sheen" aria-hidden="true" />
          </figure>
        )
      }
    </div>
  </section>

  <div class="container case__body">
    <!-- 2. Overview -->
    <section class="case__section case__section--narrow" data-reveal>
      <header class="case__h">
        <h2 class="eyebrow">{t("case.overview")}</h2>
      </header>
      {overviewParas.map((para) => <p class="case__lede body">{para}</p>)}
    </section>

    <!-- 2b. Signature visualization: «как это работает» (bespoke per project) -->
    {
      hasSignature && (
        <section class="case__section case__section--bleed" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{locale === "ru" ? "Платформа изнутри" : "Under the hood"}</h2>
            <p class="case__h-lede subtitle">{signatureLede}</p>
          </header>
          <ProjectSignature slug={p.slug} locale={locale} />
        </section>
      )
    }

    <!-- 3. Metrics -->
    {
      hasMetrics && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.metrics")}</h2>
            <p class="case__h-lede subtitle">{t("case.metricsLede")}</p>
          </header>
          <div
            class:list={[
              "case__metrics",
              "case__scale",
              metricsSpanned && "case__metrics--spanned",
            ]}
            data-scale
          >
            {p.metrics!.map((m, i) => {
              const vlen = m.value.length;
              const numClass =
                vlen >= 7 ? "case__metric-num--xs" : vlen >= 5 ? "case__metric-num--sm" : "";
              const style = metricsSpanned ? `--i:${i}; --span:${m.span ?? 3}` : `--i:${i}`;
              return (
                <div
                  class:list={["case__metric", !metricsSpanned && i === 0 && "case__metric--lead"]}
                  data-reveal
                  data-reveal-delay={i * 60}
                  style={style}
                >
                  <span class:list={["metric", numClass]}>
                    <span class="case__metric-val" data-countup>
                      {m.value}
                    </span>
                    {m.unit && <span class="metric__unit">{m.unit}</span>}
                  </span>
                  <span class="metric__label">{m.label[locale]}</span>
                  <span class="case__metric-bar" aria-hidden="true" />
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- 4. Architecture -->
    {
      hasArchitecture && (
        <section class="case__section case__section--bleed" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.architecture")}</h2>
          </header>
          <div class="case__arch">
            <Architecture
              nodes={p.architectureNodes!}
              edges={p.architectureEdges ?? []}
              clusters={p.clusters ?? []}
              locale={locale}
              hint={t("case.architectureHint")}
              ariaLabel={`${name}: ${t("case.architecture")}`}
            />
          </div>
        </section>
      )
    }

    <!-- 5. Stack matrix -->
    {
      hasStackGroups ? (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.stack")}</h2>
          </header>
          <StackComposition groups={p.stackGroups!} locale={locale} />
          <StackMatrix groups={p.stackGroups!} locale={locale} />
        </section>
      ) : (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.stack")}</h2>
          </header>
          <ul class="case__chips">
            {p.stack.map((s) => (
              <li class="case__chip">{s}</li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- 6. Capabilities -->
    {
      hasCapabilities && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.capabilities")}</h2>
            <p class="case__h-lede subtitle">{t("case.capabilitiesLede")}</p>
          </header>
          <Capabilities items={p.capabilities!} locale={locale} />
        </section>
      )
    }

    <!-- 8. Project timeline -->
    {
      hasTimeline && (
        <section class="case__section case__section--narrow" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.timeline")}</h2>
            <p class="case__h-lede subtitle">{t("case.timelineLede")}</p>
          </header>
          <CaseTimeline
            items={p.timeline!}
            locale={locale}
            collapseAfter={4}
            moreLabel={t("case.timelineMore")}
            lessLabel={t("case.timelineLess")}
          />
        </section>
      )
    }

    <!-- Repos (always shown for ecosystems with multiple repos) -->
    {
      p.repos.length > 1 && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.repos")}</h2>
          </header>
          <ul class="case__repos">
            {p.repos.map((r) => {
              const rUrl = repoUrl(r);
              return (
                <li class="case__repo glass glass--hover" data-touch-live>
                  <div class="case__repo-head">
                    <Icon name="code" size={18} />
                    <span class="case__repo-name display">{r.name}</span>
                    {r.role && <span class="case__repo-role">{r.role}</span>}
                  </div>
                  {r.description && (
                    <p class="case__repo-desc body-sm">
                      {r.description[locale] ?? r.description.ru}
                    </p>
                  )}
                  {rUrl && (
                    <a
                      href={rUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="case__repo-link"
                      data-umami-event="open-repo"
                      data-umami-event-project={p.slug}
                    >
                      <span class="mono">{rUrl.replace(/^https?:\/\//, "")}</span>
                      <Icon name="external" size={14} />
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )
    }

    {
      hasLinks && (
        <section class="case__section case__section--narrow" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.links")}</h2>
          </header>
          <ul class="case__links">
            {domainUrl && (
              <li>
                <a href={domainUrl} target="_blank" rel="noopener noreferrer" class="case__link">
                  <Icon name="globe" size={16} />
                  <span class="mono">{domainUrl}</span>
                </a>
              </li>
            )}
            {p.links?.docs && (
              <li>
                <a href={p.links.docs} target="_blank" rel="noopener noreferrer" class="case__link">
                  <Icon name="code" size={16} />
                  <span class="mono">{p.links.docs}</span>
                </a>
              </li>
            )}
            {telegramUrl && (
              <li>
                <a
                  href={telegramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="case__link"
                  data-umami-event="open-bot"
                  data-umami-event-project={p.slug}
                >
                  <Icon name="telegram" size={16} />
                  <span class="mono">{telegramUrl}</span>
                </a>
              </li>
            )}
          </ul>
        </section>
      )
    }

    <!-- 9. Cross-links to other projects -->
    <section class="case__section" data-reveal>
      <CaseFooterCrossLinks current={p.slug} locale={locale} />
    </section>
  </div>
</article>

<!-- Лайтбокс для обложки проекта -->
<div
  class="case-lightbox"
  id="case-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Просмотр обложки"
  hidden
>
  <div class="case-lightbox__backdrop" id="case-lightbox-backdrop"></div>
  <div class="case-lightbox__stage" id="case-lightbox-stage">
    <img class="case-lightbox__img" id="case-lightbox-img" src="" alt="" />
  </div>
  <button class="case-lightbox__close" id="case-lightbox-close" aria-label="Закрыть">✕</button>
  <p class="case-lightbox__hint">
    Колесо мыши: зум · Drag: перемещение · Дабл-клик: сброс · ESC: закрыть
  </p>
</div>

<style>
  .case__hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-8) var(--sp-7);
    isolation: isolate;
  }

  .case__hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80vw 50vh at 30% 0%,
      color-mix(in srgb, var(--project-accent) 16%, transparent) 0%,
      transparent 60%
    );
  }

  .case__hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: center;
  }

  .case__hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    min-width: 0;
  }

  .case__back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    padding: var(--sp-2) 0;
    margin-block-end: var(--sp-3);
    width: max-content;
  }

  .case__back:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
    color: var(--text-muted);
  }

  .case__eyebrow-divider {
    color: var(--text-faint);
  }

  .case__status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    text-transform: lowercase;
    letter-spacing: var(--ls-wide);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
  }

  .case__status--active {
    color: var(--state-ok);
  }
  .case__status--wip {
    color: var(--state-warn);
  }
  .case__status--beta {
    color: var(--state-info);
  }
  .case__status--archived {
    color: var(--text-muted);
  }

  .case__glyph {
    width: clamp(40px, 7vw, 60px);
    color: var(--project-accent);
    margin-block-start: var(--sp-4);
  }

  .case__brand {
    font-size: clamp(2.4rem, 12vw, 56px);
    line-height: var(--lh-display-xl);
    letter-spacing: var(--ls-display-xl);
    margin-block-start: var(--sp-3);
    white-space: nowrap;
    background: linear-gradient(180deg, var(--text) 0%, var(--text-secondary) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Дыхание заголовка: только яркость, «живой свет» на буквах, без геометрии.
     Старт отложен (animation-delay) до конца reveal; кадр 0% = финал reveal
     (opacity:1) → стыковка без рывка. Амплитуда крошечная, цикл медленный. */
  @keyframes case-brand-breathe {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.92;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    /* Дышит ОБЁРТКА, а не сам h1: у h1 background-clip:text, и opacity-анимация
       на таком элементе не композитится - Blink тикает её на main thread каждый
       кадр (замер: 144 recalc/с в покое), steps() не спасает. На простом блоке
       та же анимация уходит в компоситор. steps(): кадр раз в ~280мс. */
    .case__brand-breathe {
      animation: case-brand-breathe 7s steps(25) infinite;
      animation-delay: 1.1s;
    }
  }

  .case__name {
    color: var(--text-secondary);
    margin-block-start: var(--sp-2);
  }

  .case__tagline {
    font-size: var(--fs-22);
    color: var(--text);
    max-width: 38ch;
    margin-block-start: var(--sp-3);
  }

  .case__repos-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block-start: var(--sp-3);
  }

  .case__repos-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-11);
    background: var(--glass-tint-1);
  }

  .case__repos-pill-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    color: inherit;
    transition: color var(--dur-fast) var(--ease-standard);
  }

  .case__repos-pill-link:hover,
  .case__repos-pill-link:focus-visible {
    color: var(--text);
    opacity: 1;
  }

  .case__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-block-start: var(--sp-4);
  }

  .case__hero-visual {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-3);
  }

  .case__hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      transparent 30%,
      color-mix(in srgb, var(--project-accent) 12%, transparent) 100%
    );
  }

  /* Медленный свет по «стеклу»: узкая диагональная светлая полоса раз в цикл
     проезжает по обложке и надолго замирает за кадром. Только transform
     (composited); overflow:hidden у фигуры обрезает полосу. Отдельный <span>,
     а не ::before: псевдоэлементы заняты .glass (top-shine / bottom-edge). */
  .case__cover-sheen {
    position: absolute;
    inset: -25% -12%;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 43%,
      rgba(255, 255, 255, 0.1) 50%,
      transparent 57%
    );
    transform: translateX(-135%);
  }

  @keyframes case-cover-sheen {
