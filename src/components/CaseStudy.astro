  .case-lightbox__stage:active {
    cursor: grabbing;
  }

  .case-lightbox__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform-origin: center center;
    /* will-change не постоянный: висел бы в памяти и закрытым (см. .case-lightbox__stage,
