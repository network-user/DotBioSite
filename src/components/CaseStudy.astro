  /* Иконка «увеличить» поверх обложки */
  .case__cover-zoom {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.7);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    display: grid;
    place-items: center;
    opacity: 0;
    transition:
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
    pointer-events: none;
    z-index: 2;
  }

  .case__cover-zoom svg {
    width: 22px;
    height: 22px;
  }

  .case__cover-btn:hover .case__cover-zoom,
  .case__cover-btn:focus-visible .case__cover-zoom {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  /* Тач: :hover нет, поэтому лупа-подсказка не появлялась и обложка выглядела
     некликабельной. На coarse-указателе показываем её постоянно и приглушённо:
     сигнал, что по обложке можно тапнуть (лайтбокс открывается по тапу). */
  @media (pointer: coarse) {
    .case__cover-zoom {
      opacity: 0.72;
      transform: translate(-50%, -50%) scale(0.9);
    }
  }

  /* ===== Лайтбокс ===== */
  .case-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: grid;
    place-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .case-lightbox[data-open] {
    opacity: 1;
    pointer-events: auto;
  }

  /* .case-lightbox с display:grid перебивает UA-правило [hidden]{display:none}
     (тот же случай, что в CaseTimeline.astro), поэтому закрытый лайтбокс всё
     равно оставался бы в дереве слоёв. Возвращаем display:none явно: JS уже
     ставит/снимает hidden в openLightbox/closeLightbox. */
  .case-lightbox[hidden] {
    display: none;
  }

  .case-lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(4, 4, 6, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    cursor: zoom-out;
  }

  .case-lightbox__stage {
    position: relative;
    z-index: 1;
    width: min(92vw, 160vh);
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 40px 120px rgba(0, 0, 0, 0.8);
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    /* На тач: жесты pan/zoom (double-tap, drag) обрабатывает JS, поэтому гасим нативные
       жесты браузера на самой сцене, чтобы они не конфликтовали с перетаскиванием. */
    touch-action: none;
