---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import {
  type Project,
  projectName,
  projectBrand,
  projectTagline,
  projectDescription,
  projectStartDate,
  repoUrl,
} from "../lib/projects";
import Icon from "./Icon/Icon.astro";
import ProjectGlyph from "./ProjectGlyph.astro";
import Architecture from "./diagram/Architecture.astro";
import StackMatrix from "./case/StackMatrix.astro";
import StackComposition from "./case/StackComposition.astro";
import Capabilities from "./case/Capabilities.astro";
import EngineeringCallouts from "./case/EngineeringCallouts.astro";
import CaseTimeline from "./case/CaseTimeline.astro";
import CaseFooterCrossLinks from "./case/CaseFooterCrossLinks.astro";

interface Props {
  project: Project;
  locale: Locale;
}
const { project: p, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const name = projectName(p, locale);
const brand = projectBrand(p, locale);
const tagline = projectTagline(p, locale);
const desc = projectDescription(p, locale);
const startDate = projectStartDate(p);
const backHref = `${prefix}/#projects`;
const primaryRepoUrl = p.repos[0] ? repoUrl(p.repos[0]) : "";
const accent = p.accent ?? "var(--accent)";

const overviewParas = p.overview ? p.overview[locale] : [desc];

const hasMetrics = p.metrics && p.metrics.length > 0;
const hasStackGroups =
  p.stackGroups && Object.values(p.stackGroups).some((arr) => arr && arr.length > 0);
const hasArchitecture = p.architectureNodes && p.architectureNodes.length > 0;
const hasCapabilities = p.capabilities && p.capabilities.length > 0;
const hasEngineering = p.engineeringChoices && p.engineeringChoices.length > 0;
const hasTimeline = p.timeline && p.timeline.length > 0;
const hasLinks = p.links && Object.keys(p.links).length > 0;
---

<article class="case" style={`--project-accent: ${accent};`}>
  <section class="case__hero" data-case-hero>
    <div class="case__hero-bg" aria-hidden="true"></div>

    <div class="container case__hero-inner">
      <div class="case__hero-copy">
        <a href={backHref} class="case__back">
          <Icon name="arrow-right" size={16} class="case__back-arrow" />
          <span>{t("case.back")}</span>
        </a>

        <div class="case__eyebrow" data-reveal>
          <span class="eyebrow">{t(`projects.category.${p.category}`)}</span>
          {
            startDate && (
              <span class="eyebrow case__eyebrow-divider" aria-hidden="true">
                ·
              </span>
            )
          }
          {startDate && <span class="eyebrow tabular">{startDate}</span>}
          <span class="eyebrow case__eyebrow-divider" aria-hidden="true">·</span>
          <span class={`case__status case__status--${p.status}`}>
            <Icon name="dot" size={10} />
            <span>{t(`projects.status.${p.status}`)}</span>
          </span>
        </div>

        <div class="case__glyph" data-reveal aria-hidden="true">
          <ProjectGlyph slug={p.slug} />
        </div>
        <h1
          class="case__brand display-xl"
          data-reveal
          data-reveal-delay="60"
          style={`view-transition-name: project-${p.slug}-brand;`}
        >
          {brand}
        </h1>
        <p class="case__name caption" data-reveal data-reveal-delay="120">{name}</p>
        <p class="case__tagline title" data-reveal data-reveal-delay="180">{tagline}</p>

        {
          p.repos.length > 0 && (
            <ul
              class="case__repos-pills"
              aria-label={t("case.repos")}
              data-reveal
              data-reveal-delay="240"
            >
              {p.repos.map((r) => (
                <li class="case__repos-pill">
                  <Icon name="code" size={12} />
                  <span class="mono">{r.name}</span>
                </li>
              ))}
            </ul>
          )
        }

        <div class="case__actions" data-reveal data-reveal-delay="300">
          {
            primaryRepoUrl && (
              <a
                href={primaryRepoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="cta cta--primary magnetic"
              >
                <Icon name="github" size={16} />
                <span>{t("case.primaryRepo")}</span>
              </a>
            )
          }
          {
            p.links?.domain && (
              <a
                href={p.links.domain}
                target="_blank"
                rel="noopener noreferrer"
                class="cta cta--ghost magnetic"
              >
                <Icon name="globe" size={16} />
                <span>{t("projects.openSite")}</span>
              </a>
            )
          }
        </div>
      </div>

      {
        p.cover && (
          <figure
            class="case__hero-visual glass glass--bordered"
            data-reveal
            data-reveal-delay="180"
          >
            <img
              src={p.cover}
              alt=""
              class="case__hero-cover"
              width="1600"
              height="900"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        )
      }
    </div>
  </section>

  <div class="container case__body">
    <!-- 2. Overview -->
    <section class="case__section case__section--narrow" data-reveal>
      <header class="case__h">
        <h2 class="eyebrow">{t("case.overview")}</h2>
      </header>
      {overviewParas.map((para) => <p class="case__lede body">{para}</p>)}
    </section>

    <!-- 3. Metrics -->
    {
      hasMetrics && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.metrics")}</h2>
            <p class="case__h-lede subtitle">{t("case.metricsLede")}</p>
          </header>
          <div class="case__metrics">
            {p.metrics!.map((m, i) => {
              const vlen = m.value.length;
              const numClass =
                vlen >= 7 ? "case__metric-num--xs" : vlen >= 5 ? "case__metric-num--sm" : "";
              return (
                <div class="case__metric" data-reveal data-reveal-delay={i * 60}>
                  <span class:list={["metric", numClass]}>
                    <span>{m.value}</span>
                    {m.unit && <span class="metric__unit">{m.unit}</span>}
                  </span>
                  <span class="metric__label">{m.label[locale]}</span>
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    <!-- 4. Architecture -->
    {
      hasArchitecture && (
        <section class="case__section case__section--bleed" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.architecture")}</h2>
          </header>
          <div class="case__arch">
            <Architecture
              nodes={p.architectureNodes!}
              edges={p.architectureEdges ?? []}
              clusters={p.clusters ?? []}
              ariaLabel={`${name} — ${t("case.architecture")}`}
            />
          </div>
        </section>
      )
    }

    <!-- 5. Stack matrix -->
    {
      hasStackGroups ? (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.stack")}</h2>
          </header>
          <StackComposition groups={p.stackGroups!} locale={locale} />
          <StackMatrix groups={p.stackGroups!} locale={locale} />
        </section>
      ) : (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.stack")}</h2>
          </header>
          <ul class="case__chips">
            {p.stack.map((s) => (
              <li class="case__chip">{s}</li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- 6. Capabilities -->
    {
      hasCapabilities && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.capabilities")}</h2>
            <p class="case__h-lede subtitle">{t("case.capabilitiesLede")}</p>
          </header>
          <Capabilities items={p.capabilities!} locale={locale} />
        </section>
      )
    }

    <!-- 7. Engineering choices -->
    {
      hasEngineering && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.engineering")}</h2>
            <p class="case__h-lede subtitle">{t("case.engineeringLede")}</p>
          </header>
          <EngineeringCallouts items={p.engineeringChoices!} locale={locale} />
        </section>
      )
    }

    <!-- 8. Project timeline -->
    {
      hasTimeline && (
        <section class="case__section case__section--narrow" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.timeline")}</h2>
            <p class="case__h-lede subtitle">{t("case.timelineLede")}</p>
          </header>
          <CaseTimeline items={p.timeline!} locale={locale} />
        </section>
      )
    }

    <!-- Repos (always — shows multiple repos for ecosystems) -->
    {
      p.repos.length > 1 && (
        <section class="case__section" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.repos")}</h2>
          </header>
          <ul class="case__repos">
            {p.repos.map((r) => {
              const rUrl = repoUrl(r);
              return (
                <li class="case__repo glass glass--hover">
                  <div class="case__repo-head">
                    <Icon name="code" size={18} />
                    <span class="case__repo-name display">{r.name}</span>
                    {r.role && <span class="case__repo-role">{r.role}</span>}
                  </div>
                  {r.description && (
                    <p class="case__repo-desc body-sm">
                      {r.description[locale] ?? r.description.ru}
                    </p>
                  )}
                  {rUrl && (
                    <a
                      href={rUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="case__repo-link"
                    >
                      <span class="mono">{rUrl.replace(/^https?:\/\//, "")}</span>
                      <Icon name="external" size={14} />
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )
    }

    {
      hasLinks && (
        <section class="case__section case__section--narrow" data-reveal>
          <header class="case__h">
            <h2 class="eyebrow">{t("case.links")}</h2>
          </header>
          <ul class="case__links">
            {p.links?.domain && (
              <li>
                <a
                  href={p.links.domain}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="case__link"
                >
                  <Icon name="globe" size={16} />
                  <span class="mono">{p.links.domain}</span>
                </a>
              </li>
            )}
            {p.links?.docs && (
              <li>
                <a href={p.links.docs} target="_blank" rel="noopener noreferrer" class="case__link">
                  <Icon name="code" size={16} />
                  <span class="mono">{p.links.docs}</span>
                </a>
              </li>
            )}
            {p.links?.telegram && (
              <li>
                <a
                  href={p.links.telegram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="case__link"
                >
                  <Icon name="telegram" size={16} />
                  <span class="mono">{p.links.telegram}</span>
                </a>
              </li>
            )}
          </ul>
        </section>
      )
    }

    <!-- 9. Cross-links to other projects -->
    <section class="case__section" data-reveal>
      <CaseFooterCrossLinks current={p.slug} locale={locale} />
    </section>
  </div>
</article>

<style>
  .case__hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-8) var(--sp-7);
    isolation: isolate;
  }

  .case__hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80vw 50vh at 30% 0%,
      color-mix(in srgb, var(--project-accent) 16%, transparent) 0%,
      transparent 60%
    );
  }

  .case__hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: center;
  }

  .case__hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    min-width: 0;
  }

  .case__back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    padding: var(--sp-2) 0;
    margin-block-end: var(--sp-3);
    width: max-content;
  }

  .case__back-arrow {
    transform: rotate(180deg);
  }

  .case__back:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2);
    color: var(--text-muted);
  }

  .case__eyebrow-divider {
    color: var(--text-faint);
  }

  .case__status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    text-transform: lowercase;
    letter-spacing: var(--ls-wide);
    padding: var(--sp-1) var(--sp-2);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
  }

  .case__status--active {
    color: var(--state-ok);
  }
  .case__status--wip {
    color: var(--state-warn);
  }
  .case__status--beta {
    color: var(--state-info);
  }
  .case__status--archived {
    color: var(--text-muted);
  }

  .case__glyph {
    width: clamp(40px, 7vw, 60px);
    color: var(--project-accent);
    margin-block-start: var(--sp-4);
    filter: drop-shadow(0 4px 16px color-mix(in srgb, var(--project-accent) 30%, transparent));
  }

  .case__brand {
    font-size: 56px;
    line-height: var(--lh-display-xl);
    letter-spacing: var(--ls-display-xl);
    margin-block-start: var(--sp-3);
    background: linear-gradient(180deg, var(--text) 0%, var(--text-secondary) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .case__name {
    color: var(--text-secondary);
    margin-block-start: var(--sp-2);
  }

  .case__tagline {
    font-size: var(--fs-22);
    color: var(--text);
    max-width: 38ch;
    margin-block-start: var(--sp-3);
  }

  .case__repos-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block-start: var(--sp-3);
  }

  .case__repos-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-11);
    background: var(--glass-tint-1);
  }

  .case__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-block-start: var(--sp-4);
  }

  .case__hero-visual {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-3);
  }

  .case__hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      transparent 30%,
      color-mix(in srgb, var(--project-accent) 12%, transparent) 100%
    );
  }

  .case__hero-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case__body {
    padding-block: var(--sp-8) var(--sp-10);
  }

  .case__section {
    margin-block-end: var(--sp-8);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .case__section--narrow {
    max-width: var(--container-narrow);
  }

  .case__section--bleed {
    /* Architecture diagram benefits from a wider canvas. */
    max-width: none;
  }

  .case__h {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .case__h-lede {
    color: var(--text-secondary);
    max-width: 56ch;
  }

  .case__lede {
    color: var(--text-secondary);
    font-size: var(--fs-16);
    max-width: 70ch;
    line-height: var(--lh-normal);
  }

  .case__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--sp-4);
  }

  .case__metric {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-5);
    border-radius: var(--r-lg);
    background:
      radial-gradient(
        120% 100% at 0% 0%,
        color-mix(in srgb, var(--project-accent) 9%, transparent),
        transparent 58%
      ),
      var(--glass-tint-1);
    border: var(--bw-thin) solid var(--glass-edge);
    box-shadow: var(--shadow-2);
    overflow: hidden;
    min-width: 0;
  }

  /* Accent tick at the top-left corner — the data-point marker. */
  .case__metric::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: var(--sp-5);
    width: 26px;
    height: 2px;
    border-radius: 0 0 var(--r-pill) var(--r-pill);
    background: var(--project-accent);
    opacity: 0.75;
  }

  .case__metric .metric > span:first-child {
    overflow-wrap: anywhere;
  }

  /* Long values (e.g. "127.0.0.1") step down so they never overflow the tile.
     Two-class specificity beats the global responsive `.metric` sizes. */
  .case__metric .case__metric-num--sm {
    font-size: var(--fs-32);
  }

  .case__metric .case__metric-num--xs {
    font-size: var(--fs-22);
  }

  .case__arch {
    border: var(--bw-thin) solid var(--glass-edge);
    border-radius: var(--r-xl);
    background: var(--bg-elevated);
    padding: var(--sp-4);
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-inline: contain;
    -webkit-overflow-scrolling: touch;
  }

  .case__arch :global(.architecture) {
    min-width: 680px;
  }

  .case__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .case__chip {
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
  }

  .case__repos {
    display: grid;
    gap: var(--sp-3);
    grid-template-columns: 1fr;
  }

  .case__repo {
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    border-radius: var(--r-lg);
  }

  .case__repo-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
    min-width: 0;
  }

  .case__repo-name {
    font-size: var(--fs-22);
    letter-spacing: var(--ls-tight);
  }

  .case__repo-role {
    margin-left: 0;
    font-size: var(--fs-11);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    color: var(--text-muted);
  }

  .case__repo-desc {
    color: var(--text-secondary);
  }

  .case__repo-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    font-size: var(--fs-13);
    margin-block-start: auto;
    min-width: 0;
  }

  .case__repo-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .case__links {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .case__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-secondary);
    font-size: var(--fs-14);
    max-width: 100%;
    min-width: 0;
  }

  .case__link:hover {
    color: var(--text);
    opacity: 1;
  }

  @media (min-width: 720px) {
    .case__hero {
      padding-block: var(--sp-11) var(--sp-10);
    }

    .case__back {
      margin-block-end: var(--sp-6);
    }

    .case__brand {
      font-size: 120px;
    }

    .case__tagline {
      font-size: var(--fs-28);
    }

    .case__body {
      padding-block: var(--sp-11) var(--sp-12);
    }

    .case__section {
      margin-block-end: var(--sp-11);
    }

    .case__lede {
      font-size: var(--fs-17);
    }

    .case__metrics {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: var(--sp-6);
    }

    .case__arch {
      padding: var(--sp-7);
    }

    .case__arch :global(.architecture) {
      min-width: 0;
    }

    .case__repos {
      grid-template-columns: repeat(2, 1fr);
    }

    .case__repo {
      padding: var(--sp-5) var(--sp-6);
    }

    .case__repo-role {
      margin-left: auto;
    }
  }

  @media (min-width: 980px) {
    .case__hero-inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(420px, 0.8fr);
      gap: var(--sp-8);
    }
  }

  @media (min-width: 1200px) {
    .case__brand {
      font-size: 180px;
    }

    .case__tagline {
      font-size: var(--fs-32);
    }
  }

  @media (max-width: 479px) {
    .case__actions {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
