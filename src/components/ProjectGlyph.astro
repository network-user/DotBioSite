---
/**
 * ProjectGlyph.astro: минималистичный тематический глиф проекта.
 *
 * Один <svg> 48×48 на `currentColor` (наследует цвет от родителя → акцент).
 * Тема по слагу: .звук: эквалайзер, .счёт: операторы +−×÷, .работа: кейс,
 * .агенты: терминал `>_`, .скиллы: два одинаковых квадрата внахлёст (один
 * skill, продублированный ещё раз). Размер задаёт обёртка (svg тянется на
 * width:100%), поэтому компонент переиспользуется в карточках, hero кейса и
 * кросс-линках.
 */

interface Props {
  slug: string;
  class?: string;
  /** Включает тонкое idle-«дыхание» глифа (кейс-страница). По умолчанию выключено. */
  breathe?: boolean;
}

const { slug, class: className = "", breathe = false } = Astro.props;
---

<svg
  class:list={["project-glyph", breathe && "project-glyph--breathe", className]}
  data-slug={slug}
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="2.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {
    slug === "dotsound" && (
      <g fill="currentColor" stroke="none">
        <rect x="3" y="18" width="5" height="12" rx="2.5" />
        <rect x="12" y="11" width="5" height="26" rx="2.5" />
        <rect x="21.5" y="4" width="5" height="40" rx="2.5" />
        <rect x="31" y="13" width="5" height="22" rx="2.5" />
        <rect x="40" y="19" width="5" height="10" rx="2.5" />
      </g>
    )
  }
  {
    slug === "dotmath" && (
      <g>
        <path d="M13 7 V19 M7 13 H19" />
        <path d="M29 13 H41" />
        <path d="M8 30 L18 40 M18 30 L8 40" />
        <path d="M29 35 H41" />
        <circle cx="35" cy="29.5" r="1.4" fill="currentColor" stroke="none" />
        <circle cx="35" cy="40.5" r="1.4" fill="currentColor" stroke="none" />
      </g>
    )
  }
  {
    slug === "dotworkbot" && (
      <g>
        <rect x="7" y="17" width="34" height="23" rx="4" />
        <path d="M18 17 v-3 a3 3 0 0 1 3-3 h6 a3 3 0 0 1 3 3 v3" />
        <path d="M7 27 h34" />
        <path d="M24 25 v4" />
        {breathe && <path class="wb-spark" d="M7 27 h34" />}
      </g>
    )
  }
  {
    slug === "dotagents" && (
      <g>
        <rect x="6" y="10" width="36" height="28" rx="5" />
        <path d="M14 21 l6 4 -6 4" />
        <path d="M25 29 h8" />
      </g>
    )
  }
  {
    slug === "dottraceip" && (
      <g>
        <path d="M15.5 32.5 a12 12 0 1 1 17 0" />
        <path d="M19.5 28.5 a6.5 6.5 0 1 1 9 0" />
        <path d="M24 24 L37 13" />
        <circle cx="24" cy="24" r="2.6" fill="currentColor" stroke="none" />
        <circle cx="37" cy="13" r="3" fill="currentColor" stroke="none" />
        {breathe && <path class="tr-spark" d="M24 24 L37 13" />}
      </g>
    )
  }
  {
    slug === "dotcore-skills" && (
      <g>
        <rect x="8" y="8" width="24" height="24" rx="4" />
        <rect x="16" y="16" width="24" height="24" rx="4" />
      </g>
    )
  }
  {
    slug === "dotlearn" && (
      <g>
        <path d="M5 19 L24 10 L43 19 L24 28 Z" />
        <path d="M13 22.5 V31 q11 6 22 0 V22.5" />
        <g class="dl-tassel">
          <path d="M43 19 V29" />
          <circle cx="43" cy="31.5" r="1.6" fill="currentColor" stroke="none" />
        </g>
      </g>
    )
  }
</svg>

<style>
  .project-glyph {
    display: block;
    width: 100%;
    height: auto;
  }

  /* =========================================================================
   * Idle-«дыхание» глифа: включается пропом `breathe` (кейс-страница).
   *
   * Принцип: ФОРМА СТОИТ НА МЕСТЕ. Никакого scale готовой иконки. Живёт только
   * свет + один осмысленный жест по сути проекта. Все жесты медленные, с долгими
   * паузами, малой амплитудой:
   *   .звук:   световая волна бежит по столбикам эквалайзера (opacity)
   *   .счёт:   подсветка обходит операторы по кругу (идёт счёт)
   *   .работа: световой импульс пробегает по рабочему разделителю
   *   .агенты: курсор командной строки мягко мигает
   *   .след:   импульс сигнала бежит к найденной точке, точка вспыхивает
   *   .скиллы: два квадрата поочерёдно подсвечиваются (та же копия)
   *   .учёба:  кисточка диплома качается маятником от точки крепления (43,19)
   *
   * Под reduced-motion отключено (вся секция под no-preference); за экраном
   * гасится глобальным `.anim-paused` (IntersectionObserver в BaseLayout).
   * Световые клон-линии (.tr-spark / .wb-spark) рендерятся только при breathe.
   * ========================================================================= */
  @media (prefers-reduced-motion: no-preference) {
    /* ---- .звук: световая волна по столбикам эквалайзера ---- */
    @keyframes glyph-sound-wave {
      0%,
      100% {
        opacity: 0.5;
      }
      18% {
        opacity: 1;
      }
      46% {
        opacity: 0.5;
      }
    }
    .project-glyph--breathe[data-slug="dotsound"] rect {
      /* steps(): кадр раз в ~240мс вместо каждого vsync, GPU-бюджет */
      animation: glyph-sound-wave 2.4s steps(10) infinite;
    }
    .project-glyph--breathe[data-slug="dotsound"] rect:nth-of-type(1) {
      animation-delay: 0s;
    }
    .project-glyph--breathe[data-slug="dotsound"] rect:nth-of-type(2) {
      animation-delay: 0.16s;
    }
    .project-glyph--breathe[data-slug="dotsound"] rect:nth-of-type(3) {
      animation-delay: 0.32s;
    }
    .project-glyph--breathe[data-slug="dotsound"] rect:nth-of-type(4) {
      animation-delay: 0.48s;
    }
    .project-glyph--breathe[data-slug="dotsound"] rect:nth-of-type(5) {
      animation-delay: 0.64s;
    }

    /* ---- .счёт: подсветка обходит операторы по кругу ---- */
    @keyframes glyph-op-pulse {
      0%,
      100% {
        opacity: 0.6;
      }
      12% {
        opacity: 1;
      }
      40% {
        opacity: 0.6;
      }
    }
    .project-glyph--breathe[data-slug="dotmath"] path,
    .project-glyph--breathe[data-slug="dotmath"] circle {
      animation: glyph-op-pulse 4s steps(10) infinite;
    }
    .project-glyph--breathe[data-slug="dotmath"] path:nth-of-type(1) {
      animation-delay: 0s;
    }
    .project-glyph--breathe[data-slug="dotmath"] path:nth-of-type(2),
    .project-glyph--breathe[data-slug="dotmath"] circle:nth-of-type(1) {
      animation-delay: 1s;
    }
    .project-glyph--breathe[data-slug="dotmath"] path:nth-of-type(3) {
      animation-delay: 2s;
    }
    .project-glyph--breathe[data-slug="dotmath"] path:nth-of-type(4),
    .project-glyph--breathe[data-slug="dotmath"] circle:nth-of-type(2) {
      animation-delay: 3s;
    }

    /* ---- .работа: световой импульс по рабочему разделителю ---- */
    .project-glyph--breathe[data-slug="dotworkbot"] .wb-spark {
      stroke: rgba(255, 255, 255, 0.92);
      stroke-dasharray: 2 80;
      animation: glyph-work-flow 4.2s steps(50) infinite;
    }
    @keyframes glyph-work-flow {
      0%,
      6% {
        stroke-dashoffset: 0;
        opacity: 0;
      }
      16% {
        opacity: 1;
      }
      46% {
        stroke-dashoffset: -34;
        opacity: 1;
      }
      54%,
      100% {
        stroke-dashoffset: -34;
        opacity: 0;
      }
    }

    /* ---- .агенты: мягко мигающий курсор командной строки ---- */
    @keyframes glyph-caret {
      0%,
      42% {
        opacity: 1;
      }
      58%,
      74% {
        opacity: 0.1;
      }
      90%,
      100% {
        opacity: 1;
      }
    }
    .project-glyph--breathe[data-slug="dotagents"] path:nth-of-type(2) {
      animation: glyph-caret 1.5s var(--ease-standard) infinite;
    }

    /* ---- .след: импульс сигнала бежит к найденной точке, точка вспыхивает ---- */
    .project-glyph--breathe[data-slug="dottraceip"] .tr-spark {
      stroke: rgba(255, 255, 255, 0.95);
      stroke-dasharray: 2 60;
      animation: glyph-trace-travel 3.2s steps(50) infinite;
    }
    @keyframes glyph-trace-travel {
      0%,
      8% {
        stroke-dashoffset: 0;
        opacity: 0;
      }
      18% {
        opacity: 1;
      }
      50% {
        stroke-dashoffset: -17;
        opacity: 1;
      }
      58%,
      100% {
        stroke-dashoffset: -17;
        opacity: 0;
      }
    }
    .project-glyph--breathe[data-slug="dottraceip"] circle:nth-of-type(2) {
      transform-box: fill-box;
      transform-origin: center;
      animation: glyph-trace-found 3.2s var(--ease-standard) infinite;
    }
    @keyframes glyph-trace-found {
      0%,
      48% {
        transform: scale(1);
      }
      56% {
        transform: scale(1.5);
      }
      70%,
      100% {
        transform: scale(1);
      }
    }

    /* ---- .скиллы: два квадрата поочерёдно подсвечиваются ---- */
    @keyframes glyph-skills-clone {
      0%,
      100% {
        opacity: 0.5;
      }
      25% {
        opacity: 1;
      }
      55% {
        opacity: 0.5;
      }
    }
    .project-glyph--breathe[data-slug="dotcore-skills"] rect {
      animation: glyph-skills-clone 2.8s steps(12) infinite;
    }
    .project-glyph--breathe[data-slug="dotcore-skills"] rect:nth-of-type(2) {
      animation-delay: 0.6s;
    }

    /* ---- .учёба: кисточка качается маятником от точки крепления ---- */
    @keyframes glyph-tassel-swing {
      0%,
      100% {
        transform: rotate(4.5deg);
      }
      50% {
        transform: rotate(-4.5deg);
      }
    }
    .project-glyph--breathe[data-slug="dotlearn"] .dl-tassel {
      transform-box: view-box;
      transform-origin: 43px 19px;
      animation: glyph-tassel-swing 3.6s steps(16) infinite;
    }
  }
</style>
