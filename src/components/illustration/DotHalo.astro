---
/**
 * DotHalo.astro — статическое кольцо из N точек.
 *
 * Декоративный «ореол» из равномерно распределённых точек вокруг центра.
 * Применяется в About для рамки монограммы. Размер каждой точки слегка
 * пульсирует по фазе, чтобы кольцо «дышало». Полностью стационарный SVG —
 * никакого JS.
 */

interface Props {
  size?: number;
  count?: number;
  radius?: number;
  dotRadius?: number;
  class?: string;
}

const {
  size = 320,
  count = 14,
  radius = 140,
  dotRadius = 2,
  class: className = "",
} = Astro.props;

const cx = size / 2;
const cy = size / 2;
const dots = Array.from({ length: count }, (_, i) => {
  const angle = (i / count) * Math.PI * 2 - Math.PI / 2;
  return {
    x: cx + Math.cos(angle) * radius,
    y: cy + Math.sin(angle) * radius,
    delay: (i / count) * 4,
  };
});
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${size} ${size}`}
  width={size}
  height={size}
  class:list={["dot-halo", className]}
  aria-hidden="true"
>
  <circle
    cx={cx}
    cy={cy}
    r={radius}
    fill="none"
    stroke="var(--dot-edge-color)"
    stroke-width="1"
    stroke-dasharray="2 6"
    opacity="0.5"
  />
  {
    dots.map((d) => (
      <circle
        cx={d.x}
        cy={d.y}
        r={dotRadius}
        fill="var(--dot-color)"
        style={`animation-delay: -${d.delay}s`}
        class="dot-halo__dot"
      />
    ))
  }
</svg>

<style>
  .dot-halo {
    display: block;
    overflow: visible;
  }

  .dot-halo__dot {
    transform-origin: center;
    transform-box: fill-box;
    animation: halo-pulse 4s ease-in-out infinite;
  }

  @keyframes halo-pulse {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot-halo__dot {
      animation: none;
    }
  }
</style>
