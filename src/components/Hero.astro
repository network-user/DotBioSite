---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import { authorName } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const brand = authorName(locale);
const eyebrow = t("hero.eyebrow");
const tagline = t("hero.tagline");
const subtitle = t("hero.subtitle");
---

<section class="hero" id="hero" aria-label={brand}>
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__field" aria-hidden="true">
    <span class="hero__trace hero__trace--a"></span>
    <span class="hero__trace hero__trace--b"></span>
    <span class="hero__trace hero__trace--c"></span>
    <span class="hero__node hero__node--a"></span>
    <span class="hero__node hero__node--b"></span>
    <span class="hero__node hero__node--c"></span>
    <span class="hero__node hero__node--d"></span>
  </div>

  <div class="container hero__inner">
    <p class="hero__eyebrow eyebrow" data-reveal data-reveal-delay="0">
      {eyebrow}
    </p>

    <h1
      class="hero__brand display-xl"
      data-reveal
      data-reveal-delay="60"
      style="view-transition-name: brand-root;"
    >
      {brand}
    </h1>

    <p class="hero__tagline title" data-reveal data-reveal-delay="180">
      {tagline}
    </p>

    <p class="hero__subtitle subtitle" data-reveal data-reveal-delay="300">
      {subtitle}
    </p>

    <div class="hero__ctas" data-reveal data-reveal-delay="420">
      <a href={`${prefix}/#projects`} class="cta cta--primary magnetic">
        <span>{t("hero.ctaProjects")}</span>
        <Icon name="arrow-right" size={18} />
      </a>
      <a href={`${prefix}/#contact`} class="cta cta--ghost magnetic">
        <span>{t("hero.ctaContact")}</span>
      </a>
    </div>
  </div>

  <a href={`${prefix}/#about`} class="hero__scroll-cue" aria-label={t("hero.scrollCue")}>
    <span class="caption">{t("hero.scrollCue")}</span>
    <Icon name="arrow-down" size={16} />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    min-height: 88svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: var(--sp-10) var(--sp-9);
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80vw 60vh at 50% 30%,
      rgba(255, 255, 255, 0.035) 0%,
      transparent 60%
    );
  }

  .hero__field {
    position: absolute;
    top: 10%;
    right: -28%;
    z-index: 1;
    width: min(560px, 108vw);
    aspect-ratio: 1.18;
    pointer-events: none;
    opacity: 0.34;
  }

  .hero__field::before,
  .hero__field::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--r-2xl);
  }

  .hero__field::before {
    background-image: radial-gradient(rgba(255, 255, 255, 0.34) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: linear-gradient(90deg, transparent, #000 22%, #000 76%, transparent);
  }

  .hero__field::after {
    border: var(--bw-thin) solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(90deg, transparent 0 49%, rgba(255, 255, 255, 0.1) 49% 50%, transparent 50%),
      linear-gradient(0deg, transparent 0 49%, rgba(255, 255, 255, 0.08) 49% 50%, transparent 50%);
    transform: rotate(-8deg);
  }

  .hero__trace,
  .hero__node {
    position: absolute;
    z-index: 2;
  }

  .hero__trace {
    height: 1px;
    transform-origin: left center;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.44),
      rgba(255, 255, 255, 0.08)
    );
  }

  .hero__trace--a {
    top: 31%;
    left: 13%;
    width: 64%;
    transform: rotate(16deg);
  }

  .hero__trace--b {
    top: 58%;
    left: 23%;
    width: 52%;
    transform: rotate(-21deg);
  }

  .hero__trace--c {
    top: 72%;
    left: 38%;
    width: 34%;
    transform: rotate(28deg);
  }

  .hero__node {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--text);
    box-shadow:
      0 0 0 8px rgba(255, 255, 255, 0.035),
      0 0 40px rgba(255, 255, 255, 0.16);
  }

  .hero__node--a {
    top: 24%;
    left: 12%;
  }

  .hero__node--b {
    top: 38%;
    left: 72%;
    width: 18px;
    height: 18px;
  }

  .hero__node--c {
    top: 63%;
    left: 28%;
    width: 9px;
    height: 9px;
  }

  .hero__node--d {
    top: 78%;
    left: 76%;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-3);
  }

  .hero__eyebrow {
    color: var(--text-muted);
    margin-block-end: var(--sp-3);
  }

  .hero__brand {
    font-size: 56px;
    letter-spacing: var(--ls-display-xl);
    line-height: var(--lh-display-xl);
    margin: 0;
    background: linear-gradient(180deg, var(--text) 0%, var(--text-secondary) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero__tagline {
    font-size: var(--fs-24);
    color: var(--text);
    margin-block-start: var(--sp-3);
    max-width: 16ch;
  }

  .hero__subtitle {
    max-width: 56ch;
    font-size: var(--fs-16);
    color: var(--text-secondary);
    margin-block-end: var(--sp-4);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    width: 100%;
  }

  .hero__scroll-cue {
    position: absolute;
    bottom: var(--sp-7);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    z-index: 2;
    animation: scrollPulse 2.4s var(--ease-soft) infinite;
  }

  .hero__scroll-cue:hover {
    color: var(--text-secondary);
  }

  @keyframes scrollPulse {
    0%,
    100% {
      transform: translate(-50%, 0);
      opacity: 0.4;
    }
    50% {
      transform: translate(-50%, 6px);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-cue {
      animation: none;
    }
  }

  @media (max-width: 479px) {
    .hero {
      min-height: auto;
      padding-block: var(--sp-10) var(--sp-8);
    }

    .hero__brand {
      font-size: 52px;
    }

    .hero__tagline {
      font-size: var(--fs-22);
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  @media (min-width: 480px) {
    .hero__brand {
      font-size: 72px;
    }

    .hero__tagline {
      max-width: 22ch;
    }
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      padding-block: var(--sp-12) var(--sp-11);
    }

    .hero__inner {
      gap: var(--sp-4);
    }

    .hero__brand {
      font-size: 128px;
    }

    .hero__tagline {
      font-size: var(--fs-32);
      max-width: none;
    }

    .hero__subtitle {
      font-size: var(--fs-18);
    }

    .hero__ctas {
      width: auto;
    }

    .hero__field {
      top: 15%;
      right: 2%;
      width: min(42vw, 560px);
      opacity: 0.58;
    }
  }

  @media (min-width: 1200px) {
    .hero__brand {
      font-size: 180px;
    }

    .hero__tagline {
      font-size: 36px;
    }
  }
</style>
