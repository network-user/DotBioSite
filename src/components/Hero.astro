---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import { authorName } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const brand = authorName(locale);
const eyebrow = t("hero.eyebrow");
const tagline = t("hero.tagline");
const subtitle = t("hero.subtitle");

interface ProofStat {
  value: string;
  label: string;
}
const proof = t<ReadonlyArray<ProofStat>>("hero.proof", []);
---

<section class="hero" id="hero" aria-label={brand}>
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__field" aria-hidden="true">
    <span class="hero__trace hero__trace--a"></span>
    <span class="hero__trace hero__trace--b"></span>
    <span class="hero__trace hero__trace--c"></span>
    <span class="hero__node hero__node--a"></span>
    <span class="hero__node hero__node--b"></span>
    <span class="hero__node hero__node--c"></span>
    <span class="hero__node hero__node--d"></span>
  </div>

  <div class="container hero__inner">
    <p class="hero__eyebrow eyebrow" data-reveal data-reveal-delay="0">
      {eyebrow}
    </p>

    <h1
      class="hero__brand display-xl"
      data-reveal
      data-reveal-delay="60"
      style="view-transition-name: brand-root;"
    >
      {brand}
    </h1>

    <p class="hero__tagline title" data-reveal data-reveal-delay="180">
      {tagline}
    </p>

    <p class="hero__subtitle subtitle" data-reveal data-reveal-delay="300">
      {subtitle}
    </p>

    <div class="hero__ctas" data-reveal data-reveal-delay="420">
      <a href={`${prefix}/#projects`} class="cta cta--primary magnetic">
        <span>{t("hero.ctaProjects")}</span>
        <Icon name="arrow-right" size={18} />
      </a>
      <a href={`${prefix}/#contact`} class="cta cta--ghost magnetic">
        <span>{t("hero.ctaContact")}</span>
      </a>
    </div>

    {
      proof.length > 0 && (
        <dl class="hero__proof" data-reveal data-reveal-delay="540">
          {proof.map((s) => (
            <div class="hero__proof-item">
              <dt class="hero__proof-value display tabular">{s.value}</dt>
              <dd class="hero__proof-label caption">{s.label}</dd>
            </div>
          ))}
        </dl>
      )
    }
  </div>

  <a href={`${prefix}/#about`} class="hero__scroll-cue" aria-label={t("hero.scrollCue")}>
    <span class="caption">{t("hero.scrollCue")}</span>
    <Icon name="arrow-down" size={16} />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    min-height: 88svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: var(--sp-10) var(--sp-9);
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80vw 60vh at 50% 30%,
      rgba(255, 255, 255, 0.035) 0%,
      transparent 60%
    );
  }

  .hero__field {
    position: absolute;
    top: 10%;
    right: -28%;
    z-index: 1;
    width: min(560px, 108vw);
    aspect-ratio: 1.18;
    pointer-events: none;
    opacity: 0.34;
  }

  .hero__field::before,
  .hero__field::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--r-2xl);
  }

  .hero__field::before {
    background-image: radial-gradient(rgba(255, 255, 255, 0.34) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: linear-gradient(90deg, transparent, #000 22%, #000 76%, transparent);
  }

  .hero__field::after {
    border: var(--bw-thin) solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(90deg, transparent 0 49%, rgba(255, 255, 255, 0.1) 49% 50%, transparent 50%),
      linear-gradient(0deg, transparent 0 49%, rgba(255, 255, 255, 0.08) 49% 50%, transparent 50%);
    transform: rotate(-8deg);
  }

  .hero__trace,
  .hero__node {
    position: absolute;
    z-index: 2;
  }

  .hero__trace {
    height: 1px;
    transform-origin: left center;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.44),
      rgba(255, 255, 255, 0.08)
    );
  }

  .hero__trace--a {
    top: 31%;
    left: 13%;
    width: 64%;
    transform: rotate(16deg);
  }

  .hero__trace--b {
    top: 58%;
    left: 23%;
    width: 52%;
    transform: rotate(-21deg);
  }

  .hero__trace--c {
    top: 72%;
    left: 38%;
    width: 34%;
    transform: rotate(28deg);
  }

  .hero__node {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--text);
    box-shadow:
      0 0 0 8px rgba(255, 255, 255, 0.035),
      0 0 40px rgba(255, 255, 255, 0.16);
    animation: hero-float 8s var(--ease-standard) infinite alternate;
    will-change: transform;
  }

  .hero__node--a {
    top: 24%;
    left: 12%;
    animation-duration: 9s;
  }

  .hero__node--b {
    top: 38%;
    left: 72%;
    width: 18px;
    height: 18px;
    animation-duration: 11s;
    animation-delay: -3s;
  }

  .hero__node--c {
    top: 63%;
    left: 28%;
    width: 9px;
    height: 9px;
    animation-duration: 7s;
    animation-delay: -1.5s;
  }

  .hero__node--d {
    top: 78%;
    left: 76%;
    animation-duration: 10s;
    animation-delay: -4s;
  }

  @keyframes hero-float {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(8px, -12px, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__node {
      animation: none;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-3);
  }

  .hero__eyebrow {
    color: var(--text-muted);
    margin-block-end: var(--sp-3);
  }

  .hero__brand {
    font-family: var(--font-stack-display);
    font-size: 56px;
    letter-spacing: var(--ls-display-xl);
    line-height: var(--lh-display-xl);
    margin: 0;
    /* «Проявление»: мягкая белая полоса света медленно проходит по вордмарку. */
    background: linear-gradient(
      100deg,
      var(--text-secondary) 0%,
      var(--text) 30%,
      var(--accent) 46%,
      var(--text) 62%,
      var(--text-secondary) 100%
    );
    background-size: 240% 100%;
    background-position: 100% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: brand-sheen 9s var(--ease-standard) infinite;
  }

  @keyframes brand-sheen {
    0%,
    100% {
      background-position: 100% 50%;
    }
    50% {
      background-position: 0% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__brand {
      animation: none;
      background-position: 50% 50%;
    }
  }

  .hero__tagline {
    font-size: var(--fs-24);
    color: var(--text);
    margin-block-start: var(--sp-3);
    max-width: 16ch;
  }

  .hero__subtitle {
    max-width: 56ch;
    font-size: var(--fs-16);
    color: var(--text-secondary);
    margin-block-end: var(--sp-4);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    width: 100%;
  }

  /* ---------- Proof strip: честный масштаб одной строкой ---------- */
  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--sp-5) var(--sp-7);
    margin-block-start: var(--sp-7);
    padding-block-start: var(--sp-5);
    border-block-start: var(--bw-thin) solid var(--border);
    width: 100%;
  }

  .hero__proof-item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-width: 0;
  }

  .hero__proof-value {
    font-size: var(--fs-32);
    line-height: 1;
    color: var(--text);
    letter-spacing: var(--ls-display);
  }

  .hero__proof-label {
    color: var(--text-muted);
    text-transform: none;
    letter-spacing: var(--ls-snug);
    font-size: var(--fs-12);
  }

  @media (min-width: 768px) {
    .hero__proof {
      gap: var(--sp-6) var(--sp-9);
    }

    .hero__proof-value {
      font-size: var(--fs-40);
    }

    .hero__proof-label {
      font-size: var(--fs-13);
    }
  }

  .hero__scroll-cue {
    position: absolute;
    bottom: var(--sp-7);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    z-index: 2;
  }

  .hero__scroll-cue:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 479px) {
    .hero {
      min-height: auto;
      padding-block: var(--sp-10) var(--sp-8);
    }

    .hero__brand {
      font-size: 52px;
    }

    .hero__tagline {
      font-size: var(--fs-22);
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  @media (min-width: 480px) {
    .hero__brand {
      font-size: 72px;
    }

    .hero__tagline {
      max-width: 22ch;
    }
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      padding-block: var(--sp-12) var(--sp-11);
    }

    .hero__inner {
      gap: var(--sp-4);
    }

    .hero__brand {
      font-size: 128px;
    }

    .hero__tagline {
      font-size: var(--fs-32);
      max-width: none;
    }

    .hero__subtitle {
      font-size: var(--fs-18);
    }

    .hero__ctas {
      width: auto;
    }

    .hero__field {
      top: 15%;
      right: 2%;
      width: min(42vw, 560px);
      opacity: 0.58;
    }
  }

  @media (min-width: 1200px) {
    .hero__brand {
      font-size: 180px;
    }

    .hero__tagline {
      font-size: 36px;
    }
  }
</style>
