---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import { authorName } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const brand = authorName(locale);
const eyebrow = t("hero.eyebrow");
const tagline = t("hero.tagline");
const subtitle = t("hero.subtitle");
---

<section class="hero" id="hero" aria-label={brand}>
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__field" aria-hidden="true">
    <svg class="hero__core" viewBox="0 0 380 380" fill="none">
      <g class="hero__core-spin" stroke="currentColor">
        <ellipse cx="190" cy="190" rx="172" ry="64"></ellipse>
        <ellipse cx="190" cy="190" rx="172" ry="64" transform="rotate(60 190 190)"></ellipse>
        <ellipse cx="190" cy="190" rx="172" ry="64" transform="rotate(120 190 190)"></ellipse>
        <circle cx="362" cy="190" r="6" fill="currentColor" stroke="none"></circle>
        <circle cx="118" cy="246" r="4.5" fill="currentColor" stroke="none"></circle>
        <circle cx="252" cy="116" r="3.5" fill="currentColor" stroke="none"></circle>
      </g>
      <circle cx="190" cy="190" r="30" stroke="currentColor"></circle>
      <circle cx="190" cy="190" r="11" fill="currentColor" stroke="none"></circle>
    </svg>

    <!-- Созвездие: узлы на разной глубине (parallax) + тонкие связи, дышащие
         opacity. Каждый слой смещается к курсору со своим множителем -->
    <svg class="hero__constellation" viewBox="0 0 380 380" fill="none" aria-hidden="true">
      <g class="hero__links" stroke="currentColor" stroke-width="0.7" stroke-linecap="round">
        <line class="hero__link" x1="48" y1="84" x2="150" y2="46"></line>
        <line class="hero__link" x1="150" y1="46" x2="248" y2="120" style="--link-i: 1;"></line>
        <line class="hero__link" x1="48" y1="84" x2="92" y2="214" style="--link-i: 2;"></line>
        <line class="hero__link" x1="92" y1="214" x2="200" y2="290" style="--link-i: 3;"></line>
        <line class="hero__link" x1="248" y1="120" x2="332" y2="232" style="--link-i: 4;"></line>
        <line class="hero__link" x1="200" y1="290" x2="332" y2="232" style="--link-i: 5;"></line>
      </g>
    </svg>

    <!-- Узлы — отдельные элементы, чтобы каждый дрейфовал и парралаксил
         со своей глубиной (--depth) и фазой (--drift-i). -->
    <div class="hero__nodes">
      <span class="hero__node" style="--nx: 12.6%; --ny: 22.1%; --depth: 1.0; --drift-i: 0; --size: 5px;"></span>
      <span class="hero__node" style="--nx: 39.5%; --ny: 12.1%; --depth: 1.7; --drift-i: 1; --size: 4px;"></span>
      <span class="hero__node" style="--nx: 65.3%; --ny: 31.6%; --depth: 0.6; --drift-i: 2; --size: 6px;"></span>
      <span class="hero__node" style="--nx: 24.2%; --ny: 56.3%; --depth: 2.2; --drift-i: 3; --size: 3.5px;"></span>
      <span class="hero__node" style="--nx: 52.6%; --ny: 76.3%; --depth: 1.2; --drift-i: 4; --size: 4.5px;"></span>
      <span class="hero__node" style="--nx: 87.4%; --ny: 61.1%; --depth: 0.9; --drift-i: 5; --size: 5px;"></span>
    </div>
  </div>

  <div class="container hero__inner">
    <p class="hero__eyebrow eyebrow" data-reveal data-reveal-delay="0">
      {eyebrow}
    </p>

    <h1
      class="hero__brand display-xl"
      data-reveal
      data-reveal-delay="60"
      data-brand={brand}
      style="view-transition-name: brand-root;"
    >
      {brand}
    </h1>

    <p class="hero__tagline title" data-reveal data-reveal-delay="180">
      {tagline}
    </p>

    <p class="hero__subtitle subtitle" data-reveal data-reveal-delay="300">
      {subtitle}
    </p>

    <div class="hero__ctas" data-reveal data-reveal-delay="420">
      <a href={`${prefix}/#projects`} class="cta cta--primary magnetic">
        <span>{t("hero.ctaProjects")}</span>
        <Icon name="arrow-right" size={18} />
      </a>
      <a href={`${prefix}/#contact`} class="cta cta--ghost magnetic">
        <span>{t("hero.ctaContact")}</span>
      </a>
    </div>
  </div>

  <a href={`${prefix}/#about`} class="hero__scroll-cue" aria-label={t("hero.scrollCue")}>
    <span class="caption">{t("hero.scrollCue")}</span>
    <Icon name="arrow-down" size={16} />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    min-height: 88svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: var(--sp-10) var(--sp-9);
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80vw 60vh at 50% 30%,
      rgba(255, 255, 255, 0.035) 0%,
      transparent 60%
    );
  }

  .hero__field {
    position: absolute;
    top: 8%;
    right: -20%;
    z-index: 1;
    width: min(520px, 96vw);
    aspect-ratio: 1;
    pointer-events: none;
    opacity: 0.5;
    display: grid;
    place-items: center;
  }

  /* «Ядро»: атом — орбиты вокруг центра, буквальный знак .ядро. Чистые тонкие
     линии (не набросок), орбиты медленно вращаются одним GPU-transform. */
  .hero__core {
    width: 100%;
    height: 100%;
    color: var(--text-secondary);
    overflow: visible;
  }

  .hero__core ellipse,
  .hero__core circle {
    stroke-width: 1.4;
  }

  .hero__core-spin {
    transform-origin: 190px 190px;
    /* Очень медленный, ровный оборот. Длинный период = взгляд не цепляется. */
    animation: hero-orbit 150s linear infinite;
  }

  @keyframes hero-orbit {
    to {
      transform: rotate(360deg);
    }
  }

  /* Слой связей лежит поверх ядра, но под узлами; линии «дышат» прозрачностью. */
  .hero__constellation {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--accent);
    overflow: visible;
  }

  .hero__link {
    opacity: 0.16;
    /* Очень медленное «дыхание» прозрачности, мягкая синусоида. Период большой,
       сдвиги фаз разнесены — линии не мигают синхронно и не дёргают взгляд. */
    animation: hero-link-breathe 16s var(--ease-drift) infinite;
    animation-delay: calc(var(--link-i, 0) * -2.6s);
  }

  @keyframes hero-link-breathe {
    0%,
    100% {
      opacity: 0.09;
    }
    50% {
      opacity: 0.22;
    }
  }

  /* Узлы: каждый — точка, дрейфует по своей орбите (transform/opacity only)
     и сдвигается к курсору пропорционально --depth (слоистый 3D-эффект). */
  .hero__nodes {
    position: absolute;
    inset: 0;
  }

  .hero__node {
    position: absolute;
    left: var(--nx);
    top: var(--ny);
    width: var(--size, 4px);
    height: var(--size, 4px);
    border-radius: 50%;
    background: var(--text-secondary);
    /* Параллакс к курсору с узлов снят: каждый узел, читавший --ptr в transform,
       форсил page-wide style recalc на каждый mousemove. Узлы по-прежнему
       медленно дрейфуют собственным keyframe (transform), параллакс глубины
       остаётся на двух SVG-слоях (.hero__core / .hero__constellation). */
    --px: 0px;
    --py: 0px;
  }

  /* Внутренний дрейф анимируется на ::before, чтобы не конфликтовать с
     parallax-трансформом на самом узле (две независимые композиции). */
  .hero__node::before {
    content: "";
    position: absolute;
    inset: -180%;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent) 0%, transparent 68%);
    opacity: 0.14;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__node {
      /* Очень долгий дрейф (28-37s) с разнесёнными фазами: узлы плывут едва
         заметно, движение не «суетится» и не отвлекает от текста. */
      animation: hero-node-drift calc(28s + var(--drift-i, 0) * 1.8s)
        var(--ease-drift) infinite;
      animation-delay: calc(var(--drift-i, 0) * -4.6s);
    }
  }

  /* Маленькая орбита вокруг базовой позиции; амплитуда растёт с глубиной, так
     ближние узлы «плавают» чуть заметнее дальних. Амплитуду уменьшили — дрейф
     стал тише и читается как лёгкое покачивание, а не как полёт. */
  @keyframes hero-node-drift {
    0% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(0, 0);
    }
    25% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(calc(var(--depth, 1) * 3px), calc(var(--depth, 1) * -2.5px));
    }
    50% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(calc(var(--depth, 1) * -1.5px), calc(var(--depth, 1) * 3.5px));
    }
    75% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(calc(var(--depth, 1) * -3px), calc(var(--depth, 1) * -2px));
    }
    100% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__core-spin {
      animation: none;
    }

    .hero__core,
    .hero__constellation {
      transform: none;
    }

    .hero__link {
      animation: none;
      opacity: 0.16;
    }
  }

  /* На тач-устройствах параллакс не имеет смысла — гасим, оставляем дрейф. */
  @media (pointer: coarse) {
    .hero__core,
    .hero__constellation {
      transform: none;
    }

    .hero__node {
      --px: 0px;
      --py: 0px;
    }
  }

  @media (max-width: 639px) {
    .hero__field {
      opacity: 0.3;
      right: -34%;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-3);
  }

  .hero__eyebrow {
    color: var(--text-muted);
    margin-block-end: var(--sp-3);
  }

  .hero__brand {
    position: relative;
    font-family: var(--font-stack-display);
    font-size: 56px;
    letter-spacing: var(--ls-display-xl);
    line-height: var(--lh-display-xl);
    margin: 0;
    /* «Проявление»: статичный, хорошо читаемый градиент вместо бегущей полосы.
       Анимировать background-position в цикле нельзя (перф) — поэтому свет здесь
       зафиксирован, а лёгкий «доводящий» блик даёт отдельный transform-слой. */
    background: linear-gradient(
      100deg,
      var(--text-secondary) 0%,
      var(--text) 34%,
      var(--accent) 50%,
      var(--text) 66%,
      var(--text-secondary) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Блик «проявителя»: узкая светлая полоса, обрезанная по форме текста, очень
     медленно проезжает поперёк вордмарка. Двигаем ТОЛЬКО transform (translateX),
     прозрачность управляется тем же keyframe — никакого background-position. */
  .hero__brand::after {
    content: attr(data-brand);
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      100deg,
      transparent 38%,
      rgba(255, 255, 255, 0.9) 50%,
      transparent 62%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    opacity: 0;
    transform: translateX(-22%);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__brand::after {
      animation: brand-sheen 11s var(--ease-soft) infinite;
    }
  }

  /* Один проезд блика за период, с долгой паузой в покое — не мигает. */
  @keyframes brand-sheen {
    0%,
    72%,
    100% {
      opacity: 0;
      transform: translateX(-22%);
    }
    78% {
      opacity: 0.55;
    }
    92% {
      opacity: 0.55;
    }
    98% {
      opacity: 0;
      transform: translateX(22%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__brand::after {
      animation: none;
      opacity: 0;
    }
  }

  .hero__tagline {
    font-size: var(--fs-24);
    color: var(--text);
    margin-block-start: var(--sp-3);
    max-width: 16ch;
  }

  .hero__subtitle {
    max-width: 56ch;
    font-size: var(--fs-16);
    color: var(--text-secondary);
    margin-block-end: var(--sp-4);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    width: 100%;
  }

  .hero__scroll-cue {
    position: absolute;
    bottom: var(--sp-7);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    z-index: 2;
  }

  .hero__scroll-cue:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 479px) {
    .hero {
      min-height: auto;
      padding-block: var(--sp-10) var(--sp-8);
    }

    .hero__brand {
      font-size: 52px;
    }

    .hero__tagline {
      font-size: var(--fs-22);
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  @media (min-width: 480px) {
    .hero__brand {
      font-size: 72px;
    }

    .hero__tagline {
      max-width: 22ch;
    }
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      padding-block: var(--sp-12) var(--sp-11);
    }

    .hero__inner {
      gap: var(--sp-4);
    }

    .hero__brand {
      font-size: 128px;
    }

    .hero__tagline {
      font-size: var(--fs-32);
      max-width: none;
    }

    .hero__subtitle {
      font-size: var(--fs-18);
    }

    .hero__ctas {
      width: auto;
    }

    .hero__field {
      top: 15%;
      right: 2%;
      width: min(42vw, 560px);
      opacity: 0.58;
    }
  }

  @media (min-width: 1200px) {
    .hero__brand {
      font-size: 180px;
    }

    .hero__tagline {
      font-size: 36px;
    }
  }
</style>
