---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import { siteBrand } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const brand = siteBrand(locale);
const eyebrow = t("hero.eyebrow");
const tagline = t("hero.tagline");
const subtitle = t("hero.subtitle");
---

<section class="hero" id="hero" aria-label={brand}>
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__field" aria-hidden="true">
    <svg class="hero__core" viewBox="0 0 380 380" fill="none">
      <g class="hero__core-spin" stroke="currentColor">
        <ellipse cx="190" cy="190" rx="172" ry="64"></ellipse>
        <ellipse cx="190" cy="190" rx="172" ry="64" transform="rotate(60 190 190)"></ellipse>
        <ellipse cx="190" cy="190" rx="172" ry="64" transform="rotate(120 190 190)"></ellipse>
        <circle cx="362" cy="190" r="6" fill="currentColor" stroke="none"></circle>
        <circle cx="118" cy="246" r="4.5" fill="currentColor" stroke="none"></circle>
        <circle cx="252" cy="116" r="3.5" fill="currentColor" stroke="none"></circle>
      </g>
      <circle cx="190" cy="190" r="30" stroke="currentColor"></circle>
      <circle cx="190" cy="190" r="11" fill="currentColor" stroke="none"></circle>
    </svg>

    <!-- Созвездие: узлы на разной глубине (parallax) + тонкие связи, дышащие
         opacity. Каждый слой смещается к курсору со своим множителем -->
    <svg class="hero__constellation" viewBox="0 0 380 380" fill="none" aria-hidden="true">
      <g class="hero__links" stroke="currentColor" stroke-width="0.7" stroke-linecap="round">
        <line class="hero__link" x1="48" y1="84" x2="150" y2="46"></line>
        <line class="hero__link" x1="150" y1="46" x2="248" y2="120" style="--link-i: 1;"></line>
        <line class="hero__link" x1="48" y1="84" x2="92" y2="214" style="--link-i: 2;"></line>
        <line class="hero__link" x1="92" y1="214" x2="200" y2="290" style="--link-i: 3;"></line>
        <line class="hero__link" x1="248" y1="120" x2="332" y2="232" style="--link-i: 4;"></line>
        <line class="hero__link" x1="200" y1="290" x2="332" y2="232" style="--link-i: 5;"></line>
      </g>
    </svg>

    <!-- Узлы вынесены в отдельные элементы, чтобы каждый дрейфовал и парралаксил
         со своей глубиной (--depth) и фазой (--drift-i). -->
    <div class="hero__nodes">
      <span
        class="hero__node"
        style="--nx: 12.6%; --ny: 22.1%; --depth: 1.0; --drift-i: 0; --size: 5px;"></span>
      <span
        class="hero__node"
        style="--nx: 39.5%; --ny: 12.1%; --depth: 1.7; --drift-i: 1; --size: 4px;"></span>
      <span
        class="hero__node"
        style="--nx: 65.3%; --ny: 31.6%; --depth: 0.6; --drift-i: 2; --size: 6px;"></span>
      <span
        class="hero__node"
        style="--nx: 24.2%; --ny: 56.3%; --depth: 2.2; --drift-i: 3; --size: 3.5px;"></span>
      <span
        class="hero__node"
        style="--nx: 52.6%; --ny: 76.3%; --depth: 1.2; --drift-i: 4; --size: 4.5px;"></span>
      <span
        class="hero__node"
        style="--nx: 87.4%; --ny: 61.1%; --depth: 0.9; --drift-i: 5; --size: 5px;"></span>
    </div>
  </div>

  <div class="container hero__inner">
    <p class="hero__eyebrow eyebrow" data-reveal data-reveal-delay="0">
      {eyebrow}
    </p>

    <div class="hero__brand-wrap" data-reveal data-reveal-delay="60">
      <span class="hero__brand-aura" aria-hidden="true"></span>
      <h1 class="hero__brand display-xl" style="view-transition-name: brand-root;">
        {brand}
      </h1>
    </div>

    <p class="hero__tagline title" data-reveal data-reveal-delay="180">
      {tagline}
    </p>

    <p class="hero__subtitle subtitle" data-reveal data-reveal-delay="300">
      {subtitle}
    </p>

    <div class="hero__ctas" data-reveal data-reveal-delay="420">
      <a href={`${prefix}/#projects`} class="cta cta--primary magnetic">
        <span>{t("hero.ctaProjects")}</span>
        <Icon name="arrow-right" size={18} />
      </a>
      <a href={`${prefix}/#contact`} class="cta cta--ghost magnetic">
        <span>{t("hero.ctaContact")}</span>
      </a>
    </div>
  </div>

  <a href={`${prefix}/#about`} class="hero__scroll-cue" aria-label={t("hero.scrollCue")}>
    <span class="caption">{t("hero.scrollCue")}</span>
    <Icon name="arrow-down" size={16} />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 88vh;
    min-height: 88svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: var(--sp-10) var(--sp-9);
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80vw 60vh at 50% 30%,
      rgba(255, 255, 255, 0.035) 0%,
      transparent 60%
    );
  }

  .hero__field {
    position: absolute;
    top: 8%;
    right: -20%;
    z-index: 1;
    width: min(520px, 96vw);
    aspect-ratio: 1;
    pointer-events: none;
    opacity: 0.5;
    display: grid;
    place-items: center;
    /* Свой композит-слой. Внутри крутится SVG (core-spin) и дышат прозрачностью
       6 SVG-линий (link-breathe) - анимации на дочерних SVG-узлах не композитятся
       и перерисовывают слой на каждый тик. Раньше это гасил слой .main (снят в
       perf(gpu)-коммите ради экономии ~67МБ дубля #document); без своей изоляции
       эта перерисовка идёт в корневой слой прокрутки и душит rAF курсора-кольца -
       заметно только на самом верху страницы, пока Hero на экране. */
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  /* «Ядро»: атом, орбиты вокруг центра, буквальный знак .ядро. Чистые тонкие
     линии (не набросок), орбиты медленно вращаются одним GPU-transform. */
  .hero__core {
    width: 100%;
    height: 100%;
    color: var(--text-secondary);
    overflow: visible;
  }

  .hero__core ellipse,
  .hero__core circle {
    stroke-width: 1.4;
  }

  .hero__core-spin {
    transform-origin: 190px 190px;
    /* Очень медленный, ровный оборот. Длинный период = взгляд не цепляется.
       steps(1875): кадр раз в 80 мс (0.19 град, <1px на радиусе орбит) вместо
       каждого vsync - hero перестаёт держать GPU в постоянной работе. */
    animation: hero-orbit 150s steps(1875) infinite;
  }

  @keyframes hero-orbit {
    to {
      transform: rotate(360deg);
    }
  }

  /* Слой связей лежит поверх ядра, но под узлами; линии «дышат» прозрачностью. */
  .hero__constellation {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--accent);
    overflow: visible;
  }

  .hero__link {
    opacity: 0.16;
    /* Очень медленное «дыхание» прозрачности. Период большой, сдвиги фаз
       разнесены: линии не мигают синхронно и не дёргают взгляд. steps(100):
       дельта opacity за шаг ~0.001 при кадре раз в 80 мс; delay кратен шагу,
       чтобы тики всех линий попадали в общую сетку. */
    animation: hero-link-breathe 16s steps(100) infinite;
    animation-delay: calc(var(--link-i, 0) * -2.56s);
  }

  @keyframes hero-link-breathe {
    0%,
    100% {
      opacity: 0.09;
    }
    50% {
      opacity: 0.22;
    }
  }

  /* Узлы: каждый это точка, дрейфует по своей орбите (transform/opacity only)
     и сдвигается к курсору пропорционально --depth (слоистый 3D-эффект). */
  .hero__nodes {
    position: absolute;
    inset: 0;
  }

  .hero__node {
    position: absolute;
    left: var(--nx);
    top: var(--ny);
    width: var(--size, 4px);
    height: var(--size, 4px);
    border-radius: 50%;
    background: var(--text-secondary);
    /* Параллакс к курсору с узлов снят: каждый узел, читавший --ptr в transform,
       форсил page-wide style recalc на каждый mousemove. Узлы по-прежнему
       медленно дрейфуют собственным keyframe (transform), параллакс глубины
       остаётся на двух SVG-слоях (.hero__core / .hero__constellation). */
    --px: 0px;
    --py: 0px;
  }

  /* Внутренний дрейф анимируется на ::before, чтобы не конфликтовать с
     parallax-трансформом на самом узле (две независимые композиции). */
  .hero__node::before {
    content: "";
    position: absolute;
    inset: -180%;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent) 0%, transparent 68%);
    opacity: 0.14;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__node {
      /* Очень долгий дрейф с разнесёнными фазами: узлы плывут едва заметно,
         движение не «суетится» и не отвлекает от текста. Период у всех один
         (32s, кратен шагу 160 мс: сегмент 8s / 50 шагов), фазовый разброс
         дают отрицательные delay - тики узлов совпадают, GPU просыпается
         один раз на общий шаг, а не шесть раз вразнобой. */
      animation: hero-node-drift 32s steps(50) infinite;
      animation-delay: calc(var(--drift-i, 0) * -4.8s);
    }
  }

  /* Маленькая орбита вокруг базовой позиции; амплитуда растёт с глубиной, так
     ближние узлы «плавают» чуть заметнее дальних. Амплитуду уменьшили, и дрейф
     стал тише и читается как лёгкое покачивание, а не как полёт. */
  @keyframes hero-node-drift {
    0% {
      transform: translate3d(var(--px), var(--py), 0) translate(0, 0);
    }
    25% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(calc(var(--depth, 1) * 3px), calc(var(--depth, 1) * -2.5px));
    }
    50% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(calc(var(--depth, 1) * -1.5px), calc(var(--depth, 1) * 3.5px));
    }
    75% {
      transform: translate3d(var(--px), var(--py), 0)
        translate(calc(var(--depth, 1) * -3px), calc(var(--depth, 1) * -2px));
    }
    100% {
      transform: translate3d(var(--px), var(--py), 0) translate(0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__core-spin {
      animation: none;
    }

    .hero__core,
    .hero__constellation {
      transform: none;
    }

    .hero__link {
      animation: none;
      opacity: 0.16;
    }
  }

  /* На тач-устройствах параллакс не имеет смысла: гасим, оставляем дрейф. */
  @media (pointer: coarse) {
    .hero__core,
    .hero__constellation {
      transform: none;
    }

    .hero__node {
      --px: 0px;
      --py: 0px;
    }
  }

  @media (max-width: 639px) {
    .hero__field {
      opacity: 0.3;
      right: -34%;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-3);
  }

  .hero__eyebrow {
    color: var(--text-muted);
    margin-block-end: var(--sp-3);
  }

  .hero__brand {
    position: relative;
    font-family: var(--font-stack-display);
    /* Плавный мобильный/планшетный масштаб вместо ступеней 52→72: на любой
       ширине до десктопа бренд тянется без скачков и не переполняет узкий экран.
       Десктопные кегли (≥768) задаются ступенями ниже. */
    font-size: clamp(2.5rem, 11vw, 4.5rem);
    letter-spacing: var(--ls-display-xl);
    line-height: var(--lh-display-xl);
    margin: 0;
    /* «Проявление»: статичный, хорошо читаемый градиент вместо бегущей полосы.
       Анимировать background-position в цикле нельзя (перф), поэтому свет здесь
       зафиксирован, а лёгкий «доводящий» блик даёт отдельный transform-слой. */
    background: linear-gradient(
      100deg,
      var(--text-secondary) 0%,
      var(--text) 34%,
      var(--accent) 50%,
      var(--text) 66%,
      var(--text-secondary) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* Никаких масок по буквам: слово стоит на месте, а позади него медленно живёт
     мягкий свет: широкий световой «бутон», который дышит яркостью и чуть
     дрейфует вбок. Лежит ПОД текстом (изолированный стек-контекст + z-index:-1),
     поэтому даёт слову лёгкое свечение, не перекрывая буквы. Анимируем только
     opacity + transform; ни фильтров, ни background-position: дёшево и плавно. */
  .hero__brand-wrap {
    position: relative;
    display: inline-block;
    isolation: isolate;
  }

  .hero__brand-aura {
    position: absolute;
    z-index: -1;
    inset: -45% -16%;
    pointer-events: none;
    background: radial-gradient(
      ellipse 70% 62% at 50% 50%,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0.07) 38%,
      transparent 70%
    );
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__brand-aura {
      animation: brand-aura 12s var(--ease-drift) infinite;
      /* Та же синусоида --ease-drift, но дискретизированная в 75 ступеней на
         сегмент keyframes: форма дыхания сохранена, а кадр обновляется раз в
         80 мс (сдвиг ~2px по мягкому градиенту - не читается). Браузеры без
         linear() отбросят строку и оставят плавный вариант из шортката выше.
         Регенерация: node -e "N=75;f=t=>0.5-0.5*Math.cos(Math.PI*t);..."
         (сэмпл f(i/N), удержание на [i/N,(i+1)/N], финал 1 100%). */
      animation-timing-function: linear(
        0 0% 1.33%,
        0.0004 1.33% 2.67%,
        0.0018 2.67% 4%,
        0.0039 4% 5.33%,
        0.007 5.33% 6.67%,
        0.0109 6.67% 8%,
        0.0157 8% 9.33%,
        0.0213 9.33% 10.67%,
        0.0278 10.67% 12%,
        0.0351 12% 13.33%,
        0.0432 13.33% 14.67%,
        0.0521 14.67% 16%,
        0.0618 16% 17.33%,
        0.0723 17.33% 18.67%,
        0.0835 18.67% 20%,
        0.0955 20% 21.33%,
        0.1082 21.33% 22.67%,
        0.1215 22.67% 24%,
        0.1355 24% 25.33%,
        0.1502 25.33% 26.67%,
        0.1654 26.67% 28%,
        0.1813 28% 29.33%,
        0.1977 29.33% 30.67%,
        0.2146 30.67% 32%,
        0.2321 32% 33.33%,
        0.25 33.33% 34.67%,
        0.2684 34.67% 36%,
        0.2871 36% 37.33%,
        0.3062 37.33% 38.67%,
        0.3257 38.67% 40%,
        0.3455 40% 41.33%,
        0.3655 41.33% 42.67%,
        0.3858 42.67% 44%,
        0.4063 44% 45.33%,
        0.427 45.33% 46.67%,
        0.4477 46.67% 48%,
        0.4686 48% 49.33%,
        0.4895 49.33% 50.67%,
        0.5105 50.67% 52%,
        0.5314 52% 53.33%,
        0.5523 53.33% 54.67%,
        0.573 54.67% 56%,
        0.5937 56% 57.33%,
        0.6142 57.33% 58.67%,
        0.6345 58.67% 60%,
        0.6545 60% 61.33%,
        0.6743 61.33% 62.67%,
        0.6938 62.67% 64%,
        0.7129 64% 65.33%,
        0.7316 65.33% 66.67%,
        0.75 66.67% 68%,
        0.7679 68% 69.33%,
        0.7854 69.33% 70.67%,
        0.8023 70.67% 72%,
        0.8187 72% 73.33%,
        0.8346 73.33% 74.67%,
        0.8498 74.67% 76%,
        0.8645 76% 77.33%,
        0.8785 77.33% 78.67%,
        0.8918 78.67% 80%,
        0.9045 80% 81.33%,
        0.9165 81.33% 82.67%,
        0.9277 82.67% 84%,
        0.9382 84% 85.33%,
        0.9479 85.33% 86.67%,
        0.9568 86.67% 88%,
        0.9649 88% 89.33%,
        0.9722 89.33% 90.67%,
        0.9787 90.67% 92%,
        0.9843 92% 93.33%,
        0.9891 93.33% 94.67%,
        0.993 94.67% 96%,
        0.9961 96% 97.33%,
        0.9982 97.33% 98.67%,
        0.9996 98.67% 100%,
        1 100%
      );
    }
  }

  /* Непрерывное «дыхание» света: маятниковый дрейф вбок + мягкая пульсация
     яркости и масштаба. Кривая --ease-drift (синусоида) делает движение без
     рывков; на стыке цикла 0%/100% значения совпадают, поэтому шва нет. */
  @keyframes brand-aura {
    0%,
    100% {
      opacity: 0.45;
      transform: translateX(-7%) scale(0.96);
    }
    50% {
      opacity: 0.9;
      transform: translateX(7%) scale(1.05);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__brand-aura {
      animation: none;
      opacity: 0.6;
      transform: none;
    }
  }

  .hero__tagline {
    font-size: var(--fs-24);
    color: var(--text);
    margin-block-start: var(--sp-3);
    max-width: 16ch;
  }

  .hero__subtitle {
    max-width: 56ch;
    font-size: var(--fs-16);
    color: var(--text-secondary);
    margin-block-end: var(--sp-4);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    width: 100%;
  }

  .hero__scroll-cue {
    position: absolute;
    bottom: var(--sp-7);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
    z-index: 2;
  }

  .hero__scroll-cue:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 479px) {
    .hero {
      min-height: auto;
      padding-block: var(--sp-10) var(--sp-8);
    }

    .hero__tagline {
      font-size: var(--fs-22);
    }

    .hero__scroll-cue {
      display: none;
    }
  }

  @media (min-width: 480px) {
    .hero__tagline {
      max-width: 22ch;
    }
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      padding-block: var(--sp-12) var(--sp-11);
    }

    .hero__inner {
      gap: var(--sp-4);
    }

    .hero__brand {
      font-size: 128px;
    }

    .hero__tagline {
      font-size: var(--fs-32);
      max-width: none;
    }

    .hero__subtitle {
      font-size: var(--fs-18);
    }

    .hero__ctas {
      width: auto;
    }

    .hero__field {
      top: 15%;
      right: 2%;
      width: min(42vw, 560px);
      opacity: 0.58;
    }
  }

  @media (min-width: 1200px) {
    .hero__brand {
      font-size: 180px;
    }

    .hero__tagline {
      font-size: 36px;
    }
  }
</style>
