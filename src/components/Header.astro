---
import { useTranslations, alternateUrl, type Locale, localePrefix } from "../lib/i18n";
import { authorName } from "../lib/config";
import LanguageToggle from "./react/LanguageToggle.island.tsx";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const prefix = localePrefix(locale);
const altLocale: Locale = locale === "ru" ? "en" : "ru";
const altHref = alternateUrl(Astro.url, altLocale);

const brand = authorName(locale);

const navLinks = [
  { href: `${prefix}/#about`, label: t("nav.about"), section: "about" },
  { href: `${prefix}/#stack`, label: t("nav.stack"), section: "stack" },
  { href: `${prefix}/#projects`, label: t("nav.projects"), section: "projects" },
  { href: `${prefix}/#timeline`, label: t("nav.timeline"), section: "timeline" },
  { href: `${prefix}/#contact`, label: t("nav.contact"), section: "contact" },
];

// Активный пункт по умолчанию — определяется по hash в URL при первой отрисовке.
// Дальше его обновит скрипт ниже (через IntersectionObserver при скролле).
const initialHash = Astro.url.hash.replace("#", "");
---

<header class="header" data-header>
  <div class="header__inner container glass glass--liquid">
    <a href={prefix || "/"} class="header__brand" aria-label={brand}>
      <span class="header__brand-text display">{brand}</span>
    </a>

    <nav class="header__nav" aria-label="Primary" data-nav>
      <span class="header__indicator" aria-hidden="true"></span>
      {navLinks.map((l) => {
        const isActive = l.section === initialHash;
        return (
          <a
            href={l.href}
            class={`header__nav-link${isActive ? " is-active" : ""}`}
            data-section={l.section}
            aria-current={isActive ? "true" : undefined}
          >
            {l.label}
          </a>
        );
      })}
    </nav>

    <div class="header__actions">
      <LanguageToggle
        client:idle
        current={locale}
        alternate={altLocale}
        alternateUrl={altHref}
        label={t("nav.toggleLang")}
      />
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    padding-block: var(--sp-3);
    pointer-events: none;
  }

  .header__inner {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    padding: var(--sp-2) var(--sp-3) var(--sp-2) var(--sp-5);
    border-radius: var(--r-pill);
    margin-inline: auto;
    max-width: calc(var(--container-wide) - var(--sp-4));
    transition:
      background-color var(--dur-med) var(--ease-standard),
      backdrop-filter var(--dur-med) var(--ease-standard),
      box-shadow var(--dur-med) var(--ease-standard);
  }

  /* When scrolled, swap to denser tint and stronger blur via shared class. */
  .header.is-scrolled .header__inner {
    background-color: var(--glass-tint-ultra);
    backdrop-filter: blur(var(--glass-blur-strong-2)) saturate(160%);
    -webkit-backdrop-filter: blur(var(--glass-blur-strong-2)) saturate(160%);
    box-shadow: var(--shadow-2);
  }

  .header__brand {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-18);
    letter-spacing: var(--ls-display);
    line-height: 1;
    color: var(--text);
    padding: var(--sp-2) var(--sp-3);
    flex-shrink: 0;
  }

  .header__brand-text {
    display: inline-block;
  }

  .header__nav {
    position: relative;
    display: none;
    flex: 1;
    gap: var(--sp-2);
    align-items: center;
    justify-content: center;
  }

  .header__indicator {
    position: absolute;
    bottom: 4px;
    left: var(--ind-left, 0);
    width: var(--ind-width, 0);
    height: 2px;
    background: var(--text);
    border-radius: 1px;
    opacity: var(--ind-opacity, 0);
    transition:
      left var(--dur-slow) var(--ease-soft),
      width var(--dur-slow) var(--ease-soft),
      opacity var(--dur-med) var(--ease-standard);
    pointer-events: none;
  }

  .header__nav-link {
    position: relative;
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-snug);
    color: var(--text-secondary);
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--r-pill);
    transition: color var(--dur-fast) var(--ease-standard);
    min-height: var(--tap-min);
    display: inline-flex;
    align-items: center;
  }

  .header__nav-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .header__nav-link.is-active {
    color: var(--text);
    font-weight: var(--fw-semibold);
  }

  .header__actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  :global(.lang-toggle) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--tap-min);
    min-height: var(--tap-min);
    padding-inline: var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-wide);
    color: var(--text);
    text-transform: uppercase;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }

  :global(.lang-toggle:hover) {
    border-color: var(--border-hover);
    background: var(--surface-2);
    opacity: 1;
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }
</style>

<script>
  /**
   * Header behaviour: active-section underline + scrolled state.
   *
   * Active highlight strategy:
   *   1. IntersectionObserver наблюдает за всеми секциями (#about, #stack, ...).
   *   2. Из видимых выбираем ту, у которой наибольший intersectionRatio.
   *   3. Если ни одна не видна — снимаем активность со всех ссылок.
   *   4. Скользящий underline позиционируется через CSS-переменные на nav-родителе.
   *      Это даёт один плавный transition вместо отдельных tail-dot'ов.
   *
   * Scrolled state: при scrollY > 24 на <header> ставится `.is-scrolled` —
   * inner pill переключается на ultra-tint + сильный blur.
   */
  const SECTIONS = ["about", "stack", "projects", "timeline", "contact"];

  function updateIndicator(nav: HTMLElement, active: HTMLElement | null) {
    if (!active) {
      nav.style.setProperty("--ind-opacity", "0");
      return;
    }
    const navRect = nav.getBoundingClientRect();
    const linkRect = active.getBoundingClientRect();
    nav.style.setProperty("--ind-left", `${linkRect.left - navRect.left}px`);
    nav.style.setProperty("--ind-width", `${linkRect.width}px`);
    nav.style.setProperty("--ind-opacity", "1");
  }

  function setActive(section: string | null) {
    const nav = document.querySelector<HTMLElement>("[data-nav]");
    if (!nav) return;
    const links = nav.querySelectorAll<HTMLAnchorElement>("[data-section]");
    let active: HTMLAnchorElement | null = null;
    links.forEach((link) => {
      const isActive = link.dataset.section === section;
      link.classList.toggle("is-active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "true");
        active = link;
      } else {
        link.removeAttribute("aria-current");
      }
    });
    updateIndicator(nav, active);
  }

  function initHeaderNav() {
    const nav = document.querySelector<HTMLElement>("[data-nav]");
    if (!nav) return;

    const sectionEls = SECTIONS.map((id) => document.getElementById(id)).filter(
      (el): el is HTMLElement => el !== null,
    );
    if (sectionEls.length === 0) return;

    const visible = new Map<string, number>();

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          if (entry.isIntersecting) {
            visible.set(id, entry.intersectionRatio);
          } else {
            visible.delete(id);
          }
        });

        if (visible.size === 0) {
          setActive(null);
          return;
        }

        let topId: string | null = null;
        let topRatio = -1;
        visible.forEach((ratio, id) => {
          if (ratio > topRatio) {
            topRatio = ratio;
            topId = id;
          }
        });
        setActive(topId);
      },
      {
        rootMargin: "-40% 0px -40% 0px",
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );

    sectionEls.forEach((el) => io.observe(el));

    nav.querySelectorAll<HTMLAnchorElement>("[data-section]").forEach((link) => {
      link.addEventListener("click", () => {
        const id = link.dataset.section ?? null;
        setActive(id);
      });
    });

    // Reposition the underline when fonts or viewport shift it.
    const resizeObserver = new ResizeObserver(() => {
      const current = nav.querySelector<HTMLAnchorElement>(".header__nav-link.is-active");
      updateIndicator(nav, current);
    });
    resizeObserver.observe(nav);
  }

  function initHeaderScrolled() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    if (!header) return;
    const apply = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 24);
    };
    apply();
    window.addEventListener("scroll", apply, { passive: true });
  }

  function init() {
    initHeaderNav();
    initHeaderScrolled();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
