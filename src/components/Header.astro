---
import { useTranslations, alternateUrl, type Locale, localePrefix } from "../lib/i18n";
import { authorName } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const prefix = localePrefix(locale);
const altLocale: Locale = locale === "ru" ? "en" : "ru";
const altHref = alternateUrl(Astro.url, altLocale);

const brand = authorName(locale);
const menuLabel = locale === "ru" ? "Открыть меню" : "Open menu";
const closeMenuLabel = locale === "ru" ? "Закрыть меню" : "Close menu";

const navLinks = [
  { href: `${prefix}/#about`, label: t("nav.about"), section: "about" },
  { href: `${prefix}/#stack`, label: t("nav.stack"), section: "stack" },
  { href: `${prefix}/#projects`, label: t("nav.projects"), section: "projects" },
  { href: `${prefix}/#timeline`, label: t("nav.timeline"), section: "timeline" },
  { href: `${prefix}/#contact`, label: t("nav.contact"), section: "contact" },
];

// Активный пункт по умолчанию определяется по hash в URL при первой отрисовке.
// Дальше его обновит скрипт ниже (через IntersectionObserver при скролле).
const initialHash = Astro.url.hash.replace("#", "");
---

<header class="header" data-header>
  <div class="header__inner container glass glass--liquid">
    <a href={prefix || "/"} class="header__brand" aria-label={brand}>
      <span class="header__brand-text display">{brand}</span>
    </a>

    <nav class="header__nav" id="primary-nav" aria-label="Primary" data-nav>
      <span class="header__indicator" aria-hidden="true"></span>
      {
        navLinks.map((l) => {
          const isActive = l.section === initialHash;
          return (
            <a
              href={l.href}
              class={`header__nav-link${isActive ? " is-active" : ""}`}
              data-section={l.section}
              aria-current={isActive ? "true" : undefined}
            >
              {l.label}
            </a>
          );
        })
      }
    </nav>

    <div class="header__actions">
      <a
        href={altHref}
        class="lang-toggle"
        data-lang-toggle
        data-current={locale}
        data-alternate={altLocale}
        aria-label={`Switch language to ${altLocale.toUpperCase()}`}
        lang={altLocale}
        data-umami-event="switch-lang"
        data-umami-event-to={altLocale}
      >
        <span aria-hidden="true">{t("nav.toggleLang")}</span>
      </a>

      <button
        type="button"
        class="header__menu"
        data-menu-toggle
        aria-controls="primary-nav"
        aria-expanded="false"
        aria-label={menuLabel}
        data-label-open={menuLabel}
        data-label-close={closeMenuLabel}
      >
        <Icon name="menu" size={18} class="header__menu-icon header__menu-icon--open" />
        <Icon name="x" size={18} class="header__menu-icon header__menu-icon--close" />
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    padding-block: max(var(--sp-2), env(safe-area-inset-top));
    pointer-events: none;
  }

  .header__inner {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-2) var(--sp-2) var(--sp-4);
    border-radius: var(--r-pill);
    margin-inline: auto;
    max-width: calc(var(--container-wide) - var(--sp-4));
    /* box-shadow убран из перехода: тень не композируется, её анимация
       перерисовывала размытый регион хедера на каждом кадре скролла. */
    transition: background-color var(--dur-med) var(--ease-standard);
  }

  /* When scrolled, swap to denser tint and stronger blur via shared class. */
  .header.is-scrolled .header__inner {
    background-color: var(--glass-tint-ultra);
    box-shadow: var(--shadow-2);
  }

  .header__brand {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-18);
    letter-spacing: var(--ls-display);
    line-height: 1;
    color: var(--text);
    padding: var(--sp-2) var(--sp-3);
    flex-shrink: 0;
    min-width: 0;
  }

  .header__brand-text {
    display: inline-block;
    max-width: 48vw;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .header__nav {
    position: relative;
    display: none;
    flex: 1;
    gap: var(--sp-2);
    align-items: center;
    justify-content: center;
  }

  .header__indicator {
    position: absolute;
    bottom: 4px;
    left: var(--ind-left, 0);
    width: var(--ind-width, 0);
    height: 2px;
    background: var(--text);
    border-radius: 1px;
    opacity: var(--ind-opacity, 0);
    transition:
      left var(--dur-slow) var(--ease-soft),
      width var(--dur-slow) var(--ease-soft),
      opacity var(--dur-med) var(--ease-standard);
    pointer-events: none;
  }

  .header__nav-link {
    position: relative;
    font-size: var(--fs-14);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-snug);
    color: var(--text-secondary);
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--r-pill);
    transition: color var(--dur-fast) var(--ease-standard);
    min-height: var(--tap-min);
    display: inline-flex;
    align-items: center;
  }

  .header__nav-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .header__nav-link.is-active {
    color: var(--text);
    font-weight: var(--fw-semibold);
  }

  .header__actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    flex-shrink: 0;
  }

  .header__menu {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: var(--tap-min);
    height: var(--tap-min);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 72%, transparent);
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }

  .header__menu:hover {
    border-color: var(--border-hover);
    background: var(--surface-2);
  }

  .header__menu-icon {
    grid-area: 1 / 1;
    transition:
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .header__menu-icon--close {
    opacity: 0;
    transform: scale(0.82) rotate(-20deg);
  }

  .header.is-menu-open .header__menu-icon--open {
    opacity: 0;
    transform: scale(0.82) rotate(20deg);
  }

  .header.is-menu-open .header__menu-icon--close {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  :global(.lang-toggle) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--tap-min);
    min-height: var(--tap-min);
    padding-inline: var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-wide);
    color: var(--text);
    text-transform: uppercase;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background-color var(--dur-fast) var(--ease-standard);
  }

  :global(.lang-toggle:hover) {
    border-color: var(--border-hover);
    background: var(--surface-2);
    opacity: 1;
  }

  @media (max-width: 767px) {
    .header__inner {
      position: relative;
      width: calc(100% - (var(--sp-4) * 2));
      padding-inline: var(--sp-3);
      box-shadow: var(--shadow-2);
    }

    .header__nav {
      position: absolute;
      top: calc(100% + var(--sp-2));
      left: 0;
      right: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--sp-1);
      justify-content: stretch;
      padding: var(--sp-2);
      border: var(--bw-thin) solid var(--glass-edge);
      border-radius: var(--r-xl);
      background-color: var(--glass-tint-ultra);
      -webkit-backdrop-filter: blur(var(--glass-blur-strong)) saturate(var(--glass-saturate));
      backdrop-filter: blur(var(--glass-blur-strong)) saturate(var(--glass-saturate));
      box-shadow: var(--shadow-3);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px) scale(0.98);
      transform-origin: top;
      transition:
        opacity var(--dur-fast) var(--ease-standard),
        visibility var(--dur-fast) var(--ease-standard),
        transform var(--dur-fast) var(--ease-soft);
      pointer-events: none;
    }

    .header.is-menu-open .header__nav {
      opacity: 1;
      visibility: visible;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .header__indicator {
      display: none;
    }

    .header__nav-link {
      justify-content: space-between;
      width: 100%;
      padding: var(--sp-3) var(--sp-4);
      color: var(--text);
      background: color-mix(in srgb, var(--surface) 68%, transparent);
      border: var(--bw-thin) solid transparent;
    }

    .header__nav-link::after {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
      opacity: 0.28;
    }

    .header__nav-link.is-active {
      border-color: var(--border-hover);
      background: var(--surface-2);
    }
  }

  @media (min-width: 768px) {
    .header {
      padding-block: var(--sp-3);
    }

    .header__inner {
      gap: var(--sp-6);
      padding: var(--sp-2) var(--sp-3) var(--sp-2) var(--sp-5);
    }

    .header__nav {
      display: flex;
    }

    .header__brand-text {
      max-width: none;
    }

    .header__menu {
      display: none;
    }
  }

  /* Тач-отклик: на desktop фидбэк даёт :hover, на тач :active при касании
     (nav-ссылки в мобильном меню, переключатель языка, кнопка-гамбургер).
     Отдельная мобильная реализация; desktop (hover: hover) этого не видит. */
  @media (hover: none) {
    .header__nav-link:active {
      color: var(--text);
      background: color-mix(in srgb, var(--surface) 82%, transparent);
    }

    .header__menu:active,
    :global(.lang-toggle:active) {
      border-color: var(--border-hover);
      background: var(--surface-2);
    }
  }
</style>

<script>
  /**
   * Header behaviour: active-section underline + scrolled state.
   *
   * Active highlight strategy:
   *   1. IntersectionObserver наблюдает за всеми секциями (#about, #stack, ...).
   *   2. Из видимых выбираем ту, у которой наибольший intersectionRatio.
   *   3. Если ни одна не видна, снимаем активность со всех ссылок.
   *   4. Скользящий underline позиционируется через CSS-переменные на nav-родителе.
   *      Это даёт один плавный transition вместо отдельных tail-dot'ов.
   *
   * Scrolled state: при scrollY > 24 на <header> ставится `.is-scrolled`,
   * inner pill переключается на ultra-tint + сильный blur.
   */
  const SECTIONS = ["about", "stack", "projects", "timeline", "contact"];

  function updateIndicator(nav: HTMLElement, active: HTMLElement | null) {
    if (!active) {
      nav.style.setProperty("--ind-opacity", "0");
      return;
    }
    const navRect = nav.getBoundingClientRect();
    const linkRect = active.getBoundingClientRect();
    nav.style.setProperty("--ind-left", `${linkRect.left - navRect.left}px`);
    nav.style.setProperty("--ind-width", `${linkRect.width}px`);
    nav.style.setProperty("--ind-opacity", "1");
  }

  function setActive(section: string | null) {
    const nav = document.querySelector<HTMLElement>("[data-nav]");
    if (!nav) return;
    const links = nav.querySelectorAll<HTMLAnchorElement>("[data-section]");
    let active: HTMLAnchorElement | null = null;
    links.forEach((link) => {
      const isActive = link.dataset.section === section;
      link.classList.toggle("is-active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "true");
        active = link;
      } else {
        link.removeAttribute("aria-current");
      }
    });
    updateIndicator(nav, active);
  }

  function initHeaderNav() {
    const nav = document.querySelector<HTMLElement>("[data-nav]");
    if (!nav) return;

    const sectionEls = SECTIONS.map((id) => document.getElementById(id)).filter(
      (el): el is HTMLElement => el !== null,
    );
    if (sectionEls.length === 0) return;

    const visible = new Map<string, number>();

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          if (entry.isIntersecting) {
            visible.set(id, entry.intersectionRatio);
          } else {
            visible.delete(id);
          }
        });

        if (visible.size === 0) {
          setActive(null);
          return;
        }

        let topId: string | null = null;
        let topRatio = -1;
        visible.forEach((ratio, id) => {
          if (ratio > topRatio) {
            topRatio = ratio;
            topId = id;
          }
        });
        setActive(topId);
      },
      {
        rootMargin: "-40% 0px -40% 0px",
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );

    sectionEls.forEach((el) => io.observe(el));

    nav.querySelectorAll<HTMLAnchorElement>("[data-section]").forEach((link) => {
      link.addEventListener("click", () => {
        const id = link.dataset.section ?? null;
        setActive(id);
      });
    });

    // Reposition the underline when fonts or viewport shift it. rAF-обёртка
    // батчит чтения getBoundingClientRect в фазу после layout (без forced reflow).
    const resizeObserver = new ResizeObserver(() => {
      requestAnimationFrame(() => {
        const current = nav.querySelector<HTMLAnchorElement>(".header__nav-link.is-active");
        updateIndicator(nav, current);
      });
    });
    resizeObserver.observe(nav);
  }

  function initHeaderScrolled() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    if (!header) return;
    // Guard: трогаем DOM только при смене состояния, а не на каждый scroll-тик.
    let scrolled = false;
    const apply = () => {
      const next = window.scrollY > 24;
      if (next === scrolled) return;
      scrolled = next;
      header.classList.toggle("is-scrolled", next);
    };
    apply();
    window.addEventListener("scroll", apply, { passive: true });
  }

  function initMobileMenu() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    const nav = document.querySelector<HTMLElement>("[data-nav]");
    const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    if (!header || !nav || !toggle) return;

    const setOpen = (open: boolean) => {
      header.classList.toggle("is-menu-open", open);
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute(
        "aria-label",
        open
          ? (toggle.dataset.labelClose ?? "Close menu")
          : (toggle.dataset.labelOpen ?? "Open menu"),
      );
    };

    toggle.addEventListener("click", () => {
      setOpen(!header.classList.contains("is-menu-open"));
    });

    nav.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("click", (event) => {
      if (!header.classList.contains("is-menu-open")) return;
      const target = event.target as Node | null;
      if (target && header.contains(target)) return;
      setOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });

    window.matchMedia("(min-width: 768px)").addEventListener("change", (event) => {
      if (event.matches) setOpen(false);
    });
  }

  function init() {
    initHeaderNav();
    initHeaderScrolled();
    initMobileMenu();
    initLanguageToggle();
  }

  function initLanguageToggle() {
    const toggle = document.querySelector<HTMLAnchorElement>("[data-lang-toggle]");
    if (!toggle) return;
    const current = toggle.dataset.current === "en" ? "en" : "ru";
    const alternate = toggle.dataset.alternate === "en" ? "en" : "ru";

    try {
      const saved = localStorage.getItem("dc-locale");
      if (saved === "ru" || saved === "en") {
        if (saved !== current) window.location.replace(toggle.href);
      } else {
        const nav = (navigator.languages?.[0] || navigator.language || "ru").toLowerCase();
        const detected = nav.startsWith("ru") ? "ru" : "en";
        localStorage.setItem("dc-locale", detected);
        if (detected !== current) window.location.replace(toggle.href);
      }
    } catch {
      /* localStorage may be unavailable in hardened browsers. */
    }

    toggle.addEventListener("click", (e) => {
      e.preventDefault();
      try {
        localStorage.setItem("dc-locale", alternate);
      } catch {
        /* noop */
      }
      window.location.assign(toggle.href);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
