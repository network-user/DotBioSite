---
/**
 * Icon.astro — stroke-only иконки (порт DotSound).
 *
 * Все иконки рисуются в одной системе: 24×24 view-box, currentColor, без
 * заливки, толщина 1.6px, скруглённые концы. Эмодзи и Unicode-глифы в UI
 * запрещены — только через этот компонент.
 *
 * Добавление новой иконки: дописать ветку switch ниже.
 */

type IconName =
  | "arrow-right"
  | "arrow-down"
  | "external"
  | "github"
  | "telegram"
  | "linkedin"
  | "x"
  | "vk"
  | "mail"
  | "copy"
  | "check"
  | "code"
  | "spark"
  | "rocket"
  | "stack"
  | "user"
  | "globe"
  | "chevron-right"
  | "dot";

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
  "aria-label"?: string;
}

const {
  name,
  size = 24,
  strokeWidth = 1.6,
  class: className = "",
  "aria-label": ariaLabel,
} = Astro.props;

const hidden = ariaLabel ? "false" : "true";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`icon icon--${name} ${className}`}
  aria-hidden={hidden}
  aria-label={ariaLabel}
  role={ariaLabel ? "img" : undefined}
>
  {
    name === "arrow-right" && (
      <>
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="13 6 19 12 13 18" />
      </>
    )
  }
  {
    name === "arrow-down" && (
      <>
        <line x1="12" y1="5" x2="12" y2="19" />
        <polyline points="6 13 12 19 18 13" />
      </>
    )
  }
  {name === "chevron-right" && <polyline points="9 6 15 12 9 18" />}
  {
    name === "external" && (
      <>
        <path d="M14 4h6v6" />
        <path d="M20 4 11 13" />
        <path d="M19 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h5" />
      </>
    )
  }
  {
    name === "github" && (
      <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.36 1.09 2.94.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.5 9.5 0 0 1 12 6.8c.85 0 1.7.12 2.5.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z" />
    )
  }
  {name === "telegram" && <path d="m22 3-9 18-3-8-8-3 20-7Z" />}
  {
    name === "linkedin" && (
      <>
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 1 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
        <rect x="2" y="9" width="4" height="12" />
        <circle cx="4" cy="4" r="2" />
      </>
    )
  }
  {
    name === "x" && (
      <>
        <path d="M4 4l16 16" />
        <path d="M20 4 4 20" />
      </>
    )
  }
  {
    name === "vk" && (
      <path d="M2 7h4a14 14 0 0 0 5 7c1 0 1-1 1-2v-5h4v3c0 1 1 2 2 2a14 14 0 0 0 4-5h2a16 16 0 0 1-4 6c1 1 2 2 3 4l1 2h-3c-1 0-2-1-3-2l-2-2v3h-4a14 14 0 0 1-10-11z" />
    )
  }
  {
    name === "mail" && (
      <>
        <rect x="3" y="5" width="18" height="14" rx="2" />
        <polyline points="3 7 12 13 21 7" />
      </>
    )
  }
  {
    name === "copy" && (
      <>
        <rect x="8" y="8" width="11" height="11" rx="2" />
        <path d="M5 16H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </>
    )
  }
  {name === "check" && <polyline points="20 6 9 17 4 12" />}
  {
    name === "code" && (
      <>
        <polyline points="16 18 22 12 16 6" />
        <polyline points="8 6 2 12 8 18" />
      </>
    )
  }
  {
    name === "spark" && (
      <>
        <path d="M12 2v6" />
        <path d="M12 16v6" />
        <path d="M2 12h6" />
        <path d="M16 12h6" />
        <path d="m4.9 4.9 4.2 4.2" />
        <path d="m14.9 14.9 4.2 4.2" />
        <path d="m19.1 4.9-4.2 4.2" />
        <path d="m9.1 14.9-4.2 4.2" />
      </>
    )
  }
  {
    name === "rocket" && (
      <>
        <path d="M5 13a8 8 0 0 1 14-8 8 8 0 0 1-8 14" />
        <path d="M5 13c-2 1-3 5-3 5s4-1 5-3" />
        <circle cx="14" cy="10" r="1.5" />
      </>
    )
  }
  {
    name === "stack" && (
      <>
        <polyline points="12 3 22 9 12 15 2 9 12 3" />
        <polyline points="2 14 12 20 22 14" />
        <polyline points="4 18 12 22 20 18" />
      </>
    )
  }
  {
    name === "user" && (
      <>
        <circle cx="12" cy="8" r="4" />
        <path d="M4 21a8 8 0 0 1 16 0" />
      </>
    )
  }
  {
    name === "globe" && (
      <>
        <circle cx="12" cy="12" r="10" />
        <path d="M2 12h20" />
        <path d="M12 2a14 14 0 0 1 0 20A14 14 0 0 1 12 2z" />
      </>
    )
  }
  {name === "dot" && <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />}
</svg>

<style>
  .icon {
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }
</style>
