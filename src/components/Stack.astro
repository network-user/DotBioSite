---
import { useTranslations, type Locale } from "../lib/i18n";
import SectionHeader from "./SectionHeader.astro";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

type StackIcon =
  | "stack"
  | "code"
  | "rocket"
  | "spark"
  | "telegram"
  | "link"
  | "database"
  | "shield"
  | "activity";

interface StackGroup {
  id: string;
  icon: StackIcon;
  items: ReadonlyArray<string>;
  /**
   * Сколько первых чипов — «ядро» группы, которое видно всегда (только для
   * primary-групп). Остальные чипы и непоказанные группы целиком раскрываются
   * по кнопке. Порядок в `items` подобран так, что ядро — самое узнаваемое и
   * весомое; нишевое уходит в хвост.
   */
  core?: number;
}

/**
 * Стек жёстко не привязан к i18n — это технические термины,
 * читаются одинаково на обоих языках. Иконки берутся из общего набора
 * Icon.astro (24×24 stroke).
 */
const groups: ReadonlyArray<StackGroup> = [
  {
    id: "backend",
    icon: "stack",
    core: 7,
    items: [
      "Python 3.12",
      "FastAPI",
      "NestJS 10",
      "Django / DRF",
      "SQLAlchemy 2",
      "Pydantic",
      "asyncio",
      "Celery",
      "Taskiq",
      "Alembic",
      "httpx",
      "aiohttp",
      "Starlette",
      "Uvicorn",
      "Litestar",
      "pydantic-settings",
      "aiohttp-socks",
      "APScheduler",
    ],
  },
  {
    id: "frontend",
    icon: "code",
    core: 7,
    items: [
      "TypeScript",
      "React 18",
      "Astro 4",
      "Vite 5",
      "Tailwind",
      "Pyodide (WASM)",
      "Zod",
      "TanStack Router",
      "Monaco editor",
      "Framer Motion",
      "MDX",
      "Radix UI",
      "Shiki",
      "TanStack Virtual",
      "Web Workers",
      "i18next",
      "JavaScript",
      "Bootstrap",
      "Jinja2",
    ],
  },
  {
    id: "ml",
    icon: "spark",
    core: 7,
    items: [
      "PyTorch",
      "faster-whisper",
      "Demucs",
      "Claude Code",
      "Cursor",
      "Codex",
      "Antigravity",
      "ComfyUI",
      "YOLO",
      "n8n",
      "Pandas",
    ],
  },
  {
    id: "data",
    icon: "database",
    items: [
      "PostgreSQL 16",
      "Redis",
      "Elasticsearch 8",
      "MinIO / S3",
      "SQLite",
      "asyncpg",
      "psycopg 3",
      "IndexedDB / Dexie",
    ],
  },
  {
    id: "devops",
    icon: "rocket",
    items: [
      "Docker",
      "Docker Compose",
      "GitHub Actions",
      "GitLab CI/CD",
      "ArgoCD",
      "Nginx",
      "Cloudflare Pages",
      "VPS",
      "Poetry",
      "pnpm",
      "Turborepo",
      "Pytest",
      "Vitest",
      "testcontainers",
      "mypy",
      "Ruff",
      "ESLint",
      "Prettier",
      "FFmpeg",
    ],
  },
  {
    id: "observability",
    icon: "activity",
    items: ["Prometheus", "OpenTelemetry", "Grafana", "Loki", "Tempo", "Sentry", "structlog"],
  },
  {
    id: "security",
    icon: "shield",
    items: ["JWT", "TOTP / 2FA", "argon2id", "bcrypt", "HMAC", "Fernet", "AES backups", "ClamAV"],
  },
  {
    id: "mobile",
    icon: "telegram",
    items: ["aiogram 3", "Telegram Bot API", "Telegram Mini Apps", "PWA"],
  },
  {
    id: "web3",
    icon: "link",
    items: ["Web3.py", "Solidity", "Truffle / Hardhat", "Ethereum"],
  },
];

/**
 * Свёрнуто видно только ядро трёх primary-групп (Backend / Frontend / AI · ML):
 * сразу читается фокус, без свалки чипов. По кнопке-счётчику раскрывается весь
 * арсенал — хвосты primary-групп дорисовываются в тех же карточках, плюс
 * появляются остальные группы. Механика — чистый CSS (checkbox + `~`): без JS,
 * без мигания при загрузке, доступно с клавиатуры.
 */
const PRIMARY_COUNT = 3;

/** Для каждой группы: индекс, флаг primary и размер видимого ядра. */
const layout = groups.map((g, i) => {
  const isPrimary = i < PRIMARY_COUNT;
  const coreCount = isPrimary ? (g.core ?? g.items.length) : g.items.length;
  return { group: g, isPrimary, coreCount };
});

/** Сколько чипов спрятано в свёрнутом виде — это число выносим на кнопку. */
const hiddenCount = layout.reduce(
  (sum, { group, isPrimary, coreCount }) =>
    sum + (isPrimary ? Math.max(0, group.items.length - coreCount) : group.items.length),
  0,
);
---

<section class="section stack" id="stack" aria-labelledby="stack-title">
  <div class="container stack__inner">
    <SectionHeader
      id="stack-title"
      kicker={t("stack.kicker")}
      title={t("stack.title")}
      lede={t("stack.lede")}
    />

    <input type="checkbox" id="stack-expand" class="stack__expand" aria-controls="stack-grid stack-extras" />

    <div class="stack__grid" id="stack-grid" data-stack-grid>
      {
        layout
          .filter(({ isPrimary }) => isPrimary)
          .map(({ group, coreCount }, i) => {
            const label = t(`stack.categories.${group.id}`);
            const delay = String(i * 80);
            return (
              <article
                class="stack__group glass glass--hover"
                data-stack-card
                data-warp
                data-touch-live
                data-reveal
                data-reveal-delay={delay}
              >
                <span class="stack__sheen" aria-hidden="true" />
                <span class="stack__bar" aria-hidden="true" />
                <header class="stack__group-header">
                  <Icon name={group.icon} size={20} class="stack__icon" />
                  <p class="caption">{label}</p>
                </header>
                <ul class="stack__chips">
                  {group.items.map((it, j) => {
                    const extra = j >= coreCount;
                    return <li class={`stack__chip${extra ? " stack__chip--extra" : ""}`}>{it}</li>;
                  })}
                </ul>
              </article>
            );
          })
      }
    </div>

    {/* height:0 + overflow:visible — карточки плавают ниже секции, не сдвигая Projects */}
    <div class="stack__extras-wrap" id="stack-extras">
      <div class="stack__extras-grid">
        {
          layout
            .filter(({ isPrimary }) => !isPrimary)
            .map(({ group }) => {
              const label = t(`stack.categories.${group.id}`);
              return (
                <article class="stack__group stack__group--extra glass" data-stack-card data-warp>
                  <span class="stack__sheen" aria-hidden="true" />
                  <span class="stack__bar" aria-hidden="true" />
                  <header class="stack__group-header">
                    <Icon name={group.icon} size={20} class="stack__icon" />
                    <p class="caption">{label}</p>
                  </header>
                  <ul class="stack__chips">
                    {group.items.map((it) => (
                      <li class="stack__chip">{it}</li>
                    ))}
                  </ul>
                </article>
              );
            })
        }
      </div>
    </div>

    <label class="stack__more-toggle" for="stack-expand" data-warp>
      <span class="stack__more-text stack__more-text--show">
        {t("stack.morePrefix")}
        {hiddenCount}
        {t("stack.moreSuffix")}
      </span>
      <span class="stack__more-text stack__more-text--hide">{t("stack.less")}</span>
      <Icon name="chevron-right" size={16} class="stack__more-chevron" />
    </label>
  </div>
</section>

<script>
  // Scoped pointer-follow sheen for the stack cards.
  // - Only on fine pointers and when motion is allowed.
  // - One rAF batches the per-card CSS-var write; never touches layout/filter.
  // - Listeners are scoped per card (pointermove/pointerleave) and torn down on
  //   pagehide so client-side navigations don't leak them.
  const fine = window.matchMedia("(pointer: fine)");
  const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (fine.matches && motionOk) {
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-stack-card]"));
    const cleanups: Array<() => void> = [];

    cards.forEach((card) => {
      let rafId: number | null = null;
      let px = 0;
      let py = 0;

      const apply = () => {
        rafId = null;
        card.style.setProperty("--mx", `${px}px`);
        card.style.setProperty("--my", `${py}px`);
      };

      const onMove = (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        px = e.clientX - r.left;
        py = e.clientY - r.top;
        if (rafId === null) rafId = requestAnimationFrame(apply);
      };

      const onLeave = () => {
        if (rafId !== null) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      };

      card.addEventListener("pointermove", onMove, { passive: true });
      card.addEventListener("pointerleave", onLeave, { passive: true });

      cleanups.push(() => {
        if (rafId !== null) cancelAnimationFrame(rafId);
        card.removeEventListener("pointermove", onMove);
        card.removeEventListener("pointerleave", onLeave);
      });
    });

    window.addEventListener("pagehide", () => cleanups.forEach((fn) => fn()), { once: true });
  }
</script>

<style>
  .stack__grid {
    display: grid;
    gap: var(--sp-4);
    grid-template-columns: 1fr;
    /* Drift к курсору снят: чтение --ptr в transform всей сетки + каждой карточки
       форсило page-wide style recalc на каждый mousemove (главный источник лага
       этой секции). Сетка стоит ровно; «жизнь» даёт hover-подъём и sweep-полоса. */
  }

  .stack__group {
    position: relative;
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    overflow: hidden;
    /* Counter-drift к курсору снят (см. .stack__grid). Hover-подъём целиком на
       .glass--hover (translateY + тень) — он чисто hover-driven, без --ptr. */
  }

  /* Pointer-follow sheen: a soft radial light that tracks the cursor inside the
     card. Positioned via transform (translate of an oversized layer) and faded
     with opacity only — no filter/box-shadow churn. --mx/--my (px, card-local)
     are written by a rAF-batched scoped listener; defaults keep it centered. */
  .stack__sheen {
    position: absolute;
    /* Anchored at the card's top-left; its own center is pulled onto the pointer
       via -50% self-offset, then moved by --mx/--my (card-local px). */
    top: 0;
    left: 0;
    width: 280px;
    height: 280px;
    margin: -140px 0 0 -140px;
    pointer-events: none;
    z-index: 1;
    border-radius: 50%;
    opacity: 0;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--project-accent) 22%, transparent) 0%,
      transparent 68%
    );
    transform: translate3d(var(--mx, 140px), var(--my, 80px), 0);
    /* Softer, slower fade-in so the light "arrives" on the card rather than
       snapping on. Dimmer peak (0.55 -> 0.4) keeps it ambient. */
    transition: opacity var(--dur-slow) var(--ease-soft);
  }

  .stack__group:hover .stack__sheen {
    opacity: 0.4;
  }

  .stack__bar {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--glass-edge-bright) 30%,
      var(--glass-edge-bright) 70%,
      transparent
    );
    /* Slow the sweep so the eye can track the light crossing the card edge
       instead of catching only a flash. */
    transition: transform var(--dur-glacial) var(--ease-soft);
    pointer-events: none;
    z-index: 2;
  }

  .stack__group:hover .stack__bar {
    transform: translateX(100%);
  }

  .stack__group-header {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-muted);
  }

  .stack__icon {
    color: var(--text-secondary);
  }

  .stack__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .stack__chip {
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    background: var(--surface);
    letter-spacing: var(--ls-snug);
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-soft);
  }

  .stack__chip:hover {
    color: var(--text);
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  /* Disclosure: свёрнуто видно только ядро primary-групп. Раскрытие — чистый
     CSS через скрытый чекбокс + общий комбинатор `~`: без JS, без FOUC,
     фокус с клавиатуры сохранён. Хвосты ядра и доп.группы помечены `--extra`. */
  .stack__expand {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* Extra chips inside primary cards: hidden until expanded */
  .stack__chip--extra {
    display: none;
  }

  /* Extra group cards wrapper: height 0 so it doesn't push down the Projects
     section. overflow: visible lets ghost card outlines float below into the
     next section as an overlay. z-index: 1 keeps them above the next section's
     content (which has no explicit z-index). */
  .stack__extras-wrap {
    height: 0;
    overflow: visible;
    position: relative;
    z-index: 1;
    pointer-events: none;
  }

  .stack__extras-grid {
    display: grid;
    gap: var(--sp-4);
    grid-template-columns: 1fr;
    margin-top: var(--sp-4);
  }

  /* Ghost extra cards: visible border from .glass, transparent fill, no content */
  .stack__group--extra {
    background-color: transparent;
    pointer-events: none;
  }

  .stack__group--extra::before {
    opacity: 0;
  }

  .stack__group--extra .stack__group-header,
  .stack__group--extra .stack__chips {
    opacity: 0;
  }

  /* Expanded: extras-wrap takes natural height (pushes Projects down),
     cards animate in with content */
  .stack__expand:checked ~ .stack__grid .stack__chip--extra {
    display: block;
    animation: stack-more-in var(--dur-slow) var(--ease-soft);
  }

  .stack__expand:checked ~ .stack__extras-wrap {
    height: auto;
    pointer-events: auto;
    z-index: auto;
  }

  .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra {
    background-color: var(--glass-tint-frost);
    pointer-events: auto;
    animation: stack-more-in var(--dur-slow) var(--ease-soft);
  }

  .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra::before {
    opacity: 0.9;
  }

  .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra .stack__group-header,
  .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra .stack__chips {
    opacity: 1;
  }

  .stack__more-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    width: fit-content;
    margin: var(--sp-5) auto 0;
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    font-size: var(--fs-13);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-snug);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .stack__more-toggle:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  .stack__expand:focus-visible ~ .stack__more-toggle {
    outline: var(--bw-thin) solid var(--border-hover);
    outline-offset: 2px;
  }

  .stack__more-text--hide {
    display: none;
  }

  .stack__expand:checked ~ .stack__more-toggle .stack__more-text--show {
    display: none;
  }

  .stack__expand:checked ~ .stack__more-toggle .stack__more-text--hide {
    display: inline;
  }

  .stack__more-chevron {
    color: var(--text-muted);
    transition: transform var(--dur-fast) var(--ease-soft);
  }

  .stack__expand:checked ~ .stack__more-toggle .stack__more-chevron {
    transform: rotate(90deg);
  }

  @keyframes stack-more-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    /* Kill all ambient/pointer motion: no sweep, no drift, no sheen, no chip lift. */
    .stack__bar,
    .stack__sheen {
      transition: none;
    }

    .stack__grid,
    .stack__group,
    .stack__group.glass--hover:hover {
      transform: none;
      transition: none;
      will-change: auto;
    }

    .stack__sheen {
      display: none;
    }

    .stack__chip:hover {
      transform: none;
    }

    .stack__more-chevron {
      transition: none;
    }

    .stack__expand:checked ~ .stack__grid .stack__chip--extra,
    .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra,
    .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra .stack__group-header,
    .stack__expand:checked ~ .stack__extras-wrap .stack__group--extra .stack__chips {
      animation: none;
    }
  }

  /* Touch / no precise pointer: the parallax drift and the cursor-follow sheen
     have no meaning. Drop them; keep the static layout and the sweep bar. */
  @media (pointer: coarse) {
    .stack__grid,
    .stack__group {
      transform: none;
      will-change: auto;
    }

    .stack__sheen {
      display: none;
    }
  }

  /* Тач-эквивалент hover: обводку даёт общий хук .glass--hover.is-touch-active
     (glass.css), а здесь — запуск sweep-полосы, когда карточка попадает в центр
     вьюпорта при прокрутке (на desktop её запускает :hover). Отдельная мобильная
     реализация; desktop (hover: hover) этого правила не видит. */
  @media (hover: none) {
    .stack__group.is-touch-active .stack__bar {
      transform: translateX(100%);
    }
  }

  @media (min-width: 720px) {
    .stack__grid,
    .stack__extras-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stack__group {
      padding: var(--sp-5) var(--sp-6);
    }
  }

  @media (min-width: 1100px) {
    .stack__grid,
    .stack__extras-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
