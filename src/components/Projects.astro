---
import { useTranslations, type Locale } from "../lib/i18n";
import { projects, infraProjects } from "../lib/projects";
import SectionHeader from "./SectionHeader.astro";
import ProjectCard from "./ProjectCard.astro";
import InfraCard from "./InfraCard.astro";
import YearStrip from "./illustration/YearStrip.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const visible = projects.filter((p) => !p.comingSoon);
const infra = infraProjects.filter((p) => !p.comingSoon);
const years = visible.map((p) => p.year).filter((y): y is number => typeof y === "number");
---

<section class="section projects" id="projects" aria-labelledby="projects-title">
  <div class="container projects__inner">
    <SectionHeader
      id="projects-title"
      kicker={t("projects.kicker")}
      title={t("projects.title")}
      lede={t("projects.lede")}
    />

    <div class="projects__grid">
      {visible.map((p, i) => <ProjectCard project={p} locale={locale} index={i} />)}
    </div>

    {
      infra.length > 0 && (
        <div class="projects__ecosystem" data-reveal aria-labelledby="ecosystem-title">
          <div class="projects__ecosystem-head">
            <span class="projects__ecosystem-line" aria-hidden="true" />
            <h3 id="ecosystem-title" class="projects__ecosystem-title">
              {t("projects.ecosystem.title")}
            </h3>
            <p class="projects__ecosystem-lede caption">{t("projects.ecosystem.lede")}</p>
          </div>
          <div class="projects__infra-grid">
            {infra.map((p, i) => (
              <InfraCard project={p} locale={locale} index={i} />
            ))}
          </div>
        </div>
      )
    }

    {
      years.length > 1 && (
        <div class="projects__year-strip" data-reveal>
          <YearStrip years={years} />
          <p class="projects__hint caption">{t("projects.scrollHint")}</p>
        </div>
      )
    }
  </div>
</section>

<script>
  /**
   * Pointer tilt + sheen for [data-tilt] project cards.
   *
   * Sets four custom properties the card CSS already consumes:
   *   --tilt-x / --tilt-y  → subtle 3D rotation of the whole glass pane
   *   --mx / --my          → position of the pointer-following sheen highlight
   *
   * Transform-only, rAF-batched, one shared listener. Skipped entirely on
   * touch (coarse pointer) and when the user prefers reduced motion.
   */
  const MAX_TILT = 5; // degrees

  function initCardTilt() {
    const fine = window.matchMedia("(pointer: fine)").matches;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!fine || reduced) return;

    // rect карт устаревает при скролле — общий флаг ставим в scroll-хендлере без
    // чтения layout (без forced reflow); rect пересчитается на следующем move.
    let dirty = false;
    window.addEventListener(
      "scroll",
      () => {
        dirty = true;
      },
      { passive: true },
    );

    document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((card) => {
      let rect: DOMRect | null = null;
      let raf: number | null = null;
      let tx = 0; // target rotateY
      let ty = 0; // target rotateX
      let cx = 0; // current rotateY (лерп)
      let cy = 0; // current rotateX
      let mx = 50; // блик X (%)
      let my = 0; // блик Y (%)

      const tick = () => {
        cx += (tx - cx) * 0.22;
        cy += (ty - cy) * 0.22;
        card.style.setProperty("--tilt-y", `${cx.toFixed(2)}deg`);
        card.style.setProperty("--tilt-x", `${cy.toFixed(2)}deg`);
        card.style.setProperty("--mx", `${mx.toFixed(1)}%`);
        card.style.setProperty("--my", `${my.toFixed(1)}%`);
        if (Math.abs(tx - cx) > 0.01 || Math.abs(ty - cy) > 0.01) {
          raf = requestAnimationFrame(tick);
        } else {
          raf = null;
        }
      };
      const ensure = () => {
        if (raf === null) raf = requestAnimationFrame(tick);
      };

      // rect кешируется на вход в карту, а НЕ читается на каждое движение мыши
      // (раньше это был forced synchronous layout в горячем пути → дёрганый отклик).
      card.addEventListener("pointerenter", () => {
        rect = card.getBoundingClientRect();
      });

      card.addEventListener(
        "pointermove",
        (event) => {
          if (!rect || dirty) {
            rect = card.getBoundingClientRect();
            dirty = false;
          }
          const nx = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
          const ny = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
          tx = (nx - 0.5) * 2 * MAX_TILT;
          ty = (0.5 - ny) * 2 * MAX_TILT;
          mx = nx * 100;
          my = ny * 100;
          ensure();
        },
        { passive: true },
      );

      card.addEventListener("pointerleave", () => {
        tx = 0;
        ty = 0;
        mx = 50;
        my = 0;
        ensure();
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCardTilt, { once: true });
  } else {
    initCardTilt();
  }

  /**
   * Align the "highlights" row across neighboring cards in the same grid row.
   *
   * Descriptions vary in length, so `.project-card__desc` naturally ends at a
   * different height per card, pushing everything below it (highlights/stack/
   * actions) out of sync with the card next to it. CSS alone can't match a
   * sibling's height without subgrid (fragile here: the grid mixes a
   * full-width featured card with a variable-length 2-column list). Instead,
   * measure `.project-card__desc` per visual row (cards sharing the same top
   * offset) and floor them all to the tallest one in that row.
   */
  function equalizeDescHeights() {
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>(".project-card:not(.project-card--featured)"),
    );
    if (cards.length < 2) return;

    // Reset first: a resize can change the column count (mobile stacks to 1),
    // and a stale min-height from a wider layout would leave a dead gap.
    const descs = cards
      .map((card) => card.querySelector<HTMLElement>(".project-card__desc"))
      .filter((el): el is HTMLElement => el !== null);
    descs.forEach((el) => el.style.removeProperty("min-height"));

    const rows = new Map<number, HTMLElement[]>();
    cards.forEach((card) => {
      const top = Math.round(card.getBoundingClientRect().top);
      const bucket = rows.get(top);
      if (bucket) bucket.push(card);
      else rows.set(top, [card]);
    });

    rows.forEach((rowCards) => {
      if (rowCards.length < 2) return; // alone in its row (mobile stack, or an odd one out) — nothing to match
      const rowDescs = rowCards
        .map((card) => card.querySelector<HTMLElement>(".project-card__desc"))
        .filter((el): el is HTMLElement => el !== null);
      if (rowDescs.length < 2) return;
      const maxHeight = Math.max(...rowDescs.map((el) => el.getBoundingClientRect().height));
      rowDescs.forEach((el) => {
        el.style.minHeight = `${maxHeight}px`;
      });
    });
  }

  function scheduleEqualize() {
    requestAnimationFrame(equalizeDescHeights);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleEqualize, { once: true });
  } else {
    scheduleEqualize();
  }
  document.fonts?.ready.then(scheduleEqualize);

  let resizeTimer: number | undefined;
  window.addEventListener(
    "resize",
    () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(scheduleEqualize, 150);
    },
    { passive: true },
  );
</script>

<style>
  .projects {
    overflow: hidden;
  }

  .projects::before {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: var(--sp-8);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-hover), transparent);
    opacity: 0.52;
  }

  .projects__inner {
    position: relative;
    z-index: 1;
  }

  .projects__grid {
    position: relative;
    display: grid;
    gap: var(--sp-4);
    grid-template-columns: 1fr;
  }

  .projects__year-strip {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .projects__hint {
    text-align: center;
    color: var(--text-faint);
  }

  /* ---------- Ecosystem / infra tier ---------- */
  .projects__ecosystem {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    margin-block-start: var(--sp-7);
  }

  .projects__ecosystem-head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  /* Тонкий разделитель — отделяет вторичный тир от продуктовой сетки. */
  .projects__ecosystem-line {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, var(--border-hover), transparent);
    margin-block-end: var(--sp-2);
  }

  .projects__ecosystem-title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    font-size: var(--fs-22);
    color: var(--text);
  }

  .projects__ecosystem-lede {
    color: var(--text-secondary);
    max-width: 60ch;
  }

  .projects__infra-grid {
    display: grid;
    gap: var(--sp-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .projects__grid {
      gap: var(--sp-7);
      grid-template-columns: repeat(2, 1fr);
    }

    .projects__ecosystem {
      margin-block-start: var(--sp-9);
    }

    .projects__infra-grid {
      gap: var(--sp-5);
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    }
  }
</style>
