---
import { useTranslations, type Locale } from "../lib/i18n";
import { projects } from "../lib/projects";
import SectionHeader from "./SectionHeader.astro";
import ProjectCard from "./ProjectCard.astro";
import YearStrip from "./illustration/YearStrip.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const visible = projects.filter((p) => !p.comingSoon);
const years = visible
  .map((p) => p.year)
  .filter((y): y is number => typeof y === "number");
---

<section class="section projects" id="projects" aria-labelledby="projects-title">
  <div class="container projects__inner">
    <SectionHeader
      id="projects-title"
      kicker={t("projects.kicker")}
      title={t("projects.title")}
      lede={t("projects.lede")}
    />

    <div class="projects__grid">
      {visible.map((p, i) => (
        <ProjectCard project={p} locale={locale} index={i} />
      ))}
    </div>

    {years.length > 1 && (
      <div class="projects__year-strip" data-reveal>
        <YearStrip years={years} />
        <p class="projects__hint caption">{t("projects.scrollHint")}</p>
      </div>
    )}
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    gap: var(--sp-7);
    grid-template-columns: 1fr;
  }

  .projects__year-strip {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .projects__hint {
    text-align: center;
    color: var(--text-faint);
  }

  @media (min-width: 900px) {
    .projects__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
