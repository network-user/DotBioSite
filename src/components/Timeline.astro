---
import { useTranslations, type Locale } from "../lib/i18n";
import { projects, projectStartDate, timelineDateSortKey } from "../lib/projects";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

/**
 * Таймлайн строится из проектов (по полю year). Дополнительные пользовательские
 * вехи (рождение бренда, ребрендинг и т.п.) можно добавить вручную здесь же.
 */
const milestones = projects
  .filter((p) => !p.comingSoon)
  .map((p) => ({
    date: projectStartDate(p),
    title: p.brand[locale],
    subtitle: p.tagline[locale],
    description: p.name[locale],
    accent: p.accent ?? "var(--accent)",
  }))
  .filter((m) => m.date.length > 0)
  .sort((a, b) => timelineDateSortKey(b.date) - timelineDateSortKey(a.date));
---

<section class="section timeline-section" id="timeline" aria-labelledby="timeline-title">
  <div class="container timeline-section__inner">
    <SectionHeader
      id="timeline-title"
      kicker={t("timeline.kicker")}
      title={t("timeline.title")}
      lede={t("timeline.lede")}
    />

    <ol class="timeline" data-timeline data-reveal data-timeline-loop>
      {
        /* Слой «чернил»: линия + рамки + точки рисуются здесь и прогибаются от
          курсора. Включается JS-ом (класс .tl-warp-on) только на fine-указателе
          без reduced-motion; иначе видна CSS-резервная отрисовка ниже. */
      }
      <svg class="timeline__ink" data-tl-ink aria-hidden="true" preserveAspectRatio="none">
        <path class="tl-line" data-tl-line fill="none"></path>
      </svg>
      {
        milestones.map((m, i) => (
          <li
            class="timeline__item"
            data-reveal
            data-reveal-delay={i * 100}
            data-accent={m.accent}
            style={`--item-i: ${i};`}
          >
            <span class="timeline__bullet" aria-hidden="true" />
            <div class="timeline__year display tabular">{m.date}</div>
            <div class="timeline__body glass glass--hover" data-tl-card data-touch-live>
              <h3 class="timeline__title">{m.title}</h3>
              <p class="timeline__subtitle subtitle">{m.subtitle}</p>
              <p class="timeline__desc body-sm">{m.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    padding-inline-start: var(--sp-6);
  }

  /* ---------- SVG-слой «чернил» (линия + рамки + точки) ---------- */
  .timeline__ink {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* Прогиб толкает точки наружу до ~15px, поэтому не обрезаем по краям слоя. */
    overflow: visible;
    z-index: 2;
    /* По умолчанию слой не показан: его включает JS, выставив резерв на CSS. */
    display: none;
  }

  .timeline.tl-warp-on .timeline__ink {
    display: block;
    /* Собственный композит-слой: переписывание `d` путей на каждый кадр прогиба
       перерисовывает ТОЛЬКО этот слой, не задевая карточки/текст под ним. */
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  /* В режиме прогиба линию/рамки/точки рисует SVG, поэтому гасим CSS-резерв. */
  .timeline.tl-warp-on::before {
    display: none;
  }
  .timeline.tl-warp-on .timeline__bullet {
    display: none;
  }
  .timeline.tl-warp-on .timeline__body {
    border-color: transparent;
  }
  /* Подъём карточки на hover убран в режиме прогиба, иначе SVG-рамка отрывается
     от карточки. Обратную связь даёт подсветка обводки рамки (.is-hot ниже). */
  .timeline.tl-warp-on .timeline__body:hover {
    transform: none;
    box-shadow: none;
  }

  .tl-line {
    stroke: url(#tl-grad);
    stroke-width: 1.4;
    stroke-linecap: round;
    transform-box: fill-box;
    transform-origin: top center;
    transform: scaleY(0);
    transition: transform 1100ms var(--ease-soft) 200ms;
  }
  .timeline.is-visible .tl-line {
    transform: scaleY(1);
  }

  /* tl-frame / tl-dot* создаются в JS через createElementNS и НЕ получают
     scope-атрибут Astro, поэтому их правила обёрнуты в :global() (иначе селектор
     скоупится и не матчит, а SVG-path с дефолтным fill превращается в ЧЁРНЫЙ
     прямоугольник поверх карточки). Скоуп держим через предка .timeline. */
  .timeline :global(.tl-frame) {
    fill: none;
    stroke: var(--glass-edge);
    stroke-width: 1;
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.985);
    transition:
      opacity 520ms var(--ease-soft),
      stroke 200ms var(--ease-standard),
      transform 520ms var(--ease-soft);
    transition-delay: calc(var(--item-i, 0) * 90ms + 160ms);
  }
  .timeline.is-visible :global(.tl-frame) {
    opacity: 1;
    transform: scale(1);
  }
  .timeline :global(.tl-frame.is-hot) {
    stroke: var(--glass-edge-bright);
    stroke-width: 1.3;
  }

  /* Точки: внешняя <g> двигается прогибом (JS-transform), внутренняя растёт и
     дышит (CSS-transform), чтобы две анимации не конфликтовали на одном узле. */
  .timeline :global(.tl-dot__pulse) {
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.5);
    opacity: 0;
    transition:
      transform 600ms var(--ease-spring),
      opacity 600ms var(--ease-soft);
    transition-delay: calc(var(--item-i, 0) * 140ms + 260ms);
  }
  .timeline.is-visible :global(.tl-dot__pulse) {
    transform: scale(1);
    opacity: 1;
  }
  .timeline :global(.tl-dot__gap) {
    fill: var(--bg);
  }
  .timeline :global(.tl-dot__core) {
    fill: var(--text);
  }
  .timeline :global(.tl-dot__ring) {
    fill: none;
    stroke: var(--border-hover);
    stroke-width: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .timeline.is-inview :global(.tl-dot .tl-dot__pulse) {
      animation: tl-dot-pulse 6s steps(30) infinite;
      animation-delay: calc(var(--item-i, 0) * 140ms + 1100ms);
    }
  }

  @keyframes tl-dot-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.85;
    }
  }

  /* ---------- CSS-резерв: линия + точки (без JS / reduced-motion / coarse) ----------
     Коннектор «прочерчивается» сверху вниз через transform: scaleY. */
  .timeline::before {
    content: "";
    position: absolute;
    left: 11px;
    top: var(--sp-2);
    bottom: var(--sp-2);
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--border-hover) 8%,
      var(--project-accent, var(--border-hover)) 50%,
      var(--border-hover) 92%,
      transparent
    );
    transform-origin: top center;
    transform: scaleY(0);
    transition: transform 1100ms var(--ease-soft) 200ms;
    pointer-events: none;
  }

  .timeline.is-visible::before {
    transform: scaleY(1);
  }

  .timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
  }

  .timeline__bullet {
    position: absolute;
    left: -23px;
    top: 14px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--text);
    box-shadow:
      0 0 0 4px var(--bg),
      0 0 0 5px var(--border-hover);
    transform: scale(0.6);
    opacity: 0;
    transform-origin: center;
    transition:
      transform 600ms var(--ease-spring),
      opacity 600ms var(--ease-soft);
    transition-delay: calc(var(--item-i, 0) * 140ms + 260ms);
  }

  .timeline__item.is-visible .timeline__bullet {
    transform: scale(1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .timeline.is-inview .timeline__item.is-visible .timeline__bullet {
      animation: timeline-pulse 6s steps(30) infinite;
      animation-delay: calc(var(--item-i, 0) * 140ms + 1100ms);
    }
  }

  @keyframes timeline-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.85;
    }
  }

  .timeline__year {
    font-size: var(--fs-22);
    color: var(--text-muted);
    letter-spacing: var(--ls-display);
    line-height: 1;
    white-space: nowrap;
  }

  .timeline__body {
    padding: var(--sp-5);
    border-radius: var(--r-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .timeline__title {
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    font-size: var(--fs-22);
  }

  /* reduced-motion: коннектор сразу прочерчен, точки на месте без пульса. */
  @media (prefers-reduced-motion: reduce) {
    .timeline::before {
      transition: none;
      transform: scaleY(1);
    }
    .timeline__bullet {
      transition: none;
      animation: none;
      transform: scale(1);
      opacity: 1;
    }
  }

  @media (min-width: 720px) {
    .timeline__item {
      grid-template-columns: 132px 1fr;
      align-items: start;
      gap: var(--sp-6);
    }
    .timeline {
      gap: var(--sp-6);
      padding-inline-start: var(--sp-7);
    }
    .timeline__bullet {
      left: -27px;
      top: 24px;
    }
    .timeline__body {
      padding: var(--sp-5) var(--sp-6);
    }
    .timeline__title {
      font-size: var(--fs-24);
    }
    .timeline__year {
      padding-block-start: var(--sp-4);
      font-size: var(--fs-20);
    }
  }
</style>

<script>
  // ===========================================================================
  // Таймлайн: (1) гейтинг бесконечного пульса по видимости; (2) «прогиб» линии,
  // рамок и точек от курсора через SVG-слой.
  // ===========================================================================
  (() => {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!("IntersectionObserver" in window)) return;

    const ol = document.querySelector<HTMLElement>("[data-timeline-loop]");
    if (!ol) return;

    // --- Пульс точек крутится только пока таймлайн на экране ---
    const inviewIo = new IntersectionObserver(
      (entries) => {
        for (const e of entries) ol.classList.toggle("is-inview", e.isIntersecting);
      },
      { threshold: 0 },
    );
    inviewIo.observe(ol);

    // --- Прогиб от курсора (только fine-указатель, без reduced-motion) ---
    const fine = window.matchMedia("(pointer: fine)").matches;
    const ink = ol.querySelector<SVGSVGElement>("[data-tl-ink]");
    const lineEl = ol.querySelector<SVGPathElement>("[data-tl-line]");
    const section = ol.closest<HTMLElement>(".timeline-section");

    const SVGNS = "http://www.w3.org/2000/svg";
    const R = 150; // радиус влияния курсора, px
    const R2 = R * R;
    const STRENGTH = 15; // макс. прогиб, px
    const FRAME_RADIUS = 18; // скругление рамки (≈ --r-lg)
    const FRAME_STEP = 26; // шаг семплинга рёбер рамки

    let frameEls: SVGPathElement[] = [];
    let dotEls: SVGGElement[] = [];
    let baseLine: [number, number][] = [];
    let baseFrames: [number, number][][] = [];
    let baseDots: [number, number][] = [];

    let curX = 0;
    let curY = 0;
    let tgtX = 0;
    let tgtY = 0;
    let infl = 0; // текущее влияние 0..1 (лерп)
    let tgtInfl = 0;
    let raf: number | null = null;
    let inkRect: DOMRect | null = null;
    let rectDirty = true;
    let gradEl: SVGLinearGradientElement | null = null;

    // Линия белая с затуханием на концах.
    function buildGradient() {
      if (!gradEl) return;
      while (gradEl.firstChild) gradEl.removeChild(gradEl.firstChild);
      const mk = (off: number, op: number) => {
        const s = document.createElementNS(SVGNS, "stop");
        s.setAttribute("offset", off.toFixed(3));
        s.style.stopColor = "rgba(255,255,255,0.28)";
        s.style.stopOpacity = String(op);
        gradEl!.appendChild(s);
      };
      mk(0, 0);
      mk(0.07, 1);
      mk(0.93, 1);
      mk(1, 0);
    }

    function roundRectPts(
      x: number,
      y: number,
      w: number,
      h: number,
      r: number,
    ): [number, number][] {
      r = Math.min(r, w / 2, h / 2);
      const pts: [number, number][] = [];
      const edge = (x0: number, y0: number, x1: number, y1: number) => {
        const len = Math.hypot(x1 - x0, y1 - y0);
        const n = Math.max(1, Math.round(len / FRAME_STEP));
        for (let i = 0; i < n; i++) {
          const t = i / n;
          pts.push([x0 + (x1 - x0) * t, y0 + (y1 - y0) * t]);
        }
      };
      const arc = (cx: number, cy: number, a0: number, a1: number) => {
        const seg = 4;
        for (let i = 0; i <= seg; i++) {
          const a = a0 + ((a1 - a0) * i) / seg;
          pts.push([cx + Math.cos(a) * r, cy + Math.sin(a) * r]);
        }
      };
      edge(x + r, y, x + w - r, y);
      arc(x + w - r, y + r, -Math.PI / 2, 0);
      edge(x + w, y + r, x + w, y + h - r);
      arc(x + w - r, y + h - r, 0, Math.PI / 2);
      edge(x + w - r, y + h, x + r, y + h);
      arc(x + r, y + h - r, Math.PI / 2, Math.PI);
      edge(x, y + h - r, x, y + r);
      arc(x + r, y + r, Math.PI, Math.PI * 1.5);
      return pts;
    }

    // Геометрия в координатах слоя (= padding-box <ol>). offsetLeft/Top
    // инвариантны к reveal-трансформам, поэтому мерить можно в любой момент.
    function measure() {
      if (!ink || !lineEl) return;
      const items = Array.from(ol!.querySelectorAll<HTMLElement>(".timeline__item"));
      if (!items.length) return;

      const padL = parseFloat(getComputedStyle(ol!).paddingInlineStart) || 24;
      const lineX = Math.round(padL * 0.46);

      const cards = items.map((li) => {
        const body = li.querySelector<HTMLElement>(".timeline__body")!;
        const x = li.offsetLeft + body.offsetLeft;
        const y = li.offsetTop + body.offsetTop;
        const w = body.offsetWidth;
        const h = body.offsetHeight;
        return { x, y, w, h, bulletY: y + Math.min(26, h / 2) };
      });

      // Линия идёт от первой до последней точки.
      const y0 = cards[0]!.bulletY;
      const y1 = cards[cards.length - 1]!.bulletY;
      baseLine = [];
      const lineN = Math.max(2, Math.round((y1 - y0) / 16));
      for (let i = 0; i <= lineN; i++) {
        baseLine.push([lineX, y0 + ((y1 - y0) * i) / lineN]);
      }

      baseFrames = cards.map((c) =>
        roundRectPts(c.x + 0.5, c.y + 0.5, c.w - 1, c.h - 1, FRAME_RADIUS),
      );
      baseDots = cards.map((c) => [lineX, c.bulletY]);

      buildGradient();

      // DOM создаём/пересоздаём, если число элементов изменилось.
      if (frameEls.length !== cards.length) {
        frameEls.forEach((el) => el.remove());
        dotEls.forEach((el) => el.remove());
        frameEls = [];
        dotEls = [];
        cards.forEach((_, i) => {
          const fr = document.createElementNS(SVGNS, "path");
          fr.setAttribute("class", "tl-frame");
          fr.style.setProperty("--item-i", String(i));
          ink!.appendChild(fr);
          frameEls.push(fr);
        });
        cards.forEach((_, i) => {
          const g = document.createElementNS(SVGNS, "g") as SVGGElement;
          g.setAttribute("class", "tl-dot");
          const pulse = document.createElementNS(SVGNS, "g");
          pulse.setAttribute("class", "tl-dot__pulse");
          pulse.style.setProperty("--item-i", String(i));
          for (const [cls, r] of [
            ["tl-dot__gap", 7],
            ["tl-dot__core", 5],
            ["tl-dot__ring", 7],
          ] as const) {
            const c = document.createElementNS(SVGNS, "circle");
            c.setAttribute("class", cls);
            c.setAttribute("r", String(r));
            if (cls === "tl-dot__ring") c.style.stroke = "var(--border-hover)";
            pulse.appendChild(c);
          }
          g.appendChild(pulse);
          ink!.appendChild(g);
          dotEls.push(g);
        });
      }

      render();
    }

    function warp(px: number, py: number): [number, number] {
      if (infl <= 0.001) return [px, py];
      const dx = px - curX;
      const dy = py - curY;
      const d2 = dx * dx + dy * dy;
      if (d2 >= R2) return [px, py];
      const d = Math.sqrt(d2) || 0.0001;
      let fall = 1 - d / R;
      fall *= fall;
      const push = (STRENGTH * fall * infl) / d;
      return [px + dx * push, py + dy * push];
    }

    function render() {
      if (!lineEl) return;
      let dl = "";
      for (let i = 0; i < baseLine.length; i++) {
        const b = baseLine[i]!;
        const p = warp(b[0], b[1]);
        dl += (i ? " L " : "M ") + p[0].toFixed(1) + " " + p[1].toFixed(1);
      }
      lineEl.setAttribute("d", dl);

      for (let fI = 0; fI < frameEls.length; fI++) {
        const pts = baseFrames[fI]!;
        let d = "";
        for (let i = 0; i < pts.length; i++) {
          const pt = pts[i]!;
          const p = warp(pt[0], pt[1]);
          d += (i ? " L " : "M ") + p[0].toFixed(1) + " " + p[1].toFixed(1);
        }
        frameEls[fI]!.setAttribute("d", d + " Z");
      }

      for (let i = 0; i < dotEls.length; i++) {
        const b = baseDots[i]!;
        const p = warp(b[0], b[1]);
        dotEls[i]!.setAttribute("transform", `translate(${p[0].toFixed(1)} ${p[1].toFixed(1)})`);
      }
    }

    function tick() {
      curX += (tgtX - curX) * 0.25;
      curY += (tgtY - curY) * 0.25;
      infl += (tgtInfl - infl) * 0.12;
      render();
      const moving =
        Math.abs(tgtX - curX) > 0.3 ||
        Math.abs(tgtY - curY) > 0.3 ||
        Math.abs(tgtInfl - infl) > 0.002;
      if (moving) {
        raf = requestAnimationFrame(tick);
      } else {
        raf = null;
        if (tgtInfl === 0 && infl !== 0) {
          infl = 0;
          render(); // прибраться в базовое состояние одним кадром
        }
      }
    }

    function ensure() {
      if (raf === null) raf = requestAnimationFrame(tick);
    }

    function enableWarp() {
      if (!ink || !lineEl || !section) return;

      // Градиент линии (затухает к краям, акцент в середине): в defs слоя.
      // Белый градиент линии с затуханием к краям; строит buildGradient из measure().
      // objectBoundingBox + вертикаль → offset 0..1 = верх..низ линии.
      const defs = document.createElementNS(SVGNS, "defs");
      gradEl = document.createElementNS(SVGNS, "linearGradient");
      gradEl.setAttribute("id", "tl-grad");
      gradEl.setAttribute("x1", "0");
      gradEl.setAttribute("y1", "0");
      gradEl.setAttribute("x2", "0");
      gradEl.setAttribute("y2", "1");
      defs.appendChild(gradEl);
      ink.insertBefore(defs, ink.firstChild);

      ol!.classList.add("tl-warp-on");
      measure();

      // rect для перевода курсора в локальные координаты кешируем; устаревает на
      // скролле (флаг) и resize. getBoundingClientRect не читаем в горячем пути.
      window.addEventListener(
        "scroll",
        () => {
          rectDirty = true;
        },
        { passive: true },
      );

      if ("ResizeObserver" in window) {
        let rt: number | null = null;
        const ro = new ResizeObserver(() => {
          if (rt !== null) return;
          rt = requestAnimationFrame(() => {
            rt = null;
            measure();
            rectDirty = true;
          });
        });
        ro.observe(ol!);
      }

      section.addEventListener("pointerenter", () => {
        inkRect = ink.getBoundingClientRect();
        rectDirty = false;
        tgtInfl = 1;
        ensure();
      });
      section.addEventListener(
        "pointermove",
        (e) => {
          if (rectDirty || !inkRect) {
            inkRect = ink.getBoundingClientRect();
            rectDirty = false;
          }
          tgtX = e.clientX - inkRect.left;
          tgtY = e.clientY - inkRect.top;
          tgtInfl = 1;
          ensure();
        },
        { passive: true },
      );
      section.addEventListener("pointerleave", () => {
        tgtInfl = 0;
        ensure();
      });

      // Подсветка рамки при hover: нейтральный белый (без per-project цвета).
      ol!.querySelectorAll<HTMLElement>("[data-tl-card]").forEach((card, i) => {
        card.addEventListener("pointerenter", () => {
          frameEls[i]?.classList.add("is-hot");
        });
        card.addEventListener("pointerleave", () => {
          frameEls[i]?.classList.remove("is-hot");
        });
      });
    }

    if (fine && !reduced) enableWarp();

    window.addEventListener(
      "pagehide",
      () => {
        ol!.classList.remove("is-inview");
        inviewIo.disconnect();
        if (raf !== null) cancelAnimationFrame(raf);
      },
      { once: true },
    );
  })();
</script>
