---
import { useTranslations, type Locale, localePrefix } from "../lib/i18n";
import {
  type Project,
  projectName,
  projectBrand,
  projectTagline,
  projectDescription,
  repoUrl,
} from "../lib/projects";
import Icon from "./Icon/Icon.astro";
import ProjectGlyph from "./ProjectGlyph.astro";

interface Props {
  project: Project;
  locale: Locale;
  /** Индекс в сетке (для staggered scroll-reveal). */
  index?: number;
}

const { project: p, locale, index = 0 } = Astro.props;
const t = useTranslations(locale);
const prefix = localePrefix(locale);

const name = projectName(p, locale);
const brand = projectBrand(p, locale);
const tagline = projectTagline(p, locale);
const desc = projectDescription(p, locale);
const caseHref = `${prefix}/projects/${p.slug}`;
const primaryRepoUrl = p.repos[0] ? repoUrl(p.repos[0]) : "";
const accent = p.accent ?? "var(--accent)";
const highlights = p.highlights?.slice(0, 3) ?? [];
const isFeatured = index === 0;
---

<article
  class:list={["project-card glass", { "project-card--featured": isFeatured }]}
  data-reveal
  data-reveal-delay={index * 80}
  data-tilt
  aria-labelledby={`project-${p.slug}-title`}
  style={`--project-accent: ${accent};`}
>
  <a
    href={caseHref}
    class="project-card__media project-card__media--logo"
    aria-label={t("projects.viewProject")}
  >
    <span class="project-card__logo">
      <span class="project-card__glyph">
        <ProjectGlyph slug={p.slug} />
      </span>
      <span class="project-card__logo-brand display">{brand}</span>
    </span>
    <span class="project-card__media-glow" aria-hidden="true" />
    <span class="project-card__media-status" aria-hidden="true">
      <Icon name="dot" size={10} />
      <span>{t(`projects.status.${p.status}`)}</span>
    </span>
  </a>

  <header class="project-card__head">
    <div class="project-card__eyebrow">
      <span class="project-card__category eyebrow">
        {t(`projects.category.${p.category}`)}
      </span>
      <span
        class={`project-card__status project-card__status--${p.status}`}
        aria-hidden={p.cover ? "true" : undefined}
      >
        <Icon name="dot" size={10} />
        <span>{t(`projects.status.${p.status}`)}</span>
      </span>
    </div>

    <h3
      class="project-card__brand display"
      id={`project-${p.slug}-title`}
      data-text={brand}
      style={`view-transition-name: project-${p.slug}-brand;`}
    >
      {brand}
    </h3>
    <p class="project-card__name caption">{name}</p>
    <p class="project-card__tagline subtitle">{tagline}</p>
  </header>

  <p class="project-card__desc body">{desc}</p>

  {
    highlights.length > 0 && (
      <dl class="project-card__highlights" aria-label={t("projects.highlights")}>
        {highlights.map((h) => (
          <div class="project-card__highlight">
            <dt>{h.label[locale]}</dt>
            <dd>{h.value}</dd>
          </div>
        ))}
      </dl>
    )
  }

  <ul class="project-card__stack" aria-label={t("projects.stack")}>
    {p.stack.slice(0, 6).map((s) => <li class="project-card__chip">{s}</li>)}
    {
      p.stack.length > 6 && (
        <li class="project-card__chip project-card__chip--more">+{p.stack.length - 6}</li>
      )
    }
  </ul>

  {
    p.repos.length > 1 && (
      <ul class="project-card__repos" aria-label={t("projects.repos")}>
        {p.repos.map((r) => (
          <li class="project-card__repo">
            <Icon name="code" size={14} />
            <span class="mono">{r.name}</span>
            {r.role && <span class="project-card__repo-role">{r.role}</span>}
          </li>
        ))}
      </ul>
    )
  }

  <footer class="project-card__actions">
    <a href={caseHref} class="project-card__cta cta cta--primary magnetic">
      <span>{t("projects.viewProject")}</span>
      <Icon name="arrow-right" size={16} />
    </a>
    {
      primaryRepoUrl && (
        <a
          href={primaryRepoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card__cta cta cta--ghost"
        >
          <Icon name="github" size={16} />
          <span>{t("projects.viewSource")}</span>
        </a>
      )
    }
    {
      p.links?.domain && (
        <a
          href={p.links.domain}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card__cta cta cta--ghost"
        >
          <Icon name="globe" size={16} />
          <span>{t("projects.openSite")}</span>
        </a>
      )
    }
  </footer>
</article>

<style>
  /* =====================================================================
   * Project card — single liquid-glass pane.
   *
   * Apple-dark direction: one cohesive frosted surface (backdrop-filter via
   * .glass) instead of nested bordered boxes. Monochrome typography with the
   * project accent used only as a whisper (corner wash, status dot, hover ring,
   * cover glow). 3D is kept but subtle: the whole pane tilts toward the pointer
   * (set by [data-tilt] JS in Projects.astro) with a pointer-following sheen.
   * ===================================================================== */
  .project-card {
    --pad: clamp(16px, 3.2vw, 24px);
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    position: relative;
    display: grid;
    grid-template-areas:
      "media"
      "head"
      "desc"
      "highlights"
      "stack"
      "repos"
      "actions";
    gap: var(--sp-4);
    padding: var(--pad);
    border-radius: var(--r-2xl);
    background:
      radial-gradient(
        130% 90% at 0% 0%,
        color-mix(in srgb, var(--project-accent) 9%, transparent),
        transparent 56%
      ),
      var(--glass-tint-1);
    border: var(--bw-thin) solid var(--glass-edge);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 18px 48px rgba(0, 0, 0, 0.42);
    transform: perspective(1400px) rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
    /* transform УБРАН из transition: раньше CSS интерполировал каждое микро-
       изменение тилта 280ms-кривой, и панель инерционно «догоняла» курсор — это и
       есть «массив едет за мной». Теперь тилт применяется мгновенно (плавность
       даёт JS-лерп). box-shadow тоже не анимируем (тень не композируется). */
    transition: border-color var(--dur-fast) var(--ease-standard);
  }

  /* Brighter top-shine for the glass on these large surfaces. */
  .project-card.glass::before {
    background: var(--glass-top-shine);
    opacity: 0.9;
  }

  /* Pointer-following sheen — sits over the glass, under the text (z-index 0,
     same plane as .glass::before; .glass > * content is bumped to z-index 1). */
  .project-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      460px circle at var(--mx, 50%) var(--my, 0%),
      rgba(255, 255, 255, 0.1),
      transparent 60%
    );
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-standard);
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--glass-edge-bright);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 30px 72px rgba(0, 0, 0, 0.52),
      0 0 0 1px color-mix(in srgb, var(--project-accent) 22%, transparent);
  }

  .project-card:hover::after,
  .project-card:focus-within::after {
    opacity: 1;
  }

  /* ---------- Cover ---------- */
  .project-card__media {
    position: relative;
    display: block;
    grid-area: media;
    aspect-ratio: 16 / 9;
    border-radius: var(--r-xl);
    overflow: hidden;
    border: var(--bw-thin) solid rgba(255, 255, 255, 0.1);
    background: var(--bg-elevated);
    isolation: isolate;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  /* ---------- Logo lockup (replaces the cover image on cards) ---------- */
  .project-card__media--logo {
    display: grid;
    place-items: center;
    container-type: inline-size;
    background:
      radial-gradient(
        120% 100% at 50% 16%,
        color-mix(in srgb, var(--project-accent) 16%, transparent),
        transparent 62%
      ),
      var(--bg-elevated);
  }

  .project-card__logo {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-6);
    color: var(--project-accent);
    transition: transform var(--dur-slow) var(--ease-soft);
  }

  .project-card__glyph {
    display: block;
    width: clamp(42px, 16cqi, 68px);
    filter: drop-shadow(0 4px 14px color-mix(in srgb, var(--project-accent) 28%, transparent));
  }

  .project-card__logo-brand {
    font-size: clamp(var(--fs-24), 11cqi, var(--fs-40));
    line-height: 1;
    color: var(--project-accent);
    opacity: 0.94;
  }

  .project-card:hover .project-card__logo {
    transform: scale(1.04);
  }

  /* Accent glow rising from the base of the cover — the one place colour leans in. */
  .project-card__media-glow {
    position: absolute;
    inset: auto 0 0;
    height: 56%;
    pointer-events: none;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--project-accent) 30%, transparent),
      transparent 86%
    );
    opacity: 0.7;
    z-index: 1;
  }

  .project-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    border-radius: inherit;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .project-card__media-status {
    position: absolute;
    top: var(--sp-3);
    right: var(--sp-3);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-1) var(--sp-3);
    border: var(--bw-thin) solid rgba(255, 255, 255, 0.18);
    border-radius: var(--r-pill);
    /* backdrop-filter убран (правило бюджета: реальный blur только в шапке).
       Над тёмной обложкой плотная заливка читается так же, но не переразмывает
       фон при тилте карточки и на каждом кадре скролла. */
    background: rgba(5, 6, 8, 0.78);
    color: var(--text);
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    text-transform: lowercase;
  }

  .project-card__media-status :global(svg) {
    color: var(--project-accent);
  }

  /* ---------- Head ---------- */
  .project-card__head {
    grid-area: head;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    min-width: 0;
  }

  .project-card__eyebrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .project-card__category {
    color: var(--text-muted);
  }

  .project-card__status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    text-transform: lowercase;
    padding: 2px var(--sp-2);
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid color-mix(in srgb, currentColor 30%, var(--border));
    background: rgba(255, 255, 255, 0.04);
  }

  /* When a cover already shows the status pill, hide the duplicate in the head. */
  .project-card__media ~ .project-card__head .project-card__status {
    display: none;
  }

  .project-card__status--active {
    color: var(--state-ok);
  }
  .project-card__status--wip {
    color: var(--state-warn);
  }
  .project-card__status--beta {
    color: var(--state-info);
  }
  .project-card__status--archived {
    color: var(--text-muted);
  }

  .project-card__brand {
    font-size: var(--fs-28);
    line-height: 1;
    color: var(--text);
    background: linear-gradient(180deg, var(--accent) 0%, rgba(255, 255, 255, 0.74) 130%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    width: fit-content;
    max-width: 100%;
  }

  .project-card__name {
    color: var(--text-muted);
  }

  .project-card__tagline {
    font-size: var(--fs-17);
    color: var(--text);
    font-weight: var(--fw-medium);
    margin-block-start: var(--sp-1);
  }

  /* ---------- Description ---------- */
  .project-card__desc {
    grid-area: desc;
    color: var(--text-secondary);
    font-size: var(--fs-15);
    line-height: var(--lh-normal);
    max-width: 64ch;
  }

  /* ---------- Highlights (flat, divider-separated row) ---------- */
  .project-card__highlights {
    grid-area: highlights;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(92px, 1fr));
    gap: var(--sp-2) var(--sp-5);
    padding-block: var(--sp-3);
    border-block: var(--bw-thin) solid var(--border);
  }

  .project-card__highlight {
    position: relative;
    min-width: 0;
    padding-block-start: var(--sp-3);
  }

  /* Tiny accent tick above each proof point — reads as a chart marker. */
  .project-card__highlight::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    width: 16px;
    height: 2px;
    border-radius: var(--r-pill);
    background: var(--project-accent);
    opacity: 0.5;
  }

  .project-card__highlight dt {
    color: var(--text-muted);
    font-size: var(--fs-11);
    text-transform: uppercase;
    line-height: var(--lh-snug);
  }

  .project-card__highlight dd {
    color: var(--text);
    font-family: var(--font-stack-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-22);
    line-height: var(--lh-tight);
    margin-block-start: 2px;
    overflow-wrap: anywhere;
  }

  /* ---------- Stack chips ---------- */
  .project-card__stack {
    grid-area: stack;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .project-card__chip {
    padding: 3px var(--sp-2);
    font-size: var(--fs-11);
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.05);
    border: var(--bw-thin) solid rgba(255, 255, 255, 0.1);
    border-radius: var(--r-sm);
  }

  .project-card__chip--more {
    color: var(--text-muted);
  }

  /* ---------- Repos ---------- */
  .project-card__repos {
    grid-area: repos;
    display: grid;
    gap: var(--sp-1);
  }

  .project-card__repo {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-12);
    color: var(--text-secondary);
    min-width: 0;
  }

  .project-card__repo-role {
    color: var(--text-muted);
    font-size: var(--fs-11);
    text-transform: uppercase;
    margin-left: auto;
    flex-shrink: 0;
  }

  /* ---------- Actions ---------- */
  .project-card__actions {
    grid-area: actions;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-self: end;
    margin-block-start: var(--sp-1);
  }

  .project-card__cta {
    font-size: var(--fs-13);
    padding: var(--sp-2) var(--sp-4);
    min-height: var(--tap-min);
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 479px) {
    .project-card {
      border-radius: var(--r-xl);
    }

    .project-card__brand {
      font-size: var(--fs-28);
    }

    .project-card__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .project-card__cta {
      width: 100%;
    }
  }

  /* ---------- Standard card on desktop ---------- */
  @media (min-width: 900px) {
    .project-card {
      gap: var(--sp-5);
    }

    .project-card__brand {
      font-size: var(--fs-32);
    }
  }

  /* ---------- Featured card (first in grid): full-width, media beside content ---------- */
  @media (min-width: 900px) {
    .project-card--featured {
      grid-column: 1 / -1;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      grid-template-areas:
        "media head"
        "media desc"
        "media highlights"
        "media stack"
        "media repos"
        "media actions";
      align-content: start;
      column-gap: var(--sp-8);
      row-gap: var(--sp-4);
    }

    .project-card--featured .project-card__media {
      align-self: stretch;
      height: 100%;
      min-height: 260px;
      aspect-ratio: auto;
    }

    .project-card--featured .project-card__head {
      margin-block-start: var(--sp-1);
    }

    .project-card--featured .project-card__brand {
      font-size: var(--fs-44);
    }

    .project-card--featured .project-card__actions {
      margin-block-start: var(--sp-2);
    }
  }

  /* ---------- Accessibility / input-mode guards ---------- */
  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card:hover,
    .project-card:focus-within {
      transform: none;
      transition: border-color var(--dur-med), box-shadow var(--dur-med);
    }

    .project-card__logo,
    .project-card:hover .project-card__logo {
      transition: none;
      transform: none;
    }
  }

  @media (pointer: coarse) {
    /* No tilt on touch — keep the pane flat and the cover calm. */
    .project-card {
      transform: none;
    }

    .project-card:hover .project-card__logo {
      transform: none;
    }
  }
</style>
