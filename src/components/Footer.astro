---
import { useTranslations, type Locale } from "../lib/i18n";
import { config, authorName } from "../lib/config";
import { infraProjects, repoUrl as projectRepoUrl } from "../lib/projects";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const year = new Date().getFullYear();
const ghUser = config.PUBLIC_GITHUB_USER;
const ghRepo = config.PUBLIC_GITHUB_REPO;
const repoUrl = ghUser && ghRepo ? `https://github.com/${ghUser}/${ghRepo}` : "";
const brand = authorName(locale);

// Колофон: README и правила всех проектов DotCore (включая этот сайт)
// сгенерированы скиллом generate-readme из репозитория dotcore-skills. Ссылку
// берём из данных самого infra-проекта — без хардкода имени репо в двух местах.
const skills = infraProjects.find((p) => p.slug === "dotcore-skills");
const skillsRepoUrl = skills?.repos[0] ? projectRepoUrl(skills.repos[0]) : "";
---

<footer class="footer">
  <div class="container footer__inner">
    <p class="footer__cta caption">{t("footer.cta")}</p>

    <div class="footer__row">
      <div class="footer__brand">
        <span class="footer__brand-name display">{brand}</span>
        <span class="footer__brand-year">© {year}. {t("footer.rights")}</span>
      </div>

      {
        repoUrl && (
          <div class="footer__meta">
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="footer__link">
              <Icon name="github" size={14} />
              <span>{t("footer.sourceCode")}</span>
            </a>
          </div>
        )
      }
    </div>

    {
      skills && (
        <p class="footer__colophon">
          {t("footer.colophon")}{" "}
          {skillsRepoUrl ? (
            <a
              href={skillsRepoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__colophon-link"
            >
              dotcore-skills
            </a>
          ) : (
            <span class="footer__colophon-link">dotcore-skills</span>
          )}
        </p>
      )
    }
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    border-top: var(--bw-thin) solid var(--border);
    padding-block: var(--sp-6) calc(var(--sp-7) + env(safe-area-inset-bottom));
    margin-block-start: var(--sp-8);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .footer__cta {
    color: var(--text-secondary);
    letter-spacing: var(--ls-wide);
  }

  .footer__row {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .footer__brand-name {
    font-size: var(--fs-22);
    color: var(--text);
    letter-spacing: var(--ls-display);
  }

  .footer__brand-year {
    color: var(--text-secondary);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  .footer__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    color: var(--text-muted);
    font-size: var(--fs-13);
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-secondary);
  }

  .footer__link:hover {
    color: var(--text);
    opacity: 1;
  }

  .footer__colophon {
    color: var(--text-muted);
    font-size: var(--fs-12);
    line-height: var(--lh-normal);
    letter-spacing: var(--ls-wide);
  }

  .footer__colophon-link {
    color: var(--text-secondary);
    font-family: var(--font-stack-mono, monospace);
    border-bottom: var(--bw-thin) solid var(--border-hover);
  }

  a.footer__colophon-link:hover {
    color: var(--text);
    border-bottom-color: var(--text-secondary);
  }

  @media (min-width: 720px) {
    .footer {
      padding-block: var(--sp-7);
      margin-block-start: var(--sp-11);
    }

    .footer__row {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
