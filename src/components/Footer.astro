---
import { useTranslations, type Locale } from "../lib/i18n";
import { authorName, socials } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const year = new Date().getFullYear();
const brand = authorName(locale);
---

<footer class="footer">
  <div class="container footer__inner">
    <p class="footer__cta caption">{t("footer.cta")}</p>

    <div class="footer__row">
      <div class="footer__brand">
        <span class="footer__brand-name display">{brand}</span>
        <span class="footer__brand-year">© {year}. {t("footer.rights")}</span>
      </div>

      <div class="footer__meta">
        {
          socials.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer me"
              class="footer__icon-link"
              aria-label={t(`contact.${s.id}`)}
              data-umami-event="open-social"
              data-umami-event-net={s.id}
            >
              <Icon name={s.id} size={16} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    border-top: var(--bw-thin) solid var(--border);
    padding-block: var(--sp-6) calc(var(--sp-7) + env(safe-area-inset-bottom));
    margin-block-start: var(--sp-8);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .footer__cta {
    color: var(--text-secondary);
    letter-spacing: var(--ls-wide);
  }

  .footer__row {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .footer__brand-name {
    font-size: var(--fs-22);
    color: var(--text);
    letter-spacing: var(--ls-display);
  }

  .footer__brand-year {
    color: var(--text-secondary);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  .footer__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    color: var(--text-muted);
    font-size: var(--fs-13);
  }

  .footer__icon-link {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: var(--r-pill);
    border: var(--bw-thin) solid var(--border);
    color: var(--text-secondary);
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .footer__icon-link:hover {
    color: var(--text);
    border-color: var(--border-hover);
    opacity: 1;
  }

  /* Тач: доводим hit-area до 44px и даём мгновенный отклик на палец (:hover нет). */
  @media (hover: none) {
    .footer__icon-link {
      width: var(--tap-min);
      height: var(--tap-min);
    }
    .footer__icon-link:active {
      color: var(--text);
      border-color: var(--border-hover);
      opacity: 1;
    }
  }

  @media (min-width: 720px) {
    .footer {
      padding-block: var(--sp-7);
      margin-block-start: var(--sp-11);
    }

    .footer__row {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
