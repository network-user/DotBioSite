---
import { useTranslations, type Locale } from "../lib/i18n";
import { config, authorName } from "../lib/config";
import Icon from "./Icon/Icon.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const year = new Date().getFullYear();
// Собираем URL репо сайта только если оба значения непустые. Иначе ссылка
// в футере не рендерится — никакого мёртвого `github.com//` в HTML.
const ghUser = config.PUBLIC_GITHUB_USER;
const ghRepo = config.PUBLIC_GITHUB_REPO;
const repoUrl = ghUser && ghRepo ? `https://github.com/${ghUser}/${ghRepo}` : "";
const brand = authorName(locale);
---

<footer class="footer">
  <div class="container footer__inner">
    <p class="footer__cta caption">{t("footer.cta")}</p>

    <div class="footer__row">
      <div class="footer__brand">
        <span class="footer__brand-name display">{brand}</span>
        <span class="footer__brand-year">© {year}. {t("footer.rights")}</span>
      </div>

      <div class="footer__meta">
        {
          repoUrl && (
            <>
              <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="footer__link">
                <Icon name="github" size={14} />
                <span>{t("footer.sourceCode")}</span>
              </a>
              <span class="footer__sep" aria-hidden="true">
                ·
              </span>
            </>
          )
        }
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__link"
        >
          <Icon name="spark" size={14} />
          <span>{t("footer.builtWith")}</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: var(--bw-thin) solid var(--border);
    padding-block: var(--sp-6) calc(var(--sp-7) + env(safe-area-inset-bottom));
    margin-block-start: var(--sp-8);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .footer__cta {
    /* Was --text-faint (#3a3a3a) — failed WCAG AA on dark bg (contrast 1.74).
       Bumped to --text-secondary for 4.5:1+ readability. */
    color: var(--text-secondary);
    letter-spacing: var(--ls-wide);
  }

  .footer__row {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    align-items: flex-start;
    justify-content: space-between;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .footer__brand-name {
    font-size: var(--fs-22);
    color: var(--text);
    letter-spacing: var(--ls-display);
  }

  .footer__brand-year {
    /* Was --text-muted (#5a5a5a) — contrast 2.87 fails AA. */
    color: var(--text-secondary);
    font-size: var(--fs-12);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  .footer__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-2) var(--sp-3);
    color: var(--text-muted);
    font-size: var(--fs-13);
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--text-secondary);
  }

  .footer__link:hover {
    color: var(--text);
    opacity: 1;
  }

  .footer__sep {
    color: var(--text-faint);
  }

  @media (min-width: 720px) {
    .footer {
      padding-block: var(--sp-7);
      margin-block-start: var(--sp-11);
    }

    .footer__row {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
