---
import "../styles/global.css";
import "../styles/glass.css";

import { config } from "../lib/config";
import { useTranslations, alternateUrl, type Locale } from "../lib/i18n";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import NoiseBackground from "../components/react/NoiseBackground.island.tsx";
import SpotlightCursor from "../components/react/SpotlightCursor.island.tsx";
import SmoothScroll from "../components/react/SmoothScroll.island.tsx";

interface Props {
  locale: Locale;
  /** Заголовок страницы. Если не задан — берётся meta.title из словаря. */
  title?: string;
  /** Описание для SEO/OG. */
  description?: string;
  /** Класс для <main>. */
  mainClass?: string;
  /** Скрыть header/footer (для лендинга hero / случаев когда не нужен). */
  noChrome?: boolean;
}

const {
  locale,
  title,
  description,
  mainClass = "",
  noChrome = false,
} = Astro.props;

const t = useTranslations(locale);
const pageTitle = title ?? t("meta.title");
const pageDescription = description ?? t("meta.description");
const canonical = new URL(Astro.url.pathname, config.PUBLIC_DOMAIN).toString();
const altLocale: Locale = locale === "ru" ? "en" : "ru";
const altHref = new URL(alternateUrl(Astro.url, altLocale), config.PUBLIC_DOMAIN).toString();
const ogImage = new URL("/og-image.svg", config.PUBLIC_DOMAIN).toString();
const htmlLang = locale === "ru" ? "ru-RU" : "en-US";
---

<!doctype html>
<html lang={htmlLang} data-locale={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={altLocale} href={altHref} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", config.PUBLIC_DOMAIN).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" sizes="192x192" href="/icon-192.svg" />
    <link rel="icon" type="image/svg+xml" sizes="512x512" href="/icon-512.svg" />
    <link rel="apple-touch-icon" href="/icon-192.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === "ru" ? "ru_RU" : "en_US"} />
    <meta property="og:locale:alternate" content={altLocale === "ru" ? "ru_RU" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body data-locale={locale}>
    <div class="bg-layer" aria-hidden="true">
      <NoiseBackground client:idle />
    </div>

    <SpotlightCursor client:idle />
    <SmoothScroll client:idle />

    {!noChrome && <Header locale={locale} />}

    <main id="main" tabindex="-1" class={`main ${mainClass}`}>
      <slot />
    </main>

    {!noChrome && <Footer locale={locale} />}

    <a href="#main" class="skip-link">
      {locale === "ru" ? "Перейти к содержимому" : "Skip to content"}
    </a>

    <script>
      // --- Scroll-reveal через IntersectionObserver ---
      const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
      revealEls.forEach((el) => {
        const delay = el.dataset.revealDelay ?? "0";
        el.style.setProperty("--reveal-delay", delay);
      });

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduced || !("IntersectionObserver" in window)) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.15 },
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // --- Magnetic hover: CTA-кнопки притягиваются к курсору ---
      if (!reduced && window.matchMedia("(pointer: fine)").matches) {
        const STRENGTH = 0.22;
        const MAX_DISP = 6;
        const clamp = (v: number) => Math.max(-MAX_DISP, Math.min(MAX_DISP, v));
        const magnets = document.querySelectorAll<HTMLElement>(".magnetic");
        magnets.forEach((el) => {
          let raf: number | null = null;
          let tx = 0;
          let ty = 0;
          el.addEventListener("pointermove", (e) => {
            const rect = el.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            tx = clamp((e.clientX - cx) * STRENGTH);
            ty = clamp((e.clientY - cy) * STRENGTH);
            if (raf === null) {
              raf = requestAnimationFrame(() => {
                el.style.transform = `translate3d(${tx}px, ${ty}px, 0)`;
                raf = null;
              });
            }
          });
          el.addEventListener("pointerleave", () => {
            el.style.transform = "translate3d(0, 0, 0)";
          });
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* ---------- Layout primitives ---------- */
  html,
  body {
    background: var(--bg);
    color: var(--text);
  }

  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.55;
  }

  .main {
    position: relative;
    z-index: 1;
    min-height: 60vh;
  }

  /* ---------- Skip-link для клавиатуры/скринридеров ---------- */
  .skip-link {
    position: fixed;
    top: -100px;
    left: var(--sp-4);
    background: var(--bg-elevated);
    color: var(--text);
    border: var(--bw-thin) solid var(--border);
    padding: var(--sp-3) var(--sp-5);
    border-radius: var(--r-md);
    z-index: var(--z-toast);
    font-weight: var(--fw-semibold);
    transition: top var(--dur-fast) var(--ease-standard);
  }

  .skip-link:focus-visible {
    top: var(--sp-4);
  }
</style>
