---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CaseStudy from "../../../components/CaseStudy.astro";
import {
  projects,
  projectName,
  projectCaseTagline,
  projectCaseDescription,
  projectStartISO,
  projectUpdatedISO,
  repoUrl,
} from "../../../lib/projects";
import { authorName, config } from "../../../lib/config";
import { useTranslations } from "../../../lib/i18n";

export const getStaticPaths = (() => {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const locale = "en" as const;
const t = useTranslations(locale);
const title = `${projectName(project, locale)}: ${authorName(locale)}`;
const description = projectCaseTagline(project, locale);
const codeRepositories = project.repos.map((r) => repoUrl(r)).filter(Boolean);
const caseUrl = new URL(`/en/projects/${project.slug}`, config.PUBLIC_DOMAIN).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: projectName(project, locale),
  description: projectCaseDescription(project, locale),
  url: caseUrl,
  image: project.cover ? new URL(project.cover, config.PUBLIC_DOMAIN).toString() : undefined,
  codeRepository: codeRepositories.length > 0 ? codeRepositories : undefined,
  programmingLanguage: project.stackGroups?.language ?? project.stack,
  keywords: project.stack.join(", "),
  inLanguage: "en-US",
  dateCreated: projectStartISO(project),
  dateModified: projectUpdatedISO(project),
  creator: { "@id": new URL("/#person", config.PUBLIC_DOMAIN).toString() },
  isPartOf: { "@id": new URL("/#website", config.PUBLIC_DOMAIN).toString() },
};
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "DotCore",
      item: new URL("/en", config.PUBLIC_DOMAIN).toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: t("nav.projects"),
      item: new URL("/en/#projects", config.PUBLIC_DOMAIN).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: projectName(project, locale),
      item: caseUrl,
    },
  ],
};
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  image={project.ogImage ?? project.cover}
  imageAlt={projectName(project, locale)}
  structuredData={[structuredData, breadcrumb]}
>
  <CaseStudy project={project} locale={locale} />
</BaseLayout>
