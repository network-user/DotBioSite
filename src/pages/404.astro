---
import BaseLayout from "../layouts/BaseLayout.astro";
import { authorName } from "../lib/config";
import { localePrefix } from "../lib/i18n";

// Единственная 404-страница на весь сайт (ru + en в одном документе), поэтому
// locale здесь условный: определяет html lang/OG-locale в BaseLayout, контент
// ниже двуязычный сам по себе.
const locale = "ru" as const;
const enHref = localePrefix("en");
const title = `404: ${authorName(locale)}`;
const description = "Такой страницы не существует. Page not found.";
---

<BaseLayout locale={locale} title={title} description={description} noindex>
  <section class="not-found section">
    <div class="container container-narrow not-found__inner">
      <h1 class="not-found__code display-xl">404</h1>
      <p class="not-found__line body">Такой страницы не существует.</p>
      <p class="not-found__line body" lang="en">Page not found.</p>
      <div class="not-found__ctas">
        <a href="/" class="cta cta--primary">На главную</a>
        <a href={enHref} class="cta cta--ghost">Home</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    min-height: 56vh;
  }

  .not-found__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    text-align: center;
  }

  .not-found__code {
    font-size: clamp(4rem, 18vw, var(--fs-160));
    color: var(--text);
  }

  .not-found__line {
    color: var(--text-secondary);
    max-width: 40ch;
  }

  .not-found__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-3);
    width: 100%;
    margin-block-start: var(--sp-4);
  }

  @media (min-width: 480px) {
    .not-found__ctas {
      width: auto;
    }
  }
</style>
