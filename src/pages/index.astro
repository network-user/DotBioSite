---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Stack from "../components/Stack.astro";
import Projects from "../components/Projects.astro";
import Timeline from "../components/Timeline.astro";
import Contact from "../components/Contact.astro";
import { config } from "../lib/config";
import { projects, projectName } from "../lib/projects";

const locale = "ru" as const;
const visibleProjects = projects.filter((p) => !p.comingSoon);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "@id": new URL("/#profilepage", config.PUBLIC_DOMAIN).toString(),
    url: new URL("/", config.PUBLIC_DOMAIN).toString(),
    inLanguage: "ru-RU",
    mainEntity: { "@id": new URL("/#person", config.PUBLIC_DOMAIN).toString() },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: visibleProjects.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: new URL(`/projects/${p.slug}`, config.PUBLIC_DOMAIN).toString(),
      name: projectName(p, locale),
    })),
  },
];
---

<BaseLayout locale={locale} structuredData={structuredData}>
  <Hero locale={locale} />
  <About locale={locale} />
  <Stack locale={locale} />
  <Projects locale={locale} />
  <Timeline locale={locale} />
  <Contact locale={locale} />
</BaseLayout>
