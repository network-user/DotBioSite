# Bash-скрипты и шаблоны для сервера: всегда LF.
# Иначе при редактировании в Windows в файл попадёт CRLF и на Linux
# сломается shebang (bash: \r: команда не найдена).
*.sh text eol=lf
deploy/Caddyfile.tmpl text eol=lf

# OG/icon SVG: LF only. CRLF checkouts made Windows `og:render` write
# hashes that fail Linux `seo:check` even when git content matches.
*.svg text eol=lf
