{
  "name": "dotcore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": ".core / .ядро: кузница проектов. Personal portfolio site under DotCore brand.",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro check && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,astro,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,css,json,md}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
