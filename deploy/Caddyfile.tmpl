# Шаблон конфига Caddy для деплоя ЗА Cloudflare Tunnel.
# deploy/setup.sh подставит {{ROOT}} и {{PORT}} и запишет результат в
# /etc/caddy/Caddyfile. Вручную править не нужно: меняй этот шаблон и
# перезапусти setup.sh.
#
# Ключевое отличие от «обычного» деплоя: Caddy слушает ТОЛЬКО loopback
# (127.0.0.1:{{PORT}}) по HTTP и НЕ трогает порты 80/443 хоста. Публичный
# HTTPS терминирует Cloudflare, cloudflared туннелит поддомен на этот порт.
# Поэтому здесь нет имени домена и нет ACME: наружу Caddy не смотрит,
# сертификаты не выпускает, ни с чем на 80/443 не конфликтует.

# Схема http:// + loopback-адрес => Caddy НЕ включает auto-HTTPS и не биндит
# 80/443. Слушает только локальный порт, доступный лишь cloudflared на этом же
# хосте.
http://127.0.0.1:{{PORT}} {
	root * {{ROOT}}

	# Сжатие на лету (zstd предпочтительнее, gzip как фолбэк). Cloudflare может
	# сжать и сам, но так отдаём уже сжатое и на loopback.
	encode zstd gzip

	# ── Security-заголовки (доходят до браузера через Cloudflare) ────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Permissions-Policy "accelerometer=(), autoplay=(), camera=(), display-capture=(), encrypted-media=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), publickey-credentials-get=(), usb=(), xr-spatial-tracking=()"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; form-action 'self'; upgrade-insecure-requests"
		# Скрываем "Server: Caddy"
		-Server
		# HSTS: публичный доступ только по HTTPS (его обеспечивает Cloudflare).
		# Необратимо на срок max-age, браузеры запомнят поддомен как HTTPS-only.
		# "preload" добавлять только когда весь поддомен гарантированно на HTTPS.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	# ── Cache-Control ───────────────────────────────────────────────────────
	# Хэшированные ассеты: на год, immutable
	@assets path /_assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Обложки проектов и иконки: на неделю
	@week path /projects/* /favicon.svg /icon-192.svg /icon-512.svg
	header @week Cache-Control "public, max-age=604800"

	# Манифест, sitemap, robots: на час
	@shortcache path /manifest.webmanifest /sitemap.xml /robots.txt
	header @shortcache Cache-Control "public, max-age=3600"

	# Если позже добавишь src/pages/404.astro, Astro сгенерит /404.html,
	# и Caddy начнёт отдавать его на 404. Пока файла нет, отдаётся
	# стандартная страница ошибки Caddy, это безопасно.
	handle_errors {
		rewrite * /404.html
		file_server
	}

	file_server
}
